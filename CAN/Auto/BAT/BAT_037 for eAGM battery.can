  @ControlPowerSupply::Button_Set_CH2 = 1; //Pressed
  testWaitForTimeout(1000);
  @ControlPowerSupply::Button_Set_CH2 = 0; //Released
    
  testWaitForTimeout(3000);
    
  @ControlPowerSupply::Numeric_Volt_CH2 = 12;
  @ControlPowerSupply::Button_Set_CH2 = 1; //Pressed
  testWaitForTimeout(1000);
  @ControlPowerSupply::Button_Set_CH2 = 0; //Released
  
  testWaitForTimeout(2000);
  
  @panel::Switch_CGWNM = 1;
  
  //=== KEY ON ===//
  KEY_ON(); write("Run KEY_ON()");
  testWaitForTimeout(3000);
  
  check_Normal_Operation(); write("Run check_Normal_Operation()");
  
  CaptureGraphics(); write("Run CaptureGraphics()");
  
  Setup_End_test(); write("Run Setup_End_test()");
  
  KEY_OFF(); write("Run KEY_OFF()");

  @panel::Switch_CGWNM = 0;
  
  testStep("Notification","Finish BAT_037_6");
  write("Finish BAT_037_6");  
}

testcase BAT_037_7(){
  int condition1, condition2;
  condition1 = 0; condition2 = 0;
  
  testStepBegin("Notification","Start test BAT_037_7");
  write("Notification","Start test BAT_037_7");
  
  write("===SETTING BEFORE TESTING===");
  
  Turn_OFF_RecSet(); write("Run Turn_OFF_RecSet()");
  
  write("===START TEST===");  
  
  write("Case 1: Check in Alive State");
  
  setSignal(ICU_BS2SoC, 88);
  testWaitForTimeout(1000);
  
  @panel::Switch_CGWNM = 0;
  
  Setup_Function(1); write("Run Setup_Function()");
  
  @panel::Switch_CGWNM = 1;
  
  testWaitForTimeout(5000);
  
  Change_Battery_capa(88, 65); write("Run Change_Battery_capa()");
  
  if (testWaitForSignalChange(BLTN_CAM_RecSta_OWP,10000) == 1 && testWaitForSignalChange(BLTN_CAM_PrkOp_Termiate_Info,10000) == 1){
    
    if(getSignal(BLTN_CAM_PrkOp_Termiate_Info) == 0x1){
      write("Case 1 is pass");
      
      condition1 = 1;
      
      CaptureGraphics_2(); write("Run CaptureGraphics_2()");
    }
  else{
    write("Error: Case 1 is fail");
    
    Setup_End_test(); write("Run Setup_End_test()");
    
    KEY_OFF(); write("Run KEY_OFF()");
  
    stop(); write("Run stop()");    
  }  
  }
  
  testWaitForTimeout(1000);
  
  KEY_ON(); write("Run KEY_ON()"); 
  
  Change_Battery_capa(65, 88);  write("Run Change_Battery_capa()");
  testWaitForTimeout(1000);
  
  testStep("Case 2","Check in Sleep State");
  write("Case 2: Check in Sleep State");
  
  KEY_OFF(); write("Run KEY_OFF()");
  
  if (testWaitForSignalChange(BLTN_CAM_RecSta_OWP,100000) == 1){
    @panel::Switch_CGWNM = 0;
    write("OWP recording is in progress...");
  }
  else{
    write("Error: OWP recording hasn't started. Stop test !!!");
    
    Setup_End_test(); write("Run Setup_End_test()");
    
    KEY_OFF(); write("Run KEY_OFF()");
  
    stop(); write("Run stop()");   
  }  
  testWaitForTimeout(20000);
  
  if (testWaitForMessage(NM_BLTN_CAM_FD,1000) == 0 && testWaitForMessage(BLTN_CAM_FD_02_200ms,1000) == 0 && testWaitForMessage(BLTN_CAM_FD_HU_01_200ms,1000) == 0 && testWaitForMessage(BLTN_CAM_FD_STAT_01_200ms,1000) == 0){
    write("=== Sleep State ===");
    
    Change_Battery_capa(88, 65);  write("Run Change_Battery_capa()");
    
    if (testWaitForSignalChange(BLTN_CAM_RecSta_OWP,10000) == 1 && testWaitForSignalChange(BLTN_CAM_PrkOp_Termiate_Info,10000) == 1){
    
      if(getSignal(BLTN_CAM_PrkOp_Termiate_Info) == 0x1){
        write("Case 2 is pass");
      
        condition2 = 1;
      
        CaptureGraphics_2(); write("Run CaptureGraphics_2()");
      } 
      else{
        write("Error: Case 2 is fail");
    
        Setup_End_test(); write("Run Setup_End_test()");
    
        KEY_OFF(); write("Run KEY_OFF()");
  
        stop(); write("Run stop()");    
      }  
    }
  }
  else{
    write("=== Not Sleep ===");
    
    Setup_End_test(); write("Run Setup_End_test()");
    
    KEY_OFF(); write("Run KEY_OFF()");
  
    stop(); write("Run stop()");
  }
  
  if (condition1 == 1 && condition2 == 1){
    testStepPass("Pass", "Test-case is OK");
  }
  else{
    testStepFail("Fail","Test-case is NG");
  }
  @panel::Switch_CGWNM = 1;
  
  Setup_End_test(); write("Run Setup_End_test()");
  
  KEY_OFF(); write("Run KEY_OFF()");

  @panel::Switch_CGWNM = 0;
  
  testStep("Notification","Finish BAT_037_7");
  write("Finish BAT_037_7");
}

  

