void MainTest(){
  testWaitForValueInput("Enter the testcase ID (1/2/3/4/5/6/7/8):",300000);
  
  switch(testGetValueInput()){
    case(1): BAT_037_1();break; //Test case BAT_037_1
      
    case(2): BAT_037_2();break; //Test case BAT_037_2
      
    case(3): BAT_037_3();break; //Test case BAT_037_3

    case(4): BAT_037_4();break; //Test case BAT_037_4
      
