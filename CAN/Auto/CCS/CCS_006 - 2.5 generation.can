testcase CCS_006_15() {
  Send_Value_To_COM(30615);
  SetTestStep("Buoc 15 - CCS_006");
  StartTestTimer();
  testStep("Step 15", "Start test-case CCS_006_15 - Sleep + 2 rapid events");
  write("=== START CCS_006_15 ===");

  write("=== SETTING ===");

  Set_BglrAlrm(0x2);

  write("KEY ON");
  KEY_ON();
  testWaitForTimeout(3000);
  Apply_CCS_RecSettings(0x2, 0);

  write("=== TESTING ===");

  write("KEY OFF");
  KEY_OFF();

  if (WaitFor_RecSta_OWP_Recording(60000) == 1) {

    write("OWP recording started");

    write("Stopping CGW NM...");
    @panel::Switch_CGWNM = 0;
    testWaitForTimeout(3000);

    write("Waiting for network sleep (~13s)...");
    testWaitForTimeout(13000);

    write("Network should be in sleep mode");
    write("*** TRIGGER 2 RAPID IMPACT EVENTS NOW ***");
    WaitFor_RecSta_PEV_Recording(60);
     testWaitForTimeout(1000);
    WaitFor_RecSta_PEV_Recording(60);
   

    last_pev_count = $BLTN_CAM_PEV_Count;
    write("PEV_Count after rapid events: %d (expected >= 1)", last_pev_count);

    if (last_pev_count >= 1) {

      testStepPass("Pass", "Rapid events - PEV_Count >= 1");
      passed_tests++;

    } else {

      testStepFail("Fail", "Fail reason: PEV_Count < 1. Cause: expected condition was not satisfied.");
      failed_tests++;
      strncat(failed_test_names, "CCS_006_15 (PEV count check), ",
              elcount(failed_test_names));
    }
  } else {
    write("OWP recording hasn't started");
    snprintf(failReason, elcount(failReason), "Fail reason: OWP recording hasn\'t started (BLTN_CAM_RecSta_OWP=0x%X). Cause: expected condition was not satisfied.", $BLTN_CAM_RecSta_OWP);
    testStepFail("Fail", failReason);
    failed_tests++;
    strncat(failed_test_names, "CCS_006_15 (OWP timeout), ",
            elcount(failed_test_names));
  }

  total_tests++;

  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_"
                  "Recorded;BLTN_CAM_PEV_Count;SMK_TrmnlCtrlGrpStaBDC");

  write("=== FINISH CCS_006_15 ===");

  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase CCS_006_16() {
  long start_tick;
  int trigger_call_count;
  int set_before_ok;
  int set_after_ok;

  Send_Value_To_COM(30616);
  SetTestStep("Buoc 16 - CCS_006");
  StartTestTimer();
  @panel::Switch_CGWNM = 1;
  testStep("Step 16", "Set event recording time -10s/+10s and trigger continuously for 60s");
  write("=== START CCS_006_16 ===");

  write("=== SETTING ===");

  write("KEY ON");
  KEY_ON();
  testWaitForTimeout(3000);
  Apply_CCS_RecSettings(0x2, 0);

  set_before_ok = Set_EV_BeforeTime(3);
  set_after_ok = Set_EV_AfterTime(10);

  write("=== TESTING ===");

  write("KEY OFF");
  KEY_OFF();

  write("Running WaitFor_RecSta_PEV_Recording continuously for 60s...");
  start_tick = timeNow();
  trigger_call_count = 0;
  while ((timeNow() - start_tick) < 6000000) {
    WaitFor_RecSta_PEV_Recording(1);
    trigger_call_count++;
  }
  write("Continuous trigger finished. Total calls: %d", trigger_call_count);

  write("KEY ON");
  KEY_ON();
  testWaitForTimeout(3000);

  if (set_before_ok == 1 && set_after_ok == 1) {
    testStepPass("Pass", "Step 16 completed: -10s/+10s and continuous trigger 60s");
    passed_tests++;
  } else {
    testStepFail("Fail", "Fail reason: Cannot set event recording time to -10s/+10s. Cause: expected condition was not satisfied.");
    failed_tests++;
    strncat(failed_test_names, "CCS_006_16 (Set EV time), ",
            elcount(failed_test_names));
  }

  total_tests++;

  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_"
                  "Recorded;BLTN_CAM_Set_EV_BfrTime;BLTN_CAM_Set_EV_AftTime;SMK_TrmnlCtrlGrpStaBDC");

  write("=== FINISH CCS_006_16 ===");

  StopTestTimer();
  Send_Value_To_COM(44);
}

