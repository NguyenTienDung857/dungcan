/*@!Encoding:65001*/
// Preconditions: - Block CCU, ACC and IGN and ccNC/ccIC switch OFF state, AVN mode
includes
{
  
  #include "DeclarationFunction_Gen2.5.h"
  
}

variables
{
  // Message Declaration
  // CAN FD
  message HU_BLTN_CAM_01_00ms _HU_BLTN_CAM_01_00ms;
  message HU_BLTN_CAM_02_200ms _HU_BLTN_CAM_02_200ms;
  message BDC_FD_SMK_03_200ms _BDC_FD_SMK_03_200ms;
  message PDC_FD_10_200ms _PDC_FD_10_200ms;
  message IAU_FD_04_200ms _IAU_FD_04_200ms;
  message PDC_FD_11_200ms _PDC_FD_11_200ms;
  message BDC_FD_04_200ms _BDC_FD_04_200ms;
  //Global Variable Declaration
  // Global Variable Declaration
  int i;
  int flag = 0;
  int flag_RecSet_error = 0;
  int condition1 = 0, condition2 = 0, condition3 = 0;
  byte KEY_state = 0x0;
  byte Profile_value = 0x1;
  byte Mode_state = 0x2;
  byte Bat_val = 0x50; 
  byte Alarm_state = 0x0; 
  int get_PEVRecorded_change = 0;
  byte get_PEVRecorded_value = 0x0;
  // Timer Declaration  
  msTimer send_SMK_TrmnlCtrlGrpStaBDC_timer;
  msTimer send_ICU_PowerAutoCutModSta_timer;
  msTimer send_IAU_ProfileIDRVal_timer;
  msTimer send_ICU_BS2SoC_timer;
  msTimer send_BAlarm_BglrAlrmCurrentSta_timer;
}

void Capture_Graphics() {
  testWaitForTimeout(3000);
  testReportAddWindowCapture("Graphics 2","","BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BAlarm_BglrAlrm_CurrentSta","./envidence.jpg");  
}

on timer send_BAlarm_BglrAlrmCurrentSta_timer {
  _BDC_FD_04_200ms.BAlarm_BglrAlrm_CurrentSta = Alarm_state;      
  output(_BDC_FD_04_200ms);  
  send_BAlarm_BglrAlrmCurrentSta_timer.set(200);
}

on timer send_SMK_TrmnlCtrlGrpStaBDC_timer {
  _BDC_FD_SMK_03_200ms.SMK_TrmnlCtrlGrpStaBDC = KEY_state; //IGN
  output(_BDC_FD_SMK_03_200ms);
  send_SMK_TrmnlCtrlGrpStaBDC_timer.set(200);
}

on timer send_IAU_ProfileIDRVal_timer {
  _IAU_FD_04_200ms.IAU_ProfileIDRVal = Profile_value;
  output(_IAU_FD_04_200ms);
  send_IAU_ProfileIDRVal_timer.set(200);
}

on timer send_ICU_PowerAutoCutModSta_timer {
  _PDC_FD_10_200ms.ICU_PowerAutoCutModSta = Mode_state;
  output(_PDC_FD_10_200ms);
  send_ICU_PowerAutoCutModSta_timer.set(200);
}

on timer send_ICU_BS2SoC_timer {
  _PDC_FD_11_200ms.ICU_BS2SoC = Bat_val;
  output(_PDC_FD_11_200ms);
  send_ICU_BS2SoC_timer.set(200);
}

testcase CCS_009_1() {
  testStep("Notifications","Start test-case CCS_009_1");
  write("=== START CCS_009_1 ===");  
  
  write("=== SETTING ===");
  
  Alarm_state = 0x0; //Off
  
  write("KEY ON"); KEY_state = 0x1; testWaitForTimeout(3000);
  
  do {
    
    Enter_BLTN_CAM(); testWaitForTimeout(3000);
    
    if ($BLTN_CAM_RecSet_OWP == 0x1) {write("OWP On"); @panel::LED_Ctrl_SetOWP = 1; testWaitForTimeout(500);}
    if ($BLTN_CAM_RecSet_PEV == 0x1) {write("PEV On"); @panel::LED_Ctrl_SetPEV = 1; testWaitForTimeout(500);}
    if ($BLTN_CAM_Set_PEV_AppNoti == 0x1) {write("App Noti On"); @panel::Button_AppNoti_PEV = 1; testWaitForTimeout(500);}
    
    Exit_BLTN_CAM(); testWaitForTimeout(3000);
    flag_RecSet_error++;
    
  } while (($BLTN_CAM_RecSet_OWP == 0x1 || $BLTN_CAM_RecSet_PEV == 0x1 || $BLTN_CAM_Set_PEV_AppNoti == 0x1) && (flag_RecSet_error < 15));
  
  write("=== TESTING ===");
  
  write("KEY OFF"); KEY_state = 0x0;
  
  if (testWaitForSignalChange(BLTN_CAM_RecSta_OWP,10000) == 1) {
    
    write("OWP recording is started"); @panel::Switch_CGWNM = 1;
    
    Alarm_state = 0x2; //Arm
    testWaitForTimeout(5000);
    Alarm_state = 0x0; //Off
    testWaitForTimeout(5000);
    
    openPanel("Note");
    
    if (testWaitForSignalChange(BLTN_CAM_RecSta_PEV,20000) == 1) {
      
      write("PEV recording is started"); closePanel("Note");
      
      get_PEVRecorded_change = testWaitForSignalChange(BLTN_CAM_PEV_Recorded,10000);
      
      get_PEVRecorded_value = $BLTN_CAM_PEV_Recorded;
      
      if (get_PEVRecorded_change == 1 && get_PEVRecorded_value == 0x2) {
        
        write("PEV_Recorded: 0x%X << Test-case is OK >>", get_PEVRecorded_value);
        
        testStepPass("Pass","Test-case is OK");
        
      }
      else {
        
        write("PEV_Recorded: 0x%X << Test-case is NG >>", get_PEVRecorded_value);
        
        testStepFail("Fail","Test-case is NG");
      }
    }
  }
  else {
    write("OWP recording hasn't started");
    write("Stop measurement"); stop();
  }
  
  write("Run Capture_Graphics()"); Capture_Graphics();  
  
  Init();
  
  @panel::Switch_CGWNM = 0;
  
  write("=== FINISH CCS_009_1 ===");
}

