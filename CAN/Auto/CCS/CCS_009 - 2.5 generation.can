testcase CCS_009_6() {
  testStep("Notifications","Start test-case CCS_009_6");
  write("=== START CCS_009_6 ==="); 
  
  Begin();  
  
  write("=== SETTING ===");
  
  Alarm_state = 0x0; //Not used
  
  write("KEY ON"); KEY_state = 0x1; testWaitForTimeout(3000);
  
  do {
    
    Enter_BLTN_CAM(); testWaitForTimeout(3000);
    
    if ($BLTN_CAM_RecSet_OWP == 0x1) {write("OWP On"); @panel::LED_Ctrl_SetOWP = 1; testWaitForTimeout(500);}
    if ($BLTN_CAM_RecSet_PEV == 0x1) {write("PEV On"); @panel::LED_Ctrl_SetPEV = 1; testWaitForTimeout(500);}
    if ($BLTN_CAM_Set_PEV_AppNoti == 0x1) {write("App Noti On"); @panel::Button_AppNoti_PEV = 1; testWaitForTimeout(500);}
    
    Exit_BLTN_CAM(); testWaitForTimeout(3000);
    flag_RecSet_error++;
    
  } while (($BLTN_CAM_RecSet_OWP == 0x1 || $BLTN_CAM_RecSet_PEV == 0x1 || $BLTN_CAM_Set_PEV_AppNoti == 0x1) && (flag_RecSet_error < 15));
  
  write("=== TESTING ===");
  
  write("KEY OFF"); KEY_state = 0x0;
  
  if (testWaitForSignalChange(BLTN_CAM_RecSta_OWP,10000) == 1) {
    
    write("OWP recording is started"); @panel::Switch_CGWNM = 1;
    
    Alarm_state = 0x1; //DisArm
    testWaitForTimeout(5000);
    Alarm_state = 0xE; //Default
    testWaitForTimeout(5000);
    
    openPanel("Note");
    
    if (testWaitForSignalChange(BLTN_CAM_RecSta_PEV,20000) == 1) {
      
      write("PEV recording is started"); closePanel("Note");
      
      get_PEVRecorded_change = testWaitForSignalChange(BLTN_CAM_PEV_Recorded,10000);
      
      get_PEVRecorded_value = $BLTN_CAM_PEV_Recorded;
      
      if (get_PEVRecorded_change != 1 && get_PEVRecorded_value == 0x0) {
        
        write("PEV_Recorded: 0x%X << Test-case is OK >>", get_PEVRecorded_value);
        
        testStepPass("Pass","Test-case is OK");
        
      }
      else {
        
        write("PEV_Recorded: 0x%X << Test-case is NG >>", get_PEVRecorded_value);
        
        testStepFail("Fail","Test-case is NG");
      }
    }
  }
  else {
    write("OWP recording hasn't started");
    write("Stop measurement"); stop();
  }  
  
  write("Run Capture_Graphics()"); Capture_Graphics();  
  
  Init();
  
  @panel::Switch_CGWNM = 0;
  
  write("=== FINISH CCS_009_6 ===");  
}

void MainTest() {
  
  Begin();
  
  KEY_state = 0x1; testWaitForTimeout(3000);
  
  if ($BLTN_CAM_RecSet_OWD == 0x1 || $BLTN_CAM_RecSet_OWP == 0x1 || $BLTN_CAM_RecSet_DEV == 0x1 || $BLTN_CAM_RecSet_PEV == 0x1) {
    
    write("Run Set_All_Recording_OFF()"); Set_All_Recording_OFF();
  
  }
  else {
    
    write("All settings are set to Off");
  
  }
  
  KEY_state = 0x0;
  
  TestWaitForValueInput("Please enter the test ID (1/2/3/4/5/6/7)", 300000);
  switch (TestGetValueInput()){
    
   case(1) : CCS_009_1(); break;
   case(2) : CCS_009_2(); break;
   case(3) : CCS_009_3(); break; 
   case(4) : CCS_009_4(); break;
   case(5) : CCS_009_5(); break;
   case(6) : CCS_009_6(); break;
   case(7) : CCS_009_1(); CCS_009_2(); CCS_009_3(); CCS_009_4(); CCS_009_5(); CCS_009_6(); break;  
     
  }      
  
}