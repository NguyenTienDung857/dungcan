// ============================================================================
// MAIN TEST FUNCTION - Run all test cases sequentially
// ============================================================================
void MainTest()
{
  write("\n");
  write("===============================================================");
  write("  CCS_014 - PEV_Notification Setting Test 2 (2.5 generation)");
  write("===============================================================");
  write("\n");

  CCS_014_1();
  testWaitForTimeout(2000);
  CCS_014_2();
  testWaitForTimeout(2000);
  CCS_014_3();
  testWaitForTimeout(2000);
  CCS_014_4();
  testWaitForTimeout(2000);
  CCS_014_5();
