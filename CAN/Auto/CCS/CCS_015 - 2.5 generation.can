// ============================================================================
// MAIN TEST FUNCTION - Run all test cases sequentially
// ============================================================================
void MainTest()
{
  write("\n");
  write("===============================================================");
  write("  CCS_015 - PEV Notification Setting Test 3 (2.5 generation)");
  write("===============================================================");
  write("\n");

  CCS_015_1();
  testWaitForTimeout(2000);
  CCS_015_2();
  testWaitForTimeout(2000);
  CCS_015_3();
  testWaitForTimeout(2000);
  CCS_015_4();
  testWaitForTimeout(2000);
  CCS_015_5();
  testWaitForTimeout(2000);
