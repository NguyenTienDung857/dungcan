/*@!Encoding:65001*/
/*
  Test Case: CCS_015 - 2.5 generation
  Title: [PEV Notification Setting Test 3 (Bfr -20s, Aft +20s)]

  Step 1: Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, Turn_ON_OWP, Set_PEV_AppNoti ON. 
          Set EV before/after time (-20s, +20s). Key Off, Wait for OWP, PEV recording. Check PEV Rec=0x2.
  Step 2: Wait 6 mins for PEV_Recorded = 0x0.
  Step 3: SET_NM_OFF, KEY_OFF, Wait OWP recording, wait network sleep 6 min. SET_NM_ON, Wait PEV recording, check 0x1.
  Step 4: Wait 10 mins for PEV_Recorded = 0x0.
  Step 5: KEY_ON, Turn_ON_PMD, KEY_OFF, Wait PMD recording 6 mins. Wait PEV recording.
  Step 6: Wait 10 mins for PEV_Recorded = 0x0.
  Step 7: KEY_OFF, Wait network sleep 6 mins. SET_NM_ON, Wait PMD OFF, Wait PEV recording.
  Step 8: Wait 10 mins for PEV_Recorded = 0x0.
*/

includes {
#include "..\DeclarationFunction_Gen2.5.h"
}

variables {
  char failReason[512];
  int total_tests = 0;
  int passed_tests = 0;
  int failed_tests = 0;
  char failed_test_names[2048] = "";
}

// ============================================================================
// CCS_015_1: Step 1
// ============================================================================
testcase CCS_015_1()
{
  Send_Value_To_COM(31501);
  SetTestStep("Buoc 1 - CCS_015");
  StartTestTimer();
  testStep("Step 1", "Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, Turn_ON_OWP, Set_PEV_AppNoti ON. Set EV before/after time (-20s, +20s). Key Off, Wait for OWP, PEV recording. Check PEV Rec=0x2.");
  
  write("=== START CCS_015_1 ===");
  
  Set_SMK_IGN();
  Click_USM_Reset();
  Click_Rec_Reset();
  
  Turn_ON_OWP();
  Set_PEV_AppNoti(0x2);
  
  // Set the recording time for the corresponding event (Bfr -20s, Aft +20s)
  // TrackBar_EV_Time_Bfr: 1=20s, 2=15s, 3=10s
  Set_EV_BeforeTime(1); 
  Set_EV_AfterTime(20); 
  
  KEY_OFF();
  
  WaitFor_RecSta_OWP_Recording(60000); 
  WaitFor_RecSta_PEV_Recording(60); 
  Check_RecSta_PEV_Recording();
  
  testWaitForTimeout(12000); // Wait 12s
  
    if (WaitFor_PEV_Recorded_Value(0x2, 30000) == 1) {
      testStepPass("CCS_015_1", "BLTN_CAM_PEV_Recorded reached 0x2 within 30s");
    } else {
      snprintf(failReason, elcount(failReason), "Fail reason: Timeout 30s waiting BLTN_CAM_PEV_Recorded == 0x2 (Actual: 0x%X). Cause: expected condition was not satisfied.", $BLTN_CAM_PEV_Recorded);
      testStepFail("CCS_015_1", failReason);
    }
  
  write("BLTN_CAM_PEV_Count: %d", $BLTN_CAM_PEV_Count);
  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti;BLTN_CAM_Set_EV_BfrTime;BLTN_CAM_Set_EV_AftTime;SMK_TrmnlCtrlGrpStaBDC");
  
  write("=== FINISH CCS_015_1 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// CCS_015_2: Step 2
// ============================================================================
testcase CCS_015_2()
{
  long i;
  int is_ok = 0;
  Send_Value_To_COM(31502);
  SetTestStep("Buoc 2 - CCS_015");
  StartTestTimer();
  testStep("Step 2", "Wait 6 mins for PEV_Recorded = 0x0.");
  write("=== START CCS_015_2 ===");
  
  // Poll up to 6 minutes until BLTN_CAM_PEV_Recorded = 0x0
  for (i = 0; i < 360; i++) {
     if ($BLTN_CAM_PEV_Recorded == 0x0) {
         is_ok = 1;
         CaptureGraphics("CSS", "BLTN_CAM_PEV_Recorded;SMK_TrmnlCtrlGrpStaBDC");
         break;
     }
     testWaitForTimeout(1000);
  }
  
  if (is_ok) {
     testStepPass("CCS_015_2", "BLTN_CAM_PEV_Recorded resolved to 0x0");
  } else {
     testStepFail("CCS_015_2", "Fail reason: Timeout waiting for BLTN_CAM_PEV_Recorded == 0x0 within 6 mins. Cause: expected condition was not satisfied.");
  }
    write("Run CaptureGraphics()");
    CaptureGraphics("CSS", "BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti;BLTN_CAM_Set_EV_BfrTime;BLTN_CAM_Set_EV_AftTime;SMK_TrmnlCtrlGrpStaBDC");
  
  write("=== FINISH CCS_015_2 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// CCS_015_3: Step 3
// ============================================================================
testcase CCS_015_3()
{
  Send_Value_To_COM(31503);
  SetTestStep("Buoc 3 - CCS_015");
  StartTestTimer();
  testStep("Step 3", "SET_NM_OFF, KEY_OFF, Wait OWP recording, wait network sleep 6 min. SET_NM_ON, Wait PEV recording, check 0x1.");
  write("=== START CCS_015_3 ===");
  
  SET_NM_OFF();
  KEY_OFF();
  
  WaitFor_RecSta_OWP_Recording(60000);
  WaitForNetworkSleep(480); // 8 mins
  
  SET_NM_ON();
  WaitFor_RecSta_PEV_Recording(60);
  SET_NM_ON();
  
  if ($BLTN_CAM_RecSta_PEV == 0x1) {
      testStepPass("CCS_015_3_A", "BLTN_CAM_RecSta_PEV is 0x1");
  } else {
      snprintf(failReason, elcount(failReason), "Fail reason: BLTN_CAM_RecSta_PEV != 0x1 (Actual: 0x%X). Cause: expected condition was not satisfied.", $BLTN_CAM_RecSta_PEV);
      testStepFail("CCS_015_3_A", failReason);
  }

  testWaitForTimeout(12000);

  if ($BLTN_CAM_RecSta_PEV == 0x1) {
      testStepPass("CCS_015_3_B", "BLTN_CAM_RecSta_PEV is 0x1 after 12s");
  } else {
      testStepFail("CCS_015_3_B", "Fail reason: BLTN_CAM_RecSta_PEV goes off after 12s. Cause: expected condition was not satisfied.");
  }
  
    if (WaitFor_PEV_Recorded_Value(0x2, 30000) == 1) {
      testStepPass("CCS_015_3_C", "BLTN_CAM_PEV_Recorded reached 0x2 within 30s");
    } else {
      snprintf(failReason, elcount(failReason), "Fail reason: Timeout 30s waiting BLTN_CAM_PEV_Recorded == 0x2 (Actual: 0x%X). Cause: expected condition was not satisfied.", $BLTN_CAM_PEV_Recorded);
      testStepFail("CCS_015_3_C", failReason);
    }
  
  write("BLTN_CAM_PEV_Count: %d", $BLTN_CAM_PEV_Count);
  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti;BLTN_CAM_Set_EV_BfrTime;BLTN_CAM_Set_EV_AftTime;SMK_TrmnlCtrlGrpStaBDC");
  
  write("=== FINISH CCS_015_3 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

