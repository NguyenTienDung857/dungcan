               "Fail reason: Timeout 30s waiting BLTN_CAM_PEV_Recorded == 0x0 (Actual: 0x%X). Cause: expected condition was not satisfied.",
               $BLTN_CAM_PEV_Recorded);
      testStepFail("Step 12", failReason);
    }
  } else {
    testStepFail("Step 12", "Fail reason: Timeout waiting BLTN_CAM_RecSta_PEV = 0x1. Cause: expected condition was not satisfied.");
  }
  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "BAlarm_BglrAlrmCurrentSta;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;SMK_TrmnlCtrlGrpStaBDC");

  write("=== FINISH CCS_016_12 ===");
