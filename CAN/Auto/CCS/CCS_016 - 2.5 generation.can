testcase CCS_016_10()
{
  int is_ok;
  long wait_idx;
  Send_Value_To_COM(31610);
  SetTestStep("CCS_016_10");
  StartTestTimer();
  testStep("Step 10", "Wait up to 6 minutes until BLTN_CAM_PEV_Recorded = 0x0");
  write("=== START CCS_016_10 ===");
  
  is_ok = 0;
  for(wait_idx = 0; wait_idx < 360; wait_idx++) {
      if ($BLTN_CAM_PEV_Recorded == 0x0) {
          is_ok = 1;
          break;
      }
      testWaitForTimeout(1000);
  }
  if (is_ok) {
    testStepPass("Step 10", "BLTN_CAM_PEV_Recorded reached 0x0 within 6 minutes");
  } else {
    testStepFail("Step 10", "Fail reason: BLTN_CAM_PEV_Recorded did not become 0x0 within 6 minutes. Cause: expected condition was not satisfied.");
  }
  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "BAlarm_BglrAlrmCurrentSta;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;SMK_TrmnlCtrlGrpStaBDC");

  write("=== FINISH CCS_016_10 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase CCS_016_11()
{
  int is_ok;
  long wait_idx;
  Send_Value_To_COM(31611);
  SetTestStep("CCS_016_11");
  StartTestTimer();
  testStep("Step 11", "Wait PEV recording up to 1 minute, when PEV_Recorded = 0x2 then KEY ON, check PEV_Recorded = 0x0");
  write("=== START CCS_016_11 ===");
  
  testWaitForTimeout(15000);
  is_ok = WaitFor_RecSta_PEV_Recording(60);
  if (!is_ok) {
    testStepFail("Step 11", "Fail reason: Timeout waiting BLTN_CAM_RecSta_PEV = 0x1. Cause: expected condition was not satisfied.");
    write("Run CaptureGraphics()");
    CaptureGraphics("CSS", "BAlarm_BglrAlrmCurrentSta;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;SMK_TrmnlCtrlGrpStaBDC");
    write("=== FINISH CCS_016_11 ===");
    StopTestTimer();
    return;
  }
  is_ok = 0;
  for(wait_idx = 0; wait_idx < 60; wait_idx++) {
      if ($BLTN_CAM_PEV_Recorded == 0x2) {
          KEY_ON();
          is_ok = 1;
          break;
      }
      testWaitForTimeout(1000);
  }
  if (is_ok) {
      if (WaitFor_PEV_Recorded_Value(0x0, 30000) == 1) {
        testStepPass("Step 11", "BLTN_CAM_PEV_Recorded reached 0x0 within 30s after Key ON");
      } else {
        testStepFail("Step 11", "Fail reason: Timeout 30s waiting BLTN_CAM_PEV_Recorded == 0x0 after Key ON. Cause: expected condition was not satisfied.");
      }
  } else {
     testStepFail("Step 11", "Fail reason: Failed to get PEV_Recorded=2 within 1 min. Cause: expected condition was not satisfied.");
  }
  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "BAlarm_BglrAlrmCurrentSta;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;SMK_TrmnlCtrlGrpStaBDC");

  write("=== FINISH CCS_016_11 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase CCS_016_12()
{
  int is_ok;
  Send_Value_To_COM(31612);
  SetTestStep("CCS_016_12");
  StartTestTimer();
  testStep("Step 12", "wait 15s, BAlarm_BglrAlrmCurrentSta = 0xA(AutoLockTimer3) or 0x8 ? user wrote 0x8, check RecSta_PEV=1, PEV_Recorded=0");
  write("=== START CCS_016_12 ===");
  
  testWaitForTimeout(15000);
  // Re-enter parking 
  KEY_OFF();
  WaitFor_RecSta_OWP_Recording(60000);
  Set_BglrAlrm(0x8); // Assuming 0x8 might map to Timer3 or reusing it based on prompt
  is_ok = WaitFor_RecSta_PEV_Recording(60);
  if (is_ok) {
    if (WaitFor_PEV_Recorded_Value(0x0, 30000) == 1) {
      testStepPass("Step 12", "BLTN_CAM_PEV_Recorded reached 0x0 within 30s");
