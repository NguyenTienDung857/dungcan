/*@!Encoding:65001*/

/*
  Test Case: CCS_016
  Title: [PEV Notification Setting Test 4]

  Step 1: Init, Set_PEV_AppNoti ON, key off , Wait OWP,
          BAlarm_BglrAlrmCurrentSta = 0x1(Disarm), Wait PEV check RecSta_PEV=1, PEV_Recorded=0
  Step 2: wait 15s, BAlarm_BglrAlrmCurrentSta = 0x2(Arm), Wait PEV check RecSta_PEV=1, PEV_Recorded=2
  Step 3: wait 15s, BAlarm_BglrAlrmCurrentSta = 0x3(Prearm), Wait PEV check RecSta_PEV=1, PEV_Recorded=0
  Step 4: wait 15s, BAlarm_BglrAlrmCurrentSta = 0x4(Armwait), Impose shock event, Wait PEV check RecSta_PEV=1, PEV_Recorded=0
  Step 5: wait 15s, BAlarm_BglrAlrmCurrentSta = 0x5(Armhold), Wait PEV check RecSta_PEV=1, PEV_Recorded=0  // Note: user said 0x4 for Armhold but 0x5 is ArmHold usually, using 0x5 based on logical steps
  Step 6: wait 15s, BAlarm_BglrAlrmCurrentSta = 0x6(Rearm), Wait PEV check RecSta_PEV=1, PEV_Recorded=2
  Step 7: wait 15s, BAlarm_BglrAlrmCurrentSta = 0x7(AutoLockTimer1), Wait PEV check RecSta_PEV=1, PEV_Recorded=0
  Step 8: wait 15s, BAlarm_BglrAlrmCurrentSta = 0x8(AutoLockTimer2), Wait PEV check RecSta_PEV=1, PEV_Recorded=0
  Step 9: wait 15s, BAlarm_BglrAlrmCurrentSta = 0x9(Alarm), check RecSta_PEV=1, PEV_Recorded=2
  Step 10: Wait up to 6 minutes until BLTN_CAM_PEV_Recorded = 0x0
  Step 11: Wait PEV recording up to 1 minute, when PEV_Recorded = 0x2 then KEY ON, check PEV_Recorded = 0x0
  Step 12: wait 15s, BAlarm_BglrAlrmCurrentSta = 0xA(AutoLockTimer3) or 0x8 ? user wrote 0x8, check RecSta_PEV=1, PEV_Recorded=0

  Check criteria: WaitFor_RecSta_PEV_Recording + BLTN_CAM_PEV_Recorded value.
*/

includes {
#include "..\DeclarationFunction_Gen2.5.h"
}

variables {
  char failReason[512];
  int total_tests = 0;
  int passed_tests = 0;
  int failed_tests = 0;
  char failed_test_names[2048] = "";
}

testcase CCS_016_1()
{
  int is_ok;
  Send_Value_To_COM(31601);
  SetTestStep("CCS_016_1");
  StartTestTimer();
  testStep("Step 1", "Init, Set_PEV_AppNoti ON, key off , Wait OWP, BAlarm_BglrAlrmCurrentSta = 0x1(Disarm), Wait PEV check RecSta_PEV=1, PEV_Recorded=0");
  
  write("=== START CCS_016_1 ===");
  
  // Step 1
  write("--- Step 1: Init and Disarm ---");
  testWaitForTimeout(15000);
  Set_SMK_IGN();
  Click_USM_Reset();
  Click_Rec_Reset();
  Turn_ON_OWP();
  Set_PEV_AppNoti(0x2);
  KEY_OFF();
  WaitFor_RecSta_OWP_Recording(60000);
  
  Set_BglrAlrm(0x1); // Disarm
  is_ok = WaitFor_RecSta_PEV_Recording(60);
  if (is_ok) {
    if (WaitFor_PEV_Recorded_Value(0x0, 30000) == 1) {
      testStepPass("Step 1", "BLTN_CAM_PEV_Recorded reached 0x0 within 30s");
    } else {
      snprintf(failReason, elcount(failReason),
               "Fail reason: Timeout 30s waiting BLTN_CAM_PEV_Recorded == 0x0 (Actual: 0x%X). Cause: expected condition was not satisfied.",
               $BLTN_CAM_PEV_Recorded);
      testStepFail("Step 1", failReason);
    }
  } else {
    testStepFail("Step 1", "Fail reason: Timeout waiting BLTN_CAM_RecSta_PEV = 0x1. Cause: expected condition was not satisfied.");
  }
  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "BAlarm_BglrAlrmCurrentSta;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;SMK_TrmnlCtrlGrpStaBDC");
  
  write("=== FINISH CCS_016_1 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

