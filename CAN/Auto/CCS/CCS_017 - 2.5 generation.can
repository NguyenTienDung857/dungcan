// ============================================================================
// MAIN TEST FUNCTION - Run all test cases sequentially
// ============================================================================
void MainTest()
{
  write("\n");
  write("===============================================================");
  write("  CCS_017 - PEV Notification Setting Test 5 (2.5 generation)");
  write("===============================================================");
  write("\n");

  CCS_017_1();
  testWaitForTimeout(2000);
  CCS_017_2();
  testWaitForTimeout(2000);
  CCS_017_3();
  testWaitForTimeout(2000);
  CCS_017_4();
  testWaitForTimeout(2000);
  CCS_017_5();
  testWaitForTimeout(2000);
  CCS_017_6();
}

