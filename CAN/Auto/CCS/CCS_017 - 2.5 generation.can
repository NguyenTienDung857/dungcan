// ============================================================================
// CCS_017_5: Step 5
// ============================================================================
testcase CCS_017_5()
{
  int is_ok;

  Send_Value_To_COM(31705);
  SetTestStep("Buoc 5 - CCS_017");
  StartTestTimer();
  testStep("Step 5", "Arm -> Wait PEV -> wait 5 minutes -> Alarm, then verify PEV conditions");

  write("=== START CCS_017_5 ===");

  Set_BglrAlrm(0x2); // Arm
  is_ok = WaitFor_RecSta_PEV_Recording(60);
  if (is_ok == 1) {
    testStepPass("CCS_017_5_A", "PEV recording detected after Arm");
  } else {
    testStepFail("CCS_017_5_A", "Fail reason: Timeout waiting RecSta_PEV=0x1 after Arm. Cause: expected condition was not satisfied.");
  }

  testWaitForTimeout(300000); // 5 minutes
  Set_BglrAlrm(0x9); // Alarm

  if (Check_RecSta_PEV_Recording() == 1) {
    testStepPass("CCS_017_5_B", "BLTN_CAM_RecSta_PEV = 0x1 after Alarm");
  } else {
    snprintf(failReason,
             elcount(failReason),
             "Fail reason: BLTN_CAM_RecSta_PEV = 0x%X (expected 0x1) after Alarm. Cause: expected condition was not satisfied.",
             $BLTN_CAM_RecSta_PEV);
    testStepFail("CCS_017_5_B", failReason);
  }

  if (WaitFor_PEV_Recorded_Value(0x2, 30000) == 1) {
    testStepPass("CCS_017_5_C", "BLTN_CAM_PEV_Recorded reached 0x2 within 30s");
  } else {
    snprintf(failReason,
             elcount(failReason),
             "Fail reason: Timeout 30s waiting BLTN_CAM_PEV_Recorded == 0x2 (Actual: 0x%X). Cause: expected condition was not satisfied.",
             $BLTN_CAM_PEV_Recorded);
    testStepFail("CCS_017_5_C", failReason);
  }

  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "BAlarm_BglrAlrmCurrentSta;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti;SMK_TrmnlCtrlGrpStaBDC");

  write("=== FINISH CCS_017_5 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

