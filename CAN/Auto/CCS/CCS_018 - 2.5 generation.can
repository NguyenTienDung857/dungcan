  if (is_ok == 1) {
    testStepPass("CCS_018_5_B", "PEV recording detected within 60s");
  } else {
    testStepFail("CCS_018_5_B", "Fail reason: Timeout waiting BLTN_CAM_RecSta_PEV = 0x1 within 60s. Cause: expected condition was not satisfied.");
  }

  if (WaitFor_PEV_Recorded_Value(0x2, 30000) == 1) {
    testStepPass("CCS_018_5_C", "BLTN_CAM_PEV_Recorded reached 0x2 within 30s");
  } else {
    snprintf(failReason,
             elcount(failReason),
             "Fail reason: Timeout 30s waiting BLTN_CAM_PEV_Recorded == 0x2 (Actual: 0x%X). Cause: expected condition was not satisfied.",
             $BLTN_CAM_PEV_Recorded);
    testStepFail("CCS_018_5_C", failReason);
  }

  testWaitForTimeout(10000);

  is_ok = WaitFor_RecSta_PEV_Recording(60);
  if (is_ok == 1) {
    testStepPass("CCS_018_5_D", "PEV recording re-confirmed after 10s");
  } else {
    testStepFail("CCS_018_5_D", "Fail reason: Timeout waiting BLTN_CAM_RecSta_PEV = 0x1 after 10s delay. Cause: expected condition was not satisfied.");
