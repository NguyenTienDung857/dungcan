testcase CCS_018_5()
{
  int is_ok;

  Send_Value_To_COM(31805);
  SetTestStep("Buoc 5 - CCS_018");
  StartTestTimer();
  testStep("Step 5", "KEY_ON -> KEY_OFF -> wait OWP/PEV recording -> confirm PEV_Recorded=0x2 (WaitFor_PEV_Recorded_Value) -> wait 10s -> wait PEV recording -> wait 10s -> KEY_ON");

  write("=== START CCS_018_5 ===");

  KEY_ON();
  testWaitForTimeout(2000);
  KEY_OFF();

  is_ok = WaitFor_RecSta_OWP_Recording(60000);
  if (is_ok == 1) {
    testStepPass("CCS_018_5_A", "OWP recording started within 60s");
