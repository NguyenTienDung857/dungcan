/*@!Encoding:65001*/
/*
  Test Case: CCS_018 - 2.5 generation
  Title: [PEV Notification Setting Test 6]

  Step 1: Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, Turn_ON_OWP,
          Set_PEV_AppNoti ON, KEY_OFF.
          Wait OWP recording, wait PEV recording, check RecSta_PEV = 0x1.

  Step 2: KEY_ON, KEY_OFF, WaitForNetworkSleep(8 mins),
          WaitFor_RecSta_PEV_Recording, wait 20s, wait PEV recording again,
          check BLTN_CAM_PEV_Recorded = 0x2.

  Step 3: KEY_ON, KEY_OFF, wait OWP recording, wait PEV recording,
          wait 60s, KEY_ON, log request to check video manually.

  Step 4: KEY_ON, KEY_OFF, wait OWP recording, WaitForNetworkSleep(8 mins),
          wait PEV recording, wait 60s, KEY_ON, log request to check video manually.

  Step 5: KEY_ON, KEY_OFF, wait OWP recording, wait PEV recording,
          confirm BLTN_CAM_PEV_Recorded = 0x2 using WaitFor_PEV_Recorded_Value,
          wait 10s, wait PEV recording, wait 10s, KEY_ON.

  Step 6: KEY_ON, KEY_OFF, WaitForNetworkSleep(8 mins), wait PEV recording,
          confirm BLTN_CAM_PEV_Recorded = 0x2 using WaitFor_PEV_Recorded_Value
          within 30s, wait 10s, wait PEV recording, KEY_ON.
*/

includes {
#include "..\DeclarationFunction_Gen2.5.h"
}

variables {
  char failReason[512];
  int total_tests = 0;
  int passed_tests = 0;
  int failed_tests = 0;
  char failed_test_names[2048] = "";
}

// ============================================================================
// CCS_018_1: Step 1
// ============================================================================
testcase CCS_018_1()
{
  int is_ok;

  Send_Value_To_COM(31801);
  SetTestStep("Buoc 1 - CCS_018");
  StartTestTimer();
  testStep("Step 1", "Set_SMK_IGN -> USM Reset -> Rec Reset -> OWP ON -> PEV AppNoti ON -> KEY_OFF, then verify OWP/PEV recording and RecSta_PEV=0x1");

  write("=== START CCS_018_1 ===");

  Set_SMK_IGN();
  Click_USM_Reset();
  Click_Rec_Reset();

  Turn_ON_OWP();
  Set_PEV_AppNoti(0x2);
  KEY_OFF();

  is_ok = WaitFor_RecSta_OWP_Recording(60000);
  if (is_ok == 1) {
    testStepPass("CCS_018_1_A", "OWP recording started within 60s");
  } else {
    testStepFail("CCS_018_1_A", "Fail reason: Timeout waiting OWP recording start within 60s. Cause: expected condition was not satisfied.");
  }

  is_ok = WaitFor_RecSta_PEV_Recording(60);
  if (is_ok == 1) {
    testStepPass("CCS_018_1_B", "PEV recording detected within 60s");
  } else {
    testStepFail("CCS_018_1_B", "Fail reason: Timeout waiting BLTN_CAM_RecSta_PEV = 0x1 within 60s. Cause: expected condition was not satisfied.");
  }

  if (Check_RecSta_PEV_Recording() == 1) {
    testStepPass("CCS_018_1_C", "BLTN_CAM_RecSta_PEV = 0x1");
  } else {
    snprintf(failReason,
             elcount(failReason),
             "Fail reason: BLTN_CAM_RecSta_PEV = 0x%X (expected 0x1). Cause: expected condition was not satisfied.",
             $BLTN_CAM_RecSta_PEV);
    testStepFail("CCS_018_1_C", failReason);
  }

  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti");

  write("=== FINISH CCS_018_1 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// CCS_018_2: Step 2
// ============================================================================
testcase CCS_018_2()
{
  long sleep_ok;
  int is_ok;

  Send_Value_To_COM(31802);
  SetTestStep("Buoc 2 - CCS_018");
  StartTestTimer();
  testStep("Step 2", "KEY_ON -> KEY_OFF -> WaitForNetworkSleep(8 mins) -> wait PEV recording -> wait 20s -> wait PEV recording again -> check PEV_Recorded=0x2");

  write("=== START CCS_018_2 ===");

  KEY_ON();
  testWaitForTimeout(2000);
  KEY_OFF();

  sleep_ok = WaitForNetworkSleep(480);
  if (sleep_ok == 1) {
    testStepPass("CCS_018_2_A", "Network sleep detected within 6 mins");
  } else {
    testStepFail("CCS_018_2_A", "Fail reason: WaitForNetworkSleep timeout after 8 mins. Cause: expected condition was not satisfied.");
  }

  is_ok = WaitFor_RecSta_PEV_Recording(60);
  if (is_ok == 1) {
    testStepPass("CCS_018_2_B", "First PEV recording wait passed");
  } else {
    testStepFail("CCS_018_2_B", "Fail reason: Timeout waiting first BLTN_CAM_RecSta_PEV = 0x1 within 60s. Cause: expected condition was not satisfied.");
  }

  testWaitForTimeout(20000);

  is_ok = WaitFor_RecSta_PEV_Recording(60);
  if (is_ok == 1) {
    testStepPass("CCS_018_2_C", "Second PEV recording wait passed after 20s");
  } else {
    testStepFail("CCS_018_2_C", "Fail reason: Timeout waiting second BLTN_CAM_RecSta_PEV = 0x1 within 60s. Cause: expected condition was not satisfied.");
  }

  if ($BLTN_CAM_PEV_Recorded == 0x2) {
    testStepPass("CCS_018_2_D", "BLTN_CAM_PEV_Recorded = 0x2");
  } else {
    snprintf(failReason,
             elcount(failReason),
             "Fail reason: BLTN_CAM_PEV_Recorded = 0x%X (expected 0x2). Cause: expected condition was not satisfied.",
             $BLTN_CAM_PEV_Recorded);
    testStepFail("CCS_018_2_D", failReason);
  }

  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti");

  write("=== FINISH CCS_018_2 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

