// ============================================================================
// CCS_020_17: Step 17
// ============================================================================
testcase CCS_020_17()
{
  int is_ok;
  int pev_wait;
  long sleep_ok;

  Send_Value_To_COM(32017);
  SetTestStep("Buoc 17 - CCS_020");
  StartTestTimer();
  testStep("Step 17", "KEY_ON -> KEY_OFF -> Wait OWP -> Wait network sleep -> Wait PEV 5s -> check BLTN_CAM_RecSta_PEV = 0x0");

  write("=== START CCS_020_17 ===");

  KEY_ON();
  testWaitForTimeout(2000);
  KEY_OFF();

  is_ok = WaitFor_RecSta_OWP_Recording(60000);
  if (is_ok == 1) {
    testStepPass("CCS_020_17_A", "OWP recording started within 60s");
  } else {
    testStepFail("CCS_020_17_A", "Fail reason: Timeout waiting OWP recording start within 60s. Cause: expected condition was not satisfied.");
  }

  sleep_ok = WaitForNetworkSleep(480);
  if (sleep_ok == 1) {
    testStepPass("CCS_020_17_B", "Network sleep detected within 6 mins");
  } else {
    testStepFail("CCS_020_17_B", "Fail reason: WaitForNetworkSleep timeout after 8 mins. Cause: expected condition was not satisfied.");
  }

  pev_wait = WaitFor_RecSta_PEV_Recording(60);
  if (pev_wait == 0) {
    testStepPass("CCS_020_17_C", "No PEV recording detected in 60s (expected)");
  } else {
    testStepFail("CCS_020_17_C", "Fail reason: PEV recording detected within 60s while expected OFF. Cause: expected condition was not satisfied.");
  }

  if ($BLTN_CAM_RecSta_PEV == 0x0) {
    testStepPass("CCS_020_17_D", "BLTN_CAM_RecSta_PEV = 0x0");
  } else {
    snprintf(failReason,
             elcount(failReason),
             "Fail reason: BLTN_CAM_RecSta_PEV = 0x%X (expected 0x0). Cause: expected condition was not satisfied.",
             $BLTN_CAM_RecSta_PEV);
    testStepFail("CCS_020_17_D", failReason);
  }

  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_RecSta_DEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti");

  write("=== FINISH CCS_020_17 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

