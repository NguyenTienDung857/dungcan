// ============================================================================
// CCS_020_9: Step 9
// ============================================================================
testcase CCS_020_9()
{
  int is_ok;
  int cycle;

  Send_Value_To_COM(32009);
  SetTestStep("Buoc 9 - CCS_020");
  StartTestTimer();
  testStep("Step 9", "KEY ON/OFF loop 20 times -> KEY_OFF -> Wait DEV recording -> wait 12s -> check BLTN_CAM_PEV_Recorded = 0x2");

  write("=== START CCS_020_9 ===");

  for (cycle = 1; cycle <= 20; cycle++) {
    KEY_ON();
    testWaitForTimeout(1000);
    KEY_OFF();
    testWaitForTimeout(1000);
    write("  KEY ON/OFF cycle %d/20 completed", cycle);
  }

  KEY_OFF();

  is_ok = WaitFor_RecSta_PEV_Recording(60);
  if (is_ok == 1) {
    testStepPass("CCS_020_9_A", "DEV recording detected within 60s");
  } else {
    testStepFail("CCS_020_9_A", "Fail reason: Timeout waiting BLTN_CAM_RecSta_DEV = 0x1 within 60s. Cause: expected condition was not satisfied.");
  }

  testWaitForTimeout(12000);

  if ($BLTN_CAM_PEV_Recorded == 0x2) {
    testStepPass("CCS_020_9_B", "BLTN_CAM_PEV_Recorded = 0x2");
  } else {
    snprintf(failReason,
             elcount(failReason),
             "Fail reason: BLTN_CAM_PEV_Recorded = 0x%X (expected 0x2). Cause: expected condition was not satisfied.",
             $BLTN_CAM_PEV_Recorded);
    testStepFail("CCS_020_9_B", failReason);
  }

  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_RecSta_DEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti");

  write("=== FINISH CCS_020_9 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

