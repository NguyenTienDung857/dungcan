  write("=== START CCS_020_11 ===");

  KEY_ON();
  testWaitForTimeout(2000);
  KEY_OFF();

  is_ok = WaitFor_RecSta_OWP_Recording(60000);
  if (is_ok == 1) {
    testStepPass("CCS_020_11_A", "OWP recording started within 60s");
  } else {
    testStepFail("CCS_020_11_A", "Fail reason: Timeout waiting OWP recording start within 60s. Cause: expected condition was not satisfied.");
  }

  sleep_ok = WaitForNetworkSleep(480);
  if (sleep_ok == 1) {
    testStepPass("CCS_020_11_B", "Network sleep detected within 6 mins");
