/*@!Encoding:65001*/
/*
  Test Case: CCS_020 - 2.5 generation
  Title: [PEV Notification Setting Test 8 - SD Remove/Insert + Long Sequence]

  This testcase is implemented exactly by requested 17-step flow.
  It contains manual actions (remove/insert SD, manual video checks) and
  automatic signal checks using helper functions from DeclarationFunction_Gen2.5.h.

  Note:
  - WaitFor_RecSta_OWP_Recording timeout input is milliseconds.
  - WaitFor_RecSta_PEV_Recording / WaitFor_RecSta_DEV_Recording timeout input is seconds.
  - WaitForNetworkSleep timeout input is seconds.
*/

includes {
#include "..\DeclarationFunction_Gen2.5.h"
}

variables {
  char failReason[512];
  int total_tests = 0;
  int passed_tests = 0;
  int failed_tests = 0;
  char failed_test_names[2048] = "";
}

// ============================================================================
// CCS_020_1: Step 1
// ============================================================================
testcase CCS_020_1()
{
  int is_ok;
  int pev_wait;
  long sleep_ok;

  Send_Value_To_COM(32001);
  SetTestStep("Buoc 1 - CCS_020");
  StartTestTimer();
  testStep("Step 1", "Set_SMK_IGN -> USM Reset -> Rec Reset -> OWP ON -> PEV AppNoti ON -> KEY_OFF -> Wait OWP -> remove SD -> wait 10s -> wait PEV (expect 0) -> wait network sleep");

  write("=== START CCS_020_1 ===");



  Turn_ON_OWP();
  if (Set_PEV_AppNoti(0x2) == 1) {
    testStepPass("CCS_020_1_A", "Set_PEV_AppNoti ON (0x2) successful");
  } else {
    testStepFail("CCS_020_1_A", "Fail reason: Could not set PEV AppNoti to ON (0x2). Cause: expected condition was not satisfied.");
  }

  KEY_OFF();

  is_ok = WaitFor_RecSta_OWP_Recording(60000);
  if (is_ok == 1) {
    testStepPass("CCS_020_1_B", "OWP recording started within 60s");
  } else {
    testStepFail("CCS_020_1_B", "Fail reason: Timeout waiting OWP recording start within 60s. Cause: expected condition was not satisfied.");
  }

  write("*************************************************************");
  write("*** [ACTION REQUIRED] THAO THE SD NGAY BAY GIO            ***");
  write("*** Sau do doi 10 giay truoc khi tiep tuc                 ***");
  write("*************************************************************");

  testWaitForTimeout(10000);

  pev_wait = WaitFor_RecSta_PEV_Recording(60);
  if (pev_wait == 0) {
    testStepPass("CCS_020_1_C", "PEV recording not detected (PASS as expected when SD card removed)");
  } else {
    testStepFail("CCS_020_1_C", "Fail reason: PEV recording detected even though SD card is removed. Cause: expected condition was not satisfied.");
  }

  sleep_ok = WaitForNetworkSleep(480);
  if (sleep_ok == 1) {
    testStepPass("CCS_020_1_D", "Network sleep detected within 6 mins");
  } else {
    testStepFail("CCS_020_1_D", "Fail reason: WaitForNetworkSleep timeout after 8 mins. Cause: expected condition was not satisfied.");
  }

  write("Run CaptureGraphics()");
  CaptureGraphics("CSS", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_RecSta_DEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti");

  write("=== FINISH CCS_020_1 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

