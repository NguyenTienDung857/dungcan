  } else {
    testStepFail("CCS_020_11_C", "Fail reason: Timeout waiting BLTN_CAM_RecSta_PEV = 0x1 within 60s. Cause: expected condition was not satisfied.");
  }

  if (WaitFor_PEV_Recorded_Value(0x2, 40000) == 1) {
    testStepPass("CCS_020_11_D", "BLTN_CAM_PEV_Recorded reached 0x2 within 40s");
  } else {
