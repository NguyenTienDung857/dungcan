testcase HU_004_12(){
  
  testStep("Notification","Start test HU_004_12");
  write("=== START HU_004_12 ===");

  @panel::Switch_CGWNM = 1;
  
  write("Run KEY_ON()"); KEY_ON(); 
  testWaitForTimeout(3000);
  do {
  write("Run Enter_BLTN_CAM()"); Enter_BLTN_CAM();  
  testWaitForTimeout(3000);
  
  write("OWD On"); @panel::LED_Ctrl_SetOWD = 1;
  testWaitForTimeout(1000);
  
  @panel::Switch_Clock = 1;
  
  testWaitForTimeout(1000);
  
  write("Run Check_time()"); Check_time(); 
  
  testWaitForTimeout(1000);
  
  @panel::Switch_Clock = 0;
  
  write("Run Exit_BLTN_CAM()"); Exit_BLTN_CAM(); 
  
  } while ($BLTN_CAM_RecSet_OWD == 0x1);

  if (testWaitForSignalChange(BLTN_CAM_RecSta_OWD,100000) == 1){
    write("OWD recording is in progress...");
  }
  else{
    write("OWD recording hasn't started. Stop test !!!");
    
    write("Run Setup_End_test()"); Setup_End_test();
    
    write("Run stop()"); stop(); 
  }
  
  testWaitForTimeout(15000);
  
  write("=== SET TIME ===");Set_Time(check_DisplayHour_value,check_DisplayMinute_value, check_DisplaySecond_value + 0x14, check_DisplayDay_value, check_DisplayMonth_value, check_DisplayYear1_value, check_DisplayYear2_value + 0x1); write("Run Set_time()");
  
  testWaitForTimeout(120000);
  
  write("Run Enter_BLTN_CAM()"); Enter_BLTN_CAM(); 
  testWaitForTimeout(3000);
    
  write("Run Exit_BLTN_CAM()"); Exit_BLTN_CAM(); 
  
  testWaitForTimeout(11000);
  
  testStep("Notification","Check that the next recording file is created at the set time one year later");
  write("=== NEXT VIDEO ===");
 
  write("Run Setup_End_test()"); Setup_End_test();
  
  testWaitForTimeout(3000);
  write("Run KEY_OFF()"); KEY_OFF(); 
  
  testStepPass("Notification","Done testcase HU_004_12");
  write("=== FINISH HU_004_12 ===");
}

void MainTest(){
  
  write("Run Turn_OFF_RecSet()");Turn_OFF_RecSet();
  
  write("Run Init()"); Init();
  
  testWaitForValueInput("Notification: Enter the option you want ? (1/2/3/4)",300000);
  
  switch(testGetValueInput()){
    case(1): HU_004_1();break; //Test case HU_004_1
    case(2): 
      HU_004_5_6();
      
      testWaitForTimeout(1000);
      
      HU_004_7_8();
      
      testWaitForTimeout(1000);
      
      HU_004_9_10();
      
      testWaitForTimeout(1000);
      
      break; //Test case HU_004_5 -> HU_004_10
      
    case(3): HU_004_12();break; //Test case HU_004_12
      
    case(4):
      HU_004_1();
      
      HU_004_5_6();
      
      HU_004_7_8();
      
      HU_004_9_10();
      
      HU_004_12();
  }
}