/*@!Encoding:1252*/
// Preconditions: ACC and IGN and ccNC/ccIC switch OFF state, AVN mode
variables
{ // Message Declaration
  // CAN FD 
  message HU_CLOCK_01_1000ms _HU_CLOCK_01_1000ms;
  message HU_BLTN_CAM_01_00ms _HU_BLTN_CAM_01_00ms;
  message HU_BLTN_CAM_02_200ms _HU_BLTN_CAM_02_200ms;
  // Global Variable Declaration
  byte year;
  byte check_DisplayYear2_value;
  byte check_DisplayYear1_value;
  byte check_DisplayHour_value;
  byte check_DisplayMinute_value;
  byte check_DisplaySecond_value;
  byte check_DisplayMonth_value;
  byte check_DisplayDay_value;
  
  int flag_RecSet_error = 0;
}

void Check_time(){
  check_DisplayYear2_value = getSignal(HU_DisplayYear2);
  check_DisplayYear1_value = getSignal(HU_DisplayYear1);
  check_DisplayHour_value  = getSignal(HU_DisplayHour);
  check_DisplayMinute_value  = getSignal(HU_DisplayMinute);  
  check_DisplaySecond_value  = getSignal(HU_DisplaySecond);
  check_DisplayMonth_value = getSignal(HU_DisplayMonth);
  check_DisplayDay_value = getSignal(HU_DisplayDay);
}

void KEY_ON(){
  setSignal(SMK_TrmnlCtrlGrpStaBDC,0x1); // Power ON
}
void KEY_OFF(){
   setSignal(SMK_TrmnlCtrlGrpStaBDC,0x0); // Power OFF
}
void Enter_BLTN_CAM(){
  // CAN FD
  _HU_BLTN_CAM_02_200ms.HU_BLTN_CAM_UI_Mode = 0x1; //Enter BLTN_CAM mode  
  output(_HU_BLTN_CAM_02_200ms);
}

void Exit_BLTN_CAM(){
  // CAN FD
  _HU_BLTN_CAM_02_200ms.HU_BLTN_CAM_UI_Mode = 0x0; //Enter AVN mode - Exit BLTN_CAM Mode
  output(_HU_BLTN_CAM_02_200ms);      
}

void Clock_Down(long CD_time){
  write("=== START CLOCK ===");  
  while (CD_time > 0){
    write("Remaining time: %02d::%02d",CD_time/60,CD_time%60);
    testWaitForTimeout(60000);
    CD_time--;
  }
}

void Turn_OFF_RecSet(){
  if ($BLTN_CAM_RecSet_OWD == 0x2 || $BLTN_CAM_RecSet_OWP == 0x2 || $BLTN_CAM_RecSet_DEV == 0x2 || $BLTN_CAM_RecSet_PEV == 0x2){
    @panel::Switch_CGWNM = 1;
  
    KEY_ON();
    testWaitForTimeout(3000);

      
    do {
      Enter_BLTN_CAM();
      testWaitForTimeout(3000);
      
      if ($BLTN_CAM_RecSet_OWD == 0x2){
        write("OWD Off"); @panel::LED_Ctrl_SetOWD = 1; testWaitForTimeout(1000);
      } 
      
      else if ($BLTN_CAM_RecSet_OWP == 0x2){
        write("OWP Off"); @panel::LED_Ctrl_SetOWP = 1; testWaitForTimeout(1000);
      } 
      
      else if ($BLTN_CAM_RecSet_DEV == 0x2){
        write("DEV Off"); @panel::LED_Ctrl_SetDEV = 1; testWaitForTimeout(1000);
      } 
      
      else if ($BLTN_CAM_RecSet_PEV == 0x2){
        write("PEV Off"); @panel::LED_Ctrl_SetPEV = 1; testWaitForTimeout(1000);
      } 

      Exit_BLTN_CAM();
      
      flag_RecSet_error++;
      
    } while(($BLTN_CAM_RecSet_OWD == 0x2 || $BLTN_CAM_RecSet_OWP == 0x2 || $BLTN_CAM_RecSet_DEV == 0x2 || $BLTN_CAM_RecSet_PEV == 0x2) && (flag_RecSet_error <= 15));
    
    flag_RecSet_error = 0; 
    
    testWaitForTimeout(3000); 
    KEY_OFF();
  }
  else {
    write("Notifications: All recording setting are turned OFF.");
  }
}

void Setup_End_test(){
    do {
      Enter_BLTN_CAM();
      testWaitForTimeout(3000);
      
      if ($BLTN_CAM_RecSet_OWD == 0x2){
        write("OWD Off"); @panel::LED_Ctrl_SetOWD = 1; testWaitForTimeout(2000);
      } 

      Exit_BLTN_CAM();
      
      flag_RecSet_error++;
      
    } while($BLTN_CAM_RecSet_OWD == 0x2 && (flag_RecSet_error <= 15));
    
    flag_RecSet_error = 0;     
}

void Set_Time(byte hour, byte min, byte sec, byte day, byte month, byte year1,byte year2){
// CAN FD 
  _HU_CLOCK_01_1000ms.HU_TimeFormat=0x2; 
  _HU_CLOCK_01_1000ms.HU_Status= 0x2; 
  _HU_CLOCK_01_1000ms.HU_TimeSetting= 0x1; 
  _HU_CLOCK_01_1000ms.HU_DisplayHour= hour; 
  _HU_CLOCK_01_1000ms.HU_DisplayMinute= min; 
  _HU_CLOCK_01_1000ms.HU_DisplaySecond= sec; 
  _HU_CLOCK_01_1000ms.HU_DisplayYear1= year1; 
  _HU_CLOCK_01_1000ms.HU_DisplayYear2= year2; 
  _HU_CLOCK_01_1000ms.HU_DisplayMonth= month; 
  _HU_CLOCK_01_1000ms.HU_DisplayDay= day; 
  _HU_CLOCK_01_1000ms.HU_ClockInfo=0x1; 
  _HU_CLOCK_01_1000ms.HU_ComRefresh=0x2; 
  _HU_CLOCK_01_1000ms.HU_AM_PM_INFO=0x0; 
  output(_HU_CLOCK_01_1000ms);
 
}

void Init(){
  @panel::Switch_CGWNM = 1; 
  
  KEY_ON();
  
  while (getSignal(BLTN_CAM_SD_Format_Op_State) != 0x1){
    @panel::Button_RecReset = 1; 
    testWaitForSignalChange(BLTN_CAM_SD_Format_Op_State,500);
  }
    
  KEY_OFF();
  
  @panel::Switch_CGWNM = 0; 
}

testcase HU_004_1(){
  testStep("Notification","Start test HU_004_1");
  write("=== START HU_004_1 ===");

  @panel::Switch_CGWNM = 1;
  
  write("Run KEY_ON()"); KEY_ON();
  testWaitForTimeout(3000);
  
  @panel::Switch_CGWNM = 0;
  do {
    write("Run Enter_BLTN_CAM()"); Enter_BLTN_CAM();
    testWaitForTimeout(3000);
  
    write("OWD On"); @panel::LED_Ctrl_SetOWD = 1;
    testWaitForTimeout(2000);
  
    @panel::Switch_Clock = 1; 
  
    write("Run Exit_BLTN_CAM()"); Exit_BLTN_CAM();
    
  } while ($BLTN_CAM_RecSet_OWD == 0x1);
  
  if (testWaitForSignalChange(BLTN_CAM_RecSta_OWD,100000) == 1){
    write("OWD recording is in progress...");
    testWaitForTimeout(10000);
  }
  else{
    write("OWD recording hasn't started. Stop test !!!");
    
    write("Run Setup_End_test()"); Setup_End_test();
    
    stop(); write("Run stop()");
  }

  write("Run Setup_End_test()"); Setup_End_test();
  
  @panel::Switch_Clock = 0;

  testWaitForTimeout(3000);
  
  KEY_OFF(); write("Run KEY_OFF()");
  
  testStepPass("Notification","Done testcase HU_004_1");
  write("=== FINISH HU_004_1 ===");
}
testcase HU_004_5_6(){
  testStep("Notification","Start test HU_004_5 and HU_004_6");
  write("=== START HU_004_5 & HU_004_6 ===");

  @panel::Switch_CGWNM = 1;
  
  KEY_ON(); write("Run KEY_ON()");
  testWaitForTimeout(3000);
  
  @panel::Switch_CGWNM = 0;
  
  do {
    Enter_BLTN_CAM(); write("Run Enter_BLTN_CAM()"); 
    testWaitForTimeout(3000);
  
    write("OWD On"); @panel::LED_Ctrl_SetOWD = 1;
    testWaitForTimeout(1000);
  
    @panel::Switch_Clock = 1;
    testWaitForTimeout(1000);
  
    Check_time(); write("Run Check time()");
  
    @panel::Switch_Clock = 0;
    testWaitForTimeout(1000);
  
    testStep("Notification","Set time to 1 year later");
    write("Set time to 1 year later");
    Set_Time(check_DisplayHour_value,check_DisplayMinute_value,check_DisplaySecond_value, check_DisplayDay_value, check_DisplayMonth_value, check_DisplayYear1_value, check_DisplayYear2_value + 0x1);
  
    write("Run Exit_BLTN_CAM()"); Exit_BLTN_CAM(); 
    
  } while ($BLTN_CAM_RecSet_OWD == 0x1);

  if (testWaitForSignalChange(BLTN_CAM_RecSta_OWD,100000) == 1){
    write("OWD recording is in progress...");
    testWaitForTimeout(10000);
  }
  else{
    write("Error: OWD recording hasn't started");

    write("Run Setup_End_test()"); Setup_End_test();
    
    write("Run stop()"); stop(); 
  }
  
  testStep("Notification","Enter Sleep to check the time are maintained");
  write("=== ENTER SLEEP ===");
  
   write("Run KEY_OFF()"); KEY_OFF();
  
  testWaitForTimeout(20000);

  testStep("Notification","Wake up and record OWD");
  write("=== WAKE UP ===");
  
  @panel::Switch_CGWNM = 1;
  
  write("Run KEY_ON()");KEY_ON();
  testWaitForTimeout(10000);
  
  @panel::Switch_CGWNM = 0;

  write("Run Setup_End_test()"); Setup_End_test();  
  
  testWaitForTimeout(3000);
  
  write("Run KEY_OFF()"); KEY_OFF(); 
  
  testStepPass("Notification","Done testcase HU_004_5 and HU_004_6");
  write("=== FINISH HU_004_5 & HU_004_6 ===");
  
}
