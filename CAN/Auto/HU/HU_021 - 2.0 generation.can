testcase HU_021_10(){
  byte remember_OWD_recset;
  
  testStep("Notification","Start test HU_021_10");
  write("=== START HU_021_10 ===");
  
  ProfileIDRVal = 0x1; // Profile Guest
  send_IAU_timer.set(200); write("Run timer IAU");
  
  testWaitForTimeout(10000);
  
  write("Run Enter_BLTN_CAM()"); Enter_BLTN_CAM(); 
  testWaitForTimeout(3000);
  
  remember_OWD_recset = getSignal(BLTN_CAM_RecSet_OWD);
  
  if (remember_OWD_recset == 0x1){
    do{
      
      write("Turn OWD ON"); @panel::LED_Ctrl_SetOWD = 1;
      
      testWaitForTimeout(1000);
      
    } while (getSignal(BLTN_CAM_RecSet_OWD) == 0x1);
  } 
  
  write("Run Exit BLTN_CAM()"); Exit_BLTN_CAM();
  
  if(testWaitForSignalChange(BLTN_CAM_RecSta_OWD,10000) == 1){
    
    write("OWD recording is started");
    
    testWaitForTimeout(10000);
    
    ProfileIDRVal = 0x2; // Profile Driver 1
  
    if(testWaitForSignalChange(BLTN_CAM_RecSta_OWD,20000) == 1){
      testStepPass("Pass","Test-case is OK");
      write("OWD recording has ended");
    }
    else{
      testStepFail("Fail","Test-case is NG");
      write("Test case is NG because OWD hasn't ended");
    }
  }
  else {
    if (remember_OWD_recset == 0x1){
      
      do {
        
      Enter_BLTN_CAM(); write("Run Enter_BLTN_CAM()");
      testWaitForTimeout(3000);
    
      write("Turn OFF OWD"); @panel::LED_Ctrl_SetOWD = 1;  

      testWaitForTimeout(1000);
        
      } while (getSignal(BLTN_CAM_RecSet_OWD) == 0x2);
  
      Exit_BLTN_CAM(); write("Run Exit_BLTN_CAM()");
    }
    testStepFail("Fail","OWD recording hasn't started");
  }
  
  CaptureGraphics(); write("Run Capture Graphics()");
  
  testReportAddWindowCapture("Profile Settings","","Profile Driver 1","./profile_setting.jpg");  
  
  ProfileIDRVal = 0x1; // Profile Guest
  
  testWaitForTimeout(5000);
  
  if (remember_OWD_recset == 0x1){
      
    do {
        
    Enter_BLTN_CAM(); write("Run Enter_BLTN_CAM()");
    testWaitForTimeout(3000);
    
    write("Turn OFF OWD"); @panel::LED_Ctrl_SetOWD = 1;  

    testWaitForTimeout(1000);
        
    } while (getSignal(BLTN_CAM_RecSet_OWD) == 0x2);
  
    Exit_BLTN_CAM(); write("Run Exit_BLTN_CAM()");
  }
  
  ProfileIDRVal = 0x0;
  testWaitForTimeout(1000);
  
  send_IAU_timer.cancel(); write("Cancel timer");
  
  write("=== FINISH HU_021_10 ===");
}

