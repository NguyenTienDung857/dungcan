          case(2): write("Mismatch >> DEV: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(3): write("Mismatch >> PEV: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(4): write("Mismatch >> 120h: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(5): write("Mismatch >> Parking Time: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(6): write("Mismatch >> TML Interval: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(7): write("Mismatch >> Bfr Time: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(8): write("Mismatch >> Aft Time: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(9): write("Mismatch >> EV Sen Stamp: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(10): write("Mismatch >> Gear Stamp: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(11): write("Mismatch >> Location Stamp: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(12): write("Mismatch >> Velocity Stamp: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(14): write("Mismatch >> Turn Signal Stamp: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(15): write("Mismatch >> Audio: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(16): write("Mismatch >> FCAM Angle: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(17): write("Mismatch >> RCAM Angle: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(18): write("Mismatch >> DEV Sen Level: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(19): write("Mismatch >> PEV Sen Level: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
          case(20): write("Mismatch >> App Notification: driver1 = 0x%X, get = 0x%X", arr_Profile_Driver1_setting[i], arr_get_setting[i]); break;
              
          CaptureGraphics(); write("Run Capture Graphics()");
          testReportAddWindowCapture("Profile Settings","","Profile Driver 1","./profile_setting.jpg");     
          }          
        }
      }
  
      if(flag == 21){
        condition3 = 1;
        
        CaptureGraphics(); write("Run Capture Graphics()");
        testReportAddWindowCapture("Profile Settings","","Profile Driver 1","./profile_setting.jpg");     
      }  
  
      if(condition1 == 1 && condition2 == 1 && condition3 == 1){
        testStepPass("Pass","Setting value changes from 0x2 (Profile1) to 0x1 (Guest) and returns to 0x2 (Profile1). So test-case is OK");
        write("Setting value changes from 0x2 (Profile1) to 0x1 (Guest) and returns to 0x2 (Profile1). So test-case is OK");
      }
      else{
        testStepFail("Fail","Test-case is NG");
        write("Fail: Test-case is NG");
      }
    }
  }

  flag = 0;
  
  ProfileIDRValue = 0x0;
  ProfileIDRVal = 0x0;
  testWaitForTimeout(1000);
  write("Cancel timer"); send_CF_AVN_timer.cancel(); send_IAU_timer.cancel();

  write("=== FINISH HU_021_17 ===");  
}

