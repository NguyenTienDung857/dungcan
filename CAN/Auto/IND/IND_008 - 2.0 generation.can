void MainTest(){
  testWaitForValueInput("Notification: Enter the testcase ID (1/2/3/4):",300000); 
  
  switch(testGetValueInput()){
    case(1): IND_008_1();break;
    
    case(2): IND_008_2();break;
    
    case(3): IND_008_3();break;
      
    case(4): IND_008_1(); IND_008_2(); IND_008_3(); break;  
  }
}