void Set_Profile_Driver2(){
  int same;
  int loop;
  
  loop = 0;

  setSignal(IAU_ProfileIDRVal, 0x3); // Driver2's Profile 
  
  testWaitForTimeout(5000);
  
  Random_Settings();
  write("=== RANDOM SETTING ===");
