on timer BusLoadCheck_timer {
  get_BusLoad_value = canGetBusLoad(2);
  
  @Sysvar_testcase::get_BL = get_BusLoad_value;
  
  if (get_BusLoad_value < @Sysvar_testcase::expected_BL) {

    write("Low BusLoad: %d%% -> Send more messages!", get_BusLoad_value);
    
    handler_active_message();
  
  }
  else if (get_BusLoad_value > @Sysvar_testcase::expected_BL + 1){
    
    write("High BusLoad: %d%% -> Unsend some messages!", get_BusLoad_value);
    
    if (active29 == 0 && active28 == 0 && active27 == 0 && active26 == 0 && active25 == 0 && active24 == 0 && active23 == 0 && active22 == 0 && active21 == 0 && active20 == 0 && active19 == 0 && active18 == 0 && active17 == 0 && active16 == 0 && active15 == 0 && active14 == 0 && active13 == 0)
    {
      current_timer_deactive = 12 - count;
      
      handler_deactive_message();
      
    }
    else {
      
      count = 0; 
    
      handler_deactive_message();
    }
  }
  else {
    write("Current BusLoad: %d%%", get_BusLoad_value);
  }
  
  BusLoadCheck_timer.set(3);  // Check after 3s
}


