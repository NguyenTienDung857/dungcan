void handler_deactive_message(){
    switch (current_timer_deactive) {
      case 29: if (active29 == 0) {current_timer_deactive = 28; break;}
               else { write("Unsend Msg29"); active29 = 0; current_timer_deactive = 28; timer29.cancel(); } break;     
      case 28: if (active28 == 0) {current_timer_deactive = 27; break;}
               else { write("Unsend Msg28"); active28 = 0; current_timer_deactive = 27; timer28.cancel(); } break;
