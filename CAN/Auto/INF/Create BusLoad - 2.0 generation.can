variables
{
  // CAN Message Declaration
  message NM_ALBCU _1;
  message NM_ARS _2;
  message NM_ASAU _3;
  message NM_ATS _4;
  message NM_DSAU _5;
  message NM_EMCU _6;
  message NM_FCS _7;
  message NM_GW_APSU _8;
  message NM_GW_DLBCU _9;
  message NM_GW_DPSU _10;
  message NM_GW_RLPSU _11;
  message NM_GW_RRPSU _12;
  message NM_HOD _13;
  message NM_OHCL _14;
  message NM_PFSU _15;
  message NM_PSB _16;
  message NM_RCM _17;
  message NM_RCS _18;
  message NM_RLHV _19;
  message NM_RRHV _20;
  message NM_RWPC _21;
  message NM_SCM _22;
  message NM_SGU _23;
  message NM_SHVU_FR _24;
  message NM_SHVU_RR _25;
  message NM_SLB _26;
  message NM_SWRC _27;
  message NM_WPC _28;
  message NM_WPC2 _29;
  
  // Global Variable Declaration
  int get_BusLoad_value;
  int count = 0;
  int i;
  int current_timer_active = 29;
  int current_timer_deactive = 29;
  int active1, active2, active3, active4, active5, active6, active7, active8, active9, active10, 
      active11, active12, active13, active14, active15, active16, active17,active18, active19, active20, 
      active21, active22, active23, active24, active25, active26, active27, active28, active29;
  // Timer Declaration
  msTimer timer1,timer2,timer3,timer4,timer5,timer6,timer7,timer8,timer9,timer10,
          timer11,timer12,timer13,timer14,timer15,timer16,timer17,timer18, timer19, timer20, 
          timer21, timer22, timer23, timer24, timer25, timer26, timer27, timer28, timer29;
  timer BusLoadCheck_timer;
}

on sysvar_update Sysvar_testcase::Switch_CreateBL
{
  if(@Sysvar_testcase::Switch_CreateBL == 1 && (@Sysvar_testcase::get_BL >= 60 && @Sysvar_testcase::get_BL <=65))
  {
    active1 = active2 = active3 = active4 = active5 = active6 = active7 = active8 = active9 = active10 = active11 = active12 = 1;
    active13 = active14 = active15 = active16 = active17 = active18 = active19 = active20 = active21 = active22 = active23 = active24 = active25 = active26 = active27 = active28 = active29 = 0; 
  
    write("=== CREATE BUS LOAD ===");
  
    timer1.set(10);
    timer2.set(10);
    timer3.set(10);
    timer4.set(10);
    timer5.set(10);
    timer6.set(10);
    timer7.set(10);
    timer8.set(10);
    timer9.set(10);
    timer10.set(10);
    timer11.set(10);
    timer12.set(10);
  
    BusLoadCheck_timer.set(5);
  }
}

