/*@!Encoding:65001*/

includes
{
  #include "../DeclarationFunction_Gen2.5.h"
}

/*
  Test Case: INF_001 - 2.5 generation
  Title: [Driving Info Stamp Settings] - ON/OFF verification for all stamp items

  Preconditions:
    - ACC and IGN and ccNC/ccIC switch OFF, AVN mode

  Test flow:
    Step 1:  Init: Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, Turn_ON_OWD,
             Enter_BLTN_CAM, send BLTN_CAM_Time_Stm_NvalueSet=0x1(OFF),
             check BLTN_CAM_Set_Tim_Stm=0x1(OFF), Exit_BLTN_CAM, screenshot
    Step 2:  KEY OFF, KEY ON, wait 10s, KEY OFF, KEY ON
    Step 3:  Enter_BLTN_CAM, send BLTN_CAM_Time_Stm_NvalueSet=0x2(ON),
             check BLTN_CAM_Set_Tim_Stm=0x2(ON), Exit_BLTN_CAM, screenshot
    Step 4:  KEY OFF, KEY ON, wait 10s, KEY OFF
    Step 5~24: Repeat pattern for Spd_Stm, GearPos_Stm, TrnSig_Stm,
               EVSen_Stm, Locatn_Stm (OFF then ON each)

  NOTE: NvalueSet signals are sent via HU_BLTN_CAM_01_00ms CAN FD message.
        Must sync all current signal values before sending (valueSet pattern).
        Screenshots are captured only on odd steps (signal send/check steps).
        If send+check fails, retry up to 5 times (Exit -> re-Enter -> resend).
*/

variables
{
  // Result tracking
  int step1_passed = 0;
  int step3_passed = 0;
  int step5_passed = 0;
  int step7_passed = 0;
  int step9_passed = 0;
  int step11_passed = 0;
  int step13_passed = 0;
  int step15_passed = 0;
  int step17_passed = 0;
  int step19_passed = 0;
  int step21_passed = 0;
  int step23_passed = 0;

  // Message Declaration for CAN FD
  message HU_BLTN_CAM_02_200ms _HU_BLTN_CAM_02_200ms;
  message HU_BLTN_CAM_01_00ms  _HU_BLTN_CAM_01_00ms;
  message HU_CLOCK_01_1000ms   _HU_CLOCK_01_1000ms;
}


// ============================================================================
// Test Cases
// ============================================================================

testcase INF_001_Init()
{
  write("========================================");
  write("=== START TEST INF_001 - 2.5 ===");
  write("========================================");
  write("===START TEST===");
}

// ============================================================================
// STEP 1: Init + Time Stamp OFF
// ============================================================================
testcase INF_001_1()
{
  int attempt;

  SetTestStep("Bước 1 - INF_001");
  StartTestTimer();

  write("");
  write("=== STEP 1: Init + Set Time Stamp = OFF ===");
  testStep("Step1", "Init + BLTN_CAM_Time_Stm_NvalueSet=0x1(OFF), check BLTN_CAM_Set_Tim_Stm=0x1(OFF)");

  // 1.1: Set_SMK_IGN
  write("Step 1.1: Set_SMK_IGN...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);

  // 1.2: USM Reset
  write("Step 1.2: Click_USM_Reset...");
  Click_USM_Reset();

  // 1.3: Rec Reset
  write("Step 1.3: Click_Rec_Reset...");
  Click_Rec_Reset();

  // 1.4: Turn ON OWD
  write("Step 1.4: Turn_ON_OWD...");
  Turn_ON_OWD();
  testWaitForTimeout(3000);

  // 1.5: Enter BLTN_CAM + Send with retry (max 5 attempts)
  step1_passed = 0;
  for (attempt = 1; attempt <= 5; attempt++)
  {
    write("Step 1.5: Enter_BLTN_CAM (attempt %d/5)...", attempt);
    Enter_BLTN_CAM();
    testWaitForTimeout(3000);

    write("Step 1.6: Send BLTN_CAM_Time_Stm_NvalueSet = 0x1 (OFF)...");
    if (Send_Tim_Stm_NvalueSet(0x1) == 1)
    {
      step1_passed = 1;
      write(">>> [OK] Step 1 passed on attempt %d <<<", attempt);
      break;
    }

    write(">>> [NG] Attempt %d/5 failed <<<", attempt);
    Exit_BLTN_CAM();
    testWaitForTimeout(2000);
  }

  if (step1_passed == 1)
  {
    testStepPass("Step1", "BLTN_CAM_Set_Tim_Stm = 0x1 (OFF) - PASS");
    Exit_BLTN_CAM();
    testWaitForTimeout(1000);
  }
  else
  {
    Log_Error_Details();
    testStepFail("Step1", "BLTN_CAM_Set_Tim_Stm != 0x1 - FAIL after 5 attempts");
  }

  CaptureGraphics("INF", "BLTN_CAM_Set_Tim_Stm;BLTN_CAM_Time_Stm_NvalueSet");

  write("=== FINISH STEP 1 ===");
  StopTestTimer();
}

// ============================================================================
// STEP 2: KEY OFF, KEY ON, wait 10s, KEY OFF, KEY ON
// ============================================================================
testcase INF_001_2()
{
  SetTestStep("Bước 2 - INF_001");
  StartTestTimer();

  write("");
  write("=== STEP 2: KEY cycle (OFF -> ON -> 10s -> OFF -> ON) ===");
  testStep("Step2", "KEY OFF, KEY ON, wait 10s, KEY OFF, KEY ON");

  KEY_OFF();
  testWaitForTimeout(3000);

  KEY_ON();
  testWaitForTimeout(10000);

  KEY_OFF();
  testWaitForTimeout(3000);

  KEY_ON();
  testWaitForTimeout(3000);

  write("=== FINISH STEP 2 ===");
  StopTestTimer();
}

