  write("=== STEP 20: KEY cycle (OFF -> ON -> 10s -> OFF) ===");
  testStep("Step20", "KEY OFF, KEY ON, wait 10s, KEY OFF");
  KEY_OFF(); testWaitForTimeout(3000);
