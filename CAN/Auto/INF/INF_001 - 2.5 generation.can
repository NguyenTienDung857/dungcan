// ============================================================================
// STEP 21: Location Stamp OFF
// ============================================================================
testcase INF_001_21()
{
  int attempt;

  SetTestStep("Bước 21 - INF_001");
  StartTestTimer();

  write("");
  write("=== STEP 21: Set Location Stamp = OFF ===");
  testStep("Step21", "BLTN_CAM_Locatn_Stm_NvalueSet=0x1(OFF), check BLTN_CAM_Set_Locatn_Stm=0x1(OFF)");

  KEY_ON();
  testWaitForTimeout(3000);

  step21_passed = 0;
  for (attempt = 1; attempt <= 5; attempt++)
  {
    write("Step 21: Enter_BLTN_CAM (attempt %d/5)...", attempt);
    Enter_BLTN_CAM();
    testWaitForTimeout(3000);

    if (Send_Locatn_Stm_NvalueSet(0x1) == 1)
    {
      step21_passed = 1;
      write(">>> [OK] Step 21 passed on attempt %d <<<", attempt);
      break;
    }

    write(">>> [NG] Attempt %d/5 failed <<<", attempt);
    Exit_BLTN_CAM();
    testWaitForTimeout(2000);
  }

  if (step21_passed == 1)
  {
    testStepPass("Step21", "BLTN_CAM_Set_Locatn_Stm = 0x1 (OFF) - PASS");
    Exit_BLTN_CAM();
    testWaitForTimeout(1000);
  }
  else
  {
    Log_Error_Details();
    testStepFail("Step21", "BLTN_CAM_Set_Locatn_Stm != 0x1 - FAIL after 5 attempts");
  }

  CaptureGraphics("INF", "BLTN_CAM_Set_Locatn_Stm;BLTN_CAM_Locatn_Stm_NvalueSet");

  write("=== FINISH STEP 21 ===");
  StopTestTimer();
}

