/*@!Encoding:65001*/

includes
{
  #include "../DeclarationFunction_Gen2.5.h"
}

/*
  Test Case: INF_002 - 2.5 generation
  
  Preconditions:
    - ACC and IGN and ccNC/ccIC switch OFF, AVN mode
*/

variables
{
  long wait_owd_timeout_ms = 60000;
  long wait_owp_timeout_ms = 60000;
  long wait_pmd_timeout_ms = 120000;
  int wait_dev_timeout_s = 60;
  int wait_pev_timeout_s = 60;

  int setup_passed = 0;
  int step1_passed = 0;
  int step2_passed = 0;
  int step3_passed = 0;
  int step4_passed = 0;
  int step5_passed = 0;
  int step6_passed = 0;
  int step8_passed = 0;

}


// ============================================================================
// Setup Step
// ============================================================================
testcase INF_002_Setup()
{
  SetTestStep("Setup - INF_002");
  StartTestTimer();

  write("=================================================================");
  write("=== SETUP: Init and Set ALL Stamps to ON (0x2) ===");
  write("=================================================================");
  testStep("Setup", "Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, Set all stamps ON");

  write("Setup: Set_SMK_IGN...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);

  write("Setup: Click_USM_Reset...");
  Click_USM_Reset();

  write("Setup: Click_Rec_Reset...");
  Click_Rec_Reset();
  
  write("Setup: Enter_BLTN_CAM...");
  Enter_BLTN_CAM();
  testWaitForTimeout(3000);

  setup_passed = Send_All_Stm_NvalueSet(0x2);

  if (setup_passed == 1)
  {
    testStepPass("Setup", "All stamps set to ON successfully - PASS");
  }
  else
  {
    testStepFail("Setup", "Failed to set all stamps to ON - FAIL");
    Log_Error_Details();
  }

  Exit_BLTN_CAM();
  testWaitForTimeout(2000);

  StopTestTimer();
}

// ============================================================================
// Step 1: KEY OFF -> KEY ON -> Wait OWD -> wait 5s -> KEY OFF
// ============================================================================
testcase INF_002_1()
{
  SetTestStep("Bước 1 - INF_002");
  StartTestTimer();

  write("=================================================================");
  write("=== STEP 1: KEY OFF, KEY ON, Wait OWD, Wait 5s, KEY OFF ===");
  write("=================================================================");
  testStep("Step1", "Wait for OWD Recording");

  KEY_OFF();
  testWaitForTimeout(5000);

  KEY_ON();
  
  if (WaitFor_RecSta_OWD_Recording(wait_owd_timeout_ms) == 1)
  {
    testWaitForTimeout(5000);
    KEY_OFF();
    testWaitForTimeout(5000);
    step1_passed = 1;
    testStepPass("Step1", "OWD Recording started successfully - PASS");
  }
  else
  {
    step1_passed = 0;
    testStepFail("Step1", "Timeout waiting for OWD Recording - FAIL");
    Log_Error_Details();
  }

  StopTestTimer();
}

