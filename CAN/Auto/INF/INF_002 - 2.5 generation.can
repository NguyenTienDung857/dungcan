// ============================================================================
// Step 8: KEY OFF -> KEY ON -> Turn ON PMD -> KEY OFF -> Wait PMD -> Wait 5s
// ============================================================================
testcase INF_002_8()
{
  SetTestStep("Bước 8 - INF_002");
  StartTestTimer();

  write("=================================================================");
  write("=== STEP 8: KEY OFF, KEY ON, Turn ON PMD, KEY OFF, Wait PMD, Wait 5s ===");
  write("=================================================================");
  testStep("Step8", "Turn ON PMD and Wait for PMD Recording");

  KEY_OFF();
  testWaitForTimeout(5000);

  KEY_ON();
  testWaitForTimeout(5000);

  Turn_ON_PMD();
  testWaitForTimeout(3000);

  KEY_OFF();

  if (WaitFor_RecSta_PMD_Recording(wait_pmd_timeout_ms) == 1)
  {
    testWaitForTimeout(5000);
    step8_passed = 1;
    testStepPass("Step8", "PMD Recording checked successfully - PASS");
  }
  else
  {
    step8_passed = 0;
    testStepFail("Step8", "Timeout waiting for PMD Recording - FAIL");
    Log_Error_Details();
  }

  StopTestTimer();
}


// ============================================================================
// Summary
// ============================================================================
void MainTest()
{
  testReportFileName("TestReports\\INF_002 - 2.5 generation_report");

  INF_002_Setup();
  INF_002_1();
  INF_002_2();
  INF_002_3();
  INF_002_4();
  INF_002_5();
  INF_002_6();
  INF_002_8();

  write("");
  write("========================================");
  write("=== INF_002 TEST SUMMARY ===");
  write("========================================");

  if (setup_passed == 1)  write("  Setup : PASS");
  else                    write("  Setup : FAIL");

  if (step1_passed == 1)  write("  Step 1: PASS");
  else                    write("  Step 1: FAIL");

  if (step2_passed == 1)  write("  Step 2: PASS");
  else                    write("  Step 2: FAIL");

  if (step3_passed == 1)  write("  Step 3: PASS");
  else                    write("  Step 3: FAIL");

  if (step4_passed == 1)  write("  Step 4: PASS");
  else                    write("  Step 4: FAIL");

  if (step5_passed == 1)  write("  Step 5: PASS");
  else                    write("  Step 5: FAIL");

  if (step6_passed == 1)  write("  Step 6: PASS");
  else                    write("  Step 6: FAIL");

  if (step8_passed == 1)  write("  Step 8: PASS");
  else                    write("  Step 8: FAIL");

  write("========================================");
}
