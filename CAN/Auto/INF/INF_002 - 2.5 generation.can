// ============================================================================
// Step 3: KEY OFF -> KEY ON -> Wait OWD -> Wait DEV -> Wait 10s
// ============================================================================
testcase INF_002_3()
{
  SetTestStep("Bước 3 - INF_002");
  StartTestTimer();

  write("=================================================================");
  write("=== STEP 3: KEY OFF, KEY ON, Wait OWD, Wait DEV, Wait 10s ===");
  write("=================================================================");
  testStep("Step3", "Wait for OWD and DEV Recording");

  KEY_OFF();
  testWaitForTimeout(5000);

  KEY_ON();

  if (WaitFor_RecSta_OWD_Recording(wait_owd_timeout_ms) == 1)
  {
    if (WaitFor_RecSta_DEV_Recording(wait_dev_timeout_s) == 1)
    {
      testWaitForTimeout(10000);
      step3_passed = 1;
      testStepPass("Step3", "OWD and DEV Recording checked successfully - PASS");
    }
    else
    {
      step3_passed = 0;
      testStepFail("Step3", "Timeout waiting for DEV Recording - FAIL");
      Log_Error_Details();
    }
  }
  else
  {
    step3_passed = 0;
    testStepFail("Step3", "Timeout waiting for OWD Recording - FAIL");
    Log_Error_Details();
  }

  StopTestTimer();
}

