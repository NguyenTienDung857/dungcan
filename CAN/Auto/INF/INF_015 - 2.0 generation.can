/*@!Encoding:65001*/
//Precondition: Simulation Setup -> Block CGW_CCU; ccNC/ccIC switch OFF; All recording setting OFF; Enter AVN mode
//Add signal: BLTN_CAM_RecSta_OWD; VCU_GearPosSta
//Note: Set the time range in graphic to 12s
includes 
{
  #include "DeclarationFunction_Gen2.h"  
}
variables
{ // Global Variable Declaration
  byte i;
  int flag_RecSet_error = 0;
  byte KEY_STATE;
  byte GearPos_value = 0x0;
  byte Mode_state = 0x2;
  byte Bat_value = 0x50;
  dword speed_value  = 0x0;
  byte spd_UnitTyp_value = 0x2;
  byte gear_Pos_value = 0x0;
  char arr_ICE_modeType[3] = {'I','C','E'};
  char arr_HEV_modeType[3] = {'H','E','V'};
  char arr_EV_modeType[2] = {'E','V'};  
  char answer[3];  
  // Message Declaration
  message HU_BLTN_CAM_E_00 _HU_BLTN_CAM_E_00;
  message HU_BLTN_CAM_PE_00_200ms _HU_BLTN_CAM_PE_00_200ms;
  message TCU_01_10ms_1 _TCU_01_10ms_1;
  message HTCU_05_10ms_1 _HTCU_05_10ms_1;
  message HTCU_04_10ms_1 _HTCU_04_10ms_1;
  message VCU_01_10ms_1 _VCU_01_10ms_1;  
  message SMK_13_200ms _SMK_13_200ms;
  message ICU_08_200ms _ICU_08_200ms;
  message ICU_10_200ms _ICU_10_200ms;
  
  // Timer Declaration 
  msTimer send_PDC_FD_11_200ms_timer;
  msTimer send_TCU_01_10ms_timer;
  msTimer send_HTCU_04_10ms_timer;
  msTimer send_HTCU_05_10ms_timer;
  msTimer send_VCU_01_10ms_timer;
  msTimer send_ICU_ModState_timer;
  msTimer send_BDC_FD_SMK_03_200ms_timer;
}

on timer send_BDC_FD_SMK_03_200ms_timer {
  _SMK_13_200ms.SMK_TrmnlCtrlGrpStaBDC = KEY_STATE;
  output(_SMK_13_200ms);
  send_BDC_FD_SMK_03_200ms_timer.set(200);
}

on timer send_VCU_01_10ms_timer {
  _VCU_01_10ms_1.VCU_GearPosSta = GearPos_value;
  output(_VCU_01_10ms_1);
  send_VCU_01_10ms_timer.set(10);
}

on timer send_ICU_ModState_timer {
  _ICU_08_200ms.ICU_PowerAutoCutModSta = Mode_state;
  output(_ICU_08_200ms);
  send_ICU_ModState_timer.set(200);
}

on timer send_PDC_FD_11_200ms_timer {
  _ICU_10_200ms.ICU_BS2SoC = Bat_value;
  output(_ICU_10_200ms);
  send_PDC_FD_11_200ms_timer.set(200);
}

testcase INF_015_1(){
  testStep("Notifications","Start test INF_015_1");
  write("=== START INF_015_1 ===");
  
  GearPos_value = 0x5; // D 
  
  write("=== SETTING ===");
  
  write("KEY ON"); KEY_STATE = 0x2; testWaitForTimeout(3000);

  do {
    
    Enter_BLTN_CAM(); testWaitForTimeout(3000);
    
    if ($BLTN_CAM_RecSet_OWD == 0x1) {write("OWD On"); @panel::LED_Ctrl_SetOWD = 1; testWaitForTimeout(500);}
    
    if ($BLTN_CAM_Set_GearPos_Stm == 0x1) {write("Set GearPos Stamp On"); @panel::LED_Ctrl_Set_GearPos_Stm = 1; testWaitForTimeout(500);}
    
    if ($BLTN_CAM_Set_Tim_Stm == 0x2) {write("Set Time Stamp Off"); @panel::LED_Ctrl_Set_Tim_Stm = 1; testWaitForTimeout(500);}   
    
    if ($BLTN_CAM_Set_Spd_Stm == 0x2) {write("Set Speed Stamp Off"); @panel::LED_Ctrl_Set_Spd_Stm = 1; testWaitForTimeout(500);}    
    
    if ($BLTN_CAM_Set_TrnSig_Stm == 0x2) {write("Set TrnSig Stamp Off"); @panel::LED_Ctrl_Set_TrnSig_Stm = 1; testWaitForTimeout(500);}    
    
    if ($BLTN_CAM_Set_EVSen_Stm == 0x2) {write(" Set EVSen Stamp Off"); @panel::LED_Ctrl_Set_EVSen_Stm = 1; testWaitForTimeout(500);};   
    
    if ($BLTN_CAM_Set_Locatn_Stm == 0x2) {write("Set Locatn Stamp Off"); @panel::LED_Ctrl_Set_Locatn_Stm = 1; testWaitForTimeout(500);}
    
    @panel::Switch_Clock = 1;
    
    Exit_BLTN_CAM();
    
    flag_RecSet_error++;
  } while (($BLTN_CAM_RecSet_OWD == 0x1 || $BLTN_CAM_Set_GearPos_Stm == 0x1 || $BLTN_CAM_Set_EVSen_Stm == 0x2 || $BLTN_CAM_Set_Locatn_Stm == 0x2 || $BLTN_CAM_Set_Spd_Stm == 0x2 || $BLTN_CAM_Set_Tim_Stm == 0x2 || $BLTN_CAM_Set_TrnSig_Stm == 0x2) && (flag_RecSet_error < 15));
  
  flag_RecSet_error = 0;   
  
  write("=== TESTING ===");
  
  if (testWaitForSignalChange(BLTN_CAM_RecSta_OWD,10000) == 1) {
    write("OWD recording with GearPos is started");
    
    testWaitForTimeout(5000);
    
    send_VCU_01_10ms_timer.cancel();
    
    testWaitForTimeout(5000);
    
    do {
      
      write("Run Enter_BLTN_CAM()"); Enter_BLTN_CAM();
    
      testWaitForTimeout(3000);
      testReportAddWindowCapture("INF","BLTN_CAM_RecSta_OWD; VCU_GearPosSta","Sreenshot","./Husign.jpg");
      
      write("OWD Off"); @panel::LED_Ctrl_SetOWD = 1;
      
      testWaitForTimeout(1000);
      
      write("Run Exit_BLTN_CAM()"); Exit_BLTN_CAM();
      
      flag_RecSet_error++; 
      
    } while ($BLTN_CAM_RecSet_OWD == 0x2 && flag_RecSet_error);
    
    flag_RecSet_error = 0;
    
    send_VCU_01_10ms_timer.set(10);
    
    write("KEY OFF"); KEY_STATE = 0x0;
    
    @panel::Switch_Clock = 0;
    
  }
  else {
    
    write("OWD recording hasn't started");
    
    testStepWarning("Warning","OWD recording hasn't started");    
    
    do {
      
      write("Run Enter_BLTN_CAM()"); Enter_BLTN_CAM();
    
      testWaitForTimeout(3000);
      
      write("OWD Off"); @panel::LED_Ctrl_SetOWD = 1;
      
      testWaitForTimeout(1000);
      
      write("Run Exit_BLTN_CAM()"); Exit_BLTN_CAM();
      
      flag_RecSet_error++; 
      
    } while ($BLTN_CAM_RecSet_OWD == 0x2 && flag_RecSet_error);
    
    flag_RecSet_error = 0;   
    
    write("KEY OFF"); KEY_STATE = 0x0;
    
    @panel::Switch_Clock = 0;
    
    write("Stop mearsurement"); stop();    
    
  }
  
  testStep("Notifications","Done test INF_015_1");
  write("=== FINISH INF_015_1 ===");      
}

