    testStepWarning("Warning","OWD recording hasn't started");    
    
    do {
      
      write("Run Enter_BLTN_CAM()"); Enter_BLTN_CAM();
    
      testWaitForTimeout(3000);
      
      write("OWD Off"); @panel::LED_Ctrl_SetOWD = 1;
      
      testWaitForTimeout(1000);
      
      write("Run Exit_BLTN_CAM()"); Exit_BLTN_CAM();
      
      flag_RecSet_error++; 
      
    } while ($BLTN_CAM_RecSet_OWD == 0x2 && flag_RecSet_error);
    
    flag_RecSet_error = 0;   
    
    write("KEY OFF"); KEY_STATE = 0x0;
    
    @panel::Switch_Clock = 0;
    
    write("Stop mearsurement"); stop();    
    
  }
  
  testStep("Notifications","Done test INF_015_17");
  write("=== FINISH INF_015_17 ===");      
}

