}

// Wait for BLTN_CAM_RecSta_DEV = 0x1 with timeout
int WaitFor_RecSta_DEV_Recording(long timeout_ms)
{
  long elapsed = 0;
  long check_interval = 2000;  // Check every 2 seconds
  long log_interval;
  byte rec_sta_dev = 0;

  write("=== Waiting for DEV Recording (max %d seconds) ===", timeout_ms/1000);
  write("Checking every %d seconds...", check_interval/1000);

  log_interval = (timeout_ms / 6 / check_interval) * check_interval;
  if(log_interval < check_interval) log_interval = check_interval;

  while(elapsed < timeout_ms)
  {
    rec_sta_dev = $BLTN_CAM_RecSta_DEV;

    if(elapsed == 0 || elapsed % log_interval == 0)
    {
      write("  [%d s / %d s] BLTN_CAM_RecSta_DEV = 0x%X",
            elapsed/1000, timeout_ms/1000, rec_sta_dev);
    }

    // Check if DEV recording is active
    if(rec_sta_dev == 0x1)
    {
      write(">>> DETECTED: DEV Recording started after %d seconds <<<", elapsed/1000);
      write(">>> PASS: BLTN_CAM_RecSta_DEV = 0x1 (Recording) <<<");
      return 1;
    }

    testWaitForTimeout(check_interval);
    elapsed += check_interval;
  }

  // Timeout - DEV recording not detected
  write(">>> TIMEOUT: DEV Recording NOT detected after %d seconds <<<", timeout_ms/1000);
  write(">>> FAIL: BLTN_CAM_RecSta_DEV is still 0x%X <<<", rec_sta_dev);
  return 0;
}

// Check BLTN_CAM_RecSta_OWD = 0x1 (Recording)
int Check_RecSta_OWD_Recording()
{
  byte rec_sta_owd = 0;

  rec_sta_owd = $BLTN_CAM_RecSta_OWD;
  write("  BLTN_CAM_RecSta_OWD = 0x%X", rec_sta_owd);

  if(rec_sta_owd == 0x1)
  {
    write(">>> PASS: BLTN_CAM_RecSta_OWD = 0x1 (Recording) <<<");
    return 1;
  }
  else
  {
    write(">>> FAIL: BLTN_CAM_RecSta_OWD is NOT Recording <<<");
    return 0;
  }
}

// Check HU_BLTN_CAM_UI_Mode
int Check_HU_UI_Mode(byte expected_mode)
{
  byte hu_ui_mode = 0;

  hu_ui_mode = $HU_BLTN_CAM_UI_Mode;
  write("  HU_BLTN_CAM_UI_Mode = 0x%X", hu_ui_mode);

  if(hu_ui_mode == expected_mode)
  {
    write(">>> PASS: HU_BLTN_CAM_UI_Mode = 0x%X <<<", expected_mode);
    return 1;
  }
  else
  {
    write(">>> FAIL: HU_BLTN_CAM_UI_Mode != 0x%X <<<", expected_mode);
    return 0;
  }
}

// ============================================================================
// Capture Screenshot Function
// ============================================================================

void CaptureGraphics(char signalList[], char filename[])
{
  char filepath[256];
  snprintf(filepath, elcount(filepath), "D:\\project\\CAN FD\\[CANoe] CANFD\\Screenshots\\%s", filename);
  testWaitForTimeout(3000);
  testReportAddWindowCapture("OWD", signalList, "Screenshot", filepath);
  write(">>> Screenshot captured: %s <<<", filepath);
}

// Wait at AVN mode with monitoring
void Wait_At_AVN_WithMonitoring(long duration_ms)
{
  long elapsed = 0;
  long log_interval = 10000;  // Log every 10 seconds

  write("=== Waiting at AVN for %d seconds ===", duration_ms/1000);
  write("Monitoring signals during wait period...");

  while(elapsed < duration_ms)
  {
    if(elapsed % log_interval == 0)
    {
      write("  [%d s / %d s] RecSet_OWD=0x%X | RecSta_OWD=0x%X | RecSta_DEV=0x%X | RecSta_TML=0x%X | HU_UI_Mode=0x%X",
            elapsed/1000, duration_ms/1000,
            $BLTN_CAM_RecSet_OWD, $BLTN_CAM_RecSta_OWD, $BLTN_CAM_RecSta_DEV,
            $BLTN_CAM_RecSta_TML, $HU_BLTN_CAM_UI_Mode);
    }

    testWaitForTimeout(1000);
    elapsed += 1000;
  }

  write(">>> Wait complete: %d seconds elapsed <<<", duration_ms/1000);
}

// ============================================================================
// Main Test Case
// ============================================================================

testcase OWD_005()
{
  int i = 0;
  int result = 0;

  write("========================================");
  write("=== START TEST OWD_005 ===");
  write("========================================");

  // Enable CGW NM
  @panel::Switch_CGWNM = 1;
  testWaitForTimeout(3000);

  // Initialize Power Supply
  if(Init_PowerSupply() == 0)
  {
    write(">>> WARNING: Power Supply not connected. Steps 8-9 will be skipped <<<");
  }

  //============================================================================
  // STEP 1: Set SMK to IGN, click USM Reset, check BLTN_CAM_RecSet_OWD = ON
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 1: Set SMK_Signal to IGN, USM Reset, Check RecSet_OWD ===");
  write("=================================================================");
  testStep("Step1", "SMK IGN + USM Reset + RecSet_OWD verification");

  // 1.1 Set SMK to IGN
  Set_SMK_IGN();
  testWaitForTimeout(2000);

  // 1.2 Click USM Reset
  Click_USM_Reset();
  testWaitForTimeout(3000);

  // 1.3 Check BLTN_CAM_RecSet_OWD = 0x2 (ON)
  result = Check_RecSet_OWD_ON();

  // Capture screenshot
  CaptureGraphics("BLTN_CAM_RecSet_OWD;SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_HU_UI_Mode", "OWD_005_01.jpg");

  if(result == 1)
  {
    step1_passed = 1;
    testStepPass("Step1", "BLTN_CAM_RecSet_OWD = 0x2 (ON) - PASS");
  }
  else
  {
    step1_passed = 0;
    testStepFail("Step1", "BLTN_CAM_RecSet_OWD is NOT ON - FAIL");
  }

  //============================================================================
  // STEP 2: Switch to HU UI mode, click TML Start, check RecSta_TML
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 2: Switch to AVN HU UI Mode, TML Start, Check RecSta_TML ===");
  write("=================================================================");
  testStep("Step2", "AVN mode + TML Start + RecSta_TML verification");

  // 2.1 Switch to HU UI mode (HU_BLTN_CAM_UI_Mode = 0)
  write("[2.1] Switching to AVN HU UI mode (HU_BLTN_CAM_UI_Mode = 0)...");
  Exit_BLTN_CAM();
  testWaitForTimeout(2000);

  // Verify HU UI mode
  Check_HU_UI_Mode(0x0);

  // 2.2 Click TML Start
  write("[2.2] Clicking TML Start button...");
  Click_TML_Start();
  testWaitForTimeout(3000);

  // 2.3 Check BLTN_CAM_RecSta_TML = 0x1 (Recording)
  result = Check_RecSta_TML_Recording();

  // Capture screenshot
  CaptureGraphics("BLTN_CAM_RecSta_TML;BLTN_CAM_HU_UI_Mode;BLTN_CAM_RecSet_OWD", "OWD_005_02.jpg");

  if(result == 1)
  {
    step2_passed = 1;
    testStepPass("Step2", "BLTN_CAM_RecSta_TML = 0x1 (Recording) - PASS");
  }
  else
  {
    step2_passed = 0;
    testStepFail("Step2", "BLTN_CAM_RecSta_TML is NOT Recording - FAIL");
  }

  //============================================================================
  // STEP 3: Click Evt Switch, check RecSta_MAR
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 3: Click Evt Switch, Check RecSta_MAR ===");
  write("=================================================================");
  testStep("Step3", "Evt Switch + RecSta_MAR verification");

  // 3.1 Click Evt Switch
  write("[3.1] Clicking Evt Switch button...");
  Click_Evt_Switch();
  testWaitForTimeout(3000);

  // 3.2 Check BLTN_CAM_RecSta_MAR = 0x1 (Recording)
  result = Check_RecSta_MAR_Recording();

  // Capture screenshot
  CaptureGraphics("BLTN_CAM_RecSta_MAR;BLTN_CAM_RecSta_TML;BLTN_CAM_HU_UI_Mode", "OWD_005_03.jpg");

  if(result == 1)
  {
    step3_passed = 1;
    testStepPass("Step3", "BLTN_CAM_RecSta_MAR = 0x1 (Recording) - PASS");
  }
  else
  {
    step3_passed = 0;
    testStepFail("Step3", "BLTN_CAM_RecSta_MAR is NOT Recording - FAIL");
  }

  //============================================================================
  // STEP 4: Event while driving - check RecSta_DEV
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 4: Event while driving - Check RecSta_DEV ===");
  write("=================================================================");
  testStep("Step4", "Driving Event Recording verification");

  write("");
  write("*************************************************************");
  write("*** Tac dong su kien khi dang lai xe (Event while driving) ***");
  write("*************************************************************");
  write("");

  // Wait for event trigger and check DEV recording (with continuous monitoring)
  result = WaitFor_RecSta_DEV_Recording(50000);  // Check continuously for up to 50 seconds

  // Capture screenshot
  CaptureGraphics("BLTN_CAM_RecSta_DEV;BLTN_CAM_RecSta_MAR;BLTN_CAM_RecSta_TML;BLTN_CAM_HU_UI_Mode", "OWD_005_04.jpg");

  if(result == 1)
  {
    step4_passed = 1;
    testStepPass("Step4", "BLTN_CAM_RecSta_DEV = 0x1 (Recording) - PASS");
  }
  else
  {
    step4_passed = 0;
    testStepFail("Step4", "BLTN_CAM_RecSta_DEV is NOT Recording - FAIL");
  }

  //============================================================================
  // STEP 5: TML Stop, verify TML off, wait 65s, check OWD still recording
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 5: TML Stop, Wait 65s, Verify OWD Recording ===");
  write("=================================================================");
  testStep("Step5", "TML Stop + 65s wait + OWD recording verification");

  // 5.1 Click TML Stop
  write("[5.1] Clicking TML Stop button...");
  Click_TML_Stop();
  testWaitForTimeout(2000);

  // 5.2 Check BLTN_CAM_RecSta_TML = 0x0
  result = Check_RecSta_TML_NotRecording();

  if(result != 1)
  {
    write(">>> WARNING: TML recording did not stop properly <<<");
  }

  // 5.3 Wait 65 seconds at AVN mode with monitoring
  write("[5.3] Waiting 65 seconds at AVN mode...");
  Wait_At_AVN_WithMonitoring(65000);

  // 5.4 Check OWD still recording during this period
  write("[5.4] Checking OWD recording status after 65s...");
  result = Check_RecSta_OWD_Recording();

  // Capture screenshot
  CaptureGraphics("BLTN_CAM_RecSta_OWD;BLTN_CAM_RecSta_TML;BLTN_CAM_RecSta_MAR;BLTN_CAM_HU_UI_Mode", "OWD_005_05.jpg");

  if(result == 1)
  {
    step5_passed = 1;
    testStepPass("Step5", "OWD recording verified during 65s wait - PASS");
  }
  else
  {
    step5_passed = 0;
    testStepFail("Step5", "OWD recording not active during wait - FAIL");
  }

  //============================================================================
  // STEP 6: Enter/Exit Built-in Cam mode 5 times
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 6: Enter/Exit Built-in Cam Mode 5 Times ===");
  write("=================================================================");
  testStep("Step6", "Mode cycling 5 times verification");

  for(i = 1; i <= 5; i++)
  {
    write("");
    write("--- Cycle %d of 5 ---", i);

    // Enter Built-in Cam mode
    write("[6.%d.1] Entering Built-in Cam mode...", i);
    Enter_BLTN_CAM();
    testWaitForTimeout(3000);

    // Log current mode
    write("  After Enter: HU_BLTN_CAM_UI_Mode = 0x%X | BLTN_CAM_HU_UI_Mode = 0x%X",
          $HU_BLTN_CAM_UI_Mode, $BLTN_CAM_HU_UI_Mode);

    // Exit to AVN mode
    write("[6.%d.2] Exiting to AVN mode...", i);
    Exit_BLTN_CAM();
    testWaitForTimeout(3000);

    // Log current mode
    write("  After Exit: HU_BLTN_CAM_UI_Mode = 0x%X | BLTN_CAM_HU_UI_Mode = 0x%X",
          $HU_BLTN_CAM_UI_Mode, $BLTN_CAM_HU_UI_Mode);
  }

  // Verify final state is AVN HU UI mode
  write("");
  write("[6.6] Verifying final state is AVN HU UI mode...");
  result = Check_HU_UI_Mode(0x0);

  // Capture screenshot
  CaptureGraphics("HU_BLTN_CAM_UI_Mode;BLTN_CAM_HU_UI_Mode;BLTN_CAM_RecSet_OWD", "OWD_005_06.jpg");

  if(result == 1)
  {
    step6_passed = 1;
    testStepPass("Step6", "Mode cycling 5 times completed, final state AVN mode - PASS");
  }
  else
  {
    step6_passed = 0;
    testStepFail("Step6", "Mode cycling failed - FAIL");
  }

  //============================================================================
  // STEP 7: Log video verification
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 7: Video Recording Files Verification ===");
  write("=================================================================");
  testStep("Step7", "Video files verification log");

  write("");
  write("*************************************************************");
  write("*** VERIFICATION REQUIRED: ***");
  write("*** Check that the driving/impact/manual/time-lapse recording files are saved. ***");
  write("*** - Driving Recording (OWD) ***");
  write("*** - Impact/Event Recording (DEV) ***");
  write("*** - Manual Recording (MAR) ***");
  write("*** - Time-lapse Recording (TML) ***");
  write("*************************************************************");
  write("");

  // Log current recording settings
  write("Current Recording Settings:");
  write("  BLTN_CAM_RecSet_OWD = 0x%X", $BLTN_CAM_RecSet_OWD);
  write("  BLTN_CAM_RecSta_OWD = 0x%X", $BLTN_CAM_RecSta_OWD);
  write("  BLTN_CAM_RecSta_DEV = 0x%X", $BLTN_CAM_RecSta_DEV);
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);
  write("  BLTN_CAM_RecSta_TML = 0x%X", $BLTN_CAM_RecSta_TML);

  testStepPass("Step7", "Video verification logged - Manual check required");

  //============================================================================
  // STEP 8: Set voltage to 9V, wait 60s at AVN mode
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 8: Set Voltage to 9V, Wait 60s at AVN ===");
  write("=================================================================");
  testStep("Step8", "9V voltage test at AVN mode");

  // Ensure we're in AVN mode
  Exit_BLTN_CAM();
  testWaitForTimeout(1000);

  // Set voltage to 9V
  write("[8.1] Setting voltage to 9V via COM3...");
  Set_Voltage(9.0);
  PowerSupply_OutputON();
  testWaitForTimeout(2000);

  // Wait 60 seconds at AVN mode
  write("[8.2] Waiting 60 seconds at AVN HU UI mode...");
  //Wait_At_AVN_WithMonitoring(60000);
  testWaitForTimeout(60000);
  // Log status
  write("[8.3] Status after 60s at 9V:");
  write("  BLTN_CAM_RecSet_OWD = 0x%X", $BLTN_CAM_RecSet_OWD);
  write("  BLTN_CAM_RecSta_OWD = 0x%X", $BLTN_CAM_RecSta_OWD);
  write("  BLTN_CAM_HU_UI_Mode = 0x%X", $BLTN_CAM_HU_UI_Mode);
  write("  AIN (Voltage) = %.2f V", @sysvar::IO::VN1600_1::AIN);

  // Capture screenshot with AIN signal for voltage monitoring
  CaptureGraphics("BLTN_CAM_RecSet_OWD;BLTN_CAM_RecSta_OWD;BLTN_CAM_HU_UI_Mode;AIN", "OWD_005_07.jpg");

  testStepPass("Step8", "9V voltage test completed - Screenshot captured");

  //============================================================================
  // STEP 9: Set voltage to 16V, wait 60s at AVN mode
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 9: Set Voltage to 16V, Wait 60s at AVN ===");
  write("=================================================================");
  testStep("Step9", "16V voltage test at AVN mode");

  // Ensure we're in AVN mode
  Exit_BLTN_CAM();
  testWaitForTimeout(1000);

  // Set voltage to 16V
  write("[9.1] Setting voltage to 16V via COM3...");
  Set_Voltage(16.0);
  testWaitForTimeout(2000);

  // Wait 60 seconds at AVN mode
  write("[9.2] Waiting 60 seconds at AVN HU UI mode...");
  //Wait_At_AVN_WithMonitoring(60000);
  testWaitForTimeout(60000);

  // Log status
  write("[9.3] Status after 60s at 16V:");
  write("  BLTN_CAM_RecSet_OWD = 0x%X", $BLTN_CAM_RecSet_OWD);
  write("  BLTN_CAM_RecSta_OWD = 0x%X", $BLTN_CAM_RecSta_OWD);
  write("  BLTN_CAM_HU_UI_Mode = 0x%X", $BLTN_CAM_HU_UI_Mode);
  write("  AIN (Voltage) = %.2f V", @sysvar::IO::VN1600_1::AIN);

  // Capture screenshot with AIN signal for voltage monitoring
  CaptureGraphics("BLTN_CAM_RecSet_OWD;BLTN_CAM_RecSta_OWD;BLTN_CAM_HU_UI_Mode;AIN", "OWD_005_08.jpg");

  testStepPass("Step9", "16V voltage test completed - Screenshot captured");

  //============================================================================
  // TEST COMPLETE
  //============================================================================
  write("");
  write("========================================");
  write("=== TEST OWD_005 COMPLETE ===");
  write("========================================");

  // Restore voltage to normal (12V)
  write("Restoring voltage to 12V...");
  Set_Voltage(12.0);
  testWaitForTimeout(1000);

  // Close power supply connection
  Close_PowerSupply();

  // Cleanup - disable CGW NM
  @panel::Switch_CGWNM = 0;

  write("");
  write("=== FINAL STATUS ===");
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);
  write("  BLTN_CAM_RecSet_OWD = 0x%X", $BLTN_CAM_RecSet_OWD);
  write("  BLTN_CAM_RecSta_OWD = 0x%X", $BLTN_CAM_RecSta_OWD);
  write("  BLTN_CAM_RecSta_DEV = 0x%X", $BLTN_CAM_RecSta_DEV);
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);
  write("  BLTN_CAM_RecSta_TML = 0x%X", $BLTN_CAM_RecSta_TML);
  write("  BLTN_CAM_HU_UI_Mode = 0x%X", $BLTN_CAM_HU_UI_Mode);

  //============================================================================
  // Overall Test Verdict
  //============================================================================
  if(step1_passed == 1 && step2_passed == 1 && step3_passed == 1 && step4_passed == 1 && step5_passed == 1 && step6_passed == 1)
  {
    testStepPass("Overall_Verdict", "Test OWD_005: PASS");
    write("=== OVERALL VERDICT: PASS ===");
  }
  else
  {
    testStepFail("Overall_Verdict", "Test OWD_005: FAIL");
    write("=== OVERALL VERDICT: FAIL ===");
  }

  write("");
  write("=== TEST SUMMARY ===");
  if(step1_passed)
    write("Step 1: SMK IGN + USM Reset + RecSet_OWD = ON check: PASS");
  else
    write("Step 1: SMK IGN + USM Reset + RecSet_OWD = ON check: FAIL");
  if(step2_passed)
    write("Step 2: AVN HU UI mode + TML Start + RecSta_TML = Recording check: PASS");
  else
    write("Step 2: AVN HU UI mode + TML Start + RecSta_TML = Recording check: FAIL");
  if(step3_passed)
    write("Step 3: Evt Switch + RecSta_MAR = Recording check: PASS");
  else
    write("Step 3: Evt Switch + RecSta_MAR = Recording check: FAIL");
  if(step4_passed)
    write("Step 4: Driving Event + RecSta_DEV = Recording check: PASS");
  else
    write("Step 4: Driving Event + RecSta_DEV = Recording check: FAIL");
  if(step5_passed)
    write("Step 5: TML Stop + 65s wait + DEV recording verification: PASS");
  else
    write("Step 5: TML Stop + 65s wait + DEV recording verification: FAIL");
  if(step6_passed)
    write("Step 6: Enter/Exit Built-in Cam 5 times: PASS");
  else
    write("Step 6: Enter/Exit Built-in Cam 5 times: FAIL");
  write("Step 7: Video files verification log: PASS");
  write("Step 8: 9V voltage test at AVN (60s): PASS");
  write("Step 9: 16V voltage test at AVN (60s): PASS");
}

void MainTest()
{
  testReportFileName("TestReports\\OWD_005 - 2.5 generation_report");
  OWD_005();
}
