testcase OWD_006_6()
{
  KEY_OFF();
  testWaitForTimeout(3000);
  //============================================================================
  // STEP 6: Log - Check video in real device
  //============================================================================
  Send_Value_To_COM(10606);
  SetTestStep("Bước 6 - OWD_006");
  StartTestTimer();

  KEY_ON();
  testWaitForTimeout(3000);
  WaitFor_RecSta_OWD_Recording(60000); // Wait for OWD recording to start after key ON




  testStepPass("Step6", "Video verification logged - Manual check required");

  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWD", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWD;BLTN_CAM_RecSta_OWD;BLTN_CAM_RecSet_DEV;BLTN_CAM_RecSta_DEV;BLTN_CAM_RecSta_MAR");
  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase OWD_006_7()
{
  int result = 0;
  //============================================================================
  // STEP 7: Set SMK to IGN, check BLTN_CAM_RecSet_OWD = 0x2 (ON)
  //============================================================================
  Send_Value_To_COM(10607);
  SetTestStep("Bước 7 - OWD_006");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 7: Set SMK to IGN, Check RecSet_OWD = ON ===");
  write("=================================================================");
  testStep("Step7", "SMK IGN + RecSet_OWD = 0x2 verification");

  // 7.1 Set SMK to IGN via Profile Settings panel
  write("[7.1] Setting SMK_Signal to IGN via Profile Settings panel...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);

  // 7.2 Check BLTN_CAM_RecSet_OWD = 0x2 (ON)
  write("[7.2] Checking BLTN_CAM_RecSet_OWD...");
  result = Check_RecSet_OWD_ON();

  // Capture screenshot with all related signals including SMK status
  write("[7.3] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSet_OWD;BLTN_CAM_RecSta_OWD;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  if(result == 1)
  {
    step7_passed = 1;
    testStepPass("Step7", "BLTN_CAM_RecSet_OWD = 0x2 (ON) in IGN mode - PASS");
  }
  else
  {
    step7_passed = 0;
    testStepFail("Step7", "BLTN_CAM_RecSet_OWD is NOT ON in IGN mode - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase OWD_006_8()
{
  int i = 0;
  int result = 0;

  //============================================================================
  // STEP 8: Enter/Exit Build-in Cam 3 times, end at AVN HU UI mode
  //============================================================================
  Send_Value_To_COM(10608);
  SetTestStep("Bước 8 - OWD_006");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 8: Enter/Exit Build-in Cam 3 Times (IGN Mode) ===");
  write("=================================================================");
  testStep("Step8", "Mode cycling 3 times in IGN mode");

  for(i = 1; i <= 3; i++)
  {
    write("");
    write("--- Cycle %d of 3 ---", i);

    // Enter Built-in Cam mode
    write("[8.%d.1] Entering Build-in Cam mode...", i);
    Enter_BLTN_CAM();
    testWaitForTimeout(2000);  // Wait 2s for signal delay

    // Log current mode (using BLTN_CAM_HU_UI_Mode for response)
    write("  After Enter: BLTN_CAM_HU_UI_Mode = 0x%X | SMK = 0x%X",
          $BLTN_CAM_HU_UI_Mode, $SMK_TrmnlCtrlGrpStaBDC);

    // Exit to AVN mode
    write("[8.%d.2] Exiting to AVN HU UI mode...", i);
    Exit_BLTN_CAM();
    testWaitForTimeout(2000);  // Wait 2s for signal delay

    // Log current mode
    write("  After Exit: BLTN_CAM_HU_UI_Mode = 0x%X | SMK = 0x%X",
          $BLTN_CAM_HU_UI_Mode, $SMK_TrmnlCtrlGrpStaBDC);
  }

  // Verify final state is AVN HU UI mode (0x0)
  write("");
  write("[8.4] Verifying final state is AVN HU UI mode...");
  result = Check_BLTN_CAM_UI_Mode(0x0);

  // Capture screenshot with SMK status
  write("[8.5] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_HU_UI_Mode;HU_BLTN_CAM_UI_Mode;BLTN_CAM_RecSet_OWD;BLTN_CAM_RecSta_OWD;SMK_TrmnlCtrlGrpStaBDC");

  if(result == 1)
  {
    step8_passed = 1;
    testStepPass("Step8", "Mode cycling 3 times completed, final state AVN HU UI mode - PASS");
  }
  else
  {
    step8_passed = 0;
    testStepFail("Step8", "Mode cycling failed - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

