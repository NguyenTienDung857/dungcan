/*@!Encoding:65001*/

/*
  Test Case: OWD_006
  Title: [OWD Recording Test - ACC/IGN Mode with Build-in Cam Entry/Exit]
  Verification items: Check OWD recording behavior in ACC and IGN modes with BLTN_CAM UI operations

  Preconditions:
    - ACC and IGN and ccNC/ccIC switch OFF, AVN mode

  Step 1: Set SMK to IGN, click USM Reset, check BLTN_CAM_RecSta_OWD = 0x1 (Recording)
  Step 2: Log - Cannot enter build-in cam in ACC mode
  Step 3: Log - Cannot enter build-in cam in ACC mode
  Step 4: Set SMK to ACC, TML Start, wait for DEV=0x1 (max 60s), Evt Switch, check all 4 signals = 0x1
  Step 5: Log - Cannot enter build-in cam in ACC mode
  Step 6: Log - Check video in real device
  Step 7: Set SMK to IGN, check BLTN_CAM_RecSet_OWD = 0x2 (ON)
  Step 8: Enter/Exit Build-in Cam 3 times, end at AVN HU UI mode
  Step 9: Log - Check video images
  Step 10: Set SMK to IGN, TML Start, wait for DEV=0x1 (max 60s), Evt Switch, check all 4 signals = 0x1
  Step 11: Enter/Exit Build-in Cam 3 times, end at AVN HU UI mode
  Step 12: Log - Check video in real device

  NOTE: Uses BLTN_CAM_HU_UI_Mode for screenshots (response signal with delay consideration).
        Added 2s delay for state transitions.
*/

variables
{
  long max_wait_time = 60000;  // 60 seconds max wait for DEV recording

  // Result tracking variables for TEST SUMMARY
  int step1_passed = 0;
  int step4_passed = 0;
  int step7_passed = 0;
  int step8_passed = 0;
  int step10_passed = 0;
  int step11_passed = 0;

  // Message declarations
  // CAN FD Message Declaration
  message HU_BLTN_CAM_02_200ms _HU_BLTN_CAM_02_200ms;
}

// ============================================================================
// Panel Control Helper Functions
// ============================================================================

// Set SMK to IGN (0x2) via panel
void Set_SMK_IGN()
{
  write("=== Setting SMK to IGN (0x2) via panel ===");
  setSignal(SMK_TrmnlCtrlGrpStaBDC, 0x2);  // IGN
  testWaitForTimeout(2000);  // Wait 2s for signal propagation
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X (IGN)", $SMK_TrmnlCtrlGrpStaBDC);
}

// Set SMK to ACC (0x1) via panel
void Set_SMK_ACC()
{
  write("=== Setting SMK to ACC (0x1) via panel ===");
  setSignal(SMK_TrmnlCtrlGrpStaBDC, 0x1);  // ACC
  testWaitForTimeout(2000);  // Wait 2s for signal propagation
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X (ACC)", $SMK_TrmnlCtrlGrpStaBDC);
}

// Set SMK to OFF (0x0) via panel
void Set_SMK_OFF()
{
  write("=== Setting SMK to OFF (0x0) via panel ===");
  setSignal(SMK_TrmnlCtrlGrpStaBDC, 0x0);  // OFF
  testWaitForTimeout(2000);  // Wait 2s for signal propagation
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X (OFF)", $SMK_TrmnlCtrlGrpStaBDC);
}

// Get SMK status string
void Get_SMK_Status_String(char result[])
{
  byte smk_val;
  smk_val = $SMK_TrmnlCtrlGrpStaBDC;

  if(smk_val == 0x4)
    snprintf(result, 10, "%s", "IGN");
  else if(smk_val == 0x3)
    snprintf(result, 10, "%s", "ACC");
  else if(smk_val == 0x0)
    snprintf(result, 10, "%s", "OFF");
  else
    snprintf(result, 10, "%s", "Unknown");
}

void Click_USM_Reset()
{
  write("=== Clicking USM Reset button on panel ===");
  @panel::Button_USMReset = 1;
  testWaitForTimeout(5000);
  write("  USM Reset clicked");
}

void Click_TML_Start()
{
  write("=== Clicking TML Start button on panel ===");
  @panel::Button_Timelaps_Start = 1;
  testWaitForTimeout(3000);
  write("  TML Start clicked");
}

// Click TML Stop button via panel
void Click_TML_Stop()
{
  write("=== Clicking TML Stop button on panel ===");
  @panel::Button_Timelaps_Stop = 1;
  testWaitForTimeout(3000);
  write("  TML Stop clicked");
}

// Click Event Switch button via panel (Manual Event Recording)
void Click_Evt_Switch()
{
  write("=== Clicking Event Switch button on panel ===");
  @panel::Button_SwitchEvt = 1;
  testWaitForTimeout(3000);
  write("  Event Switch clicked");
}

// Enter Built-in Cam mode (HU_BLTN_CAM_UI_Mode = 0x1)
void Enter_BLTN_CAM()
{
  write(">>> Enter BLTN_CAM mode <<<");
  _HU_BLTN_CAM_02_200ms.HU_BLTN_CAM_UI_Mode = 0x1;
  output(_HU_BLTN_CAM_02_200ms);
  testWaitForTimeout(3000);
}

// Exit to AVN HU UI mode (HU_BLTN_CAM_UI_Mode = 0x0)
void Exit_BLTN_CAM()
{
  write(">>> Exit BLTN_CAM mode <<<");
  _HU_BLTN_CAM_02_200ms.HU_BLTN_CAM_UI_Mode = 0x0;
  output(_HU_BLTN_CAM_02_200ms);
  testWaitForTimeout(3000);
}

// ============================================================================
// Check Functions
// ============================================================================

// Check BLTN_CAM_RecSta_OWD = 0x1 (Recording)
int Check_RecSta_OWD_Recording()
{
  byte rec_sta_owd = 0;

  rec_sta_owd = $BLTN_CAM_RecSta_OWD;
  write("  BLTN_CAM_RecSta_OWD = 0x%X", rec_sta_owd);

  if(rec_sta_owd == 0x1)
  {
    write(">>> PASS: BLTN_CAM_RecSta_OWD = 0x1 (Recording) <<<");
    return 1;
  }
  else
  {
    write(">>> FAIL: BLTN_CAM_RecSta_OWD is NOT Recording <<<");
    return 0;
  }
}

