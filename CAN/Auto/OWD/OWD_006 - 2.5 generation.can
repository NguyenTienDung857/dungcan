testcase OWD_006_10()
{
  int result = 0;
  //============================================================================
  // STEP 10: Set SMK to IGN, TML Start, wait DEV=0x1 (60s), Evt Switch, check 4 signals
  //============================================================================
  Send_Value_To_COM(10610);
  SetTestStep("Bước 10 - OWD_006");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 10: IGN Mode - TML Start, Wait DEV, Evt Switch ===");
  write("=================================================================");
  testStep("Step10", "IGN + TML Start + DEV wait + Evt Switch + 4 signals check");

  // 10.1 Set SMK to IGN via Profile Settings panel
  write("[10.1] Setting SMK_Signal to IGN via Profile Settings panel...");
  Set_SMK_IGN();
  testWaitForTimeout(2000);

  // 10.2 Click TML Start button via BLTN_CAM_Setting panel
  write("[10.2] Clicking TML Start button via BLTN_CAM_Setting panel...");
  Click_TML_Start();
  testWaitForTimeout(2000);

  // 10.3 Wait for BLTN_CAM_RecSta_DEV = 0x1 (max 60 seconds)
  write("[10.3] Waiting for BLTN_CAM_RecSta_DEV = 0x1 (max 60 seconds)...");
  result = WaitFor_RecSta_DEV_Recording(max_wait_time);

  if(result == 1)
  {
    write(">>> DEV Recording detected, proceeding to Evt Switch <<<");
  }
  else
  {
    write(">>> WARNING: DEV Recording not detected within 60s, proceeding anyway <<<");
  }

  // 10.4 Click Evt Switch button via BLTN_CAM_Setting panel
  write("[10.4] Clicking Evt Switch button via BLTN_CAM_Setting panel...");
  Click_Evt_Switch();


  // 10.5 Check all 4 recording signals = 0x1
  write("[10.5] Checking all 4 recording signals...");
  result = Check_All_Recording_Signals();

  testWaitForTimeout(10000);
  // Capture screenshot with all related signals including SMK status
  write("[10.6] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSta_OWD;BLTN_CAM_RecSta_TML;BLTN_CAM_RecSta_DEV;BLTN_CAM_RecSta_MAR;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  // 10.7 Click TML Stop button to stop TML recording
  write("[10.7] Clicking TML Stop button to stop TML recording...");
  Click_TML_Stop();
  testWaitForTimeout(2000);

  if(result == 1)
  {
    step10_passed = 1;
    testStepPass("Step10", "All 4 signals = 0x1 (Recording) in IGN mode - PASS");
  }
  else
  {
    step10_passed = 0;
    testStepFail("Step10", "Not all signals are Recording in IGN mode - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase OWD_006_11()
{
  int i = 0;
  int result = 0;

  //============================================================================
  // STEP 11: Enter/Exit Build-in Cam 3 times, end at AVN HU UI mode
  //============================================================================
  Send_Value_To_COM(10611);
  SetTestStep("Bước 11 - OWD_006");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 11: Enter/Exit Build-in Cam 3 Times (IGN Mode) ===");
  write("=================================================================");
  testStep("Step11", "Mode cycling 3 times in IGN mode after recording");

  for(i = 1; i <= 3; i++)
  {
    write("");
    write("--- Cycle %d of 3 ---", i);

    // Enter Built-in Cam mode
    write("[11.%d.1] Entering Build-in Cam mode...", i);
    Enter_BLTN_CAM();
    testWaitForTimeout(2000);  // Wait 2s for signal delay

    // Log current mode (using BLTN_CAM_HU_UI_Mode for response)
    write("  After Enter: BLTN_CAM_HU_UI_Mode = 0x%X | SMK = 0x%X",
          $BLTN_CAM_HU_UI_Mode, $SMK_TrmnlCtrlGrpStaBDC);

    // Exit to AVN mode
    write("[11.%d.2] Exiting to AVN HU UI mode...", i);
    Exit_BLTN_CAM();
    testWaitForTimeout(2000);  // Wait 2s for signal delay

    // Log current mode
    write("  After Exit: BLTN_CAM_HU_UI_Mode = 0x%X | SMK = 0x%X",
          $BLTN_CAM_HU_UI_Mode, $SMK_TrmnlCtrlGrpStaBDC);
  }

  // Verify final state is AVN HU UI mode (0x0)
  write("");
  write("[11.4] Verifying final state is AVN HU UI mode...");
  result = Check_BLTN_CAM_UI_Mode(0x0);

  // Capture screenshot with SMK status
  write("[11.5] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_HU_UI_Mode;HU_BLTN_CAM_UI_Mode;BLTN_CAM_RecSet_OWD;BLTN_CAM_RecSta_OWD;SMK_TrmnlCtrlGrpStaBDC");

  if(result == 1)
  {
    step11_passed = 1;
    testStepPass("Step11", "Mode cycling 3 times completed, final state AVN HU UI mode - PASS");
  }
  else
  {
    step11_passed = 0;
    testStepFail("Step11", "Mode cycling failed - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

