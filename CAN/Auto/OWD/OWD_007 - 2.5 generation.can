/*@!Encoding:65001*/

includes
{
  #include "..\DeclarationFunction_Gen2.5.h"
}

/*
  Test Case: OWD_007
  Title: Camera detach/attach stress while OWD/TML/DEV recording

  Verification items:
    - Step 1: KEY OFF/ON setup, reset, OWD/TML/DEV, detach/attach front camera.
    - Step 2: OWD/TML/DEV, detach/attach rear camera.
    - Step 3: OWD/TML/DEV, detach/attach rear and front cameras.
    - Step 4: OWD recording, detach rear and front cameras, wait 10s.
    - Step 5: Attach rear/front, stress detach/attach front camera, wait 30s.
    - Step 6: Check BLTN_CAM_State = 0x0 (Normal operation), capture.
    - Step 8: OWD recording, detach rear camera, check BLTN_CAM_State = 0x2 within 60s.
    - Step 9: Attach front/rear, stress detach/attach rear camera, wait 30s.
    - Step 10: Check BLTN_CAM_State = 0x0 within 60s, capture.
    - Step 12: OWD recording, detach/attach front camera, wait DEV recording.
    - Step 13: Repeat Step 12 ten times.
    - Step 14: KEY OFF -> OWP, detach front, KEY ON, attach front, OWD/DEV.
    - Step 15: Repeat Step 14 ten times.

  Preconditions:
    - ACC and IGN and ccNC/ccIC switch OFF, AVN mode.
    - Helper functions from DeclarationFunction_Gen2.5.h are used first.
*/

variables
{
  long wait_owd_timeout_ms = 60000;
  long wait_owp_timeout_ms = 60000;
  long wait_state_timeout_ms = 60000;
  int wait_dev_timeout_s = 60;
  int front_toggle_count = 11;
  int rear_toggle_count = 10;
  int repeat_count = 10;

  int step1_passed = 0;
  int step2_passed = 0;
  int step3_passed = 0;
  int step4_passed = 0;
  int step5_passed = 0;
  int step6_passed = 0;
  int step8_passed = 0;
  int step9_passed = 0;
  int step10_passed = 0;
  int step12_passed = 0;
  int step13_passed = 0;
  int step14_passed = 0;
  int step15_passed = 0;

  message HU_BLTN_CAM_PE_00_200ms _HU_BLTN_CAM_PE_00_200ms;
  message HU_BLTN_CAM_E_01  _HU_BLTN_CAM_E_01;
  message HU_CLOCK_PE_02   _HU_CLOCK_PE_02;
}

void Log_OWD_007_Signals()
{
  write("  BLTN_CAM_State      = 0x%X", $BLTN_CAM_State);
  write("  BLTN_CAM_RecSta_OWD = 0x%X", $BLTN_CAM_RecSta_OWD);
  write("  BLTN_CAM_RecSta_OWP = 0x%X", $BLTN_CAM_RecSta_OWP);
  write("  BLTN_CAM_RecSta_DEV = 0x%X", $BLTN_CAM_RecSta_DEV);
  write("  BLTN_CAM_RecSta_TML = 0x%X", $BLTN_CAM_RecSta_TML);
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);
}

int Wait_For_BLTN_CAM_State_Value(byte expected_state, long timeout_ms, char state_name[])
{
  long elapsed = 0;

  write("Waiting BLTN_CAM_State = 0x%X (%s) for max %d s...",
        expected_state, state_name, timeout_ms / 1000);

  while(elapsed < timeout_ms)
  {
    if($BLTN_CAM_State == expected_state)
    {
      write(">>> PASS: BLTN_CAM_State = 0x%X (%s) after %d s <<<",
            expected_state, state_name, elapsed / 1000);
      return 1;
    }

    if(elapsed == 0 || elapsed % 5000 == 0)
    {
      write("  [%d s] BLTN_CAM_State = 0x%X, expected 0x%X",
            elapsed / 1000, $BLTN_CAM_State, expected_state);
    }

    testWaitForTimeout(1000);
    elapsed += 1000;
  }

  write(">>> FAIL: BLTN_CAM_State = 0x%X, expected 0x%X (%s) within %d s <<<",
        $BLTN_CAM_State, expected_state, state_name, timeout_ms / 1000);
  return 0;
}

// ============================================================================
// Main Test Case
// ============================================================================

testcase OWD_007_Init()
{
  Send_Value_To_COM(10700);
  write("========================================");
  write("=== START TEST OWD_007 ===");
  write("=== Camera detach/attach stress ===");
  write("========================================");
  testStep("Notification", "Start test OWD_007");
  Send_Value_To_COM(44);
}

testcase OWD_007_1()
{
  int result_owd = 0;
  int result_dev = 0;

  Send_Value_To_COM(10701);
  SetTestStep("Buoc 1 - OWD_007");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 1: Setup + OWD/TML/DEV + front detach/attach       ===");
  write("=================================================================");
  testStep("Step1", "KEY OFF/ON + SMK IGN + reset + OWD/TML/DEV + front detach/attach");

  write("[1.0] KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(3000);

  write("[1.0b] KEY ON...");
  KEY_ON();
  testWaitForTimeout(3000);

  write("[1.0c] Setting SMK IGN...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);

  write("[1.0d] Clicking USM Reset...");
  Click_USM_Reset();
  testWaitForTimeout(2000);

  write("[1.0e] Clicking Rec Reset...");
  Click_Rec_Reset();
  testWaitForTimeout(2000);

  write("[1.1] Waiting for BLTN_CAM_RecSta_OWD = 0x1 (Recording)...");
  result_owd = WaitFor_RecSta_OWD_Recording(wait_owd_timeout_ms);
  if(result_owd == 1)
  {
    write("[1.2] Clicking TML Start...");
    Click_TML_Start();
    testWaitForTimeout(1000);

    write("[1.3] Clicking Evt Switch...");
    Click_Evt_Switch();
    testWaitForTimeout(1000);

    write("[1.4] Waiting for BLTN_CAM_RecSta_DEV = 0x1 (Recording)...");
    result_dev = WaitFor_RecSta_DEV_Recording(wait_dev_timeout_s);
    if(result_dev != 1)
    {
      write(">>> FAIL REASON: DEV recording not detected in Step 1 <<<");
    }

    write("[1.5] Waiting 30 seconds before front camera detach...");
    testWaitForTimeout(30000);

    write("[1.6] Detaching front camera...");
    Set_Detach_Font();

    write("[1.7] Waiting 20 seconds with front camera detached...");
    testWaitForTimeout(20000);

    write("[1.8] Attaching front camera...");
    Set_Attach_Font();

    write("[1.9] Waiting 30 seconds after front camera attach...");
    testWaitForTimeout(30000);
  }
  else
  {
    write(">>> FAIL REASON: OWD recording not detected in Step 1 <<<");
  }

  Log_OWD_007_Signals();

  if(result_owd == 1 && result_dev == 1)
  {
    step1_passed = 1;
    testStepPass("Step1", "Step 1 complete - OWD/TML/DEV and front detach/attach PASS");
  }
  else
  {
    step1_passed = 0;
    Log_Error_Details();
    testStepFail("Step1", "Step 1 failed - OWD or DEV recording did not reach expected state");
  }


  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWD", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWD;BLTN_CAM_RecSta_OWD;BLTN_CAM_RecSet_DEV;BLTN_CAM_RecSta_DEV;BLTN_CAM_RecSta_TML;BLTN_CAM_State");

  StopTestTimer();
  Send_Value_To_COM(44);
}

