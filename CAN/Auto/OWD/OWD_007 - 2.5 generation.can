testcase OWD_007_13()
{
  int i = 0;
  int passed_loops = 0;
  int result_owd = 0;
  int result_dev = 0;

  Send_Value_To_COM(10713);
  SetTestStep("Buoc 13 - OWD_007");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 13: Repeat STEP 12 ten times                       ===");
  write("=================================================================");
  testStep("Step13", "Repeat Step 12 flow ten times");

  for(i = 1; i <= repeat_count; i++)
  {
    result_owd = 0;
    result_dev = 0;

    write("");
    write("--- Step 13 loop %d of %d: repeat Step 12 flow ---", i, repeat_count);

    write("[13.%d.1] Waiting for BLTN_CAM_RecSta_OWD = 0x1 (Recording)...", i);
    result_owd = WaitFor_RecSta_OWD_Recording(wait_owd_timeout_ms);
    if(result_owd == 1)
    {
      write("[13.%d.2] Waiting 30 seconds while OWD is recording...", i);
      testWaitForTimeout(30000);

      write("[13.%d.3] Detaching front camera...", i);
      Set_Detach_Font();

      write("[13.%d.4] Waiting 20 seconds with front camera detached...", i);
      testWaitForTimeout(20000);

      write("[13.%d.5] Attaching front camera...", i);
      Set_Attach_Font();

      write("[13.%d.6] Waiting for BLTN_CAM_RecSta_DEV = 0x1 (Recording)...", i);
      result_dev = WaitFor_RecSta_DEV_Recording(wait_dev_timeout_s);
      if(result_dev != 1)
      {
        write(">>> FAIL REASON: DEV recording not detected in Step 13 loop %d <<<", i);
      }

      write("[13.%d.7] Waiting 10 seconds after DEV wait...", i);
      testWaitForTimeout(10000);
    }
    else
    {
      write(">>> FAIL REASON: OWD recording not detected in Step 13 loop %d <<<", i);
    }

    Log_OWD_007_Signals();
    if(result_owd == 1 && result_dev == 1)
    {
      passed_loops++;
    }
    else
    {
      write(">>> Step 13 loop %d failed; continuing remaining loops <<<", i);
    }
  }

  write("Step 13 loop result: %d/%d loops passed", passed_loops, repeat_count);
  if(passed_loops == repeat_count)
  {
    step13_passed = 1;
    testStepPass("Step13", "All ten Step 12 repeat loops passed");
  }
  else
  {
    step13_passed = 0;
    Log_Error_Details();
    testStepFail("Step13", "One or more Step 12 repeat loops failed");
  }


  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWD", "BLTN_CAM_RecSet_OWD;BLTN_CAM_RecSta_OWD;BLTN_CAM_RecSet_DEV;BLTN_CAM_RecSta_DEV;BLTN_CAM_State;AIN");

  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase OWD_007_14()
{
  int result_owp = 0;
  int result_owd = 0;
  int result_dev = 0;

  Send_Value_To_COM(10714);
  SetTestStep("Buoc 14 - OWD_007");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 14: KEY OFF/OWP + front detach + KEY ON/OWD/DEV    ===");
  write("=================================================================");
  testStep("Step14", "KEY OFF, wait OWP, detach front, KEY ON, attach front, wait OWD, Evt, DEV, wait 60s");

  write("[14.1] KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(3000);

  write("[14.2] Waiting for BLTN_CAM_RecSta_OWP = 0x1 (Recording)...");
  result_owp = WaitFor_RecSta_OWP_Recording(wait_owp_timeout_ms);
  if(result_owp != 1)
  {
    write(">>> FAIL REASON: OWP recording not detected after KEY OFF in Step 14 <<<");
  }

  write("[14.3] Detaching front camera...");
  Set_Detach_Font();

  write("[14.4] KEY ON...");
  KEY_ON();
  testWaitForTimeout(3000);

  write("[14.5] Attaching front camera...");
  Set_Attach_Font();

  write("[14.6] Waiting for BLTN_CAM_RecSta_OWD = 0x1 (Recording)...");
  result_owd = WaitFor_RecSta_OWD_Recording(wait_owd_timeout_ms);
  if(result_owd != 1)
  {
    write(">>> FAIL REASON: OWD recording not detected after KEY ON in Step 14 <<<");
  }

  write("[14.7] Clicking Evt Switch...");
  Click_Evt_Switch();
  testWaitForTimeout(1000);

  write("[14.8] Waiting for BLTN_CAM_RecSta_DEV = 0x1 (Recording)...");
  result_dev = WaitFor_RecSta_DEV_Recording(wait_dev_timeout_s);
  if(result_dev != 1)
  {
    write(">>> FAIL REASON: DEV recording not detected in Step 14 <<<");
  }

  write("[14.9] Waiting 60 seconds after DEV wait...");
  testWaitForTimeout(60000);

  Log_OWD_007_Signals();

  if(result_owp == 1 && result_owd == 1 && result_dev == 1)
  {
    step14_passed = 1;
    testStepPass("Step14", "Step 14 complete - OWP/OWD/DEV detected PASS");
  }
  else
  {
    step14_passed = 0;
    Log_Error_Details();
    testStepFail("Step14", "Step 14 failed - OWP, OWD, or DEV recording did not reach expected state");
  }


  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWD", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWD;BLTN_CAM_RecSta_OWD;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSet_DEV;BLTN_CAM_RecSta_DEV;BLTN_CAM_State");

  StopTestTimer();
  Send_Value_To_COM(44);
}

