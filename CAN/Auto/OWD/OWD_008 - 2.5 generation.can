testcase OWD_008_6()
{
  int result = 0;

  //============================================================================
  // STEP 6: B+ ON, wait 10s, wait OWD, detach rear, B+ OFF, wait 5s, B+ ON
  //============================================================================
  Send_Value_To_COM(10806);
  SetTestStep("Buoc 6 - OWD_008");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 6: B+ ON + OWD + detach rear + B+ OFF/ON          ===");
  write("=================================================================");
  testStep("Step6", "B+ ON, wait 10s, wait OWD, detach rear, B+ OFF, wait 5s, B+ ON");

  write("[6.1] Set B+ ON...");
  Set_BPlus_On();

  write("[6.2] Waiting 10 seconds after B+ ON...");
  testWaitForTimeout(10000);

  write("[6.3] Wait for OWD recording...");
  result = WaitFor_RecSta_OWD_Recording(wait_owd_timeout_ms);
  write("[6.3] BLTN_CAM_RecSta_OWD = 0x%X, expected 0x1", $BLTN_CAM_RecSta_OWD);
  if(result != 1)
  {
    write(">>> FAIL REASON: Step 6 did not detect OWD recording <<<");
  }

  write("[6.4] Detach rear camera...");
  Set_Detach_Rear();

  write("[6.5] Set B+ OFF...");
  Set_BPlus_Off();

  write("[6.6] Waiting 5 seconds after B+ OFF...");
  testWaitForTimeout(5000);

  write("[6.7] Set B+ ON...");
 

  write("[6.8] Signal snapshot before pass/fail...");
  write("  BLTN_CAM_State      = 0x%X", $BLTN_CAM_State);
  write("  BLTN_CAM_RecSta_OWD = 0x%X", $BLTN_CAM_RecSta_OWD);
  write("  BLTN_CAM_RecSta_DEV = 0x%X", $BLTN_CAM_RecSta_DEV);
  write("  BLTN_CAM_RecSta_TML = 0x%X", $BLTN_CAM_RecSta_TML);
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);

  write("[6.9] Capturing signal evidence...");
  CaptureGraphics("OWD", "BLTN_CAM_State;BLTN_CAM_RecSta_OWD;BLTN_CAM_RecSta_DEV;BLTN_CAM_RecSta_TML;BLTN_CAM_RecSta_MAR;SMK_TrmnlCtrlGrpStaBDC");

  if(result == 1)
  {
    step6_passed = 1;
    testStepPass("Step6", "Step 6 PASS - OWD recording detected before rear detach and B+ OFF/ON");
  }
  else
  {
    step6_passed = 0;
    Log_Error_Details();
    testStepFail("Step6", "Step 6 FAIL - OWD recording was not detected before rear detach");
  }
  Set_Attach_Rear();
  StopTestTimer();
  Send_Value_To_COM(44);
  Set_BPlus_On();
  testWaitForTimeout(6000);
  Enter_BLTN_CAM();

  
}

void MainTest()
{
  testReportFileName("TestReports\\OWD_008 - 2.5 generation_report");

  OWD_008_Init();
  OWD_008_1();
  OWD_008_2();
  OWD_008_3();
  OWD_008_4();
  OWD_008_5();
  OWD_008_6();
}
