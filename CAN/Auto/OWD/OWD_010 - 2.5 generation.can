  write("");
  write("*************************************************************");
  write("*** STEP 16: LOG INFORMATION ***");
  write("*** Please capture LED photo during ACC mode recording ***");
  write("*** Check that LED indicates recording ***");
  write("*** Include this photo in the test report ***");
  write("*************************************************************");
  write("");

  testStepPass("Step16", "LED photo capture logged - Manual photo required");

  //============================================================================
  // STEP 17: Wait 15s, capture AIN and BLTN_CAM_RecSta_DEV
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 17: Wait 15s + Capture AIN and RecSta_DEV ===");
  write("=================================================================");
  testStep("Step17", "Wait 15s + AIN and RecSta_DEV capture in ACC mode");

  // 17.1 Wait 15 seconds
  write("[17.1] Waiting 15 seconds...");
  testWaitForTimeout(15000);

  // 17.2 Capture screenshot with AIN and BLTN_CAM_RecSta_DEV
  write("[17.2] Capturing screenshot with AIN and BLTN_CAM_RecSta_DEV...");
  CaptureGraphics("BLTN_CAM_RecSta_DEV;BLTN_CAM_RecSet_DEV;SMK_TrmnlCtrlGrpStaBDC", "OWD_010_08.jpg");

  testStepPass("Step17", "Wait 15s + AIN and RecSta_DEV captured in ACC mode - PASS");

  //============================================================================
  // STEP 18: Log - LED photo capture (manual)
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 18: LED Photo Capture (Manual) ===");
  write("=================================================================");
  testStep("Step18", "LED photo capture");

  write("");
  write("*************************************************************");
  write("*** STEP 18: LOG INFORMATION ***");
  write("*** Please capture LED photo ***");
  write("*** Check LED status ***");
  write("*** Include this photo in the test report ***");
  write("*************************************************************");
  write("");

  testStepPass("Step18", "LED photo capture logged - Manual photo required");

  //============================================================================
  // STEP 19: Wait 15s, capture AIN and BLTN_CAM_RecSta_DEV
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 19: Wait 15s + Capture AIN and RecSta_DEV ===");
  write("=================================================================");
  testStep("Step19", "Wait 15s + Final AIN and RecSta_DEV capture");

  // 19.1 Wait 15 seconds
  write("[19.1] Waiting 15 seconds...");
  testWaitForTimeout(15000);

  // 19.2 Capture screenshot with AIN and BLTN_CAM_RecSta_DEV
  write("[19.2] Capturing screenshot with AIN and BLTN_CAM_RecSta_DEV...");
  CaptureGraphics("BLTN_CAM_RecSta_DEV;BLTN_CAM_RecSet_DEV;SMK_TrmnlCtrlGrpStaBDC", "OWD_010_09.jpg");

  testStepPass("Step19", "Wait 15s + Final AIN and RecSta_DEV captured - PASS");

  //============================================================================
  // Overall Test Verdict
  //============================================================================
  if(step1_passed == 1 && step4_passed == 1 && step7_passed == 1 && step12_passed == 1 && step15_passed == 1)
  {
    testStepPass("Overall_Verdict", "Test OWD_010: PASS");
    write("=== OVERALL VERDICT: PASS ===");
  }
  else
  {
    testStepFail("Overall_Verdict", "Test OWD_010: FAIL");
    write("=== OVERALL VERDICT: FAIL ===");
  }

  //============================================================================
  // TEST COMPLETE
  //============================================================================
  write("");
  write("========================================");
  write("=== TEST OWD_010 COMPLETE ===");
  write("========================================");

  // Cleanup - disable CGW NM and driving info
  @panel::Switch_CGWNM = 0;
  Disable_DrivingInfo();

  write("");
  write("=== FINAL STATUS ===");
  Get_SMK_Status_String(smk_status);
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X (%s)", $SMK_TrmnlCtrlGrpStaBDC, smk_status);
  write("  BLTN_CAM_RecSet_DEV = 0x%X", $BLTN_CAM_RecSet_DEV);
  write("  BLTN_CAM_RecSta_DEV = 0x%X", $BLTN_CAM_RecSta_DEV);
  write("  BLTN_CAM_HU_UI_Mode = 0x%X", $BLTN_CAM_HU_UI_Mode);

  write("");
  write("=== TEST SUMMARY ===");
  if(step1_passed == 1)
    write("Step 1: SMK IGN + USM Reset + RecSet_DEV ON + BLTN_CAM + Monitor 15s [Screenshot] - PASS");
  else
    write("Step 1: SMK IGN + USM Reset + RecSet_DEV ON + BLTN_CAM + Monitor 15s [Screenshot] - FAIL");
  write("Step 2-3: LED OFF photo capture [Manual - Include in Report] - PASS");
  if(step4_passed == 1)
    write("Step 4: Exit to AVN + RecSta_DEV = 0x0 (OFF) [Screenshot] - PASS");
  else
    write("Step 4: Exit to AVN + RecSta_DEV = 0x0 (OFF) [Screenshot] - FAIL");
  write("Step 5-6: LED ON photo capture [Manual - Include in Report] - PASS");
  if(step7_passed == 1)
    write("Step 7: Driving event + DEV Recording within 50s [Screenshot] - PASS");
  else
    write("Step 7: Driving event + DEV Recording within 50s [Screenshot] - FAIL");
  write("Step 8: LED ON photo during recording [Manual - Include in Report] - PASS");
  write("Step 9: Wait 15s + AIN & RecSta_DEV capture [Screenshot] - PASS");
  write("Step 10: LED ON photo [Manual - Include in Report] - PASS");
  write("Step 11: AIN & RecSta_DEV capture [Screenshot] - PASS");
  if(step12_passed == 1)
    write("Step 12: SMK ACC + RecSta_DEV = 0x0 (OFF) [Screenshot] - PASS");
  else
    write("Step 12: SMK ACC + RecSta_DEV = 0x0 (OFF) [Screenshot] - FAIL");
  write("Step 13-14: LED photo in ACC mode [Manual - Include in Report] - PASS");
  if(step15_passed == 1)
    write("Step 15: ACC mode + Driving event + DEV Recording within 50s [Screenshot] - PASS");
  else
    write("Step 15: ACC mode + Driving event + DEV Recording within 50s [Screenshot] - FAIL");
  write("Step 16: LED photo during ACC recording [Manual - Include in Report] - PASS");
  write("Step 17: Wait 15s + AIN & RecSta_DEV in ACC mode [Screenshot] - PASS");
  write("Step 18: LED photo [Manual - Include in Report] - PASS");
  write("Step 19: Wait 15s + Final AIN & RecSta_DEV [Screenshot] - PASS");
}

void MainTest()
{
  testReportFileName("TestReports\\OWD_010 - 2.5 generation_report");
  OWD_010();
}
