  else
    write("Step 2: Consecutive DEV Event + Continuous Recording 4s [Screenshot] -> FAIL");
  if(step3_passed == 1)
    write("Step 3: DEV Event + Enter Build-in Cam [Screenshot] -> PASS");
  else
    write("Step 3: DEV Event + Enter Build-in Cam [Screenshot] -> FAIL");
  if(step4_passed == 1)
    write("Step 4: DEV Event + Switch to ACC [Screenshot] -> PASS");
  else
    write("Step 4: DEV Event + Switch to ACC [Screenshot] -> FAIL");
  write("Step 5: Manual verification [Log only] -> PASS");
  write("--- Round 2 ---");
  write("Step 6: (Giong Step 1) - LOG ONLY -> PASS");
  write("Step 7: (Giong Step 2) - LOG ONLY -> PASS");
  write("Step 8: (Giong Step 3) - LOG ONLY -> PASS");
  write("Step 9: (Giong Step 4) - LOG ONLY -> PASS");
  write("Step 10: (Giong Step 5) - LOG ONLY -> PASS");
}

void MainTest()
{
  testReportFileName("TestReports\\OWD_012 - 2.5 generation_report");
  OWD_012();
}
