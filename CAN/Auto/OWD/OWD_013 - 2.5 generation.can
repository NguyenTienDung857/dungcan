testcase OWD_013_Init() {
  Send_Value_To_COM(11300);
  testStep("Notification", "Start OWD_013 Initialization");
  write("Run Rec_Reset()");
  Rec_Reset();
  Send_Value_To_COM(44);
}


void MainTest() {
  testReportFileName("TestReports\\OWD_013 - 2.5 generation_report");

  OWD_013_Init();
  OWD_013_1();
  OWD_013_2();
  OWD_013_3();
}
