void MainTest(){
  testReportFileName("TestReports\\OWD_016 - 2.5 generation_report");
  write("Run Turn_OFF_RecSet()"); Turn_OFF_RecSet();
  write("Run Rec_Reset()"); Rec_Reset();
  TestWaitForValueInput("Please enter the ID testcase number: (1/2/3/4/5/6)",300000);

  switch (testGetValueInput()){

    case (1): OWD_016_1(); break;

    case (2): OWD_016_2(); break;

    case (3): OWD_016_3(); break;

    case (4): OWD_016_4(); break;

    case (5): OWD_016_5(); break;

    case (6):
      OWD_016_1();

      OWD_016_2();

      OWD_016_3();

      OWD_016_4();

      OWD_016_5();

      break;
  }

}
