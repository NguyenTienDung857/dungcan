testcase OWD_017_Summary()
{
  //============================================================================
  // Overall Test Verdict
  //============================================================================
  if(step1_passed == 1 && step4_passed == 1 && step7_passed == 1)
  {
    testStepPass("Overall_Verdict", "Test OWD_017: PASS");
    write("=== OVERALL VERDICT: PASS ===");
  }
  else
  {
    testStepFail("Overall_Verdict", "Test OWD_017: FAIL");
    write("=== OVERALL VERDICT: FAIL ===");
  }

  //============================================================================
  // TEST COMPLETE - Cleanup
  //============================================================================
  write("");
  write("========================================");
  write("=== TEST OWD_017 COMPLETE ===");
  write("========================================");

  // Cleanup
  setSignal(SMK_TrmnlCtrlGrpStaBDC, 0x0);  // KEY OFF
  testWaitForTimeout(2000);
  @panel::Switch_CGWNM = 0;

  // Final status
  write("");
  write("=== FINAL STATUS ===");
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);
  write("  BLTN_CAM_HU_UI_Mode = 0x%X", $BLTN_CAM_HU_UI_Mode);

  write("");
  write("=== TEST SUMMARY ===");
  if(step1_passed == 1)
    write("Step 1: SMK IGN + USM Reset + Rec Reset + BLTN_CAM + Evt Switch + MAR OFF [Screenshot] - PASS");
  else
    write("Step 1: SMK IGN + USM Reset + Rec Reset + BLTN_CAM + Evt Switch + MAR OFF [Screenshot] - FAIL");
  write("Step 2-3: LED photo capture [Manual - Include in Report] - PASS");
  if(step4_passed == 1)
    write("Step 4: Return to AVN + RecSta_MAR = 0x0 (OFF) [Screenshot] - PASS");
  else
    write("Step 4: Return to AVN + RecSta_MAR = 0x0 (OFF) [Screenshot] - FAIL");
  write("Step 5-6: LED photo capture [Manual - Include in Report] - PASS");
  if(step7_passed == 1)
    write("Step 7: Evt Switch + MAR Recording within 10s [Screenshot+AIN] - PASS");
  else
    write("Step 7: Evt Switch + MAR Recording within 10s [Screenshot+AIN] - FAIL");
  write("Step 8-9: LED photo capture [Manual - Include in Report] - PASS");
  write("Step 10-11: LED photo capture [Manual - Include in Report] - PASS");
}

void MainTest()
{
  testReportFileName("TestReports\\OWD_017 - 2.0 generation_report");

 // write("Run Rec_Reset()"); Rec_Reset();

  OWD_017_Init();
  OWD_017_1();
  OWD_017_2_3();
  OWD_017_4();
  OWD_017_5_6();
  OWD_017_7();
  OWD_017_8_9();
  OWD_017_10_11();
  OWD_017_Summary();
}
