{
  //============================================================================
  // STEP 2 & 3: Log - LED Photo Capture (Manual)
  //============================================================================
  Send_Value_To_COM(11702);
  write("");
  write("=================================================================");
  write("=== STEP 2 & 3: LED Photo Capture (Manual) ===");
  write("=================================================================");
  testStep("Step2_3", "LED photo capture - check signal light");

  write("");
  write("*************************************************************");
  write("*** STEP 2 & 3: LOG INFORMATION ***");
  write("*** Please capture LED photo directly ***");
  write("*** Check signal light status on the device ***");
  write("*** Include this photo in the test report ***");
  write("*************************************************************");
  write("");

  testStepPass("Step2_3", "LED photo capture logged - Manual photo required");
  Send_Value_To_COM(44);
}

testcase OWD_017_4()
{
  int result = 0;

  //============================================================================
  // STEP 4: Return to AVN HU UI mode, Check BLTN_CAM_RecSta_MAR = 0x0 (OFF)
  //============================================================================
  Send_Value_To_COM(11704);
  SetTestStep("Bước 4 - OWD_017");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 4: Return to AVN + Check RecSta_MAR = 0x0 (OFF) ===");
  write("=================================================================");
  testStep("Step4", "Exit BLTN_CAM to AVN + RecSta_MAR OFF verification");

  // 4.1 Exit to AVN HU UI mode
  write("[4.1] Exiting to AVN HU UI mode...");
  Exit_BLTN_CAM();
  testWaitForTimeout(2000);

  // 4.2 Check BLTN_CAM_RecSta_MAR = 0x0 (OFF)
  write("[4.2] Checking BLTN_CAM_RecSta_MAR = 0x0 (OFF)...");
  result = Check_RecSta_MAR_OFF();

  // 4.3 Capture screenshot
  write("[4.3] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSta_MAR;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  if(result == 1)
  {
    step4_passed = 1;
    testStepPass("Step4", "BLTN_CAM_RecSta_MAR = 0x0 (OFF) in AVN mode - PASS");
  }
  else
  {
    step4_passed = 0;
    write(">>> FAIL REASON: BLTN_CAM_RecSta_MAR expected 0x0 (OFF) but got 0x%X <<<", $BLTN_CAM_RecSta_MAR);
    Log_Error_Details();
    testStepFail("Step4", "BLTN_CAM_RecSta_MAR is NOT OFF in AVN mode - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

