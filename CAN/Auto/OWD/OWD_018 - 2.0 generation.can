testcase OWD_018_Summary()
{
  //============================================================================
  // Overall Test Verdict
  //============================================================================
  if(step1_passed == 1 && step4_passed == 1 && step7_passed == 1)
  {
    testStepPass("Overall_Verdict", "Test OWD_018: PASS");
    write("=== OVERALL VERDICT: PASS ===");
  }
  else
  {
    testStepFail("Overall_Verdict", "Test OWD_018: FAIL");
    write("=== OVERALL VERDICT: FAIL ===");
  }

  //============================================================================
  // TEST COMPLETE - Cleanup
  //============================================================================
  write("");
  write("========================================");
  write("=== TEST OWD_018 COMPLETE ===");
  write("========================================");

  // Cleanup
  setSignal(SMK_TrmnlCtrlGrpStaBDC, 0x0);  // KEY OFF
  testWaitForTimeout(2000);
  @panel::Switch_CGWNM = 0;

  // Final status
  write("");
  write("=== FINAL STATUS ===");
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);
  write("  BLTN_CAM_HU_UI_Mode = 0x%X", $BLTN_CAM_HU_UI_Mode);

  write("");
  write("=== TEST SUMMARY ===");
  if(step1_passed == 1)
    write("Step 1: SMK ACC + USM Reset + Rec Reset - Cannot enter BLTN_CAM in ACC - PASS");
  else
    write("Step 1: SMK ACC + USM Reset + Rec Reset - Cannot enter BLTN_CAM in ACC - FAIL");
  write("Step 2-3: LED photo capture [Manual - Check LED] - PASS");
  if(step4_passed == 1)
    write("Step 4: AVN HU UI mode + RecSta_MAR = 0x0 (OFF) [Screenshot] - PASS");
  else
    write("Step 4: AVN HU UI mode + RecSta_MAR = 0x0 (OFF) [Screenshot] - FAIL");
  write("Step 5-6: LED photo capture [Manual - Check LED] - PASS");
  if(step7_passed == 1)
    write("Step 7: Evt Switch + MAR Recording within 10s [Screenshot+AIN] - PASS");
  else
    write("Step 7: Evt Switch + MAR Recording within 10s [Screenshot+AIN] - FAIL");
  write("Step 8-9: LED photo capture [Manual - Check LED] - PASS");
  write("Step 10-11: LED photo capture [Manual - Check LED] - PASS");
}

void MainTest()
{
  testReportFileName("TestReports\\OWD_018 - 2.0 generation_report");

  //write("Run Rec_Reset()"); Rec_Reset();

  OWD_018_Init();
  OWD_018_1();
  OWD_018_2_3();
  OWD_018_4();
  OWD_018_5_6();
  OWD_018_7();
  OWD_018_8_9();
  OWD_018_10_11();
  OWD_018_Summary();
}
