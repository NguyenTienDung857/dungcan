void MainTest()
{
  testReportFileName("TestReports\\OWD_018 - 2.5 generation_report");

  //write("Run Rec_Reset()"); Rec_Reset();

  OWD_018_Init();
  OWD_018_1();
  OWD_018_2_3();
  OWD_018_4();
  OWD_018_5_6();
  OWD_018_7();
  OWD_018_8_9();
  OWD_018_10_11();
}
