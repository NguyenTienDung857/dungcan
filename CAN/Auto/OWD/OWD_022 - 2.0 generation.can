  testStep("Notification","Start test OWD_022_2");
  write("Start test OWD_022_2");

  Setup_Function(2); write("Run Setup_Function()");

  if( count_MARRec_time >= 14 && count_MARRec_time <= 16){
    testStepPass("Pass","Test-case is OK");
