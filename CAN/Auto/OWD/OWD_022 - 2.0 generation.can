testcase OWD_022_3(){
  testStep("Notification","Start test OWD_022_3");
  write("Start test OWD_022_3");

  Setup_Function(3); write("Run Setup_Function()");

  if( count_MARRec_time >= 19 && count_MARRec_time <= 21){
    testStepPass("Pass","Test-case is OK");
    step1_passed = 1;
    write("count_MARRec_time = %.2f",count_MARRec_time);
  }
  else{
    testStepFail("Fail","Test-case is NG");
    step1_passed = 0;
    write("count_MARRec_time = %.2f",count_MARRec_time);
  }

  CaptureGraphics(); write("Run CaptureGraphics()");

  testWaitForTimeout(1000);

  @panel::Switch_CGWNM = 0;

  @panel::Switch_Clock = 0;

  count_MARRec_time = 0.0;

  KEY_OFF(); write("Run KEY_OFF()");

  testStep("","Step 3: Screenshot ... PASS");
  write("Finish OWD_022_3");
}

testcase OWD_022_Summary(){
  //============================================================================
  // Overall Test Verdict
  //============================================================================
  if(step1_passed == 1)
  {
    testStepPass("Overall_Verdict", "Test OWD_022: PASS");
    write("=== OVERALL VERDICT: PASS ===");
  }
  else
  {
    testStepFail("Overall_Verdict", "Test OWD_022: FAIL");
    write("=== OVERALL VERDICT: FAIL ===");
  }
}

void MainTest(){
  testReportFileName("TestReports\\OWD_022 - 2.0 generation_report");

  OWD_022_Init();
  OWD_022_1();
  OWD_022_2();
  OWD_022_3();
  OWD_022_Summary();
}
