void MainTest(){
  testReportFileName("TestReports\\OWD_022 - 2.5 generation_report");
  write("Run Turn_OFF_RecSet()"); Turn_OFF_RecSet();
  
  write("Run Rec_Reset()"); Rec_Reset();
  
  TestWaitForValueInput("Please enter the ID testcase number:",300000);
  
  switch (testGetValueInput()){
    
    case (1): OWD_022_1(); break;
    
    case (2): OWD_022_2(); break;
    
    case (3): OWD_022_3(); break;
      
    case (4):
      OWD_022_1();
      
      OWD_022_2();
      
      OWD_022_3(); 
      
      break;
  }  
  
}