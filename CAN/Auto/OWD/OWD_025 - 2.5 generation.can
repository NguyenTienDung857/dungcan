void Maintest(){
  testReportFileName("TestReports\\OWD_025 - 2.5 generation_report");
  write("Run Turn_OFF_RecSet()"); Turn_OFF_RecSet();
  
  write("Run Rec_Reset()"); Rec_Reset();
  
  TestWaitForValueInput("Please enter the ID testcase number:",300000);
  
  switch (testGetValueInput()){
    
    case (1): OWD_025_1_2(); break;
    
    case (2): OWD_025_3_4(); break;
      
    case (3): OWD_025_5_6(); break;
      
    case (4):
      OWD_025_1_2();
      
      OWD_025_3_4();
      
      OWD_025_5_6();
      
      break;
  }
}

