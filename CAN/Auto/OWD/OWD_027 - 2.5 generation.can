void MainTest()
{
  testReportFileName("TestReports\\OWD_027 - 2.5 generation_report");

  //write("Run Rec_Reset()"); Rec_Reset();

  OWD_027_Init();
  OWD_027_1();
  OWD_027_2();
  OWD_027_3_4();
  OWD_027_5();
  OWD_027_6();
  OWD_027_7();
  //OWD_027_8();
  //OWD_027_9();
}
