testcase OWD_028_6()
{
  int result = 0;

  //============================================================================
  // STEP 6: TML Stop + Enter BLTN_CAM + Turn OFF OWD
  //         If RecSet_OWD = 0x1 (OFF) -> Return to AVN + TML Start
  //         Log - Ask user to trigger driving event
  //         If RecSta_DEV = 0x1 (ON) within 20s -> Immediately TML Stop
  //         Screenshot (include AIN)
  //============================================================================
  Send_Value_To_COM(12806);
  SetTestStep("Bước 6 - OWD_028");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 6: TML Stop + BLTN_CAM + OWD OFF + AVN             ===");
  write("===         TML Start + Manual driving event trigger         ===");
  write("===         DEV ON within 20s -> Immediately TML Stop        ===");
  write("=================================================================");
  testStep("Step6", "TML Stop + OWD OFF + TML Start + Driving event + DEV ON + TML Stop");

  // 6.1 Click TML Stop
  write("[6.1] Clicking TML Stop...");
  Click_TML_Stop();
  testWaitForTimeout(2000);

  // 6.2 Enter BLTN_CAM and turn OFF OWD
  write("[6.2] Entering BLTN_CAM to turn OFF OWD...");
  Turn_OFF_OWD();

  // 6.3 Click TML Start (now in AVN mode after Turn_OFF_OWD returned)
  write("[6.3] Clicking TML Start...");
  Click_TML_Start();
  testWaitForTimeout(2000);

  // 6.4 Log - Ask user to trigger driving event
  write("");
  write("*************************************************************");
  write("*** STEP 6: PLEASE TRIGGER A DRIVING EVENT NOW! ***");
  write("*** (e.g. drive the vehicle / apply impact to camera) ***");
  write("*** Waiting up to 20 seconds for DEV recording to start ***");
  write("*** When DEV = ON detected, TML will be stopped immediately ***");
  write("*************************************************************");
  write("");

  // 6.5 Wait for BLTN_CAM_RecSta_DEV = 0x1 (ON) within 20s
  write("[6.5] Waiting for BLTN_CAM_RecSta_DEV = 0x1 (ON) within 20 seconds...");
  result = WaitFor_RecSta_DEV_Recording(max_wait_time_20s / 1000);

  if(result == 1)
  {
    // 6.6 Immediately click TML Stop
    write("[6.6] DEV ON detected! Immediately clicking TML Stop...");
    Click_TML_Stop();
  }
  else
  {
    write("[6.6] DEV Recording NOT detected within 20s. Clicking TML Stop anyway...");
    Click_TML_Stop();
  }

  // 6.7 Capture screenshot
  write("[6.7] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSta_DEV;BLTN_CAM_RecSta_TML;BLTN_CAM_RecSet_OWD;AIN;BLTN_CAM_HU_UI_Mode");

  if(result == 1)
  {
    step6_passed = 1;
    testStepPass("Step6", "DEV ON detected -> TML Stop immediately - PASS");
  }
  else
  {
    step6_passed = 0;
    write(">>> FAIL REASON: DEV Recording NOT detected within 20s (OWD OFF)");
    Log_Error_Details();
    testStepFail("Step6", "DEV Recording NOT detected within 20s - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase OWD_028_7()
{
  int result = 0;

  //============================================================================
  // STEP 7: TML Stop + Enter BLTN_CAM + Turn OFF OWD
  //         If RecSet_OWD = 0x1 (OFF) -> Return to AVN + TML Start
  //         Click Evt Switch, if RecSta_MAR = 0x1 (Recording)
  //         -> Immediately TML Stop, Wait 10s, Screenshot (include AIN)
  //============================================================================
  Send_Value_To_COM(12807);
  SetTestStep("Bước 7 - OWD_028");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 7: TML Stop + BLTN_CAM + OWD OFF + AVN             ===");
  write("===         TML Start + Evt Switch + MAR Recording           ===");
  write("===         -> Immediately TML Stop + Wait 10s + Screenshot  ===");
  write("=================================================================");
  testStep("Step7", "TML Stop + OWD OFF + TML Start + Evt Switch + MAR ON + TML Stop");

  // 7.1 Click TML Stop (safety - in case still running)
  write("[7.1] Clicking TML Stop...");
  Click_TML_Stop();
  testWaitForTimeout(2000);

  // 7.2 Enter BLTN_CAM and turn OFF OWD
  write("[7.2] Entering BLTN_CAM to turn OFF OWD...");
  Turn_OFF_OWD();
  result = Check_RecSet_OWD_OFF();

  if(result == 1)
  {
    write("[7.2] OWD turned OFF confirmed (RecSet_OWD = 0x1)");
  }
  else
  {
    write("[7.2] WARNING: OWD OFF not confirmed, continuing anyway...");
  }

  // 7.3 Click TML Start (now in AVN mode)
  write("[7.3] Clicking TML Start...");
  Click_TML_Start();
  testWaitForTimeout(2000);

  // 7.4 Click Evt Switch
  write("[7.4] Clicking Evt Switch...");
  Click_Evt_Switch();

  // 7.5 Check BLTN_CAM_RecSta_MAR = 0x1 (Recording) within 10s
  write("[7.5] Waiting for BLTN_CAM_RecSta_MAR = 0x1 (Recording)...");
  result = WaitFor_RecSta_MAR_Recording(max_wait_time_10s);

  if(result == 1)
  {
    // 7.6 Immediately click TML Stop
    write("[7.6] MAR Recording detected! Immediately clicking TML Stop...");
    Click_TML_Stop();
  }
  else
  {
    write("[7.6] MAR Recording NOT detected. Clicking TML Stop anyway...");
    Click_TML_Stop();
  }

  // 7.7 Wait 10 seconds
  write("[7.7] Waiting 10 seconds...");
  testWaitForTimeout(10000);

  // 7.8 Capture screenshot
  write("[7.8] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSta_MAR;BLTN_CAM_RecSta_TML;BLTN_CAM_RecSet_OWD;AIN;BLTN_CAM_HU_UI_Mode");

  if(result == 1)
  {
    step7_passed = 1;
    testStepPass("Step7", "MAR Recording detected -> TML Stop immediately - PASS");
  }
  else
  {
    step7_passed = 0;
    write(">>> FAIL REASON: MAR Recording NOT detected after Evt Switch (OWD OFF)");
    Log_Error_Details();
    testStepFail("Step7", "MAR Recording NOT detected after Evt Switch - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase OWD_028_8()
{
  int result = 0;

  //============================================================================
  // STEP 8: Enter BLTN_CAM + Turn ON OWD
  //         If RecSet_OWD = 0x2 (ON) -> Return to AVN
  //         Within 10s check AIN > 4, Screenshot (include AIN)
  //============================================================================
  Send_Value_To_COM(12808);
  SetTestStep("Bước 8 - OWD_028");
  StartTestTimer();

  write("");
  write("=================================================================");
