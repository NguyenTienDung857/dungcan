/*@!Encoding:65001*/

includes { #include "../DeclarationFunction_Gen2.5.h" }

/*
  Test Case: OWD_028
  Title: [TML + MAR + DEV Combined Recording Test with OWD ON/OFF]
  Verification items:
    - Step 1:  SMK IGN + USM Reset + Rec Reset + AVN + TML Start -> RecSta_TML = 0x1 (ON), wait 5s, Screenshot
    - Step 2:  Evt Switch -> RecSta_MAR = 0x1 (Recording), wait 12s, Screenshot
    - Step 3:  Evt Switch -> RecSta_MAR = 0x1 (Recording), wait 10s, Screenshot
    - Step 4:  Manual event trigger -> RecSta_DEV = 0x1 (ON) within 10s, wait 10s, Screenshot
    - Step 5:  Manual event trigger -> RecSta_DEV = 0x1 (ON) within 10s, wait 10s, Screenshot
    - Step 6:  TML Stop + BLTN_CAM + OWD OFF + AVN + TML Start + Manual driving event
               -> RecSta_DEV = 0x1 within 20s -> immediately TML Stop, Screenshot
    - Step 7:  TML Stop + BLTN_CAM + OWD OFF + AVN + TML Start + Evt Switch
               -> RecSta_MAR = 0x1 -> immediately TML Stop, wait 10s, Screenshot
    - Step 8:  Enter BLTN_CAM + OWD ON + AVN -> check AIN > 4 within 10s, Screenshot
    - Step 9:  TML Start -> RecSta_TML = 0x1 (ON), Screenshot
    - Step 10: Manual event trigger -> RecSta_DEV = 0x1 within 20s, wait 10s, Screenshot
    - Step 11: Manual event trigger -> RecSta_DEV = 0x1 within 20s
               -> immediately Evt Switch, wait 10s, TML Stop, Screenshot

  Preconditions:
    - ACC and IGN and ccNC/ccIC switch OFF, AVN mode

  NOTE: Uses 2-5s delay for signal propagation after each state transition.
*/

variables
{
  long max_wait_time_10s = 60000;   // 10 seconds timeout
  long max_wait_time_20s = 60000;   // 20 seconds timeout

  // Message declarations for CAN FD
  message HU_BLTN_CAM_PE_00_200ms _HU_BLTN_CAM_PE_00_200ms;
  message HU_BLTN_CAM_E_01 _HU_BLTN_CAM_E_01;
  message HU_CLOCK_PE_02 _HU_CLOCK_PE_02;

  // Result tracking variables
  int step1_passed = 0;
  int step2_passed = 0;
  int step3_passed = 0;
  int step4_passed = 0;
  int step5_passed = 0;
  int step6_passed = 0;
  int step7_passed = 0;
  int step8_passed = 0;
  int step9_passed = 0;
  int step10_passed = 0;
  int step11_passed = 0;

}

// ============================================================================
// Main Test Case
// ============================================================================

testcase OWD_028_Init()
{
  Send_Value_To_COM(12800);
  write("========================================");
  write("=== START TEST OWD_028 ===");
  write("=== TML + MAR + DEV Combined Test   ===");
  write("=== with OWD ON/OFF                 ===");
  write("========================================");
  Send_Value_To_COM(44);
}

testcase OWD_028_1()
{
  int result = 0;

  //============================================================================
  // STEP 1: Set SMK IGN, USM Reset, Rec Reset, AVN mode,
  //         Click TML Start, Check BLTN_CAM_RecSta_TML = 0x1 (ON)
  //         Wait 5s, Screenshot (include AIN)
  //============================================================================
  Send_Value_To_COM(12801);
  SetTestStep("Bước 1 - OWD_028");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 1: SMK IGN + USM Reset + Rec Reset + AVN mode      ===");
  write("===         TML Start + Check RecSta_TML = 0x1 (ON)         ===");
  write("===         Wait 5s + Screenshot (AIN)                      ===");
  write("=================================================================");
  testStep("Step1", "SMK IGN + USM Reset + Rec Reset + AVN + TML Start + TML ON");

  // 1.1 Set SMK to IGN via panel combo box
  write("[1.1] Setting SMK_Signal to IGN via panel...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);

  // 1.2 Click USM Reset button
  write("[1.2] Clicking USM Reset button...");
  Click_USM_Reset();
  testWaitForTimeout(2000);

  // 1.3 Click Rec Reset button
  write("[1.3] Clicking Rec Reset button...");
  Click_Rec_Reset();
  testWaitForTimeout(2000);

  // 1.4 Ensure AVN mode
  write("[1.4] Ensuring AVN mode...");
  Exit_BLTN_CAM();
  testWaitForTimeout(2000);
  write("  HU_BLTN_CAM_UI_Mode = 0x%X (AVN mode)", $BLTN_CAM_HU_UI_Mode);

  // 1.5 Click TML Start
  write("[1.5] Clicking TML Start on panel...");
  Click_TML_Start();

  // 1.6 Check BLTN_CAM_RecSta_TML = 0x1 (ON)
  write("[1.6] Checking BLTN_CAM_RecSta_TML = 0x1 (ON)...");
  result = WaitFor_RecSta_TML_Recording(max_wait_time_10s);

  // 1.7 Wait 5 seconds
  write("[1.7] Waiting 5 seconds...");
  testWaitForTimeout(5000);

  // 1.8 Capture screenshot
  write("[1.8] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSta_TML;AIN;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  if(result == 1)
  {
    step1_passed = 1;
    testStepPass("Step1", "BLTN_CAM_RecSta_TML = 0x1 (ON) after TML Start - PASS");
  }
  else
  {
    step1_passed = 0;
    write(">>> FAIL REASON: TML did NOT turn ON");
    Log_Error_Details();
    testStepFail("Step1", "BLTN_CAM_RecSta_TML did NOT turn ON after TML Start - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

