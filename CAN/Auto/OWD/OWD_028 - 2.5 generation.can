  result = Check_AIN_Above_Threshold(4.0, max_wait_time_10s);

  // 8.3 Capture screenshot
  write("[8.3] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSet_OWD;AIN;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  if(result == 1)
  {
    step8_passed = 1;
    testStepPass("Step8", "AIN > 4 detected after OWD ON - PASS");
  }
  else
  {
    step8_passed = 0;
    write(">>> FAIL REASON: AIN NOT > 4 within 10s after OWD ON");
    Log_Error_Details();
    testStepFail("Step8", "AIN NOT > 4 within 10s after OWD ON - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

