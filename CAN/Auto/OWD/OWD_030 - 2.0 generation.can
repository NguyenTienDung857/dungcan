testcase OWD_030_Summary()
{
  //============================================================================
  // Overall Test Verdict
  //============================================================================
  if(step1_passed == 1 && step2_passed == 1 && step5_passed == 1)
  {
    testStepPass("Overall_Verdict", "Test OWD_030: PASS");
    write("=== OVERALL VERDICT: PASS ===");
  }
  else
  {
    testStepFail("Overall_Verdict", "Test OWD_030: FAIL");
    write("=== OVERALL VERDICT: FAIL ===");
  }

  //============================================================================
  // TEST COMPLETE - Cleanup
  //============================================================================
  write("");
  write("========================================");
  write("=== TEST OWD_030 COMPLETE ===");
  write("========================================");

  // Cleanup: KEY OFF
  write("=== Cleanup: KEY OFF ===");
  setSignal(SMK_TrmnlCtrlGrpStaBDC, 0x0);  // KEY OFF
  testWaitForTimeout(2000);
  @panel::Switch_CGWNM = 0;

  // Final status
  write("");
  write("=== FINAL STATUS ===");
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);
  write("  BLTN_CAM_RecSta_TML = 0x%X", $BLTN_CAM_RecSta_TML);
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);
  write("  BLTN_CAM_HU_UI_Mode = 0x%X", $BLTN_CAM_HU_UI_Mode);

  write("");
  write("=== TEST SUMMARY ===");
  if(step1_passed == 1)
    write("Step 1: SMK IGN + USM Reset + Rec Reset + TML Start + TML ON + Wait 5s [Screenshot AIN] - PASS");
  else
    write("Step 1: SMK IGN + USM Reset + Rec Reset + TML Start + TML ON + Wait 5s [Screenshot AIN] - FAIL");

  if(step2_passed == 1)
    write("Step 2: Evt Switch + MAR Recording + Wait 15s [Screenshot AIN] - PASS");
  else
    write("Step 2: Evt Switch + MAR Recording + Wait 15s [Screenshot AIN] - FAIL");

  write("Step 3 & 4: Check video [Manual - Include in Report] - PASS");

  if(step5_passed == 1)
    write("Step 5: Wait 1min + SMK OFF + Wait 2s + SMK IGN + TML OFF [Screenshot] - PASS");
  else
    write("Step 5: Wait 1min + SMK OFF + Wait 2s + SMK IGN + TML OFF [Screenshot] - FAIL");

  write("Step 6: Check video [Manual - Include in Report] - PASS");
}

void MainTest()
{
  testReportFileName("TestReports\\OWD_030 - 2.0 generation_report");

  //write("Run Rec_Reset()"); Rec_Reset();

  OWD_030_Init();
  OWD_030_1();
  OWD_030_2();
  OWD_030_3_4();
  OWD_030_5();
  OWD_030_6();
  OWD_030_Summary();
}
