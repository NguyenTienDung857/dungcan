testcase OWD_030_5()
{
  int result = 0;

  //============================================================================
  // STEP 5: Wait 1 minute, SMK OFF, wait 2s, SMK IGN again
  //         Check BLTN_CAM_RecSta_TML = 0x0 (OFF), Screenshot
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 5: Wait 1 min + SMK OFF + Wait 2s + SMK IGN        ===");
  write("===         Check RecSta_TML = 0x0 (OFF) + Screenshot       ===");
  write("=================================================================");
  testStep("Step5", "Wait 1min + SMK OFF + Wait 2s + SMK IGN + TML OFF check + Screenshot");

  // 5.1 Wait 1 minute (60 seconds)
  write("[5.1] Waiting 1 minute (60 seconds)...");
  testWaitForTimeout(60000);
  write("  1 minute elapsed.");

  // 5.2 Log current status before SMK OFF
  write("[5.2] Current status before SMK OFF:");
  write("  BLTN_CAM_RecSta_TML = 0x%X", $BLTN_CAM_RecSta_TML);
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);
  Get_AIN_Voltage();

  // 5.3 Set SMK to OFF via panel combo box
  write("[5.3] Setting SMK_Signal to OFF via panel...");
  Set_SMK_OFF();

  // 5.4 Wait 2 seconds (as specified)
  write("[5.4] Waiting 2 seconds after SMK OFF...");
  testWaitForTimeout(2000);
  write("  2 seconds elapsed after SMK OFF.");

  // 5.5 Set SMK to IGN again via panel combo box
  write("[5.5] Setting SMK_Signal to IGN via panel again...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);

  // 5.6 Check BLTN_CAM_RecSta_TML = 0x0 (OFF)
  write("[5.6] Checking BLTN_CAM_RecSta_TML = 0x0 (OFF)...");
  testWaitForTimeout(3000);  // Extra delay for signal stabilization after IGN ON
  result = Check_RecSta_TML_OFF();

  if(result == 1)
  {
    step5_passed = 1;
    write(">>> Step 5: PASS - BLTN_CAM_RecSta_TML = 0x0 (OFF) after IGN OFF/ON <<<");
  }
  else
  {
    step5_passed = 0;
    write(">>> Step 5: FAIL - BLTN_CAM_RecSta_TML is NOT OFF after IGN OFF/ON <<<");
  }

  // 5.7 Read AIN voltage
  write("[5.7] Reading AIN voltage...");
  Get_AIN_Voltage();

  // 5.8 Capture screenshot
  write("[5.8] Capturing screenshot...");
  write("  BLTN_CAM_RecSta_TML = 0x%X", $BLTN_CAM_RecSta_TML);
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);
  CaptureGraphics("BLTN_CAM_RecSta_TML;BLTN_CAM_RecSta_MAR;AIN;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  if(step5_passed == 1)
  {
    testStepPass("Step5", "BLTN_CAM_RecSta_TML = 0x0 (OFF) after IGN OFF/ON cycle - PASS");
  }
  else
  {
    testStepFail("Step5", "BLTN_CAM_RecSta_TML is NOT OFF after IGN OFF/ON cycle - FAIL");
  }
}

