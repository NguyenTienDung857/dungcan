testcase OWD_032_5()
{
  int result = 0;

  //============================================================================
  // STEP 5: Enter BLTN_CAM mode (Build-in Cam),
  //         Send TML_Rec_Req = 0x1 (Start Request),
  //         Check BLTN_CAM_RecSta_TML stays = 0x0 (OFF) for 5s - Screenshot (include AIN)
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 5: Enter BLTN_CAM mode + TML_Rec_Req Start         ===");
  write("===         Verify RecSta_TML stays OFF for 5s + Screenshot ===");
  write("=================================================================");
  testStep("Step5", "Enter BLTN_CAM + TML_Rec_Req Start + TML stays OFF + Screenshot");

  // 5.1 Enter BLTN_CAM mode (Build-in Cam)
  write("[5.1] Entering BLTN_CAM mode (Build-in Cam)...");
  Enter_BLTN_CAM();
  testWaitForTimeout(3000);
  write("  HU_BLTN_CAM_UI_Mode = 0x%X (BLTN_CAM mode)", $BLTN_CAM_HU_UI_Mode);

  // 5.2 Send TML_Rec_Req = 0x1 (Start Request)
  write("[5.2] Sending TML_Rec_Req = 0x1 (Start Request) in BLTN_CAM mode...");
  Send_TML_Rec_Req_Start();

  // 5.3 Check BLTN_CAM_RecSta_TML stays OFF for 5s
  write("[5.3] Verifying BLTN_CAM_RecSta_TML stays = 0x0 (OFF) for 5 seconds...");
  result = Verify_RecSta_TML_Stays_OFF(max_wait_time_5s);

  if(result == 1)
  {
    step5_passed = 1;
    write(">>> Step 5: PASS - TML stayed OFF in BLTN_CAM mode <<<");
  }
  else
  {
    step5_passed = 0;
    write(">>> Step 5: FAIL - TML turned ON unexpectedly in BLTN_CAM mode <<<");
  }

  // 5.4 Read AIN voltage
  write("[5.4] Reading AIN voltage...");
  Get_AIN_Voltage();

  // 5.5 Capture screenshot (include AIN)
  write("[5.5] Capturing screenshot...");
  write("  BLTN_CAM_RecSta_TML = 0x%X", $BLTN_CAM_RecSta_TML);
  write("  BLTN_CAM_HU_UI_Mode = 0x%X", $BLTN_CAM_HU_UI_Mode);
  CaptureGraphics("BLTN_CAM_RecSta_TML;AIN;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  if(step5_passed == 1)
  {
    testStepPass("Step5", "TML stayed OFF after TML_Rec_Req Start in BLTN_CAM mode - PASS");
  }
  else
  {
    testStepFail("Step5", "TML turned ON unexpectedly in BLTN_CAM mode - FAIL");
  }
}

testcase OWD_032_Summary()
{
  //============================================================================
  // Overall Test Verdict
  //============================================================================
  if(step1_passed == 1 && step2_passed == 1 && step3_passed == 1 && step4_passed == 1 && step5_passed == 1)
  {
    testStepPass("Overall_Verdict", "Test OWD_032: PASS");
    write("=== OVERALL VERDICT: PASS ===");
  }
  else
  {
    testStepFail("Overall_Verdict", "Test OWD_032: FAIL");
    write("=== OVERALL VERDICT: FAIL ===");
  }

  //============================================================================
  // TEST COMPLETE - Cleanup
  //============================================================================
  write("");
  write("========================================");
  write("=== TEST OWD_032 COMPLETE ===");
  write("========================================");

  // Cleanup: Exit BLTN_CAM back to AVN, then KEY OFF
  write("=== Cleanup: Exit BLTN_CAM + KEY OFF ===");
  Exit_BLTN_CAM();
  testWaitForTimeout(2000);
  setSignal(SMK_TrmnlCtrlGrpStaBDC, 0x0);  // KEY OFF
  testWaitForTimeout(2000);
  @panel::Switch_CGWNM = 0;

  // Final status
  write("");
  write("=== FINAL STATUS ===");
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);
  write("  BLTN_CAM_RecSta_TML = 0x%X", $BLTN_CAM_RecSta_TML);
  write("  BLTN_CAM_HU_UI_Mode = 0x%X", $BLTN_CAM_HU_UI_Mode);

  write("");
  write("=== TEST SUMMARY ===");
  if(step1_passed == 1)
    write("Step 1: SMK IGN + USM Reset + Rec Reset + AVN + TML_Rec_Req Start + TML ON [Screenshot AIN] - PASS");
  else
    write("Step 1: SMK IGN + USM Reset + Rec Reset + AVN + TML_Rec_Req Start + TML ON [Screenshot AIN] - FAIL");

  if(step2_passed == 1)
    write("Step 2: Wait 5s + TML_Rec_Req End + TML OFF [Screenshot AIN] - PASS");
  else
    write("Step 2: Wait 5s + TML_Rec_Req End + TML OFF [Screenshot AIN] - FAIL");

  if(step3_passed == 1)
    write("Step 3: TML_Rec_Req Start + TML ON + Wait 12s + Panel TML Stop + TML OFF [Screenshot AIN] - PASS");
  else
    write("Step 3: TML_Rec_Req Start + TML ON + Wait 12s + Panel TML Stop + TML OFF [Screenshot AIN] - FAIL");

  if(step4_passed == 1)
    write("Step 4: Panel TML Start + TML ON + Wait 12s + TML_Rec_Req End + TML OFF [Screenshot AIN] - PASS");
  else
    write("Step 4: Panel TML Start + TML ON + Wait 12s + TML_Rec_Req End + TML OFF [Screenshot AIN] - FAIL");

  if(step5_passed == 1)
    write("Step 5: Enter BLTN_CAM mode + TML_Rec_Req Start + TML stays OFF [Screenshot AIN] - PASS");
  else
    write("Step 5: Enter BLTN_CAM mode + TML_Rec_Req Start + TML stays OFF [Screenshot AIN] - FAIL");
}

void MainTest()
{
  testReportFileName("TestReports\\OWD_032 - 2.0 generation_report");

  //write("Run Rec_Reset()"); Rec_Reset();

  OWD_032_Init();
  OWD_032_1();
  OWD_032_2();
  OWD_032_3();
  OWD_032_4();
  OWD_032_5();
  OWD_032_Summary();
}
