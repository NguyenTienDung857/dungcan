/*@!Encoding:1252*/

/*
  Test Case: OWD_032
  Title: [TML Recording Test - TML_Rec_Req Start/End Request + Panel TML Start/Stop + BLTN_CAM Mode]
  Verification items:
    - Step 1: SMK IGN + USM Reset + Rec Reset + AVN mode
              Send TML_Rec_Req = 0x1 (Start Request) via HU_BLTN_CAM_E_01
              Check BLTN_CAM_RecSta_TML = 0x1 (ON) within 10s - Screenshot (include AIN)
    - Step 2: Wait 5s, Send TML_Rec_Req = 0x2 (End Request)
              Check BLTN_CAM_RecSta_TML = 0x0 (OFF) within 10s - Screenshot (include AIN)
    - Step 3: Send TML_Rec_Req = 0x1 (Start Request)
              Check TML ON, Wait 12s, Click TML Stop on panel
              Check BLTN_CAM_RecSta_TML = 0x0 (OFF) within 10s
              Wait 5s - Screenshot (include AIN)
    - Step 4: Click TML Start on panel
              Check TML ON, Wait 12s, Send TML_Rec_Req = 0x2 (End Request)
              Check BLTN_CAM_RecSta_TML = 0x0 (OFF) within 10s - Screenshot (include AIN)
    - Step 5: Enter BLTN_CAM mode (Build-in Cam)
              Send TML_Rec_Req = 0x1 (Start Request)
              Check BLTN_CAM_RecSta_TML still = 0x0 (OFF) within 5s - Screenshot (include AIN)

  Preconditions:
    - ACC and IGN and ccNC/ccIC switch OFF, AVN mode

  NOTE: Uses 2-5s delay for signal propagation after each state transition.
*/

variables
{
  long max_wait_time_10s = 10000;   // 10 seconds timeout
  long max_wait_time_5s  = 5000;    // 5 seconds timeout

  // Message declarations for CAN
  message HU_BLTN_CAM_PE_00_200ms _HU_BLTN_CAM_PE_00_200ms;
  message HU_BLTN_CAM_E_01 _HU_BLTN_CAM_E_01;
  message HU_CLOCK_PE_02 _HU_CLOCK_PE_02;

  // Result tracking variables
  int step1_passed = 0;
  int step2_passed = 0;
  int step3_passed = 0;
  int step4_passed = 0;
  int step5_passed = 0;

  int flag_RecSet_error = 0;
}

// ============================================================================
// Panel Control Helper Functions
// ============================================================================

// Set SMK to IGN (0x2) via panel combo box
void Set_SMK_IGN()
{
  write("=== Setting SMK_Signal to IGN via panel ===");
  @panel::Switch_CGWNM = 1;
  testWaitForTimeout(2000);
  setSignal(SMK_TrmnlCtrlGrpStaBDC, 0x2);  // IGN
  testWaitForTimeout(2000);
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X (IGN)", $SMK_TrmnlCtrlGrpStaBDC);
}

// Click USM Reset button on panel
void Click_USM_Reset()
{
  write("=== Clicking USM Reset button on panel ===");
  @panel::Button_USMReset = 1;
  testWaitForTimeout(2000);
  write("  USM Reset clicked");
}

// Click Rec Reset button on panel
void Click_Rec_Reset()
{
  write("=== Clicking Rec Reset button on panel ===");
  @panel::Button_RecReset = 1;
  testWaitForTimeout(2000);
  write("  Rec Reset clicked");
}

// Click TML Start button on panel Recording_Setting
void Click_TML_Start()
{
  write("=== Clicking TML Start button on panel ===");
  @panel::Button_Timelaps_Start = 0;
  testWaitForTimeout(500);
  @panel::Button_Timelaps_Start = 1;
  testWaitForTimeout(2000);
  write("  TML Start clicked");
}

// Click TML Stop button on panel Recording_Setting
void Click_TML_Stop()
{
  write("=== Clicking TML Stop button on panel ===");
  @panel::Button_Timelaps_Stop = 0;
  testWaitForTimeout(500);
  @panel::Button_Timelaps_Stop = 1;
  testWaitForTimeout(2000);
  write("  TML Stop clicked");
}

// Enter Built-in Cam mode (HU_BLTN_CAM_UI_Mode = 0x1)
void Enter_BLTN_CAM()
{
  int i;
  write(">>> Enter BLTN_CAM mode <<<");
  _HU_BLTN_CAM_PE_00_200ms.HU_BLTN_CAM_UI_Mode = 0x1;
  output(_HU_BLTN_CAM_PE_00_200ms);

  for (i = 0; i < 10; i++) {
    testWaitForTimeout(500);
    if (getSignal(BLTN_CAM_HU_UI_Mode) == 0x1) {
      write(">>> [OK] BLTN_CAM mode confirmed <<<");
      return;
    }
  }
  write(">>> [NG] Timeout: BLTN_CAM_HU_UI_Mode = 0x%X <<<",
        getSignal(BLTN_CAM_HU_UI_Mode));
}

// Exit to AVN HU UI mode (HU_BLTN_CAM_UI_Mode = 0x0)
void Exit_BLTN_CAM()
{
  int i;
  write(">>> Exit to AVN mode <<<");
  _HU_BLTN_CAM_PE_00_200ms.HU_BLTN_CAM_UI_Mode = 0x0;
  output(_HU_BLTN_CAM_PE_00_200ms);

  for (i = 0; i < 10; i++) {
    testWaitForTimeout(500);
    if (getSignal(BLTN_CAM_HU_UI_Mode) == 0x0) {
      write(">>> [OK] AVN mode confirmed <<<");
      return;
    }
  }
  write(">>> [NG] Timeout: BLTN_CAM_HU_UI_Mode = 0x%X <<<",
        getSignal(BLTN_CAM_HU_UI_Mode));
}

// ============================================================================
// TML_Rec_Req Signal Send Functions (via HU_BLTN_CAM_E_01 message)
// ============================================================================

// Send TML_Rec_Req = 0x1 (Start Request) via HU_BLTN_CAM_E_01
void Send_TML_Rec_Req_Start()
{
  message HU_BLTN_CAM_E_01 _HU_BLTN_CAM_E_01;
  int i;

  write("=== Sending TML_Rec_Req = 0x1 (Start Request) via HU_BLTN_CAM_E_01 ===");

  for(i = 0; i < 8; i++)
  {
    _HU_BLTN_CAM_E_01.byte(i) = 0xFF;
  }

  _HU_BLTN_CAM_E_01.TML_Rec_Req = 0x1;
  output(_HU_BLTN_CAM_E_01);

  testWaitForTimeout(2000);
  write("  TML_Rec_Req = 0x1 (Start Request) sent");
}

// Send TML_Rec_Req = 0x2 (End Request) via HU_BLTN_CAM_E_01
void Send_TML_Rec_Req_End()
{
  message HU_BLTN_CAM_E_01 _HU_BLTN_CAM_E_01;

  write("=== Sending TML_Rec_Req = 0x2 (End Request) via HU_BLTN_CAM_E_01 ===");

  _HU_BLTN_CAM_E_01.TML_Rec_Req = 0x2;
  output(_HU_BLTN_CAM_E_01);

  testWaitForTimeout(2000);
  write("  TML_Rec_Req = 0x2 (End Request) sent");
}

// ============================================================================
// Check Functions
// ============================================================================

// Wait for BLTN_CAM_RecSta_TML = 0x1 (ON) with timeout
int WaitFor_RecSta_TML_ON(long timeout_ms)
{
  long elapsed = 0;
  long check_interval = 1000;
  byte rec_sta_tml = 0;
  long log_interval;

  write("=== Waiting for TML Recording ON (max %d seconds) ===", timeout_ms / 1000);
  log_interval = (timeout_ms / 6 / check_interval) * check_interval; if(log_interval < check_interval) log_interval = check_interval;

  while(elapsed < timeout_ms)
  {
    rec_sta_tml = $BLTN_CAM_RecSta_TML;
    if(elapsed == 0 || elapsed % log_interval == 0)
    {
      write("  [%d s / %d s] BLTN_CAM_RecSta_TML = 0x%X",
            elapsed / 1000, timeout_ms / 1000, rec_sta_tml);
    }

    if(rec_sta_tml == 0x1)
    {
      write(">>> DETECTED: TML Recording ON after %d seconds <<<", elapsed / 1000);
      write(">>> PASS: BLTN_CAM_RecSta_TML = 0x1 (ON) <<<");
      return 1;
    }

    testWaitForTimeout(check_interval);
    elapsed += check_interval;
  }

  write(">>> TIMEOUT: TML Recording NOT ON after %d seconds <<<", timeout_ms / 1000);
  write(">>> FAIL: BLTN_CAM_RecSta_TML is still 0x%X <<<", rec_sta_tml);
  return 0;
}

// Wait for BLTN_CAM_RecSta_TML = 0x0 (OFF) with timeout
int WaitFor_RecSta_TML_OFF(long timeout_ms)
{
  long elapsed = 0;
  long check_interval = 1000;
  byte rec_sta_tml = 0;
  long log_interval;

  write("=== Waiting for TML Recording OFF (max %d seconds) ===", timeout_ms / 1000);
  log_interval = (timeout_ms / 6 / check_interval) * check_interval; if(log_interval < check_interval) log_interval = check_interval;

  while(elapsed < timeout_ms)
  {
    rec_sta_tml = $BLTN_CAM_RecSta_TML;
    if(elapsed == 0 || elapsed % log_interval == 0)
    {
      write("  [%d s / %d s] BLTN_CAM_RecSta_TML = 0x%X",
            elapsed / 1000, timeout_ms / 1000, rec_sta_tml);
    }

    if(rec_sta_tml == 0x0)
    {
      write(">>> DETECTED: TML Recording OFF after %d seconds <<<", elapsed / 1000);
      write(">>> PASS: BLTN_CAM_RecSta_TML = 0x0 (OFF) <<<");
      return 1;
    }

    testWaitForTimeout(check_interval);
    elapsed += check_interval;
  }

  write(">>> TIMEOUT: TML Recording NOT OFF after %d seconds <<<", timeout_ms / 1000);
  write(">>> FAIL: BLTN_CAM_RecSta_TML is still 0x%X <<<", rec_sta_tml);
  return 0;
}

// Check BLTN_CAM_RecSta_TML current value = 0x0 (OFF)
int Check_RecSta_TML_OFF()
{
  byte rec_sta_tml = 0;

  rec_sta_tml = $BLTN_CAM_RecSta_TML;
  write("  BLTN_CAM_RecSta_TML = 0x%X", rec_sta_tml);

  if(rec_sta_tml == 0x0)
  {
    write(">>> PASS: BLTN_CAM_RecSta_TML = 0x0 (OFF) <<<");
    return 1;
  }
  else
  {
    write(">>> FAIL: BLTN_CAM_RecSta_TML is NOT OFF (value = 0x%X) <<<", rec_sta_tml);
    return 0;
  }
}

// Verify BLTN_CAM_RecSta_TML stays OFF for the given duration
int Verify_RecSta_TML_Stays_OFF(long duration_ms)
{
  long elapsed = 0;
  long check_interval = 1000;
  byte rec_sta_tml = 0;
  long log_interval;

  write("=== Verifying TML stays OFF for %d seconds ===", duration_ms / 1000);
  log_interval = (duration_ms / 6 / check_interval) * check_interval; if(log_interval < check_interval) log_interval = check_interval;

  while(elapsed < duration_ms)
  {
    rec_sta_tml = $BLTN_CAM_RecSta_TML;
    if(elapsed == 0 || elapsed % log_interval == 0)
    {
      write("  [%d s / %d s] BLTN_CAM_RecSta_TML = 0x%X",
            elapsed / 1000, duration_ms / 1000, rec_sta_tml);
    }

    if(rec_sta_tml != 0x0)
    {
      write(">>> FAIL: TML turned ON unexpectedly at %d seconds (value = 0x%X) <<<", elapsed / 1000, rec_sta_tml);
      return 0;
    }

    testWaitForTimeout(check_interval);
    elapsed += check_interval;
  }

  write(">>> PASS: TML stayed OFF for %d seconds <<<", duration_ms / 1000);
  return 1;
}

// Read AIN voltage from CANoe VN1600 hardware
float Get_AIN_Voltage()
{
  float ain_value = 0.0;

  // Read from VN1600_1 AIN channel
  ain_value = @sysvar::IO::VN1600_1::AIN;

  write("  AIN Voltage: %.2f V", ain_value);
  return ain_value;
}

// ============================================================================
// Rec Reset Function
// ============================================================================
void Rec_Reset()
{
  @panel::Switch_CGWNM = 1;

  setSignal(SMK_TrmnlCtrlGrpStaBDC, 0x2);
  testWaitForTimeout(2000);

  while (getSignal(BLTN_CAM_SD_Format_Op_State) != 0x1)
  {
    @panel::Button_RecReset = 1;
    testWaitForSignalChange(BLTN_CAM_SD_Format_Op_State, 500);
  }

  setSignal(SMK_TrmnlCtrlGrpStaBDC, 0x0);
  testWaitForTimeout(2000);

  @panel::Switch_CGWNM = 0;
}

// ============================================================================
// Capture Screenshot Functions
// ============================================================================

// Capture screenshot with specified signal list
void CaptureGraphics(char signalList[])
{
  testWaitForTimeout(3000);
  testReportAddWindowCapture("OWD", signalList, "Screenshot");
  write(">>> Screenshot captured <<<");
}

// ============================================================================
// Main Test Case
// ============================================================================

testcase OWD_032_Init()
{
  write("========================================");
  write("=== START TEST OWD_032 ===");
  write("=== TML Recording Test              ===");
  write("=== TML_Rec_Req Start/End Request   ===");
  write("=== Panel TML Start/Stop            ===");
  write("=== BLTN_CAM Mode Check             ===");
  write("========================================");
}

testcase OWD_032_1()
{
  int result = 0;

  //============================================================================
  // STEP 1: Set SMK IGN, USM Reset, Rec Reset, AVN mode,
  //         Send TML_Rec_Req = 0x1 (Start Request) via HU_BLTN_CAM_E_01,
  //         Check BLTN_CAM_RecSta_TML = 0x1 (ON) within 10s - Screenshot (include AIN)
  //============================================================================
  write("");
  write("=================================================================");
  write("=== STEP 1: SMK IGN + USM Reset + Rec Reset + AVN mode      ===");
  write("===         Send TML_Rec_Req = 0x1 (Start Request)          ===");
  write("===         Check RecSta_TML = 0x1 (ON) + Screenshot        ===");
  write("=================================================================");
  testStep("Step1", "SMK IGN + USM Reset + Rec Reset + AVN + TML_Rec_Req Start + TML ON + Screenshot");

  // 1.1 Set SMK to IGN via panel combo box
  write("[1.1] Setting SMK_Signal to IGN via panel...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);

  // 1.2 Click USM Reset button
  write("[1.2] Clicking USM Reset button...");
  Click_USM_Reset();
  testWaitForTimeout(2000);

  // 1.3 Click Rec Reset button
  write("[1.3] Clicking Rec Reset button...");
  Click_Rec_Reset();
  testWaitForTimeout(2000);

  // 1.4 Ensure AVN mode (Exit BLTN_CAM if needed)
  write("[1.4] Ensuring AVN mode...");
  Exit_BLTN_CAM();
  testWaitForTimeout(2000);
  write("  HU_BLTN_CAM_UI_Mode = 0x%X (AVN mode)", $BLTN_CAM_HU_UI_Mode);

  // 1.5 Send TML_Rec_Req = 0x1 (Start Request) via HU_BLTN_CAM_E_01
  write("[1.5] Sending TML_Rec_Req = 0x1 (Start Request)...");
  Send_TML_Rec_Req_Start();

  // 1.6 Check BLTN_CAM_RecSta_TML = 0x1 (ON) within 10s
  write("[1.6] Checking BLTN_CAM_RecSta_TML = 0x1 (ON)...");
  result = WaitFor_RecSta_TML_ON(max_wait_time_10s);

  if(result == 1)
  {
    step1_passed = 1;
    write(">>> Step 1: PASS - BLTN_CAM_RecSta_TML = 0x1 (ON) <<<");
  }
  else
  {
    step1_passed = 0;
    write(">>> Step 1: FAIL - BLTN_CAM_RecSta_TML did NOT turn ON <<<");
  }

  // 1.7 Read AIN voltage
  write("[1.7] Reading AIN voltage...");
  Get_AIN_Voltage();

  // 1.8 Capture screenshot (include AIN)
  write("[1.8] Capturing screenshot...");
  write("  BLTN_CAM_RecSta_TML = 0x%X", $BLTN_CAM_RecSta_TML);
  CaptureGraphics("BLTN_CAM_RecSta_TML;AIN;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  if(step1_passed == 1)
  {
    testStepPass("Step1", "BLTN_CAM_RecSta_TML = 0x1 (ON) after TML_Rec_Req Start - PASS");
  }
  else
  {
    testStepFail("Step1", "BLTN_CAM_RecSta_TML did NOT turn ON after TML_Rec_Req Start - FAIL");
  }
}

testcase OWD_032_2()
{
  int result = 0;

  //============================================================================
  // STEP 2: Wait 5s, Send TML_Rec_Req = 0x2 (End Request),
  //         Check BLTN_CAM_RecSta_TML = 0x0 (OFF) within 10s - Screenshot (include AIN)
