/*@!Encoding:65001*/

includes
{
  #include "DeclarationFunction_OWP_Gen2.h"
}

//Preconditions: - ACC and IGN and ccNC/ccIC switch OFF, AVN mode
//               - Add signal: BLTN_CAM_RecSta_OWP, BLTN_CAM_RecSet_OWP, BLTN_CAM_Prk_Oprable_Time

/*
  Test Case: OWP_002 - 2.0 (OWP_002)
  Title: [Recording while Parking] - Continuous Recording ON/OFF and Operable Time

  Step 1: KEY ON (IGN), USM Reset, Rec Reset, Enter BLTN_CAM, Turn OFF [Recording while Parking]
          Check BLTN_CAM_RecSet_OWP = 0x1 (OFF)
  Step 2: Exit BLTN_CAM, KEY OFF, Check BLTN_CAM_RecSta_OWP = 0x0 (OFF)
  Step 3_4: Log - LED not blinking (manual check)
  Step 5: KEY ON, Enter BLTN_CAM, Turn ON [Recording while Parking]
          Check BLTN_CAM_RecSet_OWP = 0x0 (Default)
  Step 6: Turn ON [Recording while Parking], Exit BLTN_CAM, Set P-LBM SoC = 0xFF
          Check BLTN_CAM_Prk_Oprable_Time = 0x00
  Step 7: Check [Recording while Parking] = ON, KEY OFF, wait 3 min, KEY ON
          Log: check actual video (no screenshot)
  Step 8: Quickly press ACC&IGN ON/OFF 20 times, then OFF, wait a few seconds
          Check BLTN_CAM_RecSta_OWP = ON
  Step 9: Log - refer to additional information

  NOTE: Uses 2-5s delay for signal propagation after each state transition.
*/

variables
{
  int flag_RecSet_error = 0;

  // Result tracking
  int step1_passed = 0;
  int step2_passed = 0;
  int step3_4_passed = 0;
  int step5_passed = 0;
  int step6_passed = 0;
  int step7_passed = 0;
  int step8_passed = 0;
  int step9_passed = 0;

  // Message Declaration for CAN
  message HU_BLTN_CAM_PE_00_200ms _HU_BLTN_CAM_PE_00_200ms;
  message HU_BLTN_CAM_E_00 _HU_BLTN_CAM_E_00;
  message HU_BLTN_CAM_E_01 _HU_BLTN_CAM_E_01;
}

// ============================================================================
// File-specific Functions
// ============================================================================


// ============================================================================
// Test Cases
// ============================================================================

testcase OWP_002_Init(){
  write("========================================");
  write("=== START TEST OWP_002 - 2.0 ===");
  write("========================================");

  write("===SETTING BEFORE TESTING===");

 // write("Run Turn_OFF_RecSet()"); Turn_OFF_RecSet();

  write("===START TEST===");
}

testcase OWP_002_1(){
  //============================================================================
  // STEP 1: KEY ON (IGN), USM Reset, Rec Reset, Enter BLTN_CAM screen transition
  //         Turn OFF [Recording while Parking], Check BLTN_CAM_RecSet_OWP = 0x1 (OFF)
  //============================================================================
  write("");
  write("=== STEP 1: KEY ON (IGN), USM/Rec Reset, Enter BLTN_CAM, Turn OFF OWP ===");
  testStep("Step1", "Start test OWP_002_1");

  @panel::Switch_CGWNM = 1;
  testWaitForTimeout(2000);

  // Set SMK to IGN (0x2) via panel combo box
  write("Setting SMK_Signal to IGN (0x2)...");
  KEY_ON();
  testWaitForTimeout(3000);
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);

  // Click USM Reset
  Click_USM_Reset();

  // Click Rec Reset
  Click_Rec_Reset();

  // Enter Built-in cam screen transition
  Enter_BLTN_CAM();
  testWaitForTimeout(3000);

  // Turn Continuous Recording [Recording while Parking] set OFF
  // If OWP is currently ON (0x2), toggle it OFF
  if (getSignal(BLTN_CAM_RecSet_OWP) == 0x2){
    write("OWP is ON (0x2), toggling to OFF...");
    @panel::LED_Ctrl_SetOWP = 1;
    testWaitForTimeout(3000);
  }
  // If OWP is already OFF (0x1), no action needed
  else if (getSignal(BLTN_CAM_RecSet_OWP) == 0x1){
    write("OWP is already OFF (0x1), no toggle needed.");
  }
  // If OWP is default (0x0), toggle to set it to OFF path
  else if (getSignal(BLTN_CAM_RecSet_OWP) == 0x0){
    write("OWP is Default (0x0), need to verify after entering BLTN_CAM...");
    // Toggle once - this should turn it ON first
    @panel::LED_Ctrl_SetOWP = 1;
    testWaitForTimeout(3000);
    // If now ON, toggle once more to OFF
    if (getSignal(BLTN_CAM_RecSet_OWP) == 0x2){
      @panel::LED_Ctrl_SetOWP = 1;
      testWaitForTimeout(3000);
    }
  }

  testWaitForTimeout(2000);

  // Check BLTN_CAM_RecSet_OWP = 0x1 (OFF)
  write("BLTN_CAM_RecSet_OWP = 0x%X", $BLTN_CAM_RecSet_OWP);

  if ($BLTN_CAM_RecSet_OWP == 0x1){
    write(">>> [PASS] BLTN_CAM_RecSet_OWP = 0x1 (OFF) <<<");
    testStepPass("Step1", "BLTN_CAM_RecSet_OWP = 0x1 (OFF) - PASS");
    step1_passed = 1;
  }
  else {
    write(">>> [FAIL] BLTN_CAM_RecSet_OWP = 0x%X, expected 0x1 (OFF) <<<", $BLTN_CAM_RecSet_OWP);
    testStepFail("Step1", "BLTN_CAM_RecSet_OWP = 0x%X, expected 0x1 - FAIL", $BLTN_CAM_RecSet_OWP);
    step1_passed = 0;
  }

  CaptureGraphics("BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_HU_UI_Mode");

  write("=== FINISH STEP 1 ===");
}

testcase OWP_002_2(){
  //============================================================================
  // STEP 2: Exit BLTN_CAM, KEY OFF, Check BLTN_CAM_RecSta_OWP = 0x0 (OFF)
  //============================================================================
  write("");
  write("=== STEP 2: Exit BLTN_CAM, KEY OFF, Check RecSta_OWP = OFF ===");
  testStep("Step2", "Start test OWP_002_2");

  // Exit BLTN_CAM screen
  Exit_BLTN_CAM();
  testWaitForTimeout(3000);

  // KEY OFF
  write("KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // Check BLTN_CAM_RecSta_OWP = 0x0 (OFF)
  write("BLTN_CAM_RecSta_OWP = 0x%X", $BLTN_CAM_RecSta_OWP);

  if ($BLTN_CAM_RecSta_OWP == 0x0){
    write(">>> [PASS] BLTN_CAM_RecSta_OWP = 0x0 (OFF) <<<");
    testStepPass("Step2", "BLTN_CAM_RecSta_OWP = 0x0 (OFF) - PASS");
    step2_passed = 1;
  }
  else {
    write(">>> [FAIL] BLTN_CAM_RecSta_OWP = 0x%X, expected 0x0 (OFF) <<<", $BLTN_CAM_RecSta_OWP);
    testStepFail("Step2", "BLTN_CAM_RecSta_OWP = 0x%X, expected 0x0 - FAIL", $BLTN_CAM_RecSta_OWP);
    step2_passed = 0;
  }

  CaptureGraphics("BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSet_OWP;BLTN_CAM_HU_UI_Mode");

  write("=== FINISH STEP 2 ===");
}

testcase OWP_002_3_4(){
  //============================================================================
  // STEP 3 & 4: Log - LED not blinking (manual check)
  //============================================================================
  write("");
  write("=== STEP 3 & 4: LED not blinking check (Manual) ===");
  testStep("Step3_4", "Start test OWP_002_3_4");

  write("*************************************************************");
  write("*** [MANUAL CHECK] LED is NOT blinking                    ***");
  write("*** OWP recording is OFF, so LED should NOT blink.        ***");
  write("*** Please visually confirm that the LED is not blinking. ***");
  write("*************************************************************");

  testStepPass("Step3_4", "Log: LED not blinking - manual check required");
  step3_4_passed = 1;

  write("=== FINISH STEP 3_4 ===");
}

testcase OWP_002_5(){
  //============================================================================
  // STEP 5: KEY ON, Enter BLTN_CAM, Turn ON [Recording while Parking]
  //         Check BLTN_CAM_RecSet_OWP = 0x0 (Default) => means Turn ON action confirmed
  //============================================================================
  write("");
  write("=== STEP 5: KEY ON, Enter BLTN_CAM, Turn ON OWP ===");
  testStep("Step5", "Start test OWP_002_5");

  @panel::Switch_CGWNM = 1;

  // KEY ON
  write("KEY ON...");
  KEY_ON();
  testWaitForTimeout(3000);

  // Enter BLTN_CAM
  Enter_BLTN_CAM();
  testWaitForTimeout(3000);

  // Turn ON [Recording while Parking] - continuous recording
  write("Turning ON [Recording while Parking]...");
  write("  Current BLTN_CAM_RecSet_OWP = 0x%X", $BLTN_CAM_RecSet_OWP);

  if ($BLTN_CAM_RecSet_OWP == 0x1){
    // OWP is OFF, toggle to ON
    @panel::LED_Ctrl_SetOWP = 1;
    testWaitForTimeout(3000);
    write("  After toggle: BLTN_CAM_RecSet_OWP = 0x%X", $BLTN_CAM_RecSet_OWP);
  }

  // Check BLTN_CAM_RecSet_OWP should be 0x0 (Default) or 0x2 (ON)
  // According to test spec: check BLTN_CAM_RecSet_OWP = 0x0 (Default)
  write("BLTN_CAM_RecSet_OWP = 0x%X", $BLTN_CAM_RecSet_OWP);

  if ($BLTN_CAM_RecSet_OWP == 0x0){
    write(">>> [PASS] BLTN_CAM_RecSet_OWP = 0x0 (Default) <<<");
    testStepPass("Step5", "BLTN_CAM_RecSet_OWP = 0x0 (Default) - PASS");
    step5_passed = 1;
  }
  else if ($BLTN_CAM_RecSet_OWP == 0x2){
    write(">>> [PASS] BLTN_CAM_RecSet_OWP = 0x2 (ON) <<<");
    testStepPass("Step5", "BLTN_CAM_RecSet_OWP = 0x2 (ON) - PASS");
    step5_passed = 1;
  }
  else {
    write(">>> [FAIL] BLTN_CAM_RecSet_OWP = 0x%X, expected 0x0 (Default) or 0x2 (ON) <<<", $BLTN_CAM_RecSet_OWP);
    testStepFail("Step5", "BLTN_CAM_RecSet_OWP = 0x%X - FAIL", $BLTN_CAM_RecSet_OWP);
    step5_passed = 0;
  }

  CaptureGraphics("BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_HU_UI_Mode");

  write("=== FINISH STEP 5 ===");
}

testcase OWP_002_6(){
  //============================================================================
  // STEP 6: Turn ON [Recording while Parking], Exit BLTN_CAM,
  //         Set P-LBM SoC = 0xFF, Check BLTN_CAM_Prk_Oprable_Time = 0x00
  //============================================================================
  write("");
  write("=== STEP 6: OWP ON, Exit BLTN_CAM, Set SoC=0xFF, Check Prk_Oprable_Time ===");
  testStep("Step6", "Start test OWP_002_6");

  // Ensure OWP is ON
  write("  Current BLTN_CAM_RecSet_OWP = 0x%X", $BLTN_CAM_RecSet_OWP);
  if ($BLTN_CAM_RecSet_OWP == 0x1){
    write("OWP is OFF, toggling to ON...");
    @panel::LED_Ctrl_SetOWP = 1;
    testWaitForTimeout(3000);
  }

  // Confirm OWP is ON
  if ($BLTN_CAM_RecSet_OWP == 0x2){
    write(">>> [OK] OWP is ON (0x2) <<<");
  }
  else {
    write(">>> [WARNING] OWP = 0x%X, trying again... <<<", $BLTN_CAM_RecSet_OWP);
    // Re-enter and try again
    Exit_BLTN_CAM();
    testWaitForTimeout(2000);
    Enter_BLTN_CAM();
    testWaitForTimeout(3000);
    @panel::LED_Ctrl_SetOWP = 1;
    testWaitForTimeout(3000);
  }

  // Exit BLTN_CAM
  Exit_BLTN_CAM();
  testWaitForTimeout(3000);

  // Set P-LBM SoC: 0xFF
  write("Setting ICU_BS2SoC = 0xFF (P-LBM SoC)...");
  setSignal(ICU_BS2SoC, 0xFF);
  testWaitForTimeout(5000);

  // Check BLTN_CAM_Prk_Oprable_Time = 0x00
  write("BLTN_CAM_Prk_Oprable_Time = 0x%X", $BLTN_CAM_Prk_Oprable_Time);

  if ($BLTN_CAM_Prk_Oprable_Time == 0x00){
    write(">>> [PASS] BLTN_CAM_Prk_Oprable_Time = 0x00 <<<");
    testStepPass("Step6", "BLTN_CAM_Prk_Oprable_Time = 0x00 - PASS");
    step6_passed = 1;
  }
  else {
    write(">>> [FAIL] BLTN_CAM_Prk_Oprable_Time = 0x%X, expected 0x00 <<<", $BLTN_CAM_Prk_Oprable_Time);
    testStepFail("Step6", "BLTN_CAM_Prk_Oprable_Time = 0x%X, expected 0x00 - FAIL", $BLTN_CAM_Prk_Oprable_Time);
    step6_passed = 0;
  }

  CaptureGraphics("BLTN_CAM_RecSet_OWP;BLTN_CAM_Prk_Oprable_Time;ICU_BS2SoC;BLTN_CAM_RecSta_OWP");

  write("=== FINISH STEP 6 ===");
}

testcase OWP_002_7(){
  //============================================================================
  // STEP 7: Check [Recording while Parking] = ON, KEY OFF, wait 3 min, KEY ON
  //         Log: check actual video (no screenshot needed)
  //============================================================================
  write("");
  write("=== STEP 7: OWP ON, KEY OFF, wait 3 min, KEY ON ===");
  testStep("Step7", "Start test OWP_002_7");

  // Confirm OWP is enabled by checking RecSet_OWP
  write("  BLTN_CAM_RecSet_OWP = 0x%X", $BLTN_CAM_RecSet_OWP);

  if ($BLTN_CAM_RecSet_OWP == 0x2 || $BLTN_CAM_RecSet_OWP == 0x0){
    write(">>> [OK] [Recording while Parking] - Continuous recording enabled (ON) <<<");
  }
  else {
    write(">>> [WARNING] OWP not confirmed ON: RecSet_OWP = 0x%X <<<", $BLTN_CAM_RecSet_OWP);
  }

  // KEY OFF
  write("KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // Wait 3 minutes (180 seconds)
  write("Waiting 3 minutes (180 seconds) for OWP recording...");
  write("=== COUNT DOWN === Total: 3 min");
  {
    int remaining;
    remaining = 180;
    while (remaining > 0){
      if (remaining % 30 == 0){
        write("Remaining: %d min %02d sec (%d sec left)", remaining/60, remaining%60, remaining);
      }
      testWaitForTimeout(1000);
      remaining--;
    }
  }
  write("=== COUNT DOWN COMPLETE ===");

  // KEY ON
  write("KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // Log: no screenshot needed, check actual video
  write("*************************************************************");
  write("*** [MANUAL CHECK] Please check the actual recorded video ***");
  write("*** Confirm that OWP recording was active during the      ***");
  write("*** 3-minute KEY OFF parking period.                      ***");
  write("*** No screenshot is needed for this step.                ***");
  write("*************************************************************");

  testStepPass("Step7", "OWP recording during parking - manual video check required");
  step7_passed = 1;

  write("=== FINISH STEP 7 ===");
}

testcase OWP_002_8(){
  //============================================================================
  // STEP 8: Quickly press ACC&IGN ON/OFF 20 times, then turn OFF
  //         Wait a few seconds, Check BLTN_CAM_RecSta_OWP = ON
  //============================================================================
  write("");
  write("=== STEP 8: Quickly press ACC&IGN ON/OFF 20 times ===");
  testStep("Step8", "Start test OWP_002_8");

  // Ensure we start from a known state
  write("Starting rapid ACC&IGN ON/OFF cycle (20 times)...");

  {
    int cycle;
    for (cycle = 1; cycle <= 20; cycle++){
      // KEY ON (ACC&IGN)
      KEY_ON();
      testWaitForTimeout(500);

      // KEY OFF
      KEY_OFF();
      testWaitForTimeout(500);

      if (cycle % 5 == 0){
        write("  Cycle %d/20 completed", cycle);
      }
    }
  }

  // Final state: OFF
  write("Final KEY OFF after 20 cycles...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // Check BLTN_CAM_RecSta_OWP = ON (0x1)
  write("BLTN_CAM_RecSta_OWP = 0x%X", $BLTN_CAM_RecSta_OWP);

  if ($BLTN_CAM_RecSta_OWP == 0x1){
    write(">>> [PASS] BLTN_CAM_RecSta_OWP = 0x1 (ON) <<<");
    testStepPass("Step8", "BLTN_CAM_RecSta_OWP = 0x1 (ON) after rapid ON/OFF - PASS");
    step8_passed = 1;
  }
  else {
    write(">>> [INFO] BLTN_CAM_RecSta_OWP = 0x%X, waiting for signal change (max 30s)...", $BLTN_CAM_RecSta_OWP);

    // Wait for OWP recording to start (polling every 1s, max 30s)
    if (WaitFor_RecSta_OWP_ON(30) == 1){
      write(">>> [PASS] BLTN_CAM_RecSta_OWP = 0x1 (ON) <<<");
      testStepPass("Step8", "BLTN_CAM_RecSta_OWP = 0x1 (ON) after wait - PASS");
      step8_passed = 1;
    }
    else {
      write(">>> [FAIL] Timeout waiting for BLTN_CAM_RecSta_OWP = 0x1 <<<");
      write(">>> BLTN_CAM_RecSta_OWP = 0x%X <<<", $BLTN_CAM_RecSta_OWP);
      testStepFail("Step8", "BLTN_CAM_RecSta_OWP did not change to ON - FAIL");
      step8_passed = 0;
    }
  }

  CaptureGraphics("BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSet_OWP;BLTN_CAM_HU_UI_Mode");

  write("=== FINISH STEP 8 ===");
}

