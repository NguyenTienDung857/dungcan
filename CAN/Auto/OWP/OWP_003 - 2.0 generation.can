testcase OWP_003_6(){
  //============================================================================
  // STEP 6: OWP ON, set 20h with custom time (23:40), wait 1h, capture screenshot, OWP OFF
  //============================================================================
  write("");
  write("=== STEP 6: OWP ON -> set 20h with custom time -> wait 1h -> capture screenshot ===");
  testStep("Step6","Start test OWP_003_6");

  @panel::Switch_CGWNM = 1;

  write("Run KEY_ON()"); KEY_ON();
  testWaitForTimeout(3000);

  write("Run Enter_BLTN_CAM()"); Enter_BLTN_CAM();
  testWaitForTimeout(3000);

  BLTN_CAM_Settings(1); write("Run BLTN_CAM_Settings(1)");
  testWaitForTimeout(1000);

  @panel::Switch_Clock = 1;
  testWaitForTimeout(1000);
  write("Run Check_time()"); Check_time();
  @panel::Switch_Clock = 0;

  write("Run Set_Time()"); Set_Time(time_Hour_value, time_Minute_value, time_Second_value, check_DisplayDay_value, check_DisplayMonth_value, check_DisplayYear1_value, check_DisplayYear2_value);

  write("Run Exit_BLTN_CAM()"); Exit_BLTN_CAM();
  testWaitForTimeout(3000);

  write("Run KEY_OFF()"); KEY_OFF();

  write(">>> [Step6] KEY_OFF done. Time manually set to %02X:%02X:00",
        time_Hour_value, time_Minute_value);
  write(">>> [Step6] Waiting for BLTN_CAM_RecSta_OWP to change (OWP auto-start, max 100s)...");
  write(">>> [Step6] No action required - OWP should start automatically.");

  if (WaitFor_RecSta_OWP_ON(100) == 1){
    write(">>> [OK] BLTN_CAM_RecSta_OWP = 0x1 - OWP recording is in progress!");
    write(">>> [Step6] Starting 1h countdown...");

    Clock_Down(60); //1h
  }
  else {
    write(">>> [FAIL] OWP recording has NOT started within 100s.");
    write(">>> [FAIL] BLTN_CAM_RecSta_OWP = 0x%X (expected 0x1)", $BLTN_CAM_RecSta_OWP);
    write("Error: OWP recording hasn't started. Stop test !!!");

    write("Run Setup_End_test()"); Setup_End_test();

    write("Run KEY_OFF()"); KEY_OFF();

    step6_passed = 0;
    testStepFail("Step6","OWP recording hasn't started - FAIL");
    write("=== FINISH OWP_003_6 ===");
    stop();
  }

  write("Run Setup_End_test()"); Setup_End_test();

  @panel::Switch_CGWNM = 0;

  write("Run KEY_OFF()"); KEY_OFF();

  step6_passed = 1;
  testStepPass("Step6","OWP custom time recording test - PASS");
  write("=== FINISH OWP_003_6 ===");
}

testcase OWP_003_Summary(){
  //============================================================================
  // Overall Test Verdict
  //============================================================================
  if(step1_2_passed == 1 && step3_passed == 1 && step4_passed == 1 && step5_passed == 1 && step6_passed == 1)
  {
    testStepPass("Overall_Verdict", "Test OWP_003 - 2.0: PASS");
    write("=== OVERALL VERDICT: PASS ===");
  }
  else
  {
    testStepFail("Overall_Verdict", "Test OWP_003 - 2.0: FAIL");
    write("=== OVERALL VERDICT: FAIL ===");
  }

  //============================================================================
  // SUMMARY
  //============================================================================
  write("");
  write("=== TEST SUMMARY ===");

  if(step1_2_passed == 1)
    write("Step 1_2: OWP ON, set 20h, wait 20h, capture screenshot [Screenshot] => PASS");
  else
    write("Step 1_2: OWP ON, set 20h, wait 20h, capture screenshot [Screenshot] => FAIL");

  if(step3_passed == 1)
    write("Step 3: OWP ON, set 12h, wait 12h, capture screenshot [Screenshot] => PASS");
  else
    write("Step 3: OWP ON, set 12h, wait 12h, capture screenshot [Screenshot] => FAIL");

  if(step4_passed == 1)
    write("Step 4: OWP ON, set 6h, wait 6h, capture screenshot [Screenshot] => PASS");
  else
    write("Step 4: OWP ON, set 6h, wait 6h, capture screenshot [Screenshot] => FAIL");

  if(step5_passed == 1)
    write("Step 5: OWP ON, set 2h, wait 2h, capture screenshot [Screenshot] => PASS");
  else
    write("Step 5: OWP ON, set 2h, wait 2h, capture screenshot [Screenshot] => FAIL");

  if(step6_passed == 1)
    write("Step 6: OWP ON, set 20h with custom time, wait 1h, capture screenshot [Screenshot] => PASS");
  else
    write("Step 6: OWP ON, set 20h with custom time, wait 1h, capture screenshot [Screenshot] => FAIL");

  testStep("Notifications","Finish OWP_003 - 2.0");
  write("=== FINISH OWP_003 - 2.0 ===");
}

void MainTest(){
  testReportFileName("TestReports\\OWP_003 - 2.0 generation_report");
  OWP_003_Init();

   OWP_003_1_2();

   OWP_003_3();

   OWP_003_4();

   OWP_003_5();

   OWP_003_6();

  OWP_003_Summary();
}
