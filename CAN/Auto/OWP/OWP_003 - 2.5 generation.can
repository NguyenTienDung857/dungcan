testcase OWP_003_6(){
  testStep("Notification","Start test OWP_003_6");
  write("=== START OWP_003_6 ===");

  @panel::Switch_CGWNM = 1;
  
  write("Run KEY_ON()"); KEY_ON(); 
  testWaitForTimeout(3000);

  write("Run Enter_BLTN_CAM()"); Enter_BLTN_CAM(); 
  testWaitForTimeout(3000);
  
  BLTN_CAM_Settings(1); write("Run BLTN_CAM_Settings(1)");
  testWaitForTimeout(1000);
 
  @panel::Switch_Clock = 1;
  testWaitForTimeout(1000);
  write("Run Check_time()"); Check_time(); 
  @panel::Switch_Clock = 0;
  
  write("Run Set_Time()"); Set_Time(time_Hour_value, time_Minute_value, time_Second_value, check_DisplayDay_value, check_DisplayMonth_value, check_DisplayYear1_value, check_DisplayYear2_value); 
  
  write("Run Exit_BLTN_CAM()"); Exit_BLTN_CAM(); 
  testWaitForTimeout(3000);
  
  write("Run KEY_OFF()"); KEY_OFF(); 
  
  if (testWaitForSignalChange(BLTN_CAM_RecSta_OWP,100000) == 1){
    write("OWP recording is in progress...");
    
    Clock_Down(60); //1h  
  }
  else {
    write("Error: OWP recording hasn't started. Stop test !!!");
    
    write("Run Setup_End_test()"); Setup_End_test(); 
    
    write("KEY_OFF()"); KEY_OFF(); 
  
    write(" stop()"); stop(); 
  }  

  write("Run Setup_End_test()"); Setup_End_test(); 
  
  @panel::Switch_CGWNM = 0;
  
  write("KEY_OFF()"); KEY_OFF(); 
  
  testStep("Notifications","Finish OWP_003_6");
  write("=== FINISH OWP_003_6 ===");     
}

void MainTest(){
 write("Run Init()"); Init();
  
  write("Run Turn_OFF_RecSet()");Turn_OFF_RecSet();
  TestWaitForValueInput("Please enter the test ID (1/2/3/4/5/6)", 300000);
  switch (TestGetValueInput()){
   case(1) :
  OWP_003_1_2(); /* break;*/
   case(2) :
 OWP_003_3(); /* break;*/   
   case(3) :
  OWP_003_4(); break;        
  case(4) :
   OWP_003_5(); break; 
  case(5) :
  OWP_003_1_2();
  OWP_003_6(); break;
 case(6) :
   
   OWP_003_1_2();
     
   OWP_003_3();  

   OWP_003_4(); 
     
   OWP_003_5();
     
  OWP_003_6();  

   break;
   case(7) :
  OWP_003_4(); 
     
   OWP_003_5();
     
   OWP_003_6();  

   break;
  }
}