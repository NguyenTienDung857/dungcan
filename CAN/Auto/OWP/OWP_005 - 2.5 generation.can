testcase OWP_005_20()
{
  int i;
  int fr_ok;
  int rr_ok;
  int all_ok;

  Send_Value_To_COM(20520);
  SetTestStep("Buoc 20 - OWP_005");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 20: KEY ON, Change display angle Front/Rear -5 to +5  ===");
  write("=================================================================");
  testStep("Step20", "KEY ON -> Set FR/RR camera vertical position 1~11, mapped to -5~+5");

  write("[20.1] KEY ON");
  KEY_ON();
  testWaitForTimeout(5000);

  all_ok = 1;
  for (i = 1; i <= 11; i++)
  {
    write("[20.%d] Set_FR_Cam_VerPos(%d), display angle %d", i + 1, i, i - 6);
    fr_ok = Set_FR_Cam_VerPos(i);
    testWaitForTimeout(1000);

    write("[20.%d] Set_RR_Cam_VerPos(%d), display angle %d", i + 1, i, i - 6);
    rr_ok = Set_RR_Cam_VerPos(i);
    testWaitForTimeout(1000);

    if (fr_ok != 1 || rr_ok != 1)
      all_ok = 0;
  }

  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWP", "BLTN_CAM_Set_FR_Ver_Pos;BLTN_CAM_Set_RR_Ver_Pos;BLTN_CAM_HU_UI_Mode;BLTN_CAM_State");

  if (all_ok == 1)
  {
    step20_passed = 1;
    testStepPass("Step20", "Step 20 PASS: FR/RR display angle sweep completed");
  }
  else
  {
    Log_Error_Details();
    testStepFail("Step20", "Step 20 FAIL: one or more FR/RR display angle settings failed");
  }

  write("=== FINISH STEP 20 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

