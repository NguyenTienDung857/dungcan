  write("=== STEP 14: PMD, PEV, rear/front staged detach/attach         ===");
  write("=================================================================");
  testStep("Step14", "KEY ON -> KEY OFF -> PMD -> PEV -> detach rear/front -> attach rear/front");

  write("[14.1] KEY ON");
  KEY_ON();
  testWaitForTimeout(5000);

  write("[14.2] KEY OFF");
  KEY_OFF();
  testWaitForTimeout(5000);

  write("[14.3] WaitFor_RecSta_PMD_Recording max 6 minutes");
  pmd_ok = WaitFor_RecSta_PMD_Recording(360000);

  write("[14.4] Wait 5 seconds");
  testWaitForTimeout(5000);

  write("[14.5] WaitFor_RecSta_PEV_Recording max 6 minutes");
  pev_ok = WaitFor_RecSta_PEV_Recording(360);

  write("[14.6] Wait 30 seconds");
  testWaitForTimeout(30000);

  write("[14.7] Set_Detach_Rear");
  Set_Detach_Rear();

  write("[14.8] Wait 3 seconds");
  testWaitForTimeout(3000);

  write("[14.9] Set_Detach_Font");
  Set_Detach_Font();

  write("[14.10] Wait 20 seconds");
  testWaitForTimeout(20000);

  write("[14.11] Set_Attach_Rear");
  Set_Attach_Rear();

  write("[14.12] Wait 3 seconds");
  testWaitForTimeout(3000);

  write("[14.13] Set_Attach_Font");
  Set_Attach_Font();

  write("[14.14] Wait 30 seconds");
  testWaitForTimeout(30000);

  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_State");

  if (pmd_ok == 1 && pev_ok == 1)
  {
    step14_passed = 1;
    testStepPass("Step14", "Step 14 PASS: PMD and PEV recording detected");
  }
  else
  {
    snprintf(failReason, elcount(failReason),
             "Step 14 FAIL: pmd_ok=%d, pev_ok=%d, PMD=0x%X, PEV=0x%X.",
             pmd_ok, pev_ok, Gen20_PMD_RecSta_Value(), $BLTN_CAM_RecSta_PEV);
    Log_Error_Details();
    testStepFail("Step14", failReason);
  }

  write("=== FINISH STEP 14 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

