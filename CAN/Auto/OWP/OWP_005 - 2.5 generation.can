/*@!Encoding:65001*/

includes
{
  #include "../DeclarationFunction_Gen2.5.h"
}

/*
  Test Case: OWP_005 - 2.5 generation
  Title: OWP/PMD camera disconnect/reconnect and PEV/parking motion checks

  Step details:
    - Step 1: KEY OFF/ON, SMK IGN, USM/Rec reset, KEY OFF, wait OWP Recording,
      detach/attach front camera, trigger PEV, wait PEV Recording, then capture.
    - Step 2: KEY ON/OFF, wait OWP Recording, detach/attach rear camera,
      trigger PEV, wait PEV Recording, then capture.
    - Step 3: KEY ON/OFF, wait OWP Recording, detach rear and front cameras,
      attach rear and front cameras, trigger PEV, wait PEV Recording, capture.
    - Step 4: KEY ON/OFF, wait OWP Recording, detach front camera for 3s,
      attach front camera, then capture.
    - Step 6: KEY ON/OFF, wait OWP Recording, wait network sleep, detach front
      and rear cameras, KEY ON, wait OWD Recording, then capture.
    - Step 8: Sweep FR/RR camera vertical positions 1 to 11, then capture.
    - Step 10: KEY ON/OFF, wait OWP Recording, detach/attach front camera,
      trigger PEV, wait PEV Recording, then capture.
    - Step 12: KEY ON, Turn_ON_PMD, wait PMD Recording, wait PEV Recording,
      detach/attach front camera, then capture.
    - Step 13: KEY ON/OFF, wait PMD Recording, wait PEV Recording,
      detach/attach rear camera, then capture.
    - Step 14: KEY ON/OFF, wait PMD Recording, wait PEV Recording,
      detach rear/front and attach rear/front cameras, then capture.
    - Step 15: KEY ON/OFF, wait PMD Recording, detach front camera, wait 10s,
      then capture.
    - Step 16: KEY ON/OFF, wait PMD Recording, attach front camera, wait 10s,
      then capture.
    - Step 17: KEY ON/OFF, wait PMD Recording, detach rear camera, wait 10s,
      attach rear camera, then capture.
    - Step 20: KEY ON, sweep FR/RR camera vertical positions 1 to 11, capture.
    - Step 21: KEY ON/OFF, wait PMD Recording, detach/attach front camera,
      wait PEV Recording, then capture.
    - Step 23: KEY ON, wait OWD Recording, detach front/rear, KEY OFF, wait
      PMD OFF with shared header helper within 60s, then capture.
    - Step 24: KEY ON/OFF, wait PMD Recording, detach front, wait network sleep,
      wait PMD Recording again, attach front, then capture.
    - Step 25: KEY ON/OFF, wait PMD Recording, detach rear, wait network sleep,
      wait PMD Recording again, attach rear, then capture.

  NOTE:
    - The requested actions are written sequentially in each testcase.
    - Recording signal waits use 6 minutes maximum.
    - PMD Recording waits use WaitFor_RecSta_PMD_Recording() from the shared
      header. That helper intentionally triggers PEV first, then waits and
      checks PMD Recording internally.
    - PMD OFF waits use WaitFor_RecSta_PMD_OFF() from the shared header.
    - This file intentionally avoids raw CAPL signal-range wait calls.
    - Network sleep waits use 6 minutes maximum.
    - Extra 2-5s delay is kept after key/camera/event actions for signal delay.
*/

variables
{
  char failReason[512];

  int step1_passed = 0;
  int step2_passed = 0;
  int step3_passed = 0;
  int step4_passed = 0;
  int step6_passed = 0;
  int step8_passed = 0;
  int step10_passed = 0;
  int step12_passed = 0;
  int step13_passed = 0;
  int step14_passed = 0;
  int step15_passed = 0;
  int step16_passed = 0;
  int step17_passed = 0;
  int step20_passed = 0;
  int step21_passed = 0;
  int step23_passed = 0;
  int step24_passed = 0;
  int step25_passed = 0;

  message HU_BLTN_CAM_PE_00_200ms _HU_BLTN_CAM_PE_00_200ms;
  message HU_BLTN_CAM_E_01 _HU_BLTN_CAM_E_01;
  message HU_CLOCK_PE_02 _HU_CLOCK_PE_02;
}

testcase OWP_005_Init()
{
  Send_Value_To_COM(20500);
  write("========================================");
  write("=== START TEST OWP_005 - 2.5 ===");
  write("========================================");
  testStep("Notification", "Start test OWP_005 - 2.5");
  Send_Value_To_COM(44);
}

testcase OWP_005_1()
{
  int owp_ok;
  int pev_ok;

  Send_Value_To_COM(20501);
  SetTestStep("Buoc 1 - OWP_005");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 1: Setup, front camera disconnect, PEV trigger        ===");
  write("=================================================================");
  testStep("Step1", "KEY OFF -> KEY ON -> SMK IGN -> USM/Rec reset -> KEY OFF -> OWP -> detach/attach front -> PEV");

  write("[1.1] KEY OFF");
  KEY_OFF();
  testWaitForTimeout(3000);

  write("[1.2] KEY ON");
  KEY_ON();
  testWaitForTimeout(5000);

  write("[1.3] Set_SMK_IGN");
  Set_SMK_IGN();
  testWaitForTimeout(3000);

  write("[1.4] Click_USM_Reset");
  Click_USM_Reset();
  testWaitForTimeout(3000);

  write("[1.5] Click_Rec_Reset");
  Click_Rec_Reset();
  testWaitForTimeout(5000);

  write("[1.6] KEY OFF");
  KEY_OFF();
  testWaitForTimeout(5000);

  write("[1.7] WaitFor_RecSta_OWP_Recording max 6 minutes");
  owp_ok = WaitFor_RecSta_OWP_Recording(360000);

  write("[1.8] Wait 30 seconds");
  testWaitForTimeout(30000);

  write("[1.9] Set_Detach_Font");
  Set_Detach_Font();

  write("[1.10] Wait 20 seconds");
  testWaitForTimeout(20000);

  write("[1.11] Set_Attach_Font");
  Set_Attach_Font();

  write("[1.12] Wait 5 seconds");
  testWaitForTimeout(5000);

  write("[1.13] Click_Evt_Switch");
  Click_Evt_Switch();
  testWaitForTimeout(3000);

  write("[1.14] WaitFor_RecSta_PEV_Recording max 6 minutes");
  pev_ok = WaitFor_RecSta_PEV_Recording(360);

  write("[1.15] Wait 30 seconds");
  testWaitForTimeout(30000);

  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_RecSta_PMD;BLTN_CAM_State");

  if (owp_ok == 1 && pev_ok == 1)
  {
    step1_passed = 1;
    testStepPass("Step1", "Step 1 PASS: OWP and PEV recording detected");
  }
  else
  {
    snprintf(failReason, elcount(failReason),
             "Step 1 FAIL: owp_ok=%d, pev_ok=%d, OWP=0x%X, PEV=0x%X.",
             owp_ok, pev_ok, $BLTN_CAM_RecSta_OWP, $BLTN_CAM_RecSta_PEV);
    Log_Error_Details();
    testStepFail("Step1", failReason);
  }

  write("=== FINISH STEP 1 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

