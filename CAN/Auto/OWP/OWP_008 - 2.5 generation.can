  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 10: KEY ON, wait 5s, KEY OFF, SET_NM_OFF, wait 20s,
//          KEY ON, KEY OFF, Check PMD Recording + PEV_Count=0x0 in 30s,
//          SET_NM_ON
// ============================================================================
testcase OWP_008_10()
{
  int pmd_result;
  int pev_count;
  Send_Value_To_COM(20810);
  SetTestStep("Bước 10 - OWP_008");
  StartTestTimer();

  write("");
  write("=== STEP 10: KEY ON/OFF, NM OFF, wait 20s, KEY ON/OFF, Check PMD+PEV_Count, NM ON ===");
  testStep("Step10", "KEY ON/OFF, disable NM (20s), KEY ON->KEY OFF rapid, check BLTN_CAM_RecSta_PMD=ON & BLTN_CAM_PEV_Count = 0x0 within 30s, re-enable NM");

  // 10.1: KEY ON
  write("Step 10.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // 10.2: KEY OFF
  write("Step 10.2: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(2000);

  // 10.3: SET_NM_OFF
  write("Step 10.3: SET_NM_OFF...");
  SET_NM_OFF();
  testWaitForTimeout(20000);

  // 10.4: KEY ON then KEY OFF immediately
  write("Step 10.4: KEY ON...");
  KEY_ON();
  testWaitForTimeout(500);
  write("Step 10.4: KEY OFF immediately...");
  KEY_OFF();

  // 10.5: Check PMD Recording within 30s
  write("Step 10.5: Checking PMD Recording (max 30s)...");
  pmd_result = WaitFor_RecSta_PMD_Recording(30000);

  // 10.6: Check BLTN_CAM_PEV_Count = 0x0
  pev_count = $BLTN_CAM_PEV_Count;
  write("Step 10.6: BLTN_CAM_PEV_Count = 0x%X", pev_count);

  if (pmd_result == 1 && pev_count == 0x0)
  {
    write(">>> [PASS] PMD Recording = ON, PEV_Count = 0x0 <<<");
    step10_passed = 1;
    testStepPass("Step10", "PMD Recording ON, PEV_Count = 0x0 - PASS");
  }
  else
  {
    if (pmd_result != 1) write("  -> PMD is NOT recording");
    if (pev_count != 0x0) write("  -> PEV_Count = 0x%X, expected 0x0", pev_count);
    write(">>> [FAIL] PMD Recording or PEV_Count check failed <<<");
    step10_passed = 0;
    Log_Error_Details();
    testStepFail("Step10", "PMD=%d, PEV_Count=0x%X - FAIL", pmd_result, pev_count);
  }

  // 10.7: SET_NM_ON
  write("Step 10.7: SET_NM_ON...");
  SET_NM_ON();

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  write("=== FINISH STEP 10 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 11: KEY ON, KEY OFF, WaitFor_RecSta_PMD_Recording, log trigger event
//          immediately (special - no reusable function), Check PEV Recording
//          in 10s
// ============================================================================
testcase OWP_008_11()
{
  int pev_result;
  Send_Value_To_COM(20811);
  SetTestStep("Bước 11 - OWP_008");
  StartTestTimer();

  write("");
  write("=== STEP 11: KEY ON, KEY OFF, Wait PMD, Manual trigger, Check PEV in 10s ===");
  testStep("Step11", "KEY ON + KEY OFF, wait OWP/PMD recording (120s), trigger PEV event (manual) -> check BLTN_CAM_RecSta_PEV = 0x1 within 10s");

  // 11.1: KEY ON
  write("Step 11.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // 11.2: KEY OFF
  write("Step 11.2: KEY OFF...");
  KEY_OFF();


  // 11.3: Wait for PMD Recording (max 120s)
  write("Step 11.3: Waiting for PMD Recording (max 120s)...");
  if (WaitFor_RecSta_OWP_Recording(120000) != 1)
  {
    write(">>> [FAIL] PMD did not start within 120s. Aborting Step 11.");
    CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PMD;BLTN_CAM_State");
    Log_Error_Details();
    testStepFail("Step11", "BLTN_CAM_RecSta_PMD did not turn ON within 120s");
    step11_passed = 0;
    return;
  }
  write(">>> [OK] PMD Recording started <<<");

  // 11.4: Log trigger event immediately (special case - NOT using WaitFor_RecSta_PEV_Recording)
 WaitFor_RecSta_PEV_Recording(60);

  // 11.5: Check PEV Recording in 10s
  write("Step 11.5: Checking PEV Recording (max 10s)...");
  pev_result = WaitFor_RecSta_PEV_Recording(60);

  if (pev_result == 1)
  {
    write(">>> [PASS] PEV Recording detected within 10s <<<");
    step11_passed = 1;
    testStepPass("Step11", "PMD ON, manual trigger, PEV Recording in 10s - PASS");
  }
  else
  {
    write(">>> [FAIL] PEV Recording NOT detected within 10s <<<");
    step11_passed = 0;
    Log_Error_Details();
    testStepFail("Step11", "PEV Recording not detected within 10s - FAIL");
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  write("=== FINISH STEP 11 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 12: KEY ON/OFF rapid 20 times, KEY OFF,
//          Check_RecSta_OWP_Recording, Check BLTN_CAM_PEV_Count = 0x0
// ============================================================================
testcase OWP_008_12()
{
  int owp_result;
  int pev_count;
  Send_Value_To_COM(20812);
  SetTestStep("Bước 12 - OWP_008");
  StartTestTimer();

  write("");
  write("=== STEP 12: Rapid KEY ON/OFF x20, Check OWP Recording, Check PEV_Count = 0 ===");
  testStep("Step12", "Rapid KEY ON/OFF x20 cycles, KEY OFF -> check BLTN_CAM_RecSta_OWP = ON (recording) & BLTN_CAM_PEV_Count = 0x0, capture screenshot");

  // 12.1: Rapid KEY ON/OFF 20 times
  write("Step 12.1: Starting rapid KEY ON/OFF cycle (20 times)...");
  {
    int cycle;
    for (cycle = 1; cycle <= 20; cycle++)
    {
      KEY_ON();
      testWaitForTimeout(500);

      KEY_OFF();
      testWaitForTimeout(500);

      if (cycle % 5 == 0)
      {
        write("  Cycle %d/20 completed", cycle);
      }
    }
  }

  // 12.2: Final KEY OFF
  write("Step 12.2: Final KEY OFF after 20 cycles...");
  KEY_OFF();
  testWaitForTimeout(10000);

  // 12.3: Check OWP Recording
  write("Step 12.3: Checking BLTN_CAM_RecSta_OWP (OWP Recording)...");
  owp_result = Check_RecSta_OWP_Recording();

  // 12.4: Check BLTN_CAM_PEV_Count = 0x0
  write("Step 12.4: Checking BLTN_CAM_PEV_Count...");
  pev_count = $BLTN_CAM_PEV_Count;
  write("  BLTN_CAM_PEV_Count = 0x%X (%d)", pev_count, pev_count);

  if (owp_result == 1 && pev_count == 0x0)
  {
    write(">>> [PASS] OWP Recording = ON, PEV_Count = 0x0 <<<");
    step12_passed = 1;
    testStepPass("Step12", "OWP Recording ON, PEV_Count = 0x0 - PASS");
  }
  else
  {
    if (owp_result != 1) write("  -> OWP is NOT recording");
    if (pev_count != 0x0) write("  -> PEV_Count = 0x%X, expected 0x0", pev_count);
    write(">>> [FAIL] OWP Recording or PEV_Count check failed <<<");
    step12_passed = 0;
    Log_Error_Details();
    testStepFail("Step12", "OWP=%d, PEV_Count=0x%X - FAIL", owp_result, pev_count);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  write("=== FINISH STEP 12 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 13: KEY ON, KEY OFF, WaitFor_RecSta_OWP_Recording,
//          WaitFor_RecSta_PEV_Recording, wait 5s, log check actual video
// ============================================================================
testcase OWP_008_13()
{
  int pev_result;
  Send_Value_To_COM(20813);
  SetTestStep("Bước 13 - OWP_008");
  StartTestTimer();

  write("");
  write("=== STEP 13: KEY ON, KEY OFF, Wait OWP, PEV trigger, Wait 5s, Check video ===");
  testStep("Step13", "KEY ON + KEY OFF, wait OWP recording (120s), trigger PEV event immediately -> check BLTN_CAM_RecSta_PEV, wait 5s, manual check actual video");

  // 13.1: KEY ON
  write("Step 13.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // 13.2: KEY OFF
  write("Step 13.2: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 13.3: Wait for OWP Recording (max 120s)
  write("Step 13.3: Waiting for BLTN_CAM_RecSta_OWP = ON (max 120s)...");
  if (WaitFor_RecSta_OWP_Recording(120000) != 1)
  {
    write(">>> [FAIL] OWP did not start within 120s. Aborting Step 13.");
    CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_State");
    Log_Error_Details();
    testStepFail("Step13", "BLTN_CAM_RecSta_OWP did not turn ON within 120s");
    step13_passed = 0;
    return;
  }
  write(">>> [OK] BLTN_CAM_RecSta_OWP = 0x%X - OWP recording started <<<", $BLTN_CAM_RecSta_OWP);

  // 13.4: WaitFor_RecSta_PEV_Recording (immediately after OWP ON)
  write("Step 13.4: Triggering PEV event immediately...");
  pev_result = WaitFor_RecSta_PEV_Recording(60);

  if (pev_result == 1)
  {
    write(">>> [OK] PEV recording detected <<<");
  }
  else
  {
    write(">>> [WARNING] PEV recording not detected within timeout <<<");
  }

  // 13.5: Wait 5 seconds
  write("Step 13.5: Waiting 5 seconds...");
  testWaitForTimeout(5000);

  // 13.6: Log check actual video
  write("");
  write("*************************************************************");
  write("*** [CHECK] Hay check VIDEO THUC TE tren thiet bi!        ***");
  write("*** Kiem tra video da ghi nhan su kien PEV.                ***");
  write("*** (Step 13)                                              ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  step13_passed = 1;
  testStepPass("Step13", "OWP ON, PEV triggered, actual video check - PASS");
  write("=== FINISH STEP 13 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

