/*@!Encoding:65001*/
includes
{
  #include "../DeclarationFunction_Gen2.5.h"
}

//Preconditions: - ACC and IGN and ccNC/ccIC switch OFF, AVN mode
//               - Add signal: BLTN_CAM_RecSta_OWP, BLTN_CAM_RecSet_OWP,
//                             BLTN_CAM_RecSet_PEV, BLTN_CAM_RecSta_PEV,
//                             BLTN_CAM_PEV_Count, BLTN_CAM_State

/*
  Test Case: OWP_008 - 2.5 (OWP_008)
  Title: [PEV OFF -> OWP Recording, KEY ON/OFF rapid cycle, PEV Count Reset Check]

  Step 1:  Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, Turn_OFF_PEV, KEY OFF,
           Check BLTN_CAM_RecSet_PEV = 0x1 (OFF), capture screenshot
  Step 2:  Log "lay anh o buoc 1"
  Step 3_4: Log "check anh den LED"
  Step 5:  KEY ON, Click_USM_Reset, KEY OFF,
           WaitFor_RecSta_OWP_Recording, WaitFor_RecSta_PEV_Recording,
           log check video
  Step 6:  KEY ON, KEY OFF, WaitFor_RecSta_PEV_Recording,
           log "B+ bat tat ngay", log check video
  Step 8:  KEY ON, wait 5s, Turn_ON_PMD, KEY OFF, wait 3s,
           WaitFor_RecSta_PEV_Recording, log "B+ bat tat", log check video
  Step 9:  Log "lay anh o buoc 8"
  Step 10: KEY ON, wait 5s, KEY OFF, SET_NM_OFF, wait 20s, KEY ON, KEY OFF,
           Check PMD Recording + PEV_Count=0x0 in 30s, SET_NM_ON
  Step 11: KEY ON, KEY OFF, WaitFor_RecSta_PMD_Recording, log trigger event,
           Check PEV Recording in 10s (special manual trigger)
  Step 12: KEY ON/OFF rapid 20 times, KEY OFF,
           Check_RecSta_OWP_Recording, Check BLTN_CAM_PEV_Count = 0x0
  Step 13: KEY ON, KEY OFF, WaitFor_RecSta_OWP_Recording,
           WaitFor_RecSta_PEV_Recording, wait 5s, log check actual video

  NOTE: Uses 2-5s delay for signal propagation after each state transition.
*/

variables
{
  // Result tracking
  int step1_passed = 0;
  int step2_passed = 0;
  int step3_4_passed = 0;
  int step5_passed = 0;
  int step6_passed = 0;
  int step8_passed = 0;
  int step9_passed = 0;
  int step10_passed = 0;
  int step11_passed = 0;
  int step12_passed = 0;
  int step13_passed = 0;

  // Message Declaration for CAN FD
  message HU_BLTN_CAM_PE_00_200ms _HU_BLTN_CAM_PE_00_200ms;
  message HU_BLTN_CAM_E_01 _HU_BLTN_CAM_E_01;
  message HU_CLOCK_PE_02 _HU_CLOCK_PE_02;
}


// ============================================================================
// Test Cases
// ============================================================================

testcase OWP_008_Init()
{
  Send_Value_To_COM(20800);
  write("========================================");
  write("=== START TEST OWP_008 - 2.5 ===");
  // 1.1: Set_SMK_IGN (full init with CGWNM)
  write("Step 1.1: Set_SMK_IGN (KEY ON with CGWNM)...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);

  // 1.2: Click USM Reset
  write("Step 1.2: USM Reset...");
  Click_USM_Reset();

  // 1.3: Click Rec Reset
  write("Step 1.3: Rec Reset...");
  Click_Rec_Reset();
  write("========================================");
  write("===START TEST===");
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 1: Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, Turn_OFF_PEV,
//         KEY OFF, Check BLTN_CAM_RecSet_PEV = 0x1 (OFF), capture screenshot
// ============================================================================
testcase OWP_008_1()
{
  Send_Value_To_COM(20801);
  SetTestStep("Bước 1 - OWP_008");
  StartTestTimer();
  write("");
  write("=== STEP 1: Set_SMK_IGN, USM/Rec Reset, Turn OFF PEV, KEY OFF, Check RecSet_PEV = OFF ===");
  testStep("Step1", "SMK IGN + USM/Rec Reset + Turn OFF PEV + KEY OFF -> check BLTN_CAM_RecSet_PEV = 0x1 (OFF), capture screenshot");

  

  // 1.4: Turn OFF PEV
  write("Step 1.4: Turn OFF PEV...");
  Turn_OFF_PEV();
  testWaitForTimeout(3000);

  // 1.5: KEY OFF
  write("Step 1.5: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 1.6: Check BLTN_CAM_RecSet_PEV = 0x1 (OFF)
  write("Step 1.6: Checking BLTN_CAM_RecSet_PEV...");
  write("  BLTN_CAM_RecSet_PEV = 0x%X", $BLTN_CAM_RecSet_PEV);

  if ($BLTN_CAM_RecSet_PEV == 0x1)
  {
    write(">>> [PASS] BLTN_CAM_RecSet_PEV = 0x1 (OFF) <<<");
    step1_passed = 1;
    testStepPass("Step1", "BLTN_CAM_RecSet_PEV = 0x1 (OFF) - PASS");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_RecSet_PEV = 0x%X, expected 0x1 (OFF) <<<", $BLTN_CAM_RecSet_PEV);
    step1_passed = 0;
    Log_Error_Details();
    testStepFail("Step1", "BLTN_CAM_RecSet_PEV = 0x%X, expected 0x1 - FAIL", $BLTN_CAM_RecSet_PEV);
  }

  // 1.7: Capture screenshot
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_State");

  write("=== FINISH STEP 1 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 2: Log "lay anh o buoc 1"
// ============================================================================
testcase OWP_008_2()
{
  Send_Value_To_COM(20802);
  SetTestStep("Bước 2 - OWP_008");
  StartTestTimer();
  write("");
  write("=== STEP 2: Lay anh o buoc 1 ===");
  testStep("Step2", "Log notification - use screenshot from Step 1 (BLTN_CAM_RecSet_PEV = 0x1 OFF) as evidence");

  write("");
  write("*************************************************************");
  write("*** [INFO] LAY ANH O BUOC 1!                              ***");
  write("*** Hay su dung anh man hinh da chup o buoc 1              ***");
  write("*** lam bang chung cho buoc nay.                            ***");
  write("*************************************************************");
  write("");

  step2_passed = 1;
  testStepPass("Step2", "Log: lay anh o buoc 1 - PASS");
  write("=== FINISH STEP 2 ===");

  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWP", "BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 3 & 4: Log "check anh den LED"
// ============================================================================
testcase OWP_008_3_4()
{
  Send_Value_To_COM(20803);
  SetTestStep("Bước 3 và 4 - OWP_008");
  StartTestTimer();
  write("");
  write("=== STEP 3 & 4: Check anh den LED ===");
  testStep("Step3_4", "Log notification - manual LED check: LED should NOT blink when PEV is OFF (anh den LED)");

  write("");
  write("*************************************************************");
  write("*** [MANUAL VERIFICATION REQUIRED]                        ***");
  write("*** Hay CHECK ANH DEN LED tren thiet bi!                  ***");
  write("*** Kiem tra den LED co nhap nhay dung khong.             ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_RecSta_OWP;BLTN_CAM_State");

  step3_4_passed = 1;
  testStepPass("Step3_4", "Log: check anh den LED - manual check required");
  write("=== FINISH STEP 3 & 4 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 5: KEY ON, Click_USM_Reset, KEY OFF,
//         WaitFor_RecSta_OWP_Recording, WaitFor_RecSta_PEV_Recording,
//         log check video
// ============================================================================
testcase OWP_008_5()
{
  int pev_result;
  Send_Value_To_COM(20805);
  SetTestStep("Bước 5 - OWP_008");
  StartTestTimer();

  write("");
  write("=== STEP 5: KEY ON, USM Reset, KEY OFF, Wait OWP, PEV trigger, Check video ===");
  testStep("Step5", "KEY ON + USM Reset + KEY OFF, wait OWP recording (120s), trigger PEV event -> check BLTN_CAM_RecSta_PEV = 0x1, capture + manual check video");

  // 5.1: KEY ON
  write("Step 5.1: KEY ON...");
  KEY_ON();

  // 5.3: KEY OFF
  write("Step 5.3: KEY OFF...");
  KEY_OFF();
 

  // 5.4: Wait for OWP Recording (max 120s)
  write("Step 5.4: Waiting for BLTN_CAM_RecSta_OWP = ON (max 120s)...");
  if (WaitFor_RecSta_OWP_Recording(120000) != 1)
  {
    write(">>> [FAIL] OWP did not start within 120s. Aborting Step 5.");
    CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_State");
    Log_Error_Details();
    testStepFail("Step5", "BLTN_CAM_RecSta_OWP did not turn ON within 120s");
    step5_passed = 0;
    return;
  }
  write(">>> [OK] BLTN_CAM_RecSta_OWP = 0x%X - OWP recording started <<<", $BLTN_CAM_RecSta_OWP);
testWaitForTimeout(10000);
  // 5.5: WaitFor_RecSta_PEV_Recording
  write("Step 5.5: Triggering PEV event...");
  pev_result = WaitFor_RecSta_PEV_Recording(60);
testWaitForTimeout(10000);

  if (pev_result == 1)
  {
    write(">>> [PASS] PEV recording detected <<<");
    step5_passed = 1;
    testStepPass("Step5", "OWP ON, PEV triggered and recorded - PASS");
  }
  else
  {
    write(">>> [FAIL] PEV recording not detected <<<");
    step5_passed = 0;
    Log_Error_Details();
    testStepFail("Step5", "PEV not triggered - FAIL");
  }

  // 5.6: Log check video
  write("");
  write("*************************************************************");
  write("*** [CHECK] Hay check VIDEO tren thiet bi! (Step 5)       ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  write("=== FINISH STEP 5 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 6: KEY ON, KEY OFF, WaitFor_RecSta_PEV_Recording,
//         log "B+ bat tat ngay", log check video
// ============================================================================
testcase OWP_008_6()
{
  int pev_result;
  Send_Value_To_COM(20806);
  SetTestStep("Bước 6 - OWP_008");
  StartTestTimer();

  write("");
  write("=== STEP 6: KEY ON, KEY OFF, PEV trigger, B+ toggle, Check video ===");
  testStep("Step6", "KEY ON + KEY OFF, trigger PEV event, notify B+ toggle immediately -> manual check video file");

  // 6.1: KEY ON
  write("Step 6.1: KEY ON...");
  KEY_ON();
 

  // 6.2: KEY OFF
  write("Step 6.2: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 6.3: WaitFor_RecSta_PEV_Recording
  write("Step 6.3: Triggering PEV event...");
  pev_result = WaitFor_RecSta_PEV_Recording(60);

  if (pev_result == 1)
  {
    write(">>> [OK] PEV recording detected <<<");
  }
  else
  {
    write(">>> [WARNING] PEV recording not detected within timeout <<<");
  }
  testWaitForTimeout(4000);

  Set_BPlus_Off();
  testWaitForTimeout(4000);

 
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  step6_passed = 1;
  testStepPass("Step6", "KEY ON/OFF, PEV trigger, B+ toggle notified, Video check - PASS");
  write("=== FINISH STEP 6 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
  Set_BPlus_On();
}

// ============================================================================
// STEP 8: KEY ON, wait 5s, Turn_ON_PMD, KEY OFF, wait 3s,
//         WaitFor_RecSta_PEV_Recording, log B+ bat tat, log check video
// ============================================================================
testcase OWP_008_8()
{
  int pev_result;
  Send_Value_To_COM(20808);
  SetTestStep("Bước 8 - OWP_008");
  StartTestTimer();

  write("");
  write("=== STEP 8: KEY ON, Turn ON PMD, KEY OFF, PEV trigger, B+ toggle, Check video ===");
  testStep("Step8", "KEY ON + Turn ON PMD + KEY OFF (3s), trigger PEV event, notify B+ toggle -> manual check video file directly");
  testWaitForTimeout(10000);

  // 8.1: KEY ON
  write("Step 8.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(10000);
  
  // 8.2: Turn ON PMD
  write("Step 8.2: Turn ON PMD...");
  Turn_ON_PMD();
  testWaitForTimeout(2000);

  // 8.3: KEY OFF
  write("Step 8.3: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(10000);

  WaitFor_RecSta_PMD_Recording(90000);
  testWaitForTimeout(3000);
  
  // 8.4: WaitFor_RecSta_PEV_Recording
  write("Step 8.4: Triggering PEV event...");
  pev_result = WaitFor_RecSta_PEV_Recording(60);

  if (pev_result == 1)
  {
    write(">>> [OK] PEV recording detected <<<");
  }
  else
  {
    write(">>> [WARNING] PEV recording not detected within timeout <<<");
  }
  testWaitForTimeout(4000);
  Set_BPlus_Off();
  testWaitForTimeout(4000);
  Set_BPlus_On();
    testWaitForTimeout(4000);
KEY_ON();
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_RecSta_PMD;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  step8_passed = 1;
  testStepPass("Step8", "KEY ON, PMD ON, KEY OFF, PEV trigger, B+ toggle, Video check - PASS");
  write("=== FINISH STEP 8 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 9: Log "lay anh o buoc 8"
// ============================================================================
testcase OWP_008_9()
{
  Send_Value_To_COM(20809);
  SetTestStep("Bước 9 - OWP_008");
  StartTestTimer();
  write("");
  write("=== STEP 9: Lay anh o buoc 8 ===");
  testStep("Step9", "Log notification - use screenshot from Step 8 (PMD+PEV+B+ toggle) as evidence for this step");

  write("");
  write("*************************************************************");
  write("*** [INFO] LAY ANH O BUOC 8!                              ***");
  write("*** Hay su dung anh man hinh da chup o buoc 8              ***");
