testcase OWP_010_Summary(){
  //============================================================================
  // Overall Test Verdict
  //============================================================================
  if(step1_passed == 1 && step2_passed == 1 && step3_passed == 1 && step4_passed == 1 && step5_passed == 1)
  {
    testStepPass("Overall_Verdict", "Test OWP_010 - 2.0: PASS");
    write("=== OVERALL VERDICT: PASS ===");
  }
  else
  {
    testStepFail("Overall_Verdict", "Test OWP_010 - 2.0: FAIL");
    write("=== OVERALL VERDICT: FAIL ===");
  }

  //============================================================================
  // SUMMARY
  //============================================================================
  write("");
  write("=== TEST SUMMARY ===");

  if(step1_passed == 1)
    write("Step 1: PEV ON, Sensitivity Lv.1, Bfr -10s, Aft +10s [Screenshot] => PASS");
  else
    write("Step 1: PEV ON, Sensitivity Lv.1, Bfr -10s, Aft +10s [Screenshot] => FAIL");

  if(step2_passed == 1)
    write("Step 2: PEV ON, Sensitivity Lv.2, Bfr -10s, Aft +10s [Screenshot] => PASS");
  else
    write("Step 2: PEV ON, Sensitivity Lv.2, Bfr -10s, Aft +10s [Screenshot] => FAIL");

  if(step3_passed == 1)
    write("Step 3: PEV ON, Sensitivity Lv.3, Bfr -10s, Aft +10s [Screenshot] => PASS");
  else
    write("Step 3: PEV ON, Sensitivity Lv.3, Bfr -10s, Aft +10s [Screenshot] => FAIL");

  if(step4_passed == 1)
    write("Step 4: PEV ON, Sensitivity Lv.4, Bfr -10s, Aft +10s [Screenshot] => PASS");
  else
    write("Step 4: PEV ON, Sensitivity Lv.4, Bfr -10s, Aft +10s [Screenshot] => FAIL");

  if(step5_passed == 1)
    write("Step 5: PEV ON, Sensitivity Lv.5, Bfr -10s, Aft +10s [Screenshot] => PASS");
  else
    write("Step 5: PEV ON, Sensitivity Lv.5, Bfr -10s, Aft +10s [Screenshot] => FAIL");

  testStep("Notifications","Finish OWP_010 - 2.0");
  write("=== FINISH OWP_010 - 2.0 ===");
}

void MainTest(){
  testReportFileName("TestReports\\OWP_010 - 2.0 generation_report");
  OWP_010_Init();

  OWP_010_1();

  OWP_010_2();

  OWP_010_3();

  OWP_010_4();

  OWP_010_5();

  OWP_010_Summary();
}
