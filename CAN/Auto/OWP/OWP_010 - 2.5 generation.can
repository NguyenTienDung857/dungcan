/*@!Encoding:65001*/
variables { 
  // Global Variable Declaration
  float count_PEVRec_time = 0.0;
  int flag_RecSet_error = 0;
  byte value_SenPEV = 0x0;
  byte value_Bfr;
  byte value_Aft;
  byte value_PEVSet;
  char PLBM_Battery[4] = {'P','L','B','M'};
  char eAGM_Battery[4] = {'E','A','G','M'};
  char answer[4];     
  // Message Declaration for CAN FD
  message HU_BLTN_CAM_02_200ms _HU_BLTN_CAM_02_200ms;
  message HU_BLTN_CAM_01_00ms _HU_BLTN_CAM_01_00ms;
  message HU_CLOCK_01_1000ms _HU_CLOCK_01_1000ms;
  message BDC_FD_04_200ms _BDC_FD_04_200ms;
}

int checkBatteryType(char a[], int size)
{
  int i, matchPLBM, matchEAGM;
  
  matchPLBM = 1;
  
  matchEAGM = 1;
  
  for (i = 0; i < size; i++)
  {
    if (a[i] != PLBM_Battery[i])
    {
      matchPLBM = 0;
    }
    if (a[i] != eAGM_Battery[i])
    {
      matchEAGM = 0;
    }
  }

  if (matchPLBM)
    return 1;
  else if (matchEAGM)
    return 2;
  else
    return 0;
}

void Set_Battery(){
  int flag_Timeout; 
  int battery_Type; 
  
  flag_Timeout = 0;
  battery_Type = 0;
  
  @panel::Switch_CGWNM = 1;
  
  KEY_ON();
  
  do
  {
    testWaitForStringInput("Please enter kind of battery (PLBM or EAGM):", 300000);
    
    testGetStringInput(answer, 5);
    
    write("You entered: %c%c%c%c", answer[0], answer[1], answer[2], answer[3]);
    
    battery_Type = checkBatteryType(answer,4);
    
    if(battery_Type == 0){
      write("Invalid input! Please enter 'PLBM' or 'EAGM'.");
    }
  } while(battery_Type == 0);
  
  switch(battery_Type){
    case(1): 
      write("Battery type is PLBM.");     
      @ControlPowerSupply::RadioBtn_PwrSplyModel = 1; //Choose model power suplly TL305TP
      @ControlPowerSupply::Numeric_PortNum = 3; //Choose numberic port to connect PC 
 
      if( @ControlPowerSupply::RadioBtn_PwrSplyModel == 1 && @ControlPowerSupply::Numeric_PortNum == 3 ){
        while (@ControlPowerSupply::isConectedPwrSply == 0 && flag_Timeout <= 30){
        @ControlPowerSupply::Button_Connect = 0; 
        testWaitForTimeout(1000);
        @ControlPowerSupply::Button_Connect = 1;
        testWaitForTimeout(1000);  
        @ControlPowerSupply::Button_Connect = 0;
        flag_Timeout++;  
        }
      }
      flag_Timeout = 0;
      break;
    case(2):
      write("Battery type is EAGM.");
      setSignal(ICU_BS2SoC, 0x64); break;
  }

  KEY_OFF();
  
  @panel::Switch_CGWNM = 0;
}

void BLTN_CAM_Settings(int Choose_Option){
  switch (Choose_Option){
    case(1):
      if ($BLTN_CAM_RecSet_PEV == 0x1){
        @panel::LED_Ctrl_SetPEV = 1; value_PEVSet = 0x2;
        
        testWaitForTimeout(500);
        
        if ($BLTN_CAM_RecSet_PEV == 0x2){
          
          write("PEV: 0x%X (ON)",$BLTN_CAM_RecSet_PEV);
        } 
        else if ($BLTN_CAM_RecSet_PEV == 0x1){
          
          write("PEV: 0x%X (OFF)",$BLTN_CAM_RecSet_PEV);
        }
      }
      testWaitForTimeout(500);
      value_SenPEV = 0x1; write("SenPEV: Lv.1"); @panel::TrackBar_PEV_Sen = 1;/* Parked Sensitivity Lv.1 */
      value_Bfr = 0x0; write("Bft: -10"); @panel::TrackBar_EV_Time_Bfr = 3;/*Before Time Setting: -10s*/
      value_Aft = 0x0; write("Aft: +10"); @panel::TrackBar_EV_Time_Aft = 10;/*After Time Setting: +10s*/break; 
    case(2):
      if ($BLTN_CAM_RecSet_PEV == 0x1){
        @panel::LED_Ctrl_SetPEV = 1; value_PEVSet = 0x2; 
        
        testWaitForTimeout(500);
        
        if ($BLTN_CAM_RecSet_PEV == 0x2){
          
          write("PEV: 0x%X (ON)",$BLTN_CAM_RecSet_PEV);
        } 
        else if ($BLTN_CAM_RecSet_PEV == 0x1){
          
          write("PEV: 0x%X (OFF)",$BLTN_CAM_RecSet_PEV);
          
        }
      }
      testWaitForTimeout(500);
      value_SenPEV = 0x2; write("SenPEV: Lv.2"); @panel::TrackBar_PEV_Sen = 2;/* Parked Sensitivity Lv.2 */
      value_Bfr = 0x0; write("Bft: -10"); @panel::TrackBar_EV_Time_Bfr = 3;/*Before Time Setting: -10s*/
      value_Aft = 0x0; write("Aft: +10"); @panel::TrackBar_EV_Time_Aft = 10;/*After Time Setting: +10s*/break;       
    case(3):
      if ($BLTN_CAM_RecSet_PEV == 0x1){
        @panel::LED_Ctrl_SetPEV = 1; value_PEVSet = 0x2; 
        
        testWaitForTimeout(500);
        
        if ($BLTN_CAM_RecSet_PEV == 0x2){
          
          write("PEV: 0x%X (ON)",$BLTN_CAM_RecSet_PEV);
        } 
        else if ($BLTN_CAM_RecSet_PEV == 0x1){
          
          write("PEV: 0x%X (OFF)",$BLTN_CAM_RecSet_PEV);
          
        }
      }
      testWaitForTimeout(500);
      value_SenPEV = 0x3; write("SenPEV: Lv.3"); @panel::TrackBar_PEV_Sen = 3;/* Parked Sensitivity Lv.3 */
      value_Bfr = 0x0; write("Bft: -10"); @panel::TrackBar_EV_Time_Bfr = 3;/*Before Time Setting: -10s*/
      value_Aft = 0x0; write("Aft: +10"); @panel::TrackBar_EV_Time_Aft = 10;/*After Time Setting: +10s*/break;       
    case(4):
      if ($BLTN_CAM_RecSet_PEV == 0x1){
        @panel::LED_Ctrl_SetPEV = 1; value_PEVSet = 0x2;  
        
        testWaitForTimeout(500);
        
        if ($BLTN_CAM_RecSet_PEV == 0x2){
          
          write("PEV: 0x%X (ON)",$BLTN_CAM_RecSet_PEV);
        } 
        else if ($BLTN_CAM_RecSet_PEV == 0x1){
          
          write("PEV: 0x%X (OFF)",$BLTN_CAM_RecSet_PEV);
          
        }
      }
      testWaitForTimeout(500);
      value_SenPEV = 0x4; write("SenPEV: Lv.4"); @panel::TrackBar_PEV_Sen = 4;/* Parked Sensitivity Lv.4 */
      value_Bfr = 0x0; write("Bft: -10"); @panel::TrackBar_EV_Time_Bfr = 3;/*Before Time Setting: -10s*/
      value_Aft = 0x0; write("Aft: +10"); @panel::TrackBar_EV_Time_Aft = 10;/*After Time Setting: +10s*/break;       
    case(5):
      if ($BLTN_CAM_RecSet_PEV == 0x1){
        @panel::LED_Ctrl_SetPEV = 1; value_PEVSet = 0x2;  
        
        testWaitForTimeout(500);
        
        if ($BLTN_CAM_RecSet_PEV == 0x2){
          
          write("PEV: 0x%X (ON)",$BLTN_CAM_RecSet_PEV);
        } 
        else if ($BLTN_CAM_RecSet_PEV == 0x1){
          
          write("PEV: 0x%X (OFF)",$BLTN_CAM_RecSet_PEV);
          
        }
      }
      testWaitForTimeout(500);
      value_SenPEV = 0x5; write("SenPEV: Lv.5"); @panel::TrackBar_PEV_Sen = 5;/* Parked Sensitivity Lv.5 */
      value_Bfr = 0x0; write("Bft: -10"); @panel::TrackBar_EV_Time_Bfr = 3;/*Before Time Setting: -10s*/
      value_Aft = 0x0; write("Aft: +10"); @panel::TrackBar_EV_Time_Aft = 10;/*After Time Setting: +10s*/break;       
  }
  
  testWaitForTimeout(500);
    
  if($BLTN_CAM_Set_EV_BfrTime != value_Bfr){
      
    write("Bfr_time is not match");
    
    write("Stop test"); stop();
    
  }
  else if($BLTN_CAM_Set_EV_AftTime != value_Aft){
    
    write("Aft_time is not match");
    
    write("Stop test"); stop();
    
  }  
}

void KEY_ON(){
  setSignal(SMK_TrmnlCtrlGrpStaBDC,0x1); // Power ON
}

void KEY_OFF(){
   setSignal(SMK_TrmnlCtrlGrpStaBDC,0x0); // Power OFF
}

void Enter_BLTN_CAM(){
  // CAN FD
  _HU_BLTN_CAM_02_200ms.HU_BLTN_CAM_UI_Mode = 0x1; //Enter BLTN_CAM mode
  output(_HU_BLTN_CAM_02_200ms);
}

void Exit_BLTN_CAM(){
  // CAN FD 
  _HU_BLTN_CAM_02_200ms.HU_BLTN_CAM_UI_Mode = 0x0; //Enter AVN mode - Exit BLTN_CAM Mode
  output(_HU_BLTN_CAM_02_200ms);
}

void CaptureGraphics(){
  testWaitForTimeout(3000);
  testReportAddWindowCapture("Graphics 2","BLTN_CAM_RecSta_PEV","Sreenshot","./Husign.jpg");
}

void Turn_OFF_RecSet(){
  if (getSignal(BLTN_CAM_RecSet_OWD) == 0x2 || getSignal(BLTN_CAM_RecSet_OWP) == 0x2 || getSignal(BLTN_CAM_RecSet_DEV) == 0x2 || getSignal(BLTN_CAM_RecSet_PEV) == 0x2){
    @panel::Switch_CGWNM = 1;
  
    KEY_ON();
    testWaitForTimeout(3000);
      
    do {
      Enter_BLTN_CAM();
      testWaitForTimeout(3000);
      
      if (getSignal(BLTN_CAM_RecSet_OWD) == 0x2){
        write("OWD Off"); @panel::LED_Ctrl_SetOWD = 1; testWaitForTimeout(1000);
      } 
      
      else if (getSignal(BLTN_CAM_RecSet_OWP) == 0x2){
        write("OWP Off"); @panel::LED_Ctrl_SetOWP = 1; testWaitForTimeout(1000);
      } 
      
      else if (getSignal(BLTN_CAM_RecSet_DEV) == 0x2){
        write("DEV Off"); @panel::LED_Ctrl_SetDEV = 1; testWaitForTimeout(1000);
      } 
      
      else if (getSignal(BLTN_CAM_RecSet_PEV) == 0x2){
        write("PEV Off"); @panel::LED_Ctrl_SetPEV = 1; testWaitForTimeout(1000);
      } 

      Exit_BLTN_CAM();
      
      flag_RecSet_error++;
      
    } while((getSignal(BLTN_CAM_RecSet_OWD) == 0x2 || getSignal(BLTN_CAM_RecSet_OWP) == 0x2 || getSignal(BLTN_CAM_RecSet_DEV) == 0x2 || getSignal(BLTN_CAM_RecSet_PEV) == 0x2) && (flag_RecSet_error <= 15));
    
    flag_RecSet_error = 0; 
    
    testWaitForTimeout(3000); 
    KEY_OFF();
  }
  else {
    write("Notifications: All recording setting are turned OFF.");
  }
}

void Setup_Function(int Option, long Wait_Time){
  float start_sec, end_sec;
  
    @panel::Switch_CGWNM = 1;
  
    KEY_ON();
    testWaitForTimeout(3000);
  
    do {
    Enter_BLTN_CAM();
    testWaitForTimeout(3000);

    BLTN_CAM_Settings(Option);
    testWaitForTimeout(2000);
    
    @panel::Switch_Clock = 1;
  
    Exit_BLTN_CAM();
    testWaitForTimeout(3000);
    } while ($BLTN_CAM_RecSet_PEV != value_PEVSet);
  
    KEY_OFF();

    testWaitForTimeout(Wait_Time);
  
    openPanel("Note"); 
  
    if (testWaitForSignalChange(BLTN_CAM_RecSta_PEV, 10000) == 1){
      write("PEV recording is started");
      start_sec = timeNow()/100000.0;
    }
    else {
      write("Error: PEV recording hasn't started");
      testStepFail("Fail","PEV recording hasn't started");
      stop();
    }
  
    if (testWaitForSignalChange(BLTN_CAM_RecSta_PEV, 30000) == 1){
      write("PEV recording is stopped");
      end_sec = timeNow()/100000.0; 
    }
  
    count_PEVRec_time = end_sec - start_sec;
    
    closePanel("Note");    
}

void Setup_End_test(){
  
  KEY_ON();
  testWaitForTimeout(3000);
  

  while(getSignal(BLTN_CAM_RecSet_PEV) == 0x2 && flag_RecSet_error < 15){
    
    Enter_BLTN_CAM();
    testWaitForTimeout(3000);
    write("PEV Off"); @panel::LED_Ctrl_SetPEV = 1;
    testWaitForTimeout(1000);
    Exit_BLTN_CAM();
    testWaitForTimeout(1000);      
    flag_RecSet_error++;
    
  }
  
  flag_RecSet_error = 0;
}

void Init(){
  @panel::Switch_CGWNM = 1; 
  
  KEY_ON();
  
  while (getSignal(BLTN_CAM_SD_Format_Op_State) != 0x1){
    @panel::Button_RecReset = 1; 
    testWaitForSignalChange(BLTN_CAM_SD_Format_Op_State,500);
  }
  
  write("Run Set_Battery()");
  Set_Battery();
  
  KEY_OFF();
  
  @panel::Switch_CGWNM = 0; 
}

testcase OWP_010_1(){
  testStep("Notification","Start test OWP_010_1");
  write("=== START OWP_010_1 ===");

  write("Run Setup_Function()"); Setup_Function(1, 11000); 
 
  write("count_PEVRec_time = %.2f",count_PEVRec_time);
  
  write("Run CaptureGraphics()"); CaptureGraphics(); 
  
  write("Run Setup_End_test()"); Setup_End_test();
  
  @panel::Switch_Clock = 0;
  
  @panel::Switch_CGWNM = 0;
  
  count_PEVRec_time = 0.0;
  
   write("Run KEY_OFF()"); KEY_OFF();
  
  testStep("Notifications","Finish OWP_010_1");
  write("=== FINISH OWP_010_1 ===");  
}

