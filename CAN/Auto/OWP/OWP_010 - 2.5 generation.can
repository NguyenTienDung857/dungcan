void MainTest(){
  write("Turn_OFF_RecSet()"); Turn_OFF_RecSet();
  
  write("Init()"); Init();
  
  TestWaitForValueInput("Please enter the ID testcase number: (1/2/3/4/5/6)",300000); 
  switch (testGetValueInput()){
    
    case (1): OWP_010_1(); break;
    
    case (2): OWP_010_2(); break;
    
    case (3): OWP_010_3(); break;
      
    case (4): OWP_010_4(); break;
    
    case (5): OWP_010_5(); break;  

    case (10): 
      OWP_010_1(); 
      
      OWP_010_2();
      
      OWP_010_3();
      
      OWP_010_4();
      
      OWP_010_5();
  
      break;        
  }  
}
