// Summary
// ============================================================================

void MainTest()
{
  testReportFileName("TestReports\\OWP_016 - 2.5 generation_report");

  OWP_016_Init();

  // Part A: PMD Default Settings Check
  OWP_016_1();
  OWP_016_2();
  OWP_016_3();
  OWP_016_4();
  OWP_016_5();
  OWP_016_6();

  // Part B: PEV Trigger with OWP Recording
  OWP_016_2b();
  OWP_016_3_4b();
  OWP_016_5b();
  OWP_016_6b();

  // Part C: Rapid KEY ON/OFF + Final PEV test
  OWP_016_12();
  OWP_016_13();

}
