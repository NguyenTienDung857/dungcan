  write("=== FINISH STEP 5 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 6: Turn_OFF_PMD, check Set_PMD=0x1(OFF), RecSet_PEV=0x1(OFF)
// ============================================================================
testcase OWP_016_6()
{
  int pmd_val;
  int pev_off_result;
  Send_Value_To_COM(21606);
  SetTestStep("Bước 6 - OWP_016");
  StartTestTimer();

  write("");
  write("=== STEP 6: Turn OFF PMD, Check Set_PMD=0x1(OFF), RecSet_PEV=0x1(OFF) ===");
  testStep("Step6", "Turn OFF PMD, Check Set_PMD OFF, RecSet_PEV OFF");

  // 6.1: Turn OFF PMD
  write("Step 6.1: Turn OFF PMD...");
  Turn_OFF_PMD();
  testWaitForTimeout(3000);

  // 6.2: Check BLTN_CAM_Set_PMD = 0x1 (OFF)
  write("Step 6.2: Check BLTN_CAM_Set_PMD...");
  pmd_val = Gen20_PMD_Set_Value();
  write("  BLTN_CAM_Set_PMD = 0x%X", pmd_val);

  if (pmd_val == 0x1)
  {
    write(">>> [PASS] BLTN_CAM_Set_PMD = 0x1 (OFF) <<<");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_Set_PMD = 0x%X, expected 0x1 (OFF) <<<", pmd_val);
  }

  // 6.3: Check BLTN_CAM_RecSet_PEV = 0x1 (OFF)
  write("Step 6.3: Check RecSet_PEV = OFF...");
  pev_off_result = Check_RecSet_PEV_OFF();

  CaptureGraphics("OWP", "BLTN_CAM_Set_PMD;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSet_OWP;BLTN_CAM_State");

  if (pmd_val == 0x1 && pev_off_result == 1)
  {
    step6_passed = 1;
    testStepPass("Step6", "Set_PMD=0x1(OFF), RecSet_PEV=OFF - PASS");
  }
  else
  {
    step6_passed = 0;
    Log_Error_Details();
    testStepFail("Step6", "Set_PMD=0x%X, PEV_OFF=%d - FAIL", pmd_val, pev_off_result);
  }

  write("=== FINISH STEP 6 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

