// ============================================================================
// STEP 3_4b: Log "check den LED"
// ============================================================================
testcase OWP_016_3_4b()
{
  Send_Value_To_COM(21603);
  SetTestStep("Bước 3 và 4b - OWP_016");
  StartTestTimer();
  write("");
  write("=== STEP 3 & 4 (LED): Check den LED ===");
  testStep("Step3_4b", "Check den LED");

  write("");
  write("*************************************************************");
  write("*** [MANUAL VERIFICATION REQUIRED]                        ***");
  write("*** Hay CHECK DEN LED tren thiet bi!                      ***");
  write("*** Kiem tra den LED co nhap nhay dung khong.             ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_State");

  step3_4b_passed = 1;
  testStepPass("Step3_4b", "Log: check den LED - manual check required");
  write("=== FINISH STEP 3_4b ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 5b: KEY ON, Click_USM_Reset, KEY OFF,
//          WaitFor_RecSta_OWP_Recording, WaitFor_RecSta_PEV_Recording,
//          log check video
// ============================================================================
testcase OWP_016_5b()
{
  int pev_result;
  Send_Value_To_COM(21605);
  SetTestStep("Bước 5b - OWP_016");
  StartTestTimer();

  write("");
  write("=== STEP 5b: KEY ON, USM Reset, KEY OFF, Wait OWP, PEV trigger, Check video ===");
  testStep("Step5b", "KEY ON, USM Reset, KEY OFF, Wait OWP Recording, PEV trigger");

  // 5b.1: KEY ON
  write("Step 5b.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(3000);

  // 5b.2: Click USM Reset
  write("Step 5b.2: USM Reset...");
  Click_USM_Reset();

  // 5b.3: KEY OFF
  write("Step 5b.3: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 5b.4: Wait for OWP Recording (max 120s)
  write("Step 5b.4: Waiting for BLTN_CAM_RecSta_OWP = ON (max 120s)...");
  if (WaitFor_RecSta_OWP_Recording(120000) != 1)
  {
    write(">>> [FAIL] OWP did not start within 120s. Aborting Step 5b.");
    CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_State");
    Log_Error_Details();
    testStepFail("Step5b", "BLTN_CAM_RecSta_OWP did not turn ON within 120s");
    step5b_passed = 0;
    return;
  }
  write(">>> [OK] BLTN_CAM_RecSta_OWP = 0x%X - OWP recording started <<<", $BLTN_CAM_RecSta_OWP);

  // 5b.5: WaitFor_RecSta_PEV_Recording
  write("Step 5b.5: Triggering PEV event...");
  pev_result = WaitFor_RecSta_PEV_Recording(60);

  if (pev_result == 1)
  {
    write(">>> [PASS] PEV recording detected <<<");
    step5b_passed = 1;
    testStepPass("Step5b", "OWP ON, PEV triggered and recorded - PASS");
  }
  else
  {
    write(">>> [FAIL] PEV recording not detected <<<");
    step5b_passed = 0;
    Log_Error_Details();
    testStepFail("Step5b", "PEV not triggered - FAIL");
  }

  // 5b.6: Log check video
  write("");
  write("*************************************************************");
  write("*** [CHECK] Hay check VIDEO tren thiet bi! (Step 5b)      ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  write("=== FINISH STEP 5b ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 6b: KEY ON, KEY OFF, WaitFor_RecSta_PEV_Recording,
//          log "bat tat B+ ngay", log check video
// ============================================================================
testcase OWP_016_6b()
{
  int pev_result;
  Send_Value_To_COM(21606);
  SetTestStep("Bước 6b - OWP_016");
  StartTestTimer();

  write("");
  write("=== STEP 6b: KEY ON, KEY OFF, PEV trigger, B+ toggle, Check video ===");
  testStep("Step6b", "KEY ON, KEY OFF, PEV trigger, B+ toggle");

  // 6b.1: KEY ON
  write("Step 6b.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // 6b.2: KEY OFF
  write("Step 6b.2: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 6b.3: WaitFor_RecSta_PEV_Recording
  write("Step 6b.3: Triggering PEV event...");
  pev_result = WaitFor_RecSta_PEV_Recording(60);

  if (pev_result == 1)
  {
    write(">>> [OK] PEV recording detected <<<");
  }
  else
  {
    write(">>> [WARNING] PEV recording not detected within timeout <<<");
  }

  // 6b.4: Log B+ bat tat ngay
  write("");
  write("*************************************************************");
  write("*** [ACTION REQUIRED] B+ BAT TAT NGAY!                    ***");
  write("*** >> Hay bat tat B+ ngay bay gio! <<                     ***");
  write("*************************************************************");
  write("");
  testWaitForTimeout(5000);

  // 6b.5: Log check video
  write("");
  write("*************************************************************");
  write("*** [CHECK] Hay check VIDEO tren thiet bi! (Step 6b)      ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  step6b_passed = 1;
  testStepPass("Step6b", "KEY ON/OFF, PEV trigger, B+ toggle notified, Video check - PASS");
  write("=== FINISH STEP 6b ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 12: Rapid KEY ON/OFF x20, KEY OFF,
//          Check_RecSta_OWP_Recording, Check PEV_Count = 0x0
// ============================================================================
testcase OWP_016_12()
{
  int owp_result;
  int pev_count;
  Send_Value_To_COM(21612);
  SetTestStep("Bước 12 - OWP_016");
  StartTestTimer();

  write("");
  write("=== STEP 12: Rapid KEY ON/OFF x20, Check OWP Recording, Check PEV_Count = 0 ===");
  testStep("Step12", "Rapid KEY ON/OFF x20, OWP Recording, PEV_Count = 0");

  // 12.1: Rapid KEY ON/OFF 20 times
  write("Step 12.1: Starting rapid KEY ON/OFF cycle (20 times)...");
  {
    int cycle;
    for (cycle = 1; cycle <= 20; cycle++)
    {
      KEY_ON();
      testWaitForTimeout(500);

      KEY_OFF();
      testWaitForTimeout(500);

      if (cycle % 5 == 0)
      {
        write("  Cycle %d/20 completed", cycle);
      }
    }
  }

  // 12.2: Final KEY OFF
  write("Step 12.2: Final KEY OFF after 20 cycles...");
  KEY_OFF();
  testWaitForTimeout(10000);

  // 12.3: Check OWP Recording
  write("Step 12.3: Checking BLTN_CAM_RecSta_OWP (OWP Recording)...");
  owp_result = Check_RecSta_OWP_Recording();

  // 12.4: Check BLTN_CAM_PEV_Count = 0x0
  write("Step 12.4: Checking BLTN_CAM_PEV_Count...");
  pev_count = $BLTN_CAM_PEV_Count;
  write("  BLTN_CAM_PEV_Count = 0x%X (%d)", pev_count, pev_count);

  if (owp_result == 1 && pev_count == 0x0)
  {
    write(">>> [PASS] OWP Recording = ON, PEV_Count = 0x0 <<<");
    step12_passed = 1;
    testStepPass("Step12", "OWP Recording ON, PEV_Count = 0x0 - PASS");
  }
  else
  {
    if (owp_result != 1) write("  -> OWP is NOT recording");
    if (pev_count != 0x0) write("  -> PEV_Count = 0x%X, expected 0x0", pev_count);
    write(">>> [FAIL] OWP Recording or PEV_Count check failed <<<");
    step12_passed = 0;
    Log_Error_Details();
    testStepFail("Step12", "OWP=%d, PEV_Count=0x%X - FAIL", owp_result, pev_count);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  write("=== FINISH STEP 12 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 13: KEY ON, KEY OFF, WaitFor_RecSta_OWP_Recording,
//          WaitFor_RecSta_PEV_Recording, wait 5s, log check video thuc te
// ============================================================================
testcase OWP_016_13()
{
  int pev_result;
  Send_Value_To_COM(21613);
  SetTestStep("Bước 13 - OWP_016");
  StartTestTimer();

  write("");
  write("=== STEP 13: KEY ON, KEY OFF, Wait OWP, PEV trigger, Wait 5s, Check video ===");
  testStep("Step13", "KEY ON, KEY OFF, Wait OWP Recording, PEV trigger, Check actual video");

  // 13.1: KEY ON
  write("Step 13.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // 13.2: KEY OFF
  write("Step 13.2: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 13.3: Wait for OWP Recording (max 120s)
  write("Step 13.3: Waiting for BLTN_CAM_RecSta_OWP = ON (max 120s)...");
  if (WaitFor_RecSta_OWP_Recording(120000) != 1)
  {
    write(">>> [FAIL] OWP did not start within 120s. Aborting Step 13.");
    CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_State");
    Log_Error_Details();
    testStepFail("Step13", "BLTN_CAM_RecSta_OWP did not turn ON within 120s");
    step13_passed = 0;
    return;
  }
  write(">>> [OK] BLTN_CAM_RecSta_OWP = 0x%X - OWP recording started <<<", $BLTN_CAM_RecSta_OWP);

  // 13.4: WaitFor_RecSta_PEV_Recording (immediately after OWP ON)
  write("Step 13.4: Triggering PEV event immediately...");
  pev_result = WaitFor_RecSta_PEV_Recording(60);

  if (pev_result == 1)
  {
    write(">>> [OK] PEV recording detected <<<");
  }
  else
  {
    write(">>> [WARNING] PEV recording not detected within timeout <<<");
  }

  // 13.5: Wait 5 seconds
  write("Step 13.5: Waiting 5 seconds...");
  testWaitForTimeout(5000);

  // 13.6: Log check actual video
  write("");
  write("*************************************************************");
  write("*** [CHECK] Hay check VIDEO THUC TE tren thiet bi!        ***");
  write("*** Kiem tra video da ghi nhan su kien PEV.                ***");
  write("*** (Step 13)                                              ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  step13_passed = 1;
  testStepPass("Step13", "OWP ON, PEV triggered, actual video check - PASS");
  write("=== FINISH STEP 13 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

