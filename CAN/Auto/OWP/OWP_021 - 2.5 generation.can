// ============================================================================
// Summary
// ============================================================================

void MainTest()
{
  testReportFileName("TestReports\\OWP_021 - 2.5 generation_report");

  OWP_021_Init();

  OWP_021_1();
  OWP_021_2();
  OWP_021_3();
  OWP_021_4();
  OWP_021_5();
  OWP_021_6();

}
