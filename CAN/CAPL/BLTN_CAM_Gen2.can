on sysvar_update panel::TrackBar_OWP_TIME
{ 
  OWPSetTime = getSignal(BLTN_CAM_Set_PrkTime);
  
  if(@panel::TrackBar_OWP_TIME != OWPSetTime)
  {
    valueSet_HU_BLTN_CAM_E_00();
    
    switch (@panel::TrackBar_OWP_TIME) {
      case 2 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x2; output(_HU_BLTN_CAM_E_00); break;
      case 3 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x3; output(_HU_BLTN_CAM_E_00); break;
      case 4 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x4; output(_HU_BLTN_CAM_E_00); break;
      case 5 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x5; output(_HU_BLTN_CAM_E_00); break;
      case 6 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x6; output(_HU_BLTN_CAM_E_00); break;
      case 7 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x7; output(_HU_BLTN_CAM_E_00); break;
      case 8 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x8; output(_HU_BLTN_CAM_E_00); break;
      case 9 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x9; output(_HU_BLTN_CAM_E_00); break;
      case 10 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0xA; output(_HU_BLTN_CAM_E_00); break;
      case 11 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0xB; output(_HU_BLTN_CAM_E_00); break;
      case 12 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0xC; output(_HU_BLTN_CAM_E_00); break;
      case 13 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0xD; output(_HU_BLTN_CAM_E_00); break;
      case 14 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0xE; output(_HU_BLTN_CAM_E_00); break;
      case 15 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0xF; output(_HU_BLTN_CAM_E_00); break;
      case 16 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x10; output(_HU_BLTN_CAM_E_00); break;
      case 17 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x11; output(_HU_BLTN_CAM_E_00); break;
      case 18 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x12; output(_HU_BLTN_CAM_E_00); break;
      case 19 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x13; output(_HU_BLTN_CAM_E_00); break;
      case 20 : _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = 0x14; output(_HU_BLTN_CAM_E_00); break;
      default : write("TrackBar_OWP_TIME default"); break;
        write("OWD Time");
    }
  }
}

on sysvar_update panel::TrackBar_Timelaps_TIME
{
  TmlpsRecSetTime = getSignal(BLTN_CAM_Set_Drv_TML_Int);
  
  if(@panel::TrackBar_Timelaps_TIME != TmlpsRecSetTime)
  {
    valueSet_HU_BLTN_CAM_E_00();
    
    switch (@panel::TrackBar_Timelaps_TIME) {
      case 1 : _HU_BLTN_CAM_E_00.BLTN_CAM_TML_Int_NvalueSet = 0x1; output(_HU_BLTN_CAM_E_00); break;
      case 2 : _HU_BLTN_CAM_E_00.BLTN_CAM_TML_Int_NvalueSet = 0x2; output(_HU_BLTN_CAM_E_00); break;
      case 3 : _HU_BLTN_CAM_E_00.BLTN_CAM_TML_Int_NvalueSet = 0x5; output(_HU_BLTN_CAM_E_00); break;
      default : write("TrackBar_Timelaps_TIME default"); break;
    }
        write("TmlpsRecSetTime");
  }
}

on sysvar_update panel::TrackBar_FR_Ver_Pos
{
  valueSet_HU_BLTN_CAM_E_01();

  CAM_Pos_FR = getSignal(BLTN_CAM_Set_FR_Ver_Pos);
  
  switch (@panel::TrackBar_FR_Ver_Pos) {
    case 1 : if(CAM_Pos_FR == MINUS_5) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_FR_VerPos_NvalueSet = MINUS_5; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_FR -5"); break;
    case 2 : if(CAM_Pos_FR == MINUS_4) break;                                             
      _HU_BLTN_CAM_E_01.BLTN_CAM_FR_VerPos_NvalueSet = MINUS_4; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_FR -4"); break;
    case 3 : if(CAM_Pos_FR == MINUS_3) break;                                             
      _HU_BLTN_CAM_E_01.BLTN_CAM_FR_VerPos_NvalueSet = MINUS_3; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_FR -3"); break;
    case 4 : if(CAM_Pos_FR == MINUS_2) break;                                           
      _HU_BLTN_CAM_E_01.BLTN_CAM_FR_VerPos_NvalueSet = MINUS_2; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_FR -2"); break;
    case 5 : if(CAM_Pos_FR == MINUS_1) break;                                               
      _HU_BLTN_CAM_E_01.BLTN_CAM_FR_VerPos_NvalueSet = MINUS_1; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_FR -1"); break;
    case 6 : if(CAM_Pos_FR == ZERO_0) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_FR_VerPos_NvalueSet = ZERO_0; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_FR 0");  break;
    case 7 : if(CAM_Pos_FR == PLUS_1) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_FR_VerPos_NvalueSet = PLUS_1; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_FR +1");  break;
    case 8 : if(CAM_Pos_FR == PLUS_2) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_FR_VerPos_NvalueSet = PLUS_2; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_FR +2");  break;
    case 9 : if(CAM_Pos_FR == PLUS_3) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_FR_VerPos_NvalueSet = PLUS_3; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_FR +3");  break;
    case 10 : if(CAM_Pos_FR == PLUS_4) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_FR_VerPos_NvalueSet = PLUS_4; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_FR +4");  break;
    case 11 : if(CAM_Pos_FR == PLUS_5) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_FR_VerPos_NvalueSet = PLUS_5; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_FR +5"); break;
    default : write("TrackBar_FR_Ver_Pos default"); break;
  }
}

