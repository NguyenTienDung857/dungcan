on timer timer_GetScrollBarSettingInfo
{
  //주차녹화시간 SET
  OWPSetTime = getSignal(BLTN_CAM_Set_PrkTime);
  
  
  @sysvar::panel::TrackBar_OWP_TIME = OWPSetTime;
  
  //타임랩스 녹화시간 SET
  TmlpsRecSetTime = getSignal(BLTN_CAM_Set_Drv_TML_Int);
  @sysvar::panel::TrackBar_Timelaps_TIME = TmlpsRecSetTime;
  
  //F-CAM 각도 SET
  CAM_Pos_FR = getSignal(BLTN_CAM_Set_FR_Ver_Pos);
  
  switch(CAM_Pos_FR)
  {
    case MINUS_5: @sysvar::panel::TrackBar_FR_Ver_Pos = 1; break;
    case MINUS_4: @sysvar::panel::TrackBar_FR_Ver_Pos = 2; break;
    case MINUS_3: @sysvar::panel::TrackBar_FR_Ver_Pos = 3; break;
    case MINUS_2: @sysvar::panel::TrackBar_FR_Ver_Pos = 4; break;
    case MINUS_1: @sysvar::panel::TrackBar_FR_Ver_Pos = 5; break;
    case ZERO_0: @sysvar::panel::TrackBar_FR_Ver_Pos = 6; break;
    case PLUS_1: @sysvar::panel::TrackBar_FR_Ver_Pos = 7; break;
    case PLUS_2: @sysvar::panel::TrackBar_FR_Ver_Pos = 8; break;
    case PLUS_3: @sysvar::panel::TrackBar_FR_Ver_Pos = 9; break;
    case PLUS_4: @sysvar::panel::TrackBar_FR_Ver_Pos = 10; break;
    case PLUS_5: @sysvar::panel::TrackBar_FR_Ver_Pos = 11; break;
  }
  
  //R-CAM 각도 SET
  CAM_Pos_RR = getSignal(BLTN_CAM_Set_RR_Ver_Pos);
  
  switch(CAM_Pos_RR)
  {
    case MINUS_5: @sysvar::panel::TrackBar_RR_Ver_Pos = 1; break;
    case MINUS_4: @sysvar::panel::TrackBar_RR_Ver_Pos = 2; break;
    case MINUS_3: @sysvar::panel::TrackBar_RR_Ver_Pos = 3; break;
    case MINUS_2: @sysvar::panel::TrackBar_RR_Ver_Pos = 4; break;
    case MINUS_1: @sysvar::panel::TrackBar_RR_Ver_Pos = 5; break;
    case ZERO_0: @sysvar::panel::TrackBar_RR_Ver_Pos = 6; break;
    case PLUS_1: @sysvar::panel::TrackBar_RR_Ver_Pos = 7; break;
    case PLUS_2: @sysvar::panel::TrackBar_RR_Ver_Pos = 8; break;
    case PLUS_3: @sysvar::panel::TrackBar_RR_Ver_Pos = 9; break;
    case PLUS_4: @sysvar::panel::TrackBar_RR_Ver_Pos = 10; break;
    case PLUS_5: @sysvar::panel::TrackBar_RR_Ver_Pos = 11; break;
  }

  //이벤트 민감도 SET
  DEVSenSetValue = getSignal(BLTN_CAM_SenSet_DEV);
  @sysvar::panel::TrackBar_DEV_Sen = DEVSenSetValue;
  PEVSenSetValue = getSignal(BLTN_CAM_SenSet_PEV);
  @sysvar::panel::TrackBar_PEV_Sen = PEVSenSetValue;
  
  //이벤트 녹화시간 After SET(트랙바 순서때문에 Before랑 다르게 해야됨
  Evt_BfrTime = getSignal(BLTN_CAM_Set_EV_BfrTime) + 10;
  
  switch(Evt_BfrTime)
  {
    case 10: @sysvar::panel::TrackBar_EV_Time_Bfr = 3; break;
    case 15: @sysvar::panel::TrackBar_EV_Time_Bfr = 2; break;
    case 20: @sysvar::panel::TrackBar_EV_Time_Bfr = 1; break;
  }

  //이벤트 녹화 After 시간 SET
  Evt_AftTime = getSignal(BLTN_CAM_Set_EV_AftTime) + 10;
  @sysvar::panel::TrackBar_EV_Time_Aft = Evt_AftTime;
  
  
  timer_GetScrollBarSettingInfo.Set(TIME_GetScrollBarSettingInfo);
}

on timer timer_HU_CLOCK_PE
{
  if(@sysvar::panel::Switch_Clock == 1)
  {
    message HU_CLOCK_PE_02 _HU_CLOCK_PE_02; //CAN
    //message HU_CLOCK_01_1000ms _HU_CLOCK_PE_02; //CANFD

    long time[9];
    getLocalTime(time);
    
    _HU_CLOCK_PE_02.HU_DisplayYear1 = 0x1;
    _HU_CLOCK_PE_02.HU_DisplayYear2 = (time[5]+1900) - 2000;
    _HU_CLOCK_PE_02.HU_DisplayMonth = time[4]+1;
    _HU_CLOCK_PE_02.HU_DisplayDay = time[3];
    _HU_CLOCK_PE_02.HU_DisplayHour = time[2];
    _HU_CLOCK_PE_02.HU_DisplayMinute= time[1];
    _HU_CLOCK_PE_02.HU_DisplaySecond = time[0]; 
    
    _HU_CLOCK_PE_02.HU_Status = 0x2; //GPS Time receving
    _HU_CLOCK_PE_02.HU_TimeSetting = 0x2; //GPS Time
    
    output(_HU_CLOCK_PE_02);
  }
  
  else
  {
  }

  timer_HU_CLOCK_PE.Set(TIME_HU_CLOCK);
}


on timer timer_SubBatt_Charge
{
  if(@sysvar::panel::Switch_SubBattCharge == 1)
  {
    /*
    if($SMK_TrmnlCtrlGrpStaBDC == 0x0)
      output(msgSubBattDisCharge);
    
    else if($SMK_TrmnlCtrlGrpStaBDC == 0x4)
      output(msgSubBattCharge);
    */
    if($HCU_HevRdySta == 0x1)
      output(msgSubBattCharge);
    if($VCU_EvDrvRdySta == 0x1)
      output(msgSubBattCharge);
    if($SMK_TrmnlCtrlGrpStaBDC == 0x4)
      output(msgSubBattCharge);
    
    if($HCU_HevRdySta == 0x0 && $VCU_EvDrvRdySta == 0x0 && $SMK_TrmnlCtrlGrpStaBDC == 0x0)
      output(msgSubBattDisCharge);
  }
  
  else
  {
  }

  timer_SubBatt_Charge.Set(TIME_timer_SubBatt_Charge);
}



on timer timer_CGW_NM
{
  long channel = 2; //2번 채널

  //message NM_BLTN_CAM_FD _NM_CGW_CCU; //CANFD 
  message CAN2::NM_CGW_CCU _NM_CGW_CCU; //CAN
  
  if( @sysvar::panel::Switch_CGWNM == 0x1) //system variable 'Switch_CGWNM' 값이 1(ON) 이면
  {
    canSetChannelOutput(channel,1);
    _NM_CGW_CCU.Destination_CGW_CCU = 0x68; //뭔진 모르겠지만 이 값을 넣으니 통신상태 유지됨
    _NM_CGW_CCU.NMCommandCode_CGW_CCU = 0x2;
    _NM_CGW_CCU.NMSleepFlag_CGW_CCU = 0x1;
    
    output(_NM_CGW_CCU); //생성한 메시지 출력
  }
  else
  {}
  
    timer_CGW_NM.Set(TIME_CGW_NM); //타이머 다시 세팅(입력한 시간만큼 지나서 timer가 수행됨)
}

on timer timer_CF_AVN_CluUSMReset
{
  //message  HU_USM_02_00ms _HU_USM_E_04; //CANFD
  message HU_USM_E_04 _HU_USM_E_04; //CAN
  
  _HU_USM_E_04.CF_AVN_CluUSMReset = 0x0;//Default
  
  output(_HU_USM_E_04);
}

on timer timer_HU_BLTN_CAM_E_01
{
  //message HU_BLTN_CAM_01_00ms _HU_BLTN_CAM_E_01;//CANFD
  message HU_BLTN_CAM_E_01 _HU_BLTN_CAM_E_01; //CAN

  int i;
  for( i=0; i<8; i++)
  {
    _HU_BLTN_CAM_E_01.byte(i) = 0xFF;
  }
  
  output(_HU_BLTN_CAM_E_01);
}


/* system variable event handler */

on sysvar_update panel::LED_Ctrl_SetOWD
{
  valueSet_HU_BLTN_CAM_E_00();
  
  if($BLTN_CAM_RecSet_OWD == 0x1)
    _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_OWD_NvalueSet = 0x2;//ON
  else
    _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_OWD_NvalueSet = 0x1;//OFF

  output(_HU_BLTN_CAM_E_00);
}

