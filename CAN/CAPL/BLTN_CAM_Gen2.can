  _HU_BLTN_CAM_E_00.BLTN_CAM_Locatn_Stm_NvalueSet = $BLTN_CAM_Set_Locatn_Stm;
  _HU_BLTN_CAM_E_00.BLTN_CAM_PrkTime_NvalueSet = $BLTN_CAM_Set_PrkTime;
  _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_DEV_NvalueSet = $BLTN_CAM_RecSet_DEV;
  _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_OWD_NvalueSet = $BLTN_CAM_RecSet_OWD;
  _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_OWP_NvalueSet = $BLTN_CAM_RecSet_OWP;
  _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_PEV_NvalueSet = $BLTN_CAM_RecSet_PEV;
  _HU_BLTN_CAM_E_00.BLTN_CAM_Spd_Stm_NvalueSet = $BLTN_CAM_Set_Spd_Stm;
  //_HU_BLTN_CAM_E_00.BLTN_CAM_Strangl_Stm_NvalueSet = 
  _HU_BLTN_CAM_E_00.BLTN_CAM_TML_Int_NvalueSet = $BLTN_CAM_Set_Drv_TML_Int;
  _HU_BLTN_CAM_E_00.BLTN_CAM_Time_Stm_NvalueSet = $BLTN_CAM_Set_Tim_Stm;
  _HU_BLTN_CAM_E_00.BLTN_CAM_TrnSig_Stm_NvalueSet = $BLTN_CAM_Set_TrnSig_Stm;
  _HU_BLTN_CAM_E_00.BLTN_CAM_EV_RecMaxTime_NvalueSet = $BLTN_CAM_Set_EV_RecMaxTime;
  
}

void valueSet_HU_BLTN_CAM_E_01()
{
  _HU_BLTN_CAM_E_01.BLTN_CAM_AppNoti_PEV_NvalueSet= $BLTN_CAM_Set_PEV_AppNoti;
  _HU_BLTN_CAM_E_01.BLTN_CAM_WiFi_AutoOn_NvalueSet= $BLTN_CAM_Set_WiFi_AutoOn;
