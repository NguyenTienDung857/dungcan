on sysvar_update panel::TrackBar_EV_Time_Bfr  //트랙바의 값이 변동되면 실행
{
    Evt_BfrTime = getSignal(BLTN_CAM_Set_EV_BfrTime) + 10; //현재 빌트인캠 Bfr 시간 세팅 값 가져오기
  
    valueSet_HU_BLTN_CAM_E_00(); //비어있는 _HU_BLTN_CAM_E_00 메시지 생성 후 현재 빌트인캠 세팅값으로 채우기
    
    switch (@panel::TrackBar_EV_Time_Bfr) //트랙바의 값 받기
    {
      case 1 : //트랙바가 1 이면 수행    
        if(Evt_BfrTime == 20)//Bfrtime가 이미 20s이면
          break; //switch문 탈출
        
        _HU_BLTN_CAM_E_00.BLTN_CAM_EV_BfrTime_NvalueSet = 0xA;//0xA: 20s가 아니면 0xA 값을 생성한 메시지에 값 넣기
        output(_HU_BLTN_CAM_E_00); //생성한 메시지 송출하기
        write("Evt_BfrTime 20"); //출력창에 "Evt_BfrTime 20" 출력하기
        break; //switch문 탈출
        
      case 2 : if(Evt_BfrTime == 15) break;
        _HU_BLTN_CAM_E_00.BLTN_CAM_EV_BfrTime_NvalueSet = 0x5; output(_HU_BLTN_CAM_E_00); write("Evt_BfrTime 15"); break;
      case 3 : if(Evt_BfrTime == 10) break;
        _HU_BLTN_CAM_E_00.BLTN_CAM_EV_BfrTime_NvalueSet = 0x0; output(_HU_BLTN_CAM_E_00); write("Evt_BfrTime 10"); break;
      default : write("TrackBar_DEV_Time_Bfr default"); break;
    }
}

on sysvar_update panel::TrackBar_EV_Time_Aft
{
  Evt_AftTime = getSignal(BLTN_CAM_Set_EV_AftTime) + 10;

  valueSet_HU_BLTN_CAM_E_00();
  
  if(@panel::TrackBar_EV_Time_Aft != Evt_AftTime)
  {
    switch (@panel::TrackBar_EV_Time_Aft) {
      case 10 : _HU_BLTN_CAM_E_00.BLTN_CAM_EV_AftTime_NvalueSet = 0x0; output(_HU_BLTN_CAM_E_00); write("Evt_AftTime 10"); break;
      case 15 : _HU_BLTN_CAM_E_00.BLTN_CAM_EV_AftTime_NvalueSet = 0x5; output(_HU_BLTN_CAM_E_00); write("Evt_AftTime 15"); break;
      case 20 : _HU_BLTN_CAM_E_00.BLTN_CAM_EV_AftTime_NvalueSet = 0xA; output(_HU_BLTN_CAM_E_00); write("Evt_AftTime 20"); break;
      default : write("TrackBar_PEV_Time_Aft default"); break;
    }
  }
}

on sysvar_update panel::TrackBar_EV_Time_Before
{
  Evt_BfrTime = getSignal(BLTN_CAM_Set_EV_BfrTime) + 10;
  
  valueSet_HU_BLTN_CAM_E_00();
    
  switch (@panel::TrackBar_EV_Time_Bfr)
  {
    case 1 :
    {
      if(Evt_BfrTime == 20)
        break;

      _HU_BLTN_CAM_E_00.BLTN_CAM_EV_BfrTime_NvalueSet = 0xA;
      output(_HU_BLTN_CAM_E_00);
      write("Evt_BfrTime 20");
      break;
    }
      
    case 2 :
    {
      if(Evt_BfrTime == 15)
        break;
      
      _HU_BLTN_CAM_E_00.BLTN_CAM_EV_BfrTime_NvalueSet = 0x5;
      output(_HU_BLTN_CAM_E_00);
      write("Evt_BfrTime 15");
      break;
    }
      
    case 3 :
    {
      if(Evt_BfrTime == 10)
        break;
      
      _HU_BLTN_CAM_E_00.BLTN_CAM_EV_BfrTime_NvalueSet = 0x0;
      output(_HU_BLTN_CAM_E_00);
      write("Evt_BfrTime 10");
      break;
    }
      
    default :
    {
        write("TrackBar_DEV_Time_Bfr default");
        break;
    }
  }
}

