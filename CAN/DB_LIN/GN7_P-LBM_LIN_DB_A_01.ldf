Diagnostic_signals {
  MasterReqB0: 8, 0 ;
  MasterReqB1: 8, 0 ;
  MasterReqB2: 8, 0 ;
  MasterReqB3: 8, 0 ;
  MasterReqB4: 8, 0 ;
  MasterReqB5: 8, 0 ;
  MasterReqB6: 8, 0 ;
  MasterReqB7: 8, 0 ;
  SlaveRespB0: 8, 0 ;
  SlaveRespB1: 8, 0 ;
  SlaveRespB2: 8, 0 ;
  SlaveRespB3: 8, 0 ;
  SlaveRespB4: 8, 0 ;
  SlaveRespB5: 8, 0 ;
  SlaveRespB6: 8, 0 ;
  SlaveRespB7: 8, 0 ;
}



Frames {
  BMS_CERTI: 16, Master1, 8 {
    Rdm_Val1, 0 ;
    Rdm_Val2, 16 ;
    Rdm_Val3, 32 ;
    Rdm_Val4, 48 ;
  }
  BMS_CERTI_CHECK: 17, Slave1, 8 {
    Rdm_Rval1, 0 ;
    Rdm_Rval2, 16 ;
    Rdm_Rval3, 32 ;
    Rdm_Rval4, 48 ;
  }
  BMS_INFO_01: 18, Slave1, 8 {
    BAT_Type, 0 ;
    BAT_Capa_for_BLTN_CAM, 8 ;
    BAT_SOH, 16 ;
    B_VOLTAGE, 24 ;
    IGN_VOLTAGE, 32 ;
    BAT_Capa_Total, 40 ;
    BMS_INFO_01_Reserved7, 56 ;
    BAT_Option_Type, 4 ;
  }
  BMS_INFO_02: 19, Slave1, 8 {
    BAT_SOC_for_BLTN_CAM, 0 ;
    BAT_Volt, 8 ;
    BAT_Current, 16 ;
    BAT_Temp, 32 ;
    BMS_INFO_02_Reserved7, 56 ;
    BMS_INFO_02_Reserved6, 48 ;
  }
  BMS_INFO_03: 20, Slave1, 8 {
    BAT_Status, 0 ;
    BAT_Volt_Fault_Info, 8 ;
    BAT_Fault_Info, 16 ;
    BAT_Current_Fault_Info, 24 ;
    LBM_Maxdischr_Info, 48 ;
    BAT_Discharging_Time_Info, 32 ;
    BLTM_CAM_Current, 40 ;
    BLTN_CAM_End_Request, 50 ;
    BMS_INFO_03_Reserved1, 52 ;
    BMS_INFO_03_Reserved2, 56 ;
  }
  BMS_OPERATION_CONTROL: 21, Master1, 8 {
    BAT_Charge_Control, 0 ;
    Reserved3M_16bit, 24 ;
    Reserved45M_16bit, 32 ;
    Reserved67M_16bit, 48 ;
    BAT_Discharging_Time, 8 ;
    Key_On_Off_Info, 16 ;
  }
  LIBS_DATA_INFO_01: 22, Slave1, 8 {
    Total_Charge_Capa, 0 ;
    Cycle_Index, 32 ;
    Reserved6, 48 ;
    Reserved7, 56 ;
  }
  BMS_VERSION: 36, Slave1, 8 {
    SW_Version, 0 ;
    HW_Version, 32 ;
  }
}



Diagnostic_frames {
  MasterReq: 0x3c {
    MasterReqB0, 0 ;
    MasterReqB1, 8 ;
    MasterReqB2, 16 ;
    MasterReqB3, 24 ;
    MasterReqB4, 32 ;
    MasterReqB5, 40 ;
    MasterReqB6, 48 ;
    MasterReqB7, 56 ;
  }
  SlaveResp: 0x3d {
    SlaveRespB0, 0 ;
    SlaveRespB1, 8 ;
    SlaveRespB2, 16 ;
    SlaveRespB3, 24 ;
    SlaveRespB4, 32 ;
    SlaveRespB5, 40 ;
    SlaveRespB6, 48 ;
    SlaveRespB7, 56 ;
  }
}

Node_attributes {
  Slave1{
    LIN_protocol = "2.1" ;
    configured_NAD = 0x2 ;
    initial_NAD = 0xB ;
    product_id = 0x1F, 0x2, 1 ;
    P2_min = 100 ms ;
    ST_min = 20 ms ;
    N_As_timeout = 1000 ms ;
    N_Cr_timeout = 1000 ms ;
    configurable_frames {
      BMS_CERTI ;
      BMS_CERTI_CHECK ;
      BMS_INFO_01 ;
      BMS_INFO_02 ;
      BMS_INFO_03 ;
      BMS_OPERATION_CONTROL ;
      LIBS_DATA_INFO_01 ;
      BMS_VERSION ;
    }
  }
}

Schedule_tables {
 NormalTable {
    BMS_CERTI delay 10 ms ;
    BMS_CERTI_CHECK delay 10 ms ;
    BMS_INFO_01 delay 240 ms ;
    BMS_INFO_02 delay 240 ms ;
    BMS_INFO_03 delay 240 ms ;
    BMS_OPERATION_CONTROL delay 10 ms ;
    LIBS_DATA_INFO_01 delay 240 ms ;
    BMS_VERSION delay 10 ms ;
  }
}


Signal_encoding_types {
  ACU_Current_Encoding {
    physical_value, 0, 0, 1, 0 ;
    logical_value, 0, "PDC_ConverterReq != 0x3" ;
    logical_value, 1, "PDC_ConverterReq == 0x3" ;
  }
