void MainTest(){
  Mode_state = 0x2;
  send_SMK_TrmnlCtrlGrpStaBDC_timer.set(10);
  send_ICU_PowerAutoCutModSta_timer.set(10);
  send_IAU_ProfileIDRVal_timer.set(10);
  send_IAU_ProfileIDRVal_timer.set(10);  
  
  TestWaitForValueInput("Please enter the test ID (1/2/3/4/5/6)", 300000);
  switch (TestGetValueInput()){
    
   case(1) : BAS_017_1(); break;
   case(2) : BAS_017_4(); break;
   case(3) : BAS_017_7(); break; 
   case(4) : BAS_017_8(); break;
   case(5) : BAS_017_11(); break;
   case(6) : BAS_017_14(); break;
     
  }    
} 

