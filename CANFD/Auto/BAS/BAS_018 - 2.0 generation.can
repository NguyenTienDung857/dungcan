void MainTest(){
  write("=== RUN BAS_018 SEQUENTIALLY: 1 -> 2 -> 3 -> 4 -> 5 -> 6 -> 7 -> 8 ===");

  @panel::Switch_CGWNM = 1;
  BAS_018_1();

  @panel::Switch_CGWNM = 1;
  BAS_018_2();

  @panel::Switch_CGWNM = 1;
  BAS_018_3();

  @panel::Switch_CGWNM = 1;
  BAS_018_4();

  @panel::Switch_CGWNM = 1;
  BAS_018_5();

  @panel::Switch_CGWNM = 1;
  BAS_018_6();

  @panel::Switch_CGWNM = 1;
  BAS_018_7();

  @panel::Switch_CGWNM = 1;
  BAS_018_8();

  @panel::Switch_CGWNM = 0;
}
