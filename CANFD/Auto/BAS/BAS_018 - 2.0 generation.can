/*@!Encoding:1252*/
/*
  LUONG HOAT DONG - BAS_018 - 2.0 generation

  Muc dich:
    - Kiem tra hanh vi xoa/giu recorded files va trang thai recording setting
      khi Built-in Cam da co file ghi san, Guest profile da bi random setting,
      sau do ICU_PowerAutoCutModSta chuyen tu Factory/Dealer sang Customer.
    - File nay tap trung vao thoi diem chuyen mode so voi KEY OFF, KEY ON,
      ACC ON, ACC+IGN ON.

  Setup chung cua moi testcase:
    1. Set battery bang Set_Battery().
    2. Tao parking recorded video bang Create_PRK_Recorded_vid().
    3. Tao driving recorded video bang Create_DRV_Recorded_vid().
    4. Random setting Guest profile bang Set_Profile_Guest().
    5. Chuyen ICU_PowerAutoCutModSta theo tung scenario.
    6. Khong dung message box; tu dong set KEY/ACC/IGN va kiem tra
       recording/default/Guest settings bang signal.
    7. Goi Init() va tat Switch_CGWNM sau testcase.

  BAS_018_1 - Factory -> Customer khi khong chen KEY OFF/ON rieng:
    - Tao file, set ICU_PowerAutoCutModSta = 0x0 Factory.
    - Random Guest profile, cho 5s.
    - Set ICU_PowerAutoCutModSta = 0x2 Customer.
    - Pass condition1 neu OWD/OWP/DEV/PEV setting deu OFF (0x1).
    - Pass condition2 neu 21 setting ve default bang signal.

  BAS_018_2 - Dealer -> Customer khi khong chen KEY OFF/ON rieng:
    - Giong BAS_018_1 nhung mode ban dau la 0x1 Dealer.
    - Ky vong: tat ca recording setting OFF va 21 setting ve default.

  BAS_018_3 - KEY OFF, Factory, KEY ON, Customer:
    - Tao file va random Guest profile.
    - KEY OFF, set Factory mode 0x0, cho 5s.
    - KEY ON, cho 4s, sau do set Customer mode 0x2.
    - Pass neu 21 setting ve default bang signal.

  BAS_018_4 - KEY OFF, Dealer, KEY ON, Customer:
    - Giong BAS_018_3 nhung mode truoc KEY ON la 0x1 Dealer.
    - Pass neu 21 setting ve default bang signal.

  BAS_018_5 - KEY OFF, Factory, ACC+IGN ON, Customer:
    - KEY OFF, set Factory mode 0x0.
    - Tu dong set KEY_ON de thay thao tac ACC va IGN ON.
    - Sau 1.5s, set Customer mode 0x2.
    - Pass neu 21 setting van bang snapshot Guest profile.

  BAS_018_6 - KEY OFF, Dealer, ACC+IGN ON, Customer:
    - Giong BAS_018_5 nhung mode truoc ACC+IGN ON la 0x1 Dealer.
    - Pass neu 21 setting van bang snapshot Guest profile.

  BAS_018_7 - KEY OFF, Factory, chi ACC ON, Customer:
    - KEY OFF, set Factory mode 0x0.
    - Tu dong set SMK_TrmnlCtrlGrpStaBDC = 0x1 de thay thao tac ACC ON.
    - Sau 1.5s, set Customer mode 0x2.
    - Pass neu 21 setting van bang snapshot Guest profile.

  BAS_018_8 - KEY OFF, Dealer, chi ACC ON, Customer:
    - Giong BAS_018_7 nhung mode truoc ACC ON la 0x1 Dealer.
    - Pass neu 21 setting van bang snapshot Guest profile.

  MainTest:
    - Khong hoi chon test ID nua.
    - Chay tuan tu BAS_018_1 -> BAS_018_2 -> BAS_018_3 -> BAS_018_4 ->
      BAS_018_5 -> BAS_018_6 -> BAS_018_7 -> BAS_018_8.
    - Bat lai Switch_CGWNM = 1 truoc moi testcase vi moi testcase tat switch
      sau khi ket thuc.
    - Moi testcase chup anh cua so BAS bang CaptureGraphics() voi cac signal
      lien quan den mode, KEY, parking recording va recording setting.
*/
// Preconditions: - ACC and IGN and ccNC/ccIC switch OFF state, AVN mode
// Add graphics: Graphics 2: BLTN_CAM_RecSta_OWP;ICU_PowerAutoCutModSta
includes
{

  #include "DeclarationFunction_Gen2.h"

}

variables
{
  // Message Declaration
  // CAN
  message HU_BLTN_CAM_E_00 _HU_BLTN_CAM_E_00;
  message HU_BLTN_CAM_PE_00_200ms _HU_BLTN_CAM_PE_00_200ms;
  message HU_BLTN_CAM_E_01 _HU_BLTN_CAM_E_01;
  message SMK_13_200ms _SMK_13_200ms;
  message ICU_08_200ms _ICU_08_200ms;
  message IAU_16_200ms _IAU_16_200ms;
  //Global Variable Declaration
//  byte set_120h_value = 0x1; // For model using 120h parking but I turn OFF this setting
  byte set_120h_value = 0x0;  // For model don't have 120h parking
  byte arr_RecSet[2] = {0x1,0x2};
  byte arr_OWPTime[19] = {0x2,0x3,0x4,0x5,0x6,0x7,0x8,0x9,0xA,0xB,0xC,0xD,0xE,0xF,0x10,0x11,0x12,0x13,0x14};
  byte arr_EVtime[3] = {0x0,0x5,0xA};
  byte arr_TMLinterval[3] = {0x1,0x2,0x5};
  byte arr_CAMAngle[10] = {0x1,0x2,0x3,0x4,0x5,0x11,0x12,0x13,0x14,0x15};
  byte arr_EVSen[5] = {0x1,0x2,0x3,0x4,0x5};
  byte arr_random_setting[21];
  byte arr_get_setting[21];
  byte arr_Profile_Guest_setting[21];
  byte arr_Profile_Driver1_setting[21];
  byte arr_Profile_Driver2_setting[21];
  byte arr_Default_Setting[21] = {0x1,0x1,0x1,0x1,0x0,0x14,0x1,0x0,0x0,0x2,0x2,0x2,0x2,0x2,0x2,0x2,0x0,0x0,0x3,0x3,0x2}; //arr_Default_Setting[5] = 0x0 - Don't have 120h Parking
                                                                                                                          //arr_Default_Setting[5] = 0x1 - For model using 120h Parking
  int index;
  int i;
  int flag = 0;
  int flag_RecSet_error = 0;
  int condition1 = 0, condition2 = 0, condition3 = 0;
  byte KEY_state = 0x0;
  byte Profile_value = 0x0;
  byte Mode_state = 0x0;
  byte Bat_val;
  char PLBM_Battery[4] = {'P','L','B','M'};
  char eAGM_Battery[4] = {'E','A','G','M'};
  char answer[4];
  // Timer Declaration
  msTimer send_SMK_TrmnlCtrlGrpStaBDC_timer;
  msTimer send_ICU_PowerAutoCutModSta_timer;
  msTimer send_IAU_ProfileIDRVal_timer;
  msTimer send_ICU_BS2SoC_timer;
}

int BAS_018_Check_Default_Settings(){
  int idx;

  Get_setting();

  for (idx = 0; idx <= 20; idx++){
    if (arr_get_setting[idx] != arr_Default_Setting[idx]){
      write("Default setting mismatch at index %d: actual=0x%X, expected=0x%X", idx, arr_get_setting[idx], arr_Default_Setting[idx]);
      return 0;
    }
  }

  write("All settings are initialized to default settings");
  return 1;
}

int BAS_018_Check_Guest_Settings(){
  int idx;

  Get_setting();

  for (idx = 0; idx <= 20; idx++){
    if (arr_get_setting[idx] != arr_Profile_Guest_setting[idx]){
      write("Guest setting mismatch at index %d: actual=0x%X, expected=0x%X", idx, arr_get_setting[idx], arr_Profile_Guest_setting[idx]);
      return 0;
    }
  }

  write("All settings remain unchanged from Guest profile snapshot");
  return 1;
}

testcase BAS_018_1(){
  testStep("Notifications","Start test-case BAS_018_1");
  write("=== START BAS_018_1 ===");

  write("=== Create Recorded File ===");

  write("Set Battery"); Set_Battery();

  write("Create_PRK_Recorded_vid"); Create_PRK_Recorded_vid();Create_PRK_Recorded_vid();

  setSignal(ICU_PowerAutoCutModSta,0x0); write("Factory Mode");

  write("Create_DRV_Recorded_vid"); Create_DRV_Recorded_vid();

  write("=== Random Settings ===");

  Set_Profile_Guest();

  testReportAddWindowCapture("Profile Settings","","Profile Guest","./profile_setting.jpg");

  testWaitForTimeout(5000);

  setSignal(ICU_PowerAutoCutModSta,0x2); write("Customer Mode");

  testWaitForTimeout(5000);

  if ($BLTN_CAM_RecSet_OWD == 0x1 && $BLTN_CAM_RecSet_OWP == 0x1 && $BLTN_CAM_RecSet_DEV == 0x1 && $BLTN_CAM_RecSet_PEV == 0x1) {

    write("All recording settings are turned Off");

    condition1 = 1;

  }

  write("Verify default settings automatically instead of asking for recorded-file deletion confirmation");
  if (BAS_018_Check_Default_Settings() == 1) {
    condition2 = 1;
  }

  if (condition1 == 1 && condition2 == 1) {
    testStepPass("Pass","All conditions have met. Test-case is OK");
    write("Test-case is OK");
  }
  else {
    int arr[3];

    arr[0] = condition1;
    arr[1] = condition2;

    testStepFail("Fail","Condition hasn't met. Test-case is NG");

    for (i = 0; i < 2; i++){

      if (arr[i] != 1){

        write("Condition %d is not met", i+1);

      }
    }
  }

  write("[Capture] Capture related BAS_018_1 signals before reset");
  CaptureGraphics("BAS", "BLTN_CAM_RecSta_OWP;ICU_PowerAutoCutModSta;SMK_TrmnlCtrlGrpStaBDC;ICU_BS2SoC;BLTN_CAM_RecSet_OWD;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSet_DEV;BLTN_CAM_RecSet_PEV;IAU_ProfileIDRVal");

  Init();
  @panel::Switch_CGWNM = 0;

  testStep("Notifications","Done test-case BAS_018_1");
  write("=== FINISH BAS_018_1 ===");
}

