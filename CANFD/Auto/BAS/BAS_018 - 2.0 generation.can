void MainTest(){
  @panel::Switch_CGWNM = 1;  
  
  TestWaitForValueInput("Please enter the test ID (1/2/3/4/5/6/7/8)", 300000);
  switch (TestGetValueInput()){
    
   case(1) : BAS_018_1(); break;
   case(2) : BAS_018_2(); break;
   case(3) : BAS_018_3(); break; 
   case(4) : BAS_018_4(); break; 
   case(5) : BAS_018_5(); break; 
   case(6) : BAS_018_6(); break; 
   case(7) : BAS_018_7(); break; 
   case(8) : BAS_018_8(); break;      
     
  }
  
  @panel::Switch_CGWNM = 0;  
}