/*@!Encoding:1252*/
// Preconditions: - ACC and IGN and ccNC/ccIC switch OFF state, AVN mode
// Add graphics: Graphics 2: BLTN_CAM_RecSta_OWP;ICU_PowerAutoCutModSta
includes 
{

  #include "DeclarationFunction_Gen2.h"

}

variables
{
  // Message Declaration
  // CAN
  message HU_BLTN_CAM_E_00 _HU_BLTN_CAM_E_00;
  message HU_BLTN_CAM_PE_00_200ms _HU_BLTN_CAM_PE_00_200ms;
  message HU_BLTN_CAM_E_01 _HU_BLTN_CAM_E_01;
  message SMK_13_200ms _SMK_13_200ms;
  message ICU_08_200ms _ICU_08_200ms;
  message IAU_16_200ms _IAU_16_200ms;  
  //Global Variable Declaration
//  byte set_120h_value = 0x1; // For model using 120h parking but I turn OFF this setting 
  byte set_120h_value = 0x0;  // For model don't have 120h parking 
  byte arr_RecSet[2] = {0x1,0x2};
  byte arr_OWPTime[19] = {0x2,0x3,0x4,0x5,0x6,0x7,0x8,0x9,0xA,0xB,0xC,0xD,0xE,0xF,0x10,0x11,0x12,0x13,0x14}; 
  byte arr_EVtime[3] = {0x0,0x5,0xA};
  byte arr_TMLinterval[3] = {0x1,0x2,0x5};
  byte arr_CAMAngle[10] = {0x1,0x2,0x3,0x4,0x5,0x11,0x12,0x13,0x14,0x15};
  byte arr_EVSen[5] = {0x1,0x2,0x3,0x4,0x5};
  byte arr_random_setting[21];
  byte arr_get_setting[21];
  byte arr_Profile_Guest_setting[21];
  byte arr_Profile_Driver1_setting[21];
  byte arr_Profile_Driver2_setting[21];
  byte arr_Default_Setting[21] = {0x1,0x1,0x1,0x1,0x0,0x14,0x1,0x0,0x0,0x2,0x2,0x2,0x2,0x2,0x2,0x2,0x0,0x0,0x3,0x3,0x2}; //arr_Default_Setting[5] = 0x0 - Don't have 120h Parking 
                                                                                                                          //arr_Default_Setting[5] = 0x1 - For model using 120h Parking 
  int index;
  int i;
  int flag = 0;
  int flag_RecSet_error = 0;
  int condition1 = 0, condition2 = 0, condition3 = 0;
  byte KEY_state = 0x0;
  byte Profile_value = 0x0;
  byte Mode_state = 0x0;
  byte Bat_val;
  char PLBM_Battery[4] = {'P','L','B','M'};
  char eAGM_Battery[4] = {'E','A','G','M'};
  char answer[4];    
  // Timer Declaration
  msTimer send_SMK_TrmnlCtrlGrpStaBDC_timer;
  msTimer send_ICU_PowerAutoCutModSta_timer;
  msTimer send_IAU_ProfileIDRVal_timer;
  msTimer send_ICU_BS2SoC_timer;
}

testcase BAS_018_1(){
  testStep("Notifications","Start test-case BAS_018_1");
  write("=== START BAS_018_1 ===");
  
  write("=== Create Recorded File ===");
  
  write("Set Battery"); Set_Battery();  
  
  write("Create_PRK_Recorded_vid"); Create_PRK_Recorded_vid();Create_PRK_Recorded_vid();
  
  setSignal(ICU_PowerAutoCutModSta,0x0); write("Factory Mode");
  
  write("Create_DRV_Recorded_vid"); Create_DRV_Recorded_vid();
  
  write("=== Random Settings ===");
  
  Set_Profile_Guest();
  
  testReportAddWindowCapture("Profile Settings","","Profile Guest","./profile_setting.jpg");  
  
  testWaitForTimeout(5000);
  
  setSignal(ICU_PowerAutoCutModSta,0x2); write("Customer Mode");
  
  testWaitForTimeout(5000);
  
  if ($BLTN_CAM_RecSet_OWD == 0x1 && $BLTN_CAM_RecSet_OWP == 0x1 && $BLTN_CAM_RecSet_DEV == 0x1 && $BLTN_CAM_RecSet_PEV == 0x1) {
    
    write("All recording settings are turned Off");
    
    condition1 = 1;
    
  }
      
  if (testWaitForMessageBox("Turn ON ACC and IGN and ccNC/ccIC to check whether the recorded files are deleted",300000,"Choose Yes/No",4) == 6) {
        
    write("Recorded files are deleted");
        
    condition2 = 1;
      
  }
  else {
    
    write("Recorded files aren't deleted");
    
  }
  
  if (condition1 == 1 && condition2 == 1) {
    testStepPass("Pass","All conditions have met. Test-case is OK");
    write("Test-case is OK");
  }
  else {
    int arr[3];
    
    arr[0] = condition1;
    arr[1] = condition2;
    
    testStepFail("Fail","Condition hasn't met. Test-case is NG");
    
    for (i = 0; i < 2; i++){
      
      if (arr[i] != 1){
        
        write("Condition %d is not met", i+1);
        
      }   
    }
  }
  
  Init();
  @panel::Switch_CGWNM = 0;
  
  testStep("Notifications","Done test-case BAS_018_1");
  write("=== FINISH BAS_018_1 ===");
}

