void MainTest(){
  TestWaitForValueInput("Please enter the test ID", 300000);
  switch (TestGetValueInput()){
   case(1) :
   BAT_007_2(); break;
   case(2) :
   BAT_007_3(); break;    
   case(3) :
   BAT_007_4(); break;        
   case(4) :
   BAT_007_5(); break; 
   case(5) :
   BAT_007_6(); break;
   case(6) :
   BAT_007_7(); break;  
   case(7) :
   BAT_007_8(); break;  
   case(8) :
    BAT_007_2();
    BAT_007_3();
    BAT_007_4();
    BAT_007_5();
    BAT_007_6();
    BAT_007_7();
    BAT_007_8();   
  }
}