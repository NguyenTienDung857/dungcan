          case(16): write("Mismatch >> FCAM Angle: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(17): write("Mismatch >> RCAM Angle: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(18): write("Mismatch >> DEV Sen Level: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(19): write("Mismatch >> PEV Sen Level: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
