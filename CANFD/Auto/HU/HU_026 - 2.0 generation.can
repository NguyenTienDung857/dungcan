  testWaitForTimeout(5000);
  
  write("Reset Profile 1");
  setSignal(IAU_ProfileIDRVal, 0x2); // Profile Driver 1
  testWaitForTimeout(5000);  
  @panel::Button_clu_USMReset = 1; // Clu_USMReset
  testWaitForTimeout(5000);  
  
  write("Reset Profile 2");
  setSignal(IAU_ProfileIDRVal, 0x3); // Profile Driver 2
  testWaitForTimeout(5000);  
  @panel::Button_clu_USMReset = 1; // Clu_USMReset
  testWaitForTimeout(5000);    
  
  write("=== FRS OPERATION ===");
  
  write("Set Customer Mode"); setSignal(ICU_PowerAutoCutModSta, 0x2); //Customer Mode
  testWaitForTimeout(1000);
  write("Set Profile Guest"); setSignal(IAU_ProfileIDRVal, 0x1); // Profile Guest
  testWaitForTimeout(5000);
  write("Send NvalueSet Value");
  
  _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_OWD_NvalueSet = 0x2; // ON
  _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_OWP_NvalueSet = 0x2; // ON
  _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_DEV_NvalueSet = 0x2; // ON
  _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_PEV_NvalueSet = 0x2; // ON
  
  Random_Settings();
  write("=== RANDOM SETTING ===");
  for (i = 0; i <= 20; i++){
   write("arr_random_setting[%d] = 0x%X", i, arr_random_setting[i]);
  }
  
  write("=== ENTER BLTN_CAM ==="); Enter_BLTN_CAM();
  testWaitForTimeout(4000);
    
  BLTN_CAM_Settings();
    
  write("=== EXIT BLTN_CAM ==="); Exit_BLTN_CAM();
  testWaitForTimeout(3000);
  
  testReportAddWindowCapture("Profile Settings","","Profile Guest","./profile_setting.jpg");  
  
  write("=== ENTER BLTN_CAM ==="); Enter_BLTN_CAM();
  
  write("=== CHANGE PROFILE ===");
  
  write("Change to Profile Driver 1");
  setSignal(IAU_ProfileIDRVal, 0x2); // Profile Driver 1
  testWaitForTimeout(5000);
  
  write("Run Get_setting()"); Get_setting(); 
  
  for( i = 0; i <= 20; i++){
    if(arr_Profile_Guest_setting[i] == arr_get_setting[i]){
      flag++;
    }
    else{
      write("Fail: Test-case is NG");
      switch(i){
          case(0): write("Mismatch >> OWD: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(1): write("Mismatch >> OWP: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(2): write("Mismatch >> DEV: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(3): write("Mismatch >> PEV: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(4): write("Mismatch >> 120h: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(5): write("Mismatch >> Parking Time: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(6): write("Mismatch >> TML Interval: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(7): write("Mismatch >> Bfr Time: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(8): write("Mismatch >> Aft Time: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(9): write("Mismatch >> EV Sen Stamp: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(10): write("Mismatch >> Gear Stamp: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(11): write("Mismatch >> Location Stamp: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(12): write("Mismatch >> Velocity Stamp: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(13): write("Mismatch >> Time Stamp: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(16): write("Mismatch >> FCAM Angle: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(17): write("Mismatch >> RCAM Angle: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(18): write("Mismatch >> DEV Sen Level: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(19): write("Mismatch >> PEV Sen Level: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(20): write("Mismatch >> App Notification: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
      }
    }
  }
  if (flag == 21) {
    write("Profile 1 is copied from Guest Profile");
    condition1 = 1;
  }
  else {
    testStepFail("Fail", "Test-case is NG");
  }
  flag = 0;
  
  CaptureGraphics(); write("Run Capture Graphics()");
  testReportAddWindowCapture("Profile Settings","","Profile Driver 1","./profile_setting.jpg");  
  
  write("Change to Profile Driver 2");
  setSignal(IAU_ProfileIDRVal, 0x3); // Profile Driver 2
  testWaitForTimeout(5000);
  
  write("Run Get_setting()"); Get_setting();

  for( i = 0; i <= 20; i++){
    if(arr_Profile_Guest_setting[i] == arr_get_setting[i]){
      flag++;
    }
    else{
      write("Fail: Test-case is NG");
      switch(i){
          case(0): write("Mismatch >> OWD: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(1): write("Mismatch >> OWP: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(2): write("Mismatch >> DEV: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(3): write("Mismatch >> PEV: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(4): write("Mismatch >> 120h: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(5): write("Mismatch >> Parking Time: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(6): write("Mismatch >> TML Interval: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(7): write("Mismatch >> Bfr Time: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(8): write("Mismatch >> Aft Time: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(9): write("Mismatch >> EV Sen Stamp: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(10): write("Mismatch >> Gear Stamp: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(11): write("Mismatch >> Location Stamp: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(12): write("Mismatch >> Velocity Stamp: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(13): write("Mismatch >> Time Stamp: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(16): write("Mismatch >> FCAM Angle: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(17): write("Mismatch >> RCAM Angle: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(18): write("Mismatch >> DEV Sen Level: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(19): write("Mismatch >> PEV Sen Level: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
          case(20): write("Mismatch >> App Notification: guest = 0x%X, get = 0x%X", arr_Profile_Guest_setting[i], arr_get_setting[i]); break;
      }
    }
  }
  if (flag == 21) {
    write("Profile 2 is copied from Guest Profile");
    condition2 = 1;
  }
  else {
    testStepFail("Fail", "Test-case is NG");
  }
  flag = 0;
  
  CaptureGraphics(); write("Run Capture Graphics()");
  testReportAddWindowCapture("Profile Settings","","Profile Driver 2","./profile_setting.jpg");    
  
  if (condition1 == 1 && condition2 == 1) {
    testStepPass("Pass","All conditions have met. Test-case is OK");
    write("Test-case is OK");
  }
  else {
    int arr[3];
    
    arr[0] = condition1;
    arr[1] = condition2;
    
    testStepFail("Fail","Condition hasn't met. Test-case is NG");
    
    for (i = 0; i < 2; i++){
      
      if (arr[i] != 1){
        
        write("Condition %d is not met", i+1);
        
      }   
    }
  }  
  
  write("KEY_OFF"); KEY_OFF();
  
  @panel::Switch_Clock = 0;
  @panel::Switch_CGWNM = 0; 
  
  write("=== FINISH HU_026_3 ===");  
}

void MainTest(){
  
  write("Run Init()"); Init(); 

  testWaitForValueInput("Notification: Enter the testcase ID: (1/2/3)",300000); 
  
  switch(testGetValueInput()){

    case 1: HU_026_1(); HU_026_2(); break;

    case 2: HU_026_3(); break;  
      
    case 3: HU_026_1(); HU_026_2(); HU_026_3(); break;   
  }

}

