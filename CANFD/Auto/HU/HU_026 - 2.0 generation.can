          case(9): write("Mismatch >> EV Sen Stamp: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
          case(10): write("Mismatch >> Gear Stamp: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
          case(11): write("Mismatch >> Location Stamp: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
          case(12): write("Mismatch >> Velocity Stamp: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
          case(13): write("Mismatch >> Time Stamp: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
          case(14): write("Mismatch >> Turn Signal Stamp: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
          case(15): write("Mismatch >> Audio: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
          case(16): write("Mismatch >> FCAM Angle: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
          case(17): write("Mismatch >> RCAM Angle: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
          case(18): write("Mismatch >> DEV Sen Level: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
          case(19): write("Mismatch >> PEV Sen Level: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
          case(20): write("Mismatch >> App Notification: random = 0x%X, get = 0x%X", arr_random_setting[i], arr_get_setting[i]); break;
        }
        break;
      }
    }
    loop++;
    
    if (loop == 2){
      switch(i){
        case(0): @panel::LED_Ctrl_SetOWP = 1; break;
        case(1): @panel::LED_Ctrl_SetOWD = 1; break;
        case(2): @panel::LED_Ctrl_SetPEV = 1; break;
        case(3): @panel::LED_Ctrl_SetDEV = 1; break;
        case(5): @panel::TrackBar_Timelaps_TIME = arr_random_setting[6]; break; 
        case(6): @panel::TrackBar_OWP_TIME = arr_random_setting[5]; break;
        case(7): @panel::TrackBar_EV_Time_Aft = arr_random_setting[8] + 10; break;
        case(8): if (arr_random_setting[7] == 0x0){@panel::TrackBar_EV_Time_Bfr = 1;}
                 else if (arr_random_setting[7] == 0x5){@panel::TrackBar_EV_Time_Bfr = 2;}
                 else {@panel::TrackBar_EV_Time_Bfr = 3;} break;
        case(9): @panel::LED_Ctrl_AudRec_Set = 1; break;  
        case(10): @panel::LED_Ctrl_Set_Locatn_Stm = 1; break;
        case(11): @panel::LED_Ctrl_Set_GearPos_Stm = 1; break;
        case(12): @panel::LED_Ctrl_Set_Tim_Stm = 1; break;           
        case(13): @panel::LED_Ctrl_Set_Spd_Stm = 1; break; 
        case(14): @panel::LED_Ctrl_Set_TrnSig_Stm = 1; break; 
        case(15): @panel::LED_Ctrl_Set_EVSen_Stm = 1; break; 
        case(16): @panel::TrackBar_RR_Ver_Pos = arr_random_setting[17]; break; 
        case(17): @panel::TrackBar_FR_Ver_Pos = arr_random_setting[16]; break;         
        case(18): @panel::TrackBar_PEV_Sen = arr_random_setting[19]; break; 
        case(19): @panel::TrackBar_DEV_Sen = arr_random_setting[19]; break; 
        case(20): @panel::Button_AppNoti_PEV = 1; break;      
      }
    } 
  } while (!same);
  
  loop = 0;
  
  write("=== PROFILE DRIVER 2 ===");  
  
  for (i = 0; i <= 20; i++){
   arr_Profile_Driver2_setting[i] = arr_get_setting[i];
   write("Profile_Driver2_setting[%d] = 0x%X", i, arr_Profile_Driver2_setting[i]);
  }
  
  testReportAddWindowCapture("Profile Settings","","Profile Driver 2","./profile_setting.jpg");  
}

void Init(){
  @panel::Switch_CGWNM = 1;
  
  @panel::Switch_Clock = 1;
  
  write("KEY_ON()"); KEY_ON();

  testWaitForTimeout(3000);
  
  send_ICU_ModState_timer.set(200);

  while (getSignal(BLTN_CAM_SD_Format_Op_State) != 0x1){
    @panel::Button_RecReset = 1; 
    testWaitForSignalChange(BLTN_CAM_SD_Format_Op_State,500);
  }
  
  write("KEY_OFF"); KEY_OFF();
  
  @panel::Switch_CGWNM = 0;
  
  @panel::Switch_Clock = 0; 
}

testcase HU_026_1() {
  testStep("Notification","Start test HU_026_1");
  write("=== START HU_026_1 ===");
  
  @panel::Switch_CGWNM = 1;
  
  @panel::Switch_Clock = 1;  
  
  write("KEY_ON"); KEY_ON();
  testWaitForTimeout(3000);

  write("=== RESET PROFILES ===");
  
  write("Set Factory Mode"); setSignal(ICU_PowerAutoCutModSta, 0x0); // Factory Mode
  testWaitForTimeout(1000);
  
  write("Reset Guest");
  setSignal(IAU_ProfileIDRVal, 0x1); // Profile Guest
  testWaitForTimeout(5000);  
  @panel::Button_clu_USMReset = 1; // Clu_USMReset
  testWaitForTimeout(5000);
  
  write("Reset Profile 1");
  setSignal(IAU_ProfileIDRVal, 0x2); // Profile Driver 1
