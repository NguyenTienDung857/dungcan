void MainTest(){
  write("===START TEST===");
  @panel::Switch_Clock=1;
  testWaitForValueInput("Enter testcase ID (Example: if you want test INF_012, please enter '12' on keyboard)", 300000);
  if(testGetValueInput()==12){
    BLTN_CAM_Settings();
    
    INF_012_1_2();
    write("Done INF_012_1_2");
    
    testWaitForTimeout(2000);
    
    INF_012_3_to_19();
    write("Done INF_012_3_to_19");
    
    testWaitForTimeout(1000);
  
    _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_OWD_NvalueSet = 0x1; //OWD setting OFF state
    output(_HU_BLTN_CAM_E_00);
    write("===FINISH TEST INF_012===");     
  }
  else if(testGetValueInput()==13){
    BLTN_CAM_Settings();
    
    INF_013_1_2();
    write("Done INF_013_1_2");
    
    testWaitForTimeout(2000);
    
    INF_013_3_to_19();
    write("Done INF_013_3_to_19");
    
    testWaitForTimeout(1000);
  
    _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_OWD_NvalueSet = 0x1; //OWD setting OFF state
    output(_HU_BLTN_CAM_E_00);
    write("===FINISH TEST INF_013===");      
  }
   else if(testGetValueInput()==14){
    BLTN_CAM_Settings();
    
    INF_014_1_2();
    write("Done INF_014_1_2");
    
    testWaitForTimeout(2000);
    
    INF_014_3_to_19();
    write("Done INF_014_3_to_19");
    
    testWaitForTimeout(1000);
  
    _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_OWD_NvalueSet = 0x1; //OWD setting OFF state
    output(_HU_BLTN_CAM_E_00);
    write("===FINISH TEST INF_014===");   
  }
   else if(testGetValueInput()==15){
    BLTN_CAM_Settings();
    
    INF_015_1_2();
    write("Done INF_015_1_2");
    
    testWaitForTimeout(2000);
    
    INF_015_3_to_19();
    write("Done INF_015_3_to_19");
    
    testWaitForTimeout(1000);
  
    _HU_BLTN_CAM_E_00.BLTN_CAM_Rec_OWD_NvalueSet = 0x1; //OWD setting OFF state
    output(_HU_BLTN_CAM_E_00);
    write("===FINISH TEST INF_015===");   
  }  
  
  write("===FINISH TEST===");
}