/*@!Encoding:65001*/
includes { #include "../DeclarationFunction_Gen2.5.h" }

/*
  Test Case: OWD_026
  Title: [TML Recording Test - Start/Stop/Repeat/Enter BLTN_CAM]
  Verification items:
    - Step 1: Start TML recording, check BLTN_CAM_RecSta_TML = 0x1 (ON) - Screenshot
    - Step 2,3,4: Log - LED photo capture (manual)
    - Step 5: Wait 10s, Stop TML, check BLTN_CAM_RecSta_TML = 0x0 (OFF) - Screenshot
    - Step 6,7: Log - LED photo capture (manual)
    - Step 8: Start/Stop TML x5 times, verify ON/OFF each cycle - Screenshot after 5 cycles
    - Step 9: Start TML, wait 5s, Stop TML, check OFF - Screenshot + check video
    - Step 10: Start TML, wait 10s, Enter BLTN_CAM, check TML OFF - Screenshot + check video

  Preconditions:
    - ACC and IGN and ccNC/ccIC switch OFF, AVN mode

  NOTE: Uses 2-5s delay for signal propagation after each state transition.
*/

variables
{
  long max_wait_time_10s = 10000;   // 10 seconds timeout

  // Message declarations for CAN FD
  message HU_BLTN_CAM_02_200ms _HU_BLTN_CAM_02_200ms;
  message HU_BLTN_CAM_01_00ms _HU_BLTN_CAM_01_00ms;
  message HU_CLOCK_01_1000ms _HU_CLOCK_01_1000ms;

  // Result tracking variables
  int step1_passed = 0;
  int step5_passed = 0;
  int step8_passed = 0;
  int step9_passed = 0;
  int step10_passed = 0;

}

// ============================================================================
// Main Test Case
// ============================================================================

testcase OWD_026_Init()
{
  Send_Value_To_COM(12600);
  write("========================================");
  write("=== START TEST OWD_026 ===");
  write("=== TML Recording Start/Stop Test   ===");
  write("========================================");
  Send_Value_To_COM(44);
}

testcase OWD_026_1()
{
  int result = 0;

  //============================================================================
  // STEP 1: Set SMK IGN, USM Reset, Rec Reset, AVN mode,
  //         Click TML Start, Check BLTN_CAM_RecSta_TML = 0x1 (ON) - Screenshot
  //============================================================================
  Send_Value_To_COM(12601);
  SetTestStep("Bước 1 - OWD_026");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 1: SMK IGN + USM Reset + Rec Reset + AVN mode      ===");
  write("===         TML Start + Check RecSta_TML = 0x1 (ON)         ===");
  write("=================================================================");
  testStep("Step1", "SMK IGN + USM Reset + Rec Reset + AVN + TML Start + TML ON");

  // 1.1 Set SMK to IGN via panel combo box
  write("[1.1] Setting SMK_Signal to IGN via panel...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);

  // 1.2 Click USM Reset button
  write("[1.2] Clicking USM Reset button...");
  Click_USM_Reset();
  testWaitForTimeout(2000);

  // 1.3 Click Rec Reset button
  write("[1.3] Clicking Rec Reset button...");
  Click_Rec_Reset();
  testWaitForTimeout(2000);

  // 1.4 Ensure AVN mode (Exit BLTN_CAM)
  write("[1.4] Ensuring AVN mode...");
  Exit_BLTN_CAM();
  testWaitForTimeout(2000);
  write("  HU_BLTN_CAM_UI_Mode = 0x%X (AVN mode)", $BLTN_CAM_HU_UI_Mode);

  // 1.5 Click TML Start on panel Recording_Setting
  write("[1.5] Clicking TML Start on panel Recording_Setting...");
  Click_TML_Start();

  // 1.6 Check BLTN_CAM_RecSta_TML = 0x1 (ON)
  write("[1.6] Checking BLTN_CAM_RecSta_TML = 0x1 (ON)...");
  result = WaitFor_RecSta_TML_Recording(max_wait_time_10s);

  // 1.7 Capture screenshot
  write("[1.7] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSta_TML;AIN;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  if(result == 1)
  {
    step1_passed = 1;
    testStepPass("Step1", "BLTN_CAM_RecSta_TML = 0x1 (ON) after TML Start - PASS");
  }
  else
  {
    step1_passed = 0;
    write(">>> FAIL REASON: BLTN_CAM_RecSta_TML did NOT turn ON after TML Start <<<");
    Log_Error_Details();
    testStepFail("Step1", "BLTN_CAM_RecSta_TML did NOT turn ON after TML Start - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase OWD_026_2_3_4()
{
  //============================================================================
  // STEP 2, 3, 4: Log - LED Photo Capture (Manual)
  //============================================================================
  Send_Value_To_COM(12602);
  write("");
  write("=================================================================");
  write("=== STEP 2, 3, 4: LED Photo Capture (Manual) ===");
  write("=================================================================");
  testStep("Step2_3_4", "LED photo capture - check signal light");

  write("");
  write("*************************************************************");
  write("*** STEP 2, 3, 4: LOG INFORMATION ***");
  write("*** Please capture LED photo directly ***");
  write("*** Check signal light status on the device ***");
  write("*** Include this photo in the test report ***");
  write("*************************************************************");
  write("");

  testStepPass("Step2_3_4", "LED photo capture logged - Manual photo required");
  Send_Value_To_COM(44);
}

testcase OWD_026_5()
{
  int result = 0;

  //============================================================================
  // STEP 5: Wait 10s, Click TML Stop, Check BLTN_CAM_RecSta_TML = 0x0 (OFF)
  //         - Screenshot
  //============================================================================
  Send_Value_To_COM(12605);
  SetTestStep("Bước 5 - OWD_026");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 5: Wait 10s + TML Stop + Check RecSta_TML = 0x0    ===");
  write("=================================================================");
  testStep("Step5", "Wait 10s + TML Stop + RecSta_TML OFF verification");

  // 5.1 Wait 10 seconds
  write("[5.1] Waiting 10 seconds...");
  testWaitForTimeout(10000);
  write("  10 seconds elapsed.");

  // 5.2 Click TML Stop on panel
  write("[5.2] Clicking TML Stop on panel...");
  Click_TML_Stop();

  // 5.3 Check BLTN_CAM_RecSta_TML = 0x0 (OFF)
  write("[5.3] Checking BLTN_CAM_RecSta_TML = 0x0 (OFF)...");
  result = WaitFor_RecSta_TML_OFF(max_wait_time_10s / 1000);

  // 5.4 Capture screenshot
  write("[5.4] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSta_TML;AIN;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  if(result == 1)
  {
    step5_passed = 1;
    testStepPass("Step5", "BLTN_CAM_RecSta_TML = 0x0 (OFF) after TML Stop - PASS");
  }
  else
  {
    step5_passed = 0;
    write(">>> FAIL REASON: BLTN_CAM_RecSta_TML did NOT turn OFF after TML Stop <<<");
    Log_Error_Details();
    testStepFail("Step5", "BLTN_CAM_RecSta_TML did NOT turn OFF after TML Stop - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

