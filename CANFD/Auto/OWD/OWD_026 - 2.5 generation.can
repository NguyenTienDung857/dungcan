{
  //============================================================================
  // STEP 6, 7: Log - LED Photo Capture (Manual)
  //============================================================================
  Send_Value_To_COM(12606);
  write("");
  write("=================================================================");
  write("=== STEP 6, 7: LED Photo Capture (Manual) ===");
  write("=================================================================");
  testStep("Step6_7", "LED photo capture - check signal light");

  write("");
  write("*************************************************************");
  write("*** STEP 6, 7: LOG INFORMATION ***");
  write("*** Please capture LED photo directly ***");
  write("*** Check signal light status on the device ***");
  write("*** Include this photo in the test report ***");
