testcase OWD_026_8()
{
  int result = 0;
  int i = 0;
  int cycle_all_pass = 1;

  //============================================================================
  // STEP 8: TML Start/Stop cycle x5 times
  //         Each cycle: Start -> check ON -> Stop -> check OFF
  //         Screenshot after 5 cycles
  //============================================================================
  Send_Value_To_COM(12608);
  SetTestStep("Bước 8 - OWD_026");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 8: TML Start/Stop x5 Cycles                        ===");
  write("=================================================================");
  testStep("Step8", "TML Start/Stop repeat 5 cycles");

  cycle_all_pass = 1;

  for(i = 1; i <= 5; i++)
  {
    write("");
    write("--- Cycle %d / 5 ---", i);

    // Start TML
    write("[8.%d.1] Clicking TML Start...", i);
    Click_TML_Start();

    // Check TML ON
    write("[8.%d.2] Checking BLTN_CAM_RecSta_TML = 0x1 (ON)...", i);
    result = WaitFor_RecSta_TML_Recording(max_wait_time_10s);
    if(result != 1)
    {
      write(">>> FAIL: Cycle %d - TML did NOT turn ON <<<", i);
      cycle_all_pass = 0;
    }
    else
    {
      write(">>> Cycle %d - TML ON confirmed <<<", i);
    }

    // Stop TML
    write("[8.%d.3] Clicking TML Stop...", i);
    Click_TML_Stop();

    // Check TML OFF
    write("[8.%d.4] Checking BLTN_CAM_RecSta_TML = 0x0 (OFF)...", i);
    result = WaitFor_RecSta_TML_OFF(max_wait_time_10s / 1000);
    if(result != 1)
    {
      write(">>> FAIL: Cycle %d - TML did NOT turn OFF <<<", i);
      cycle_all_pass = 0;
    }
    else
    {
      write(">>> Cycle %d - TML OFF confirmed <<<", i);
    }
  }

  // Capture screenshot after 5 cycles
  write("[8.6] Capturing screenshot after 5 cycles...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSta_TML;AIN;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  if(cycle_all_pass == 1)
  {
    step8_passed = 1;
    testStepPass("Step8", "TML Start/Stop x5 cycles all PASS");
  }
  else
  {
    step8_passed = 0;
    write(">>> FAIL REASON: TML Start/Stop x5 cycles - some cycles failed <<<");
    Log_Error_Details();
    testStepFail("Step8", "TML Start/Stop x5 cycles - some cycles FAILED");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase OWD_026_9()
{
  int result = 0;

  //============================================================================
  // STEP 9: TML Start -> check ON -> wait 5s -> TML Stop -> check OFF
  //         Screenshot + log check video
  //============================================================================
  Send_Value_To_COM(12609);
  SetTestStep("Bước 9 - OWD_026");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 9: TML Start + Wait 5s + TML Stop + Check Video    ===");
  write("=================================================================");
  testStep("Step9", "TML Start + wait 5s + TML Stop + check OFF + check video");

  // 9.1 Click TML Start
  write("[9.1] Clicking TML Start...");
  Click_TML_Start();

  // 9.2 Check BLTN_CAM_RecSta_TML = 0x1 (ON)
  write("[9.2] Checking BLTN_CAM_RecSta_TML = 0x1 (ON)...");
  result = WaitFor_RecSta_TML_Recording(max_wait_time_10s);
  if(result != 1)
  {
    write(">>> FAIL: TML did NOT turn ON for Step 9 <<<");
  }

  // 9.3 Wait 5 seconds
  write("[9.3] Waiting 5 seconds...");
  testWaitForTimeout(5000);
  write("  5 seconds elapsed.");

  // 9.4 Click TML Stop
  write("[9.4] Clicking TML Stop...");
  Click_TML_Stop();

  // 9.5 Check BLTN_CAM_RecSta_TML = 0x0 (OFF)
  write("[9.5] Checking BLTN_CAM_RecSta_TML = 0x0 (OFF)...");
  result = WaitFor_RecSta_TML_OFF(max_wait_time_10s / 1000);

  // 9.6 Capture screenshot
  write("[9.6] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSta_TML;AIN;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  // 9.7 Log: Check video
  write("");
  write("*************************************************************");
  write("*** STEP 9: CHECK VIDEO ***");
  write("*** Please verify the TML recording video ***");
  write("*** TML was recording for ~5 seconds before stop ***");
  write("*************************************************************");
  write("");

  if(result == 1)
  {
    step9_passed = 1;
    testStepPass("Step9", "TML Start + wait 5s + TML Stop + OFF confirmed + check video - PASS");
  }
  else
  {
    step9_passed = 0;
    write(">>> FAIL REASON: TML did NOT turn OFF after Stop in Step 9 <<<");
    Log_Error_Details();
    testStepFail("Step9", "TML did NOT turn OFF after Stop in Step 9 - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}

testcase OWD_026_10()
{
  int result = 0;

  //============================================================================
  // STEP 10: TML Start -> check ON -> wait 10s -> Enter BLTN_CAM
  //          -> check TML OFF -> Screenshot + log check video
  //============================================================================
  Send_Value_To_COM(12610);
  SetTestStep("Bước 10 - OWD_026");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 10: TML Start + Wait 10s + Enter BLTN_CAM          ===");
  write("===          Check TML OFF + Screenshot + Check Video        ===");
  write("=================================================================");
  testStep("Step10", "TML Start + wait 10s + Enter BLTN_CAM + check TML OFF + check video");

  // 10.1 Click TML Start
  write("[10.1] Clicking TML Start...");
  Click_TML_Start();

  // 10.2 Check BLTN_CAM_RecSta_TML = 0x1 (ON)
  write("[10.2] Checking BLTN_CAM_RecSta_TML = 0x1 (ON)...");
  result = WaitFor_RecSta_TML_Recording(max_wait_time_10s);
  if(result != 1)
  {
    write(">>> FAIL: TML did NOT turn ON for Step 10 <<<");
  }

  // 10.3 Wait 10 seconds
  write("[10.3] Waiting 10 seconds...");
  testWaitForTimeout(10000);
  write("  10 seconds elapsed.");

  // 10.4 Enter Built-in Cam mode
  write("[10.4] Entering Built-in Cam (BLTN_CAM) mode...");
  Enter_BLTN_CAM();
  testWaitForTimeout(3000);
  write("  HU_BLTN_CAM_UI_Mode = 0x%X", $BLTN_CAM_HU_UI_Mode);

  // 10.5 Check BLTN_CAM_RecSta_TML = 0x0 (OFF)
  write("[10.5] Checking BLTN_CAM_RecSta_TML = 0x0 (OFF) after entering BLTN_CAM...");
  result = WaitFor_RecSta_TML_OFF(max_wait_time_10s / 1000);

  // 10.6 Capture screenshot
  write("[10.6] Capturing screenshot...");
  CaptureGraphics("OWD", "BLTN_CAM_RecSta_TML;AIN;BLTN_CAM_HU_UI_Mode;SMK_TrmnlCtrlGrpStaBDC");

  // 10.7 Log: Check video
  write("");
  write("*************************************************************");
  write("*** STEP 10: CHECK VIDEO ***");
  write("*** Please verify the TML recording video ***");
  write("*** TML was recording for ~10s then entered BLTN_CAM mode ***");
  write("*** Entering BLTN_CAM mode should stop TML recording ***");
  write("*************************************************************");
  write("");

  if(result == 1)
  {
    step10_passed = 1;
    testStepPass("Step10", "TML OFF after entering BLTN_CAM mode confirmed + check video - PASS");
  }
  else
  {
    step10_passed = 0;
    write(">>> FAIL REASON: TML did NOT turn OFF after entering BLTN_CAM mode <<<");
    Log_Error_Details();
    testStepFail("Step10", "TML did NOT turn OFF after entering BLTN_CAM mode - FAIL");
  }
  StopTestTimer();
  Send_Value_To_COM(44);
}


void MainTest()
{
  testReportFileName("TestReports\\OWD_026 - 2.5 generation_report");

  //write("Run Rec_Reset()"); Rec_Reset();

  OWD_026_Init();
  OWD_026_1();
  OWD_026_2_3_4();
  OWD_026_5();
  OWD_026_6_7();
  OWD_026_8();
  OWD_026_9();
  OWD_026_10();
}
