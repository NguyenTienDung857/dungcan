void MainTest(){
  testReportFileName("TestReports\\OWP_001 - 2.5 generation_report");

   Send_Value_To_COM(8);
  OWP_001_Init();
  OWP_001_1();
  OWP_001_2();
  OWP_001_3();
  OWP_001_4();
  OWP_001_5();
  OWP_001_6();
  OWP_001_7();
}
