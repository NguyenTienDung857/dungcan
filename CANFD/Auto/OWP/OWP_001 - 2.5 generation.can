  Send_Value_To_COM(20106);
  SetTestStep("Bước 6 - OWP_001");
  StartTestTimer();
  //============================================================================
  // STEP 6: Log notification - LED blinking verification (manual)
  //============================================================================
  write("");
  write("=== STEP 6: LED Blinking Verification (Manual) ===");
  testStep("Step6", "Log notification - LED blinking verification (manual): check LED indicator status on device");

  write("");
  write("*************************************************************");
