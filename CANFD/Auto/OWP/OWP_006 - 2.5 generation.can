    snprintf(failReason, elcount(failReason),
             "Step 2 FAIL: OWP=%d, PEV=%d, RecSta_OWP=0x%X, RecSta_PEV=0x%X.",
             owp_ok, pev_ok, $BLTN_CAM_RecSta_OWP, $BLTN_CAM_RecSta_PEV);
    Log_Error_Details();
    testStepFail("Step2", failReason);
  }

  write("=== FINISH STEP 2 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
