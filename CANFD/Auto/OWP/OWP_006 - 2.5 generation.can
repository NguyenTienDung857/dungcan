  testStep("Step6", "KEY ON, wait 5s, Turn_ON_PMD, KEY OFF, wait PMD, 5s, B+ OFF 3s, B+ ON");

  write("[6.1] KEY_ON");
  KEY_ON();

  write("[6.2] Wait 5 seconds");
  testWaitForTimeout(10000);

  write("[6.3] Turn_ON_PMD");
  Turn_ON_PMD();
  pmd_set_ok = Check_Set_PMD_ON();
  write("[6.3] BLTN_CAM_Set_PMD = 0x%X, expected 0x2", $BLTN_CAM_Set_PMD);

  write("[6.4] KEY_OFF");
  KEY_OFF();
  testWaitForTimeout(5000);

  write("[6.5] WaitFor_RecSta_PMD_Recording max %d seconds", 120);
  pmd_ok = WaitFor_RecSta_PMD_Recording(120000);
  write("[6.5] BLTN_CAM_RecSta_PMD = 0x%X, expected 0x1", $BLTN_CAM_RecSta_PMD);

  write("[6.6] Wait 5 seconds");
  testWaitForTimeout(5000);

  write("[6.7] Set_BPlus_Off");
  Set_BPlus_Off();

  write("[6.8] Wait 3 seconds with B+ OFF");
  testWaitForTimeout(3000);

  write("[6.9] Set_BPlus_On");
  Set_BPlus_On();

  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_RecSta_OWP;BLTN_CAM_State");

  if (pmd_set_ok == 1 && pmd_ok == 1)
