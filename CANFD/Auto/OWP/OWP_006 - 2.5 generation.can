void MainTest()
{
  testReportFileName("TestReports\\OWP_006 - 2.5 generation_report");

  OWP_006_Init();

  OWP_006_1();
  OWP_006_2();
  OWP_006_3();
  OWP_006_4();
  OWP_006_5();
  OWP_006_6();
  OWP_006_7();
}
