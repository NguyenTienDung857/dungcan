    step6_passed = 1;
    testStepPass("Step6", "Step 6 PASS - PMD setting and PMD recording detected before B+ OFF/ON");
  }
  else
  {
    step6_passed = 0;
    snprintf(failReason, elcount(failReason),
             "Step 6 FAIL: PMD set=%d, PMD recording=%d, Set_PMD=0x%X, RecSta_PMD=0x%X.",
             pmd_set_ok, pmd_ok, $BLTN_CAM_Set_PMD, $BLTN_CAM_RecSta_PMD);
    Log_Error_Details();
    testStepFail("Step6", failReason);
  }

  write("=== FINISH STEP 6 ===");
