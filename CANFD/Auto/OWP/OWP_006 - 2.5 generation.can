/*@!Encoding:65001*/

includes
{
  #include "../DeclarationFunction_Gen2.5.h"
}

/*
  Test Case: OWP_006 - 2.5 generation
  Title: OWP/PEV/PMD recording behavior across B+ OFF/ON interruptions

  Verification items:
    - Step 1: Init with SMK IGN, USM reset, Rec reset, KEY OFF, wait OWP,
              wait 10s, B+ OFF 3s, B+ ON.
    - Step 2: KEY ON, wait 3s, KEY OFF, wait OWP, wait 10s, wait PEV,
              B+ OFF 3s, B+ ON.
    - Step 3: KEY ON, wait 3s, KEY OFF, wait OWP, wait 10s, Click_Evt_Switch,
              B+ OFF 3s, B+ ON.
    - Step 4: KEY ON, wait 3s, KEY OFF, wait OWP, wait 10s, wait PEV,
              Click_Evt_Switch, B+ OFF 3s, B+ ON.
    - Step 5: KEY ON, wait 3s, KEY OFF, wait OWP, wait 10s, detach rear 2s,
              B+ OFF 3s, attach rear 2s, B+ ON.
    - Step 6: KEY ON, wait 5s, Turn_ON_PMD, KEY OFF, wait PMD, wait 5s,
              B+ OFF 3s, B+ ON.
    - Step 7: KEY ON, wait 3s, KEY OFF, wait PMD, wait 5s, wait PEV,
              B+ OFF 3s, B+ ON.

  Preconditions:
    - ACC and IGN and ccNC/ccIC switch OFF, AVN mode.
    - Helper functions from DeclarationFunction_Gen2.5.h are used first.
*/

variables
{
  char failReason[512];

  int step1_passed = 0;
  int step2_passed = 0;
  int step3_passed = 0;
  int step4_passed = 0;
  int step5_passed = 0;
  int step6_passed = 0;
  int step7_passed = 0;

  message HU_BLTN_CAM_02_200ms _HU_BLTN_CAM_02_200ms;
  message HU_BLTN_CAM_01_00ms  _HU_BLTN_CAM_01_00ms;
  message HU_CLOCK_01_1000ms   _HU_CLOCK_01_1000ms;
}

testcase OWP_006_Init()
{
  Send_Value_To_COM(20600);
  write("========================================");
  write("=== START TEST OWP_006 - 2.5 ===");
  write("=== OWP/PEV/PMD B+ interruption flow ===");
  write("========================================");
  testStep("Notification", "Start test OWP_006 - 2.5");
  Send_Value_To_COM(44);
}

testcase OWP_006_1()
{
  int owp_ok = 0;

  Send_Value_To_COM(20601);
  SetTestStep("Buoc 1 - OWP_006");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 1: Init, OWP recording, B+ OFF/ON                  ===");
  write("=================================================================");
  testStep("Step1", "Set_SMK_IGN, USM reset, Rec reset, KEY OFF, wait OWP, 10s, B+ OFF 3s, B+ ON");

  write("[1.1] Set_SMK_IGN");
  Set_SMK_IGN();

  write("[1.2] Click_USM_Reset");
  Click_USM_Reset();

  write("[1.3] Click_Rec_Reset");
  Click_Rec_Reset();

  write("[1.4] KEY_OFF");
  KEY_OFF();

  write("[1.5] WaitFor_RecSta_OWP_Recording max %d seconds", 60);
  owp_ok = WaitFor_RecSta_OWP_Recording(60000);
  write("[1.5] BLTN_CAM_RecSta_OWP = 0x%X, expected 0x1", $BLTN_CAM_RecSta_OWP);

  write("[1.6] Wait 10 seconds");
  testWaitForTimeout(10000);

  write("[1.7] Set_BPlus_Off");
  Set_BPlus_Off();

  write("[1.8] Wait 3 seconds with B+ OFF");
  testWaitForTimeout(3000);

  write("[1.9] Set_BPlus_On");
  Set_BPlus_On();

  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_PEV;BLTN_CAM_RecSta_PMD;BLTN_CAM_Set_PMD;BLTN_CAM_State");

  if (owp_ok == 1)
  {
    step1_passed = 1;
    testStepPass("Step1", "Step 1 PASS - OWP recording detected before B+ OFF/ON");
  }
  else
  {
    step1_passed = 0;
    snprintf(failReason, elcount(failReason),
             "Step 1 FAIL: OWP wait=%d, RecSta_OWP=0x%X expected 0x1.",
             owp_ok, $BLTN_CAM_RecSta_OWP);
    Log_Error_Details();
    testStepFail("Step1", failReason);
  }

  write("=== FINISH STEP 1 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

