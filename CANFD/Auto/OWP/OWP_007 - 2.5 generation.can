// ============================================================================
// STEP 7: KEY OFF, log "tac dong su kien PEV",
//         trong 30s check RecSta_PEV = 0x1 (Recording) -> PASS,
//         capture BLTN_CAM_PEV_Recorded
// ============================================================================
testcase OWP_007_7()
{
  Send_Value_To_COM(20707);
  SetTestStep("Bước 7 - OWP_007");
  StartTestTimer();
  write("");
  write("=== STEP 7: KEY OFF, Tac dong su kien PEV, Check RecSta_PEV = Recording ===");
  testStep("Step7", "KEY OFF, trigger PEV event (physical) -> check BLTN_CAM_RecSta_PEV = 0x1 (Recording) within 30s, capture BLTN_CAM_PEV_Recorded");

  // 7.1: KEY OFF
  write("Step 7.1: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 7.2 & 7.3: Log PEV action + Wait for RecSta_PEV = Recording (60s)
  if (WaitFor_RecSta_PEV_Recording(60) == 1)
  {
    step7_passed = 1;
    testStepPass("Step7", "BLTN_CAM_RecSta_PEV = 0x1 (Recording) - PASS");
  }
  else
  {
    step7_passed = 0;
    Log_Error_Details();
    testStepFail("Step7", "BLTN_CAM_RecSta_PEV did not reach 0x1 - FAIL");
  }

  // 7.4: Capture screenshot including BLTN_CAM_PEV_Recorded
  write("Step 7.4: Capturing screenshot...");
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti;BLTN_CAM_State");

  write("=== FINISH STEP 7 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

