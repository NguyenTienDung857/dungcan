/*@!Encoding:65001*/
includes
{
  #include "../DeclarationFunction_Gen2.5.h"
}

//Preconditions: - ACC and IGN and ccNC/ccIC switch OFF, AVN mode
//               - Add signal: BLTN_CAM_RecSta_PEV, BLTN_CAM_RecSet_PEV,
//                             BLTN_CAM_Set_PEV_AppNoti, BLTN_CAM_PEV_Recorded,
//                             BLTN_CAM_PEV_Count, BLTN_CAM_RecSta_OWP,
//                             BLTN_CAM_RecSet_OWP, BLTN_CAM_State

/*
  Test Case: OWP_007 - 2.5 (OWP_007)
  Title: [PEV Recording - Initial Setup, Event Trigger, Multi-Event Count Check]

  Step 1:  Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, Set_Factory_Mode,
           Set_Customer_Mode, capture screenshot (related signals + PEV_AppNoti)
  Step 2:  Log "Turn_ON_OWD, Turn_ON_OWP roi FSR de check"
  Step 3:  Set_SMK_IGN, Click_USM_Reset, Turn_ON_PEV, check BLTN_CAM_RecSet_PEV = 0x2 (On)
  Step 4:  KEY OFF, check BLTN_CAM_RecSta_PEV = 0x0 (OFF) -> PASS
  Step 5_6: Log "check anh den LED"
  Step 7:  KEY OFF, log "tac dong su kien PEV", trong 30s check RecSta_PEV = 0x1 (Recording) -> PASS,
           capture BLTN_CAM_PEV_Recorded
  Step 8_9: Log "check anh den LED"
  Step 10: KEY ON -> KEY OFF, log "tac dong su kien PEV lien tuc trong 60s",
           wait 90s, capture screenshot, KEY ON, log "chup anh video co nhieu su kien trong 80s"
  Step 11: Log "lay anh o buoc 10"
  Step 12: KEY ON -> KEY OFF, tac dong su kien PEV x3 (11s apart),
           check BLTN_CAM_PEV_Count >= 3, capture screenshot, log check video
  Step 13_14_15: Log "check video tren may tinh"
  Step 16: Log "dung anh man hinh chup o buoc 12"

  NOTE: Uses 2-5s delay for signal propagation after each state transition.
*/

variables
{
  // Result tracking
  int step1_passed = 0;
  int step2_passed = 0;
  int step3_passed = 0;
  int step4_passed = 0;
  int step5_6_passed = 0;
  int step7_passed = 0;
  int step8_9_passed = 0;
  int step10_passed = 0;
  int step11_passed = 0;
  int step12_passed = 0;
  int step13_14_15_passed = 0;
  int step16_passed = 0;

  // Message Declaration for CAN FD
  message HU_BLTN_CAM_02_200ms _HU_BLTN_CAM_02_200ms;
  message HU_BLTN_CAM_01_00ms _HU_BLTN_CAM_01_00ms;
  message HU_CLOCK_01_1000ms _HU_CLOCK_01_1000ms;
}


// ============================================================================
// Test Cases
// ============================================================================

testcase OWP_007_Init()
{
  Send_Value_To_COM(20700);
  write("========================================");
  write("=== START TEST OWP_007 - 2.5 ===");
  write("========================================");
  write("===START TEST===");
  // 1.1: Set_SMK_IGN (full init with CGWNM)
  write("Step 1.1: Set_SMK_IGN (KEY ON with CGWNM)...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);

  // 1.2: Click USM Reset
  write("Step 1.2: USM Reset...");
  Click_USM_Reset();

  // 1.3: Click Rec Reset
  write("Step 1.3: Rec Reset...");
  Click_Rec_Reset();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 1: Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset,
//         Set_Factory_Mode, Set_Customer_Mode,
//         capture screenshot (related signals + PEV_AppNoti)
// ============================================================================
testcase OWP_007_1()
{
  Send_Value_To_COM(20701);
  SetTestStep("Bước 1 - OWP_007");
  StartTestTimer();
  write("");
  write("=== STEP 1: Set_SMK_IGN, USM/Rec Reset, Factory->Customer mode ===");
  testStep("Step1", "SMK IGN + USM/Rec Reset + Factory->Customer mode change, check ICU_PowerAutoCutModSta, capture BLTN_CAM_Set_PEV_AppNoti screenshot");

  

  // 1.4: Set Factory Mode
  write("Step 1.4: Setting Factory Mode...");
  if (Set_Factory_Mode() == 0)
  {
    write(">>> [FAIL] Failed to set Factory Mode <<<");
    Log_Error_Details();
    testStepFail("Step1.4", "Failed to set Factory Mode");
  }
  else
  {
    write(">>> [OK] Factory Mode set successfully <<<");
    testStepPass("Step1.4", "Factory Mode set");
  }
  testWaitForTimeout(3000);

  // 1.5: Set Customer Mode
  write("Step 1.5: Setting Customer Mode...");
  if (Set_Customer_Mode() == 0)
  {
    write(">>> [FAIL] Failed to set Customer Mode <<<");
    Log_Error_Details();
    testStepFail("Step1.5", "Failed to set Customer Mode");
  }
  else
  {
    write(">>> [OK] Customer Mode set successfully <<<");
    testStepPass("Step1.5", "Customer Mode set");
  }
  testWaitForTimeout(3000);

  // 1.6: Log all signals
  write("Step 1.6: Logging signal values...");

  // 1.7: Capture screenshot of related signals and PEV_AppNoti
  write("Step 1.7: Capturing screenshot...");
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;ICU_PowerAutoCutModSta;CF_AVN_BLTN_CAM_RecReset;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_Set_PEV_AppNoti;BLTN_CAM_State");

  step1_passed = 1;
  testStepPass("Step1", "Set_SMK_IGN, USM/Rec Reset, Factory->Customer, Screenshot - PASS");
  write("=== FINISH STEP 1 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 2: Log "Turn_ON_OWD, Turn_ON_OWP roi FSR de check"
// ============================================================================
testcase OWP_007_2()
{
  Send_Value_To_COM(20702);
  SetTestStep("Bước 2 - OWP_007");
  StartTestTimer();
  write("");
  write("=== STEP 2: Turn ON OWD, OWP roi FSR de check ===");
  testStep("Step2", "Log notification - manual action: Turn ON OWD, Turn ON OWP, then perform FSR (Factory Setting Reset) to verify");

  write("");
  write("*************************************************************");
  write("*** [ACTION REQUIRED]                                     ***");
  write("*** Hay Turn_ON_OWD, Turn_ON_OWP roi FSR de check!       ***");
  write("*** Thuc hien tren thiet bi:                              ***");
  write("***   1. Bat OWD (Continuous Driving Recording)           ***");
  write("***   2. Bat OWP (Continuous Parking Recording)           ***");
  write("***   3. Thuc hien FSR (Factory Setting Reset) de check   ***");
  write("*************************************************************");
  write("");

  testWaitForTimeout(3000);

  step2_passed = 1;
  testStepPass("Step2", "Log: Turn_ON_OWD, Turn_ON_OWP roi FSR de check - PASS");
  write("=== FINISH STEP 2 ===");

  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWP", "BLTN_CAM_RecSet_OWD;BLTN_CAM_RecSta_OWD;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSta_MAR");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 3: Set_SMK_IGN, Click_USM_Reset, Turn_ON_PEV,
//         check BLTN_CAM_RecSet_PEV = 0x2 (On)
// ============================================================================
testcase OWP_007_3()
{
  Send_Value_To_COM(20703);
  SetTestStep("Bước 3 - OWP_007");
  StartTestTimer();
  write("");
  write("=== STEP 3: Set_SMK_IGN, USM Reset, Turn ON PEV, Check RecSet_PEV = 0x2 ===");
  testStep("Step3", "SMK IGN + USM Reset + Turn ON PEV -> check BLTN_CAM_RecSet_PEV = 0x2 (On), capture screenshot");

  // 3.1: Set_SMK_IGN
  write("Step 3.1: Set_SMK_IGN...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);

  // 3.2: Click USM Reset
  write("Step 3.2: USM Reset...");
  Click_USM_Reset();

  // 3.3: Turn ON PEV
  write("Step 3.3: Turn ON PEV...");
  Turn_ON_PEV();
  testWaitForTimeout(3000);

  // 3.4: Check BLTN_CAM_RecSet_PEV = 0x2 (On)
  write("Step 3.4: Checking BLTN_CAM_RecSet_PEV...");
  write("  BLTN_CAM_RecSet_PEV = 0x%X", $BLTN_CAM_RecSet_PEV);

  if ($BLTN_CAM_RecSet_PEV == 0x2)
  {
    write(">>> [PASS] BLTN_CAM_RecSet_PEV = 0x2 (On) <<<");
    step3_passed = 1;
    testStepPass("Step3", "BLTN_CAM_RecSet_PEV = 0x2 (On) - PASS");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_RecSet_PEV = 0x%X, expected 0x2 (On) <<<", $BLTN_CAM_RecSet_PEV);
    step3_passed = 0;
    Log_Error_Details();
    testStepFail("Step3", "BLTN_CAM_RecSet_PEV = 0x%X, expected 0x2 - FAIL", $BLTN_CAM_RecSet_PEV);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_Set_PEV_AppNoti;BLTN_CAM_State");

  write("=== FINISH STEP 3 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

