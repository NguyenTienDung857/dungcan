// ============================================================================
// STEP 10: KEY ON -> KEY OFF, log "tac dong su kien PEV lien tuc trong 60s",
//          wait 90s, capture screenshot, KEY ON,
//          log "chup anh video co nhieu su kien tac dong trong 80s"
// ============================================================================
testcase OWP_007_10()
{
  Send_Value_To_COM(20710);
  SetTestStep("Bước 10 - OWP_007");
  StartTestTimer();
  write("");
  write("=== STEP 10: KEY ON->OFF, PEV events 60s, wait 90s, KEY ON, check video ===");
  testStep("Step10", "KEY ON->KEY OFF, trigger PEV events continuously for 60s, wait 90s, capture screenshot -> check BLTN_CAM_PEV_Count, KEY ON, check video");

  // 10.1: KEY ON
  write("Step 10.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // 10.2: KEY OFF
  write("Step 10.2: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 10.3: Log "tac dong su kien PEV lien tuc trong 60s"
  write("");
  write("*************************************************************");
   write("");
  write("***     [ACTION REQUIRED] TAC DONG SU KIEN PEV LIEN TUC TRONG 60 GIAY!         ***");
   write("");
  write("*************************************************************");

  write("");

  // 10.4: Wait 90 seconds for events to be recorded
  write("Step 10.4: Waiting 90 seconds for PEV events to be recorded...");
  {
    int remaining;
    remaining = 90;
    while (remaining > 0)
    {
      if (remaining % 15 == 0)
      {
        write("  Remaining: %d seconds (RecSta_PEV=0x%X, PEV_Count=%d)",
              remaining, $BLTN_CAM_RecSta_PEV, $BLTN_CAM_PEV_Count);
      }
      testWaitForTimeout(1000);
      remaining--;
    }
  }
  write("=== 90s Wait Complete ===");

  // 10.5: Capture screenshot
  write("Step 10.5: Capturing screenshot after 90s wait...");
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti;BLTN_CAM_State");

  // 10.6: KEY ON
  write("Step 10.6: KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // 10.7: Log "chup anh video co nhieu su kien tac dong trong 80s"
  write("");
  write("*************************************************************");
  write("*** [ACTION REQUIRED]                                     ***");
  write("*** CHUP ANH VIDEO MA CO NHIEU SU KIEN TAC DONG TRONG 80s***");
  write("*** Hay chup man hinh video da ghi nhan nhieu su kien PEV ***");
  write("*** trong khoang thoi gian 80 giay tren thiet bi.         ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_State");

  step10_passed = 1;
  testStepPass("Step10", "PEV multi-event recording, screenshot captured - PASS");
  write("=== FINISH STEP 10 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

