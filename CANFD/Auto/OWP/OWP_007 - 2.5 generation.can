// ============================================================================
// STEP 12: KEY ON -> KEY OFF, tac dong su kien PEV 3 lan (11s apart),
//          check BLTN_CAM_PEV_Count >= 3, capture screenshot, log check video
// ============================================================================
testcase OWP_007_12()
{
  int event_count;
  int event_attempt;
  Send_Value_To_COM(20712);
  SetTestStep("Bước 12 - OWP_007");
  StartTestTimer();

  write("");
  write("=== STEP 12: KEY ON->OFF, 3x PEV events (11s apart), Check PEV_Count >= 3 ===");
  testStep("Step12", "KEY ON->KEY OFF, trigger PEV event x3 (11s apart), check BLTN_CAM_PEV_Count >= 3, capture screenshot, manual check video");

  // 12.1: KEY ON
  write("Step 12.1: KEY ON...");
  KEY_ON();
  

 
  KEY_OFF();
  WaitFor_RecSta_OWP_Recording(30000);
  testWaitForTimeout(10000);

  // 12.3: First PEV event trigger
  write("Step 12.3: PEV event 1/3...");
  if (WaitFor_RecSta_PEV_Recording(60) == 1)
  {
    write(">>> [OK] Event 1: BLTN_CAM_RecSta_PEV = 0x1 (Recording) <<<");
    write("  PEV_Count = %d", $BLTN_CAM_PEV_Count);
  }
  else
  {
    write(">>> [WARNING] Event 1: RecSta_PEV did not change to ON within 60s <<<");
  }


  // 12.4: Wait 11 seconds before next event
  write("Step 12.4: Waiting 11 seconds before event 2...");
  testWaitForTimeout(11000);

  // 12.5: Second PEV event trigger
  write("Step 12.5: PEV event 2/3...");
  if (WaitFor_RecSta_PEV_Recording(60) == 1)
  {
    write(">>> [OK] Event 2: BLTN_CAM_RecSta_PEV = 0x1 (Recording) <<<");
    write("  PEV_Count = %d", $BLTN_CAM_PEV_Count);
  }
  else
  {
    write(">>> [WARNING] Event 2: RecSta_PEV did not change to ON within 60s <<<");
  }


  // 12.6: Wait 11 seconds before next event
  write("Step 12.6: Waiting 11 seconds before event 3...");
  testWaitForTimeout(11000);

  // 12.7: Third PEV event trigger
  write("Step 12.7: PEV event 3/3...");
  if (WaitFor_RecSta_PEV_Recording(60) == 1)
  {
    write(">>> [OK] Event 3: BLTN_CAM_RecSta_PEV = 0x1 (Recording) <<<");
    write("  PEV_Count = %d", $BLTN_CAM_PEV_Count);
  }
  else
  {
    write(">>> [WARNING] Event 3: RecSta_PEV did not change to ON within 60s <<<");
  }

  // 12.8: Wait 11 seconds for last event to complete
  write("Step 12.8: Waiting 11 seconds for last event to finalize...");
  testWaitForTimeout(11000);

  // 12.9: Check BLTN_CAM_PEV_Count >= 3
  write("Step 12.9: Checking BLTN_CAM_PEV_Count...");
  event_count = $BLTN_CAM_PEV_Count;
  write("  BLTN_CAM_PEV_Count = %d", event_count);

  if (event_count >= 3)
  {
    write(">>> [PASS] BLTN_CAM_PEV_Count = %d (>= 3) <<<", event_count);
    step12_passed = 1;
    testStepPass("Step12", "BLTN_CAM_PEV_Count = %d >= 3 - PASS", event_count);
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_PEV_Count = %d, expected >= 3 <<<", event_count);
    step12_passed = 0;
    Log_Error_Details();
    testStepFail("Step12", "BLTN_CAM_PEV_Count = %d < 3 - FAIL", event_count);
  }

  // 12.10: Capture screenshot
  write("Step 12.10: Capturing screenshot...");
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_PEV_Count;BLTN_CAM_Set_PEV_AppNoti;BLTN_CAM_State");

  // 12.11: Log check video
  write("");
  write("*************************************************************");
  write("*** [ACTION REQUIRED] CHECK VIDEO TREN THIET BI!          ***");
  write("*** Hay kiem tra video da ghi nhan 3 su kien PEV.          ***");
  write("*************************************************************");
  write("");

  write("=== FINISH STEP 12 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
  KEY_ON();
}

// ============================================================================
// STEP 13, 14, 15: Log "check video tren may tinh"
// ============================================================================
testcase OWP_007_13_14_15()
{
  Send_Value_To_COM(20713);
  SetTestStep("Bước 13 và 14 và 15 - OWP_007");
  StartTestTimer();
  write("");
  write("=== STEP 13, 14, 15: Check video tren may tinh ===");
  testStep("Step13_14_15", "Log notification - manual check: verify PEV recorded videos on PC (quality, duration, content) for Steps 13/14/15");

  write("");
  write("*************************************************************");
  write("*** [MANUAL VERIFICATION REQUIRED]                        ***");
  write("*** CHECK VIDEO TREN MAY TINH!                            ***");
  write("***                                                       ***");
  write("*** Step 13: Kiem tra video PEV da ghi tren may tinh      ***");
  write("*** Step 14: Kiem tra chat luong video PEV                ***");
  write("*** Step 15: Kiem tra thoi gian ghi video PEV             ***");
  write("*************************************************************");
  write("");

  step13_14_15_passed = 1;
  testStepPass("Step13_14_15", "Log: check video tren may tinh - manual check required");
  write("=== FINISH STEP 13, 14, 15 ===");

  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWP", "BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_RecSta_MAR");
  StopTestTimer();
  Send_Value_To_COM(44);
}

