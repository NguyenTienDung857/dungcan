// ============================================================================
// STEP 11: KEY ON, Set_BglrAlrm(0x0), Check RecSta_PEV = 0x0 (OFF)
// ============================================================================
testcase OWP_011_11()
{
  int recsta_pev;
  Send_Value_To_COM(21111);
  SetTestStep("Bước 11 - OWP_011");
  StartTestTimer();

  write("");
  write("=== STEP 11: KEY ON, Set BglrAlrm = 0x0, Check RecSta_PEV = OFF ===");
  testStep("Step11", "KEY ON + Set_BglrAlrm(0x0) -> check BLTN_CAM_RecSta_PEV = 0x0 (OFF), captures screenshot");

  // 11.1: KEY ON
  write("Step 11.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(3000);

  // 11.2: Set Burglar Alarm Signal back to 0x0 (Off)
  write("Step 11.2: Setting Burglar Alarm Signal to 0x0 (Off)...");
  if (Set_BglrAlrm(0x0) == 1)
  {
    write(">>> [OK] BglrAlrm set to 0x0 (Off) <<<");
  }
  else
  {
    write(">>> [WARNING] Failed to set BglrAlrm to 0x0 <<<");
  }
  testWaitForTimeout(3000);

  // 11.3: Check BLTN_CAM_RecSta_PEV = 0x0 (OFF)
  write("Step 11.3: Checking BLTN_CAM_RecSta_PEV = 0x0 (OFF)...");
  recsta_pev = $BLTN_CAM_RecSta_PEV;
  write("  BLTN_CAM_RecSta_PEV = 0x%X", recsta_pev);

  if (recsta_pev == 0x0)
  {
    write(">>> [PASS] BLTN_CAM_RecSta_PEV = 0x0 (OFF) <<<");
    step11_passed = 1;
    testStepPass("Step11", "BglrAlrm OFF, RecSta_PEV = 0x0 (OFF) - PASS");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_RecSta_PEV = 0x%X, expected 0x0 (OFF) <<<", recsta_pev);
    step11_passed = 0;
    Log_Error_Details();
    testStepFail("Step11", "RecSta_PEV = 0x%X, expected 0x0 - FAIL", recsta_pev);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PEV;BAlarm_BglrAlrm_CurrentSta;BLTN_CAM_State");

  write("=== FINISH STEP 11 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

