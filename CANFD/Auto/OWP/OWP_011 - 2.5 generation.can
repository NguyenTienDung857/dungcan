// ============================================================================
// STEP 18: Set_BglrAlrm = 9, Check RecSta_PEV = Recording,
//          wait 12s, check PEV_Recorded = 2, wait 305s, check PEV_Recorded = 0,
//          Check Set_PMD = ON
// ============================================================================
testcase OWP_011_18()
{
  int recsta_pev_result;
  int pmd_result;
  Send_Value_To_COM(21118);
  SetTestStep("Bước 18 - OWP_011");
  StartTestTimer();

  write("");
  write("=== STEP 18: BglrAlrm=9, PEV Recording, PEV_Recorded 2->0, Set_PMD=ON ===");
  testStep("Step18", "Set_BglrAlrm(0x9) -> check BLTN_CAM_RecSta_PEV = Recording, wait 12s -> check PEV_Recorded = 0x2, wait 305s -> check PEV_Recorded = 0x0 & BLTN_CAM_Set_PMD = ON");

  // 18.1: Set BglrAlrm = 0x9
  write("Step 18.1: Setting BglrAlrm = 0x9...");
  if (Set_BglrAlrm(0x9) == 1)
  {
    write(">>> [OK] BglrAlrm set to 0x9 (Alarm) <<<");
  }
  else
  {
    write(">>> [WARNING] Failed to set BglrAlrm to 0x9 <<<");
  }

  // 18.2: Check RecSta_PEV = Recording
  write("Step 18.2: Checking RecSta_PEV = Recording...");
  recsta_pev_result = Check_RecSta_PEV_Recording();

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BAlarm_BglrAlrm_CurrentSta;BLTN_CAM_State");

  // 18.3: Wait 12 seconds
  write("Step 18.3: Waiting 12 seconds...");
  testWaitForTimeout(12000);

  // 18.4: Check PEV_Recorded = 0x2
  write("Step 18.4: Checking BLTN_CAM_PEV_Recorded = 0x2...");
  pev_recorded = $BLTN_CAM_PEV_Recorded;
  write("  BLTN_CAM_PEV_Recorded = 0x%X", pev_recorded);

  if (pev_recorded == 0x2)
  {
    write(">>> [PASS] BLTN_CAM_PEV_Recorded = 0x2 <<<");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_PEV_Recorded = 0x%X, expected 0x2 <<<", pev_recorded);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BAlarm_BglrAlrm_CurrentSta;BLTN_CAM_State");

  // 18.5: Wait 305 seconds
  write("Step 18.5: Waiting 305 seconds for PEV_Recorded to change to 0x0...");
  remaining = 305;
  while (remaining > 0)
  {
    if (remaining % 60 == 0)
    {
      write("  Remaining: %d seconds (PEV_Recorded=0x%X, RecSta_PEV=0x%X)",
            remaining, $BLTN_CAM_PEV_Recorded, $BLTN_CAM_RecSta_PEV);
    }
    testWaitForTimeout(1000);
    remaining--;
  }
  write("=== 305s Wait Complete ===");

  // 18.6: Check PEV_Recorded = 0x0
  write("Step 18.6: Checking BLTN_CAM_PEV_Recorded = 0x0...");
  pev_recorded = $BLTN_CAM_PEV_Recorded;
  write("  BLTN_CAM_PEV_Recorded = 0x%X", pev_recorded);

  if (pev_recorded == 0x0)
  {
    write(">>> [PASS] BLTN_CAM_PEV_Recorded = 0x0 <<<");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_PEV_Recorded = 0x%X, expected 0x0 <<<", pev_recorded);
  }

  // 18.7: Check Set_PMD = ON
  write("Step 18.7: Checking BLTN_CAM_Set_PMD = 0x2 (ON)...");
  pmd_result = Check_Set_PMD_ON();

  if (recsta_pev_result == 1 && pev_recorded == 0x0 && pmd_result == 1)
  {
    write(">>> [PASS] RecSta_PEV=Recording, PEV_Recorded=0x0, Set_PMD=ON <<<");
    step18_passed = 1;
    testStepPass("Step18", "BglrAlrm trigger, PEV Recording, PEV_Recorded 0x2->0x0, PMD=ON - PASS");
  }
  else
  {
    write(">>> [FAIL] RecSta_PEV=%d, PEV_Recorded=0x%X, PMD=%d <<<", recsta_pev_result, pev_recorded, pmd_result);
    step18_passed = 0;
    Log_Error_Details();
    testStepFail("Step18", "RecSta=%d, PEV_Recorded=0x%X, PMD=%d - FAIL", recsta_pev_result, pev_recorded, pmd_result);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_Set_PMD;BLTN_CAM_State");

  write("=== FINISH STEP 18 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 19: Check BLTN_CAM_Prk_Oprable_Time = BLTN_CAM_Set_PrkTime - BLTN_CAM_PRK_Oped_Time
// ============================================================================
testcase OWP_011_19()
{
  int prk_oprable;
  int set_prktime;
  int prk_oped;
  int expected_oprable;
  Send_Value_To_COM(21119);
  SetTestStep("Bước 19 - OWP_011");
  StartTestTimer();

  write("");
  write("=== STEP 19: Check Prk_Oprable_Time = Set_PrkTime - Prk_Oped_Time ===");
  testStep("Step19", "Check BLTN_CAM_Prk_Oprable_Time = BLTN_CAM_Set_PrkTime - BLTN_CAM_Prk_Oped_Time formula, capture screenshot");

  testWaitForTimeout(3000);

  set_prktime = $BLTN_CAM_Set_PrkTime;
  prk_oped = $BLTN_CAM_Prk_Oped_Time;
  prk_oprable = $BLTN_CAM_Prk_Oprable_Time;
  expected_oprable = set_prktime - prk_oped;

  write("  BLTN_CAM_Set_PrkTime       = 0x%X (%d Hr)", set_prktime, set_prktime);
  write("  BLTN_CAM_Prk_Oped_Time     = 0x%X (%d Hr)", prk_oped, prk_oped);
  write("  BLTN_CAM_Prk_Oprable_Time  = 0x%X (%d Hr)", prk_oprable, prk_oprable);
  write("  Expected (Set - Oped)       = %d Hr", expected_oprable);

  if (prk_oprable == expected_oprable)
  {
    write(">>> [PASS] Prk_Oprable_Time = %d = Set_PrkTime(%d) - Prk_Oped_Time(%d) <<<",
          prk_oprable, set_prktime, prk_oped);
    step19_passed = 1;
    testStepPass("Step19", "Prk_Oprable_Time = Set_PrkTime - Prk_Oped_Time - PASS");
  }
  else
  {
    write(">>> [FAIL] Prk_Oprable_Time = %d, expected %d (Set=%d - Oped=%d) <<<",
          prk_oprable, expected_oprable, set_prktime, prk_oped);
    step19_passed = 0;
    Log_Error_Details();
    testStepFail("Step19", "Prk_Oprable=%d, expected=%d - FAIL", prk_oprable, expected_oprable);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PrkTime;BLTN_CAM_Prk_Oped_Time;BLTN_CAM_Prk_Oprable_Time;BLTN_CAM_State");

  write("=== FINISH STEP 19 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

