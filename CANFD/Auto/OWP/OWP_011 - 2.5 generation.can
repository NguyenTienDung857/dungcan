// ============================================================================
// STEP 14: KEY ON, Click_USM_Reset, Turn_ON_PMD,
//          Check BLTN_CAM_Set_PMD = 0x2 (ON), Check BLTN_CAM_Set_PEV_AppNoti = 0x2 (ON)
// ============================================================================
testcase OWP_011_14()
{
  int pmd_result;
  int appnoti_result;
  Send_Value_To_COM(21114);
  SetTestStep("Bước 14 - OWP_011");
  StartTestTimer();

  write("");
  write("=== STEP 14: KEY ON, USM Reset, Turn ON PMD, Check Set_PMD=ON, PEV_AppNoti=ON ===");
  testStep("Step14", "KEY ON + USM Reset + Turn ON PMD -> check BLTN_CAM_Set_PMD = 0x2 (ON) & BLTN_CAM_Set_PEV_AppNoti = 0x2 (ON), capture screenshot");

  // 14.1: KEY ON
  write("Step 14.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(3000);

  // 14.2: Click USM Reset
  write("Step 14.2: USM Reset...");
  Click_USM_Reset();

  // 14.3: Turn ON PMD
  write("Step 14.3: Turn ON PMD...");
  Turn_ON_PMD();
  testWaitForTimeout(3000);

  // 14.4: Check BLTN_CAM_Set_PMD = 0x2 (ON)
  write("Step 14.4: Checking BLTN_CAM_Set_PMD = 0x2 (ON)...");
  pmd_result = Check_Set_PMD_ON();

  // 14.5: Check BLTN_CAM_Set_PEV_AppNoti = 0x2 (ON)
  write("Step 14.5: Checking BLTN_CAM_Set_PEV_AppNoti = 0x2 (ON)...");
  appnoti_result = Check_PEV_AppNoti(0x2);

  if (pmd_result == 1 && appnoti_result == 1)
  {
    write(">>> [PASS] Set_PMD = ON, PEV_AppNoti = ON <<<");
    step14_passed = 1;
    testStepPass("Step14", "Set_PMD=ON, PEV_AppNoti=ON - PASS");
  }
  else
  {
    write(">>> [FAIL] Set_PMD result=%d, PEV_AppNoti result=%d <<<", pmd_result, appnoti_result);
    step14_passed = 0;
    Log_Error_Details();
    testStepFail("Step14", "Set_PMD=%d, PEV_AppNoti=%d - FAIL", pmd_result, appnoti_result);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_Set_PEV_AppNoti;BLTN_CAM_RecSta_PEV;BLTN_CAM_State");

  write("=== FINISH STEP 14 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 15: KEY OFF, Set_BglrAlrm = 0,
//          Check BLTN_CAM_PEV_Recorded = 0x0 (Default),
//          Check BLTN_CAM_RecSta_PEV = 0x0 (OFF)
// ============================================================================
testcase OWP_011_15()
{
  int pev_recorded_val;
  int recsta_pev_result;
  Send_Value_To_COM(21115);
  SetTestStep("Bước 15 - OWP_011");
  StartTestTimer();

  write("");
  write("=== STEP 15: KEY OFF, Set BglrAlrm=0, Check PEV_Recorded=0x0, RecSta_PEV=OFF ===");
  testStep("Step15", "KEY OFF + Set_BglrAlrm(0x0) -> check BLTN_CAM_PEV_Recorded = 0x0 (Default) & BLTN_CAM_RecSta_PEV = 0x0 (OFF), capture screenshot");

  // 15.1: KEY OFF
  write("Step 15.1: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 15.2: Set_BglrAlrm = 0
  write("Step 15.2: Setting BglrAlrm = 0...");
  Set_BglrAlrm(0x0);
  testWaitForTimeout(3000);

  // 15.3: Check BLTN_CAM_PEV_Recorded = 0x0 (Default)
  write("Step 15.3: Checking BLTN_CAM_PEV_Recorded = 0x0 (Default)...");
  pev_recorded_val = $BLTN_CAM_PEV_Recorded;
  write("  BLTN_CAM_PEV_Recorded = 0x%X", pev_recorded_val);

  if (pev_recorded_val == 0x0)
  {
    write(">>> [PASS] BLTN_CAM_PEV_Recorded = 0x0 (Default) <<<");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_PEV_Recorded = 0x%X, expected 0x0 (Default) <<<", pev_recorded_val);
  }

  // 15.4: Check BLTN_CAM_RecSta_PEV = 0x0 (OFF)
  write("Step 15.4: Checking RecSta_PEV = OFF...");
  recsta_pev_result = Check_RecSta_PEV_OFF();

  if (pev_recorded_val == 0x0 && recsta_pev_result == 1)
  {
    write(">>> [PASS] PEV_Recorded = 0x0, RecSta_PEV = OFF <<<");
    step15_passed = 1;
    testStepPass("Step15", "PEV_Recorded=0x0, RecSta_PEV=OFF - PASS");
  }
  else
  {
    write(">>> [FAIL] PEV_Recorded=0x%X, RecSta_PEV_OFF=%d <<<", pev_recorded_val, recsta_pev_result);
    step15_passed = 0;
    Log_Error_Details();
    testStepFail("Step15", "PEV_Recorded=0x%X, RecSta_PEV_OFF=%d - FAIL", pev_recorded_val, recsta_pev_result);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_State");

  write("=== FINISH STEP 15 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

