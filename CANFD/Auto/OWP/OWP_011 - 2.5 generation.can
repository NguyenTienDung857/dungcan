/*@!Encoding:65001*/
includes
{
  #include "../DeclarationFunction_Gen2.5.h"
}

//Preconditions: - ACC and IGN and ccNC/ccIC switch OFF, AVN mode
//               - Add signal: BLTN_CAM_RecSta_PEV, BLTN_CAM_RecSet_PEV,
//                             BLTN_CAM_Set_PEV_AppNoti, BLTN_CAM_PEV_Recorded,
//                             BLTN_CAM_RecSta_OWP, BLTN_CAM_RecSet_OWP,
//                             BLTN_CAM_Set_PrkTime, BLTN_CAM_Prk_Oped_Time,
//                             BLTN_CAM_Prk_Oprable_Time, BAlarm_BglrAlrm_CurrentSta,
//                             BLTN_CAM_State

/*
  Test Case: OWP_011 - 2.5 (OWP_011)
  Title: [PEV Burglar Alarm Trigger - Recording, PEV_Recorded, Prk_Oprable_Time Check]

  Step 1:  Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, Turn_OFF_OWP,
           Check_PEV_AppNoti, capture screenshot
  Step 2:  KEY OFF, Check BLTN_CAM_PEV_Recorded = 0x0 (Default),
           Check_RecSta_PEV_OFF, capture screenshot
  Step 3_4: Log "check den LED"
  Step 5:  KEY ON, Switch_CGWNM = 0, Set_BglrAlrm(0x9),
           Check RecSta_PEV = 0x1 (Recording), wait 11s,
           Check PEV_Recorded = 0x2, wait 5 min, Check PEV_Recorded = 0x0
  Step 6:  KEY OFF, KEY ON, Switch_CGWNM = 1,
           Check Prk_Oprable_Time = Set_PrkTime - Prk_Oped_Time
  Step 7_8: Log "check den LED"
  Step 9_10: Log "check video la tao ra video 20s"
  Step 11: KEY ON, Set_BglrAlrm(0x0), Check RecSta_PEV = 0x0 (OFF)
  Step 12_13: Log "check den LED"

  Step 14: KEY ON, Click_USM_Reset, Turn_ON_PMD,
           Check BLTN_CAM_Set_PMD = 0x2 (ON), Check BLTN_CAM_Set_PEV_AppNoti = 0x2 (ON)
  Step 15: KEY OFF, Set_BglrAlrm = 0,
           Check BLTN_CAM_PEV_Recorded = 0x0, Check BLTN_CAM_RecSta_PEV = 0x0 (OFF)
  Step 16_17: Log "check den LED"
  Step 18: Set_BglrAlrm = 9, Check RecSta_PEV = Recording,
           wait 12s, Check PEV_Recorded = 0x2,
           wait 305s, Check PEV_Recorded = 0x0, Check Set_PMD = ON
  Step 19: Check Prk_Oprable_Time = Set_PrkTime - Prk_Oped_Time
  Step 20_21: Log "check den LED"
  Step 22: KEY OFF, wait 20s, KEY ON,
           Check RecSta_OWD = 0x1 (Recording), Check RecSta_DEV = 0x0 (OFF)
  Step 23_24: Log "check video o buoc 18"
  Step 25: If BglrAlrm=9 set 0, else set 9 wait 15s set 0,
           Check RecSta_PEV = 0x0 (OFF)
  Step 26_27: Log "check den LED"

  NOTE: Uses 2-5s delay for signal propagation after each state transition.
*/

variables
{
  // Result tracking
  int step1_passed = 0;
  int step2_passed = 0;
  int step3_4_passed = 0;
  int step5_passed = 0;
  int step6_passed = 0;
  int step7_8_passed = 0;
  int step9_10_passed = 0;
  int step11_passed = 0;
  int step12_13_passed = 0;
  int step14_passed = 0;
  int step15_passed = 0;
  int step16_17_passed = 0;
  int step18_passed = 0;
  int step19_passed = 0;
  int step20_21_passed = 0;
  int step22_passed = 0;
  int step23_24_passed = 0;
  int step25_passed = 0;
  int step26_27_passed = 0;
  int recsta_pev;
  int pev_recorded;
  int remaining;
  // Message Declaration for CAN FD
  message HU_BLTN_CAM_02_200ms _HU_BLTN_CAM_02_200ms;
  message HU_BLTN_CAM_01_00ms _HU_BLTN_CAM_01_00ms;
  message HU_CLOCK_01_1000ms _HU_CLOCK_01_1000ms;
}


// ============================================================================
// Test Cases
// ============================================================================

testcase OWP_011_Init()
{
  Send_Value_To_COM(21100);
  write("========================================");
  write("=== START TEST OWP_011 - 2.5 ===");
  // 1.1: Set_SMK_IGN (full init with CGWNM)
  write("Step 1.1: Set_SMK_IGN (KEY ON with CGWNM)...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);

  // 1.2: Click USM Reset
  write("Step 1.2: USM Reset...");
  Click_USM_Reset();

  // 1.3: Click Rec Reset
  write("Step 1.3: Rec Reset...");
  Click_Rec_Reset();

  write("========================================");
  write("===START TEST===");
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 1: Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, Turn_OFF_OWP,
//         Check_PEV_AppNoti, capture screenshot
// ============================================================================
testcase OWP_011_1()
{
  int appnoti_result;
  Send_Value_To_COM(21101);
  SetTestStep("Bước 1 - OWP_011");
  StartTestTimer();

  

  // 1.4: Turn OFF OWP
  write("Step 1.4: Turn OFF OWP...");
  Turn_OFF_OWP();
  testWaitForTimeout(3000);

  // 1.5: Check PEV App Notification
  write("Step 1.5: Checking PEV App Notification...");
  appnoti_result = Check_PEV_AppNoti($BLTN_CAM_Set_PEV_AppNoti);
  write("  BLTN_CAM_Set_PEV_AppNoti = 0x%X", $BLTN_CAM_Set_PEV_AppNoti);

  // 1.6: Capture screenshot
  write("Step 1.6: Capturing screenshot...");
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSta_OWP;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_Set_PEV_AppNoti;BLTN_CAM_State");

  step1_passed = 1;
  testStepPass("Step1", "Set_SMK_IGN, USM/Rec Reset, Turn OFF OWP, PEV AppNoti checked - PASS");
  write("=== FINISH STEP 1 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 2: KEY OFF, Check BLTN_CAM_PEV_Recorded = 0x0 (Default),
//         Check_RecSta_PEV_OFF, capture screenshot
// ============================================================================
testcase OWP_011_2()
{
  int pev_recorded_val;
  int recsta_pev_result;
  Send_Value_To_COM(21102);
  SetTestStep("Bước 2 - OWP_011");
  StartTestTimer();

  write("");
  write("=== STEP 2: KEY OFF, Check PEV_Recorded = 0x0, Check RecSta_PEV = OFF ===");
  testStep("Step2", "KEY OFF -> check BLTN_CAM_PEV_Recorded = 0x0 (Default) & BLTN_CAM_RecSta_PEV = 0x0 (OFF), capture screenshot");

  // 2.1: KEY OFF
  write("Step 2.1: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 2.2: Check BLTN_CAM_PEV_Recorded = 0x0 (Default)
  write("Step 2.2: Checking BLTN_CAM_PEV_Recorded...");
  pev_recorded_val = $BLTN_CAM_PEV_Recorded;
  write("  BLTN_CAM_PEV_Recorded = 0x%X", pev_recorded_val);

  if (pev_recorded_val == 0x0)
  {
    write(">>> [PASS] BLTN_CAM_PEV_Recorded = 0x0 (Default) <<<");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_PEV_Recorded = 0x%X, expected 0x0 (Default) <<<", pev_recorded_val);
  }

  // 2.3: Check BLTN_CAM_RecSta_PEV = 0x0 (OFF)
  write("Step 2.3: Checking RecSta_PEV = OFF...");
  recsta_pev_result = Check_RecSta_PEV_OFF();
  write("  BLTN_CAM_RecSta_PEV = 0x%X", $BLTN_CAM_RecSta_PEV);

  if (pev_recorded_val == 0x0 && recsta_pev_result == 1)
  {
    write(">>> [PASS] PEV_Recorded = 0x0, RecSta_PEV = OFF <<<");
    step2_passed = 1;
    testStepPass("Step2", "PEV_Recorded = 0x0, RecSta_PEV = OFF - PASS");
  }
  else
  {
    write(">>> [FAIL] PEV_Recorded = 0x%X or RecSta_PEV check failed <<<", pev_recorded_val);
    step2_passed = 0;
    Log_Error_Details();
    testStepFail("Step2", "PEV_Recorded=0x%X, RecSta_PEV_OFF=%d - FAIL", pev_recorded_val, recsta_pev_result);
  }

  // 2.4: Capture screenshot
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BLTN_CAM_RecSta_OWP;BLTN_CAM_State");

  write("=== FINISH STEP 2 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

