// ============================================================================
// STEP 5: KEY ON, Switch_CGWNM = 0, Set_BglrAlrm(0x9),
//         Check RecSta_PEV = 0x1 (Recording), wait 11s,
//         Check PEV_Recorded = 0x2, wait 5 min, Check PEV_Recorded = 0x0
// ============================================================================
testcase OWP_011_5()
{
  Send_Value_To_COM(21105);
  SetTestStep("Bước 5 - OWP_011");
  StartTestTimer();


  write("");
  write("=== STEP 5: KEY ON, CGWNM=0, BglrAlrm=0x9, Check PEV Recording, PEV_Recorded ===");
  testStep("Step5", "KEY ON + CGWNM=0 + Set_BglrAlrm(0x9), check BLTN_CAM_RecSta_PEV = 0x1 (Recording), wait 11s, check PEV_Recorded = 0x2, wait 5min, check PEV_Recorded = 0x0");

  // 5.1: KEY ON
  write("Step 5.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(6000);
  Turn_ON_OWP();

  // 5.2: Switch_CGWNM = 0
  write("Step 5.2: Setting Switch_CGWNM = 0...");
  @panel::Switch_CGWNM = 0;
  testWaitForTimeout(2000);
  KEY_OFF();
  testWaitForTimeout(3000);
  // 5.3: Set Burglar Alarm Signal 0x0 -> 0x9 (Rising Edge)
  write("Step 5.3: Setting Burglar Alarm Signal to 0x9 (Alarm)...");
  if (Set_BglrAlrm(0x9) == 1)
  {
    write(">>> [OK] BglrAlrm set to 0x9 (Alarm) <<<");
  }
  else
  {
    write(">>> [WARNING] Failed to set BglrAlrm to 0x9 <<<");
  }
 

  // 5.4: Check BLTN_CAM_RecSta_PEV = 0x1 (Recording)
  
  recsta_pev = $BLTN_CAM_RecSta_PEV;
 

  if (recsta_pev == 0x1)
  {
    write(">>> [PASS] BLTN_CAM_RecSta_PEV = 0x1 (Recording) <<<");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_RecSta_PEV = 0x%X, expected 0x1 (Recording) <<<", recsta_pev);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BAlarm_BglrAlrm_CurrentSta;BLTN_CAM_State");

  // 5.5: Wait 11 seconds
  write("Step 5.5: Waiting 11 seconds...");
  testWaitForTimeout(11000);

  // 5.6: Check BLTN_CAM_PEV_Recorded = 0x2 (Park Event Recorded)
  write("Step 5.6: Checking BLTN_CAM_PEV_Recorded = 0x2 (Park Event Recorded)...");
  pev_recorded = $BLTN_CAM_PEV_Recorded;
  write("  BLTN_CAM_PEV_Recorded = 0x%X", pev_recorded);

  if (pev_recorded == 0x2)
  {
    write(">>> [PASS] BLTN_CAM_PEV_Recorded = 0x2 (Park Event Recorded) <<<");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_PEV_Recorded = 0x%X, expected 0x2 <<<", pev_recorded);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BAlarm_BglrAlrm_CurrentSta;BLTN_CAM_State");

  // 5.7: Wait 5 minutes (300 seconds)
  write("Step 5.7: Waiting 5 minutes (300s) for PEV_Recorded to change to 0x0 (Off)...");
  remaining = 305;
  while (remaining > 0)
  {
    if (remaining % 60 == 0)
    {
      write("  Remaining: %d seconds (PEV_Recorded=0x%X, RecSta_PEV=0x%X)",
            remaining, $BLTN_CAM_PEV_Recorded, $BLTN_CAM_RecSta_PEV);
    }
    testWaitForTimeout(1000);
    remaining--;
  }
  write("=== 5 min Wait Complete ===");

  // 5.8: Check BLTN_CAM_PEV_Recorded = 0x0 (Off)
  write("Step 5.8: Checking BLTN_CAM_PEV_Recorded = 0x0 (Off)...");
  pev_recorded = $BLTN_CAM_PEV_Recorded;
  write("  BLTN_CAM_PEV_Recorded = 0x%X", pev_recorded);

  if (recsta_pev == 0x1 && pev_recorded == 0x0)
  {
    write(">>> [PASS] RecSta_PEV was Recording, PEV_Recorded now = 0x0 (Off) <<<");
    step5_passed = 1;
    testStepPass("Step5", "BglrAlrm trigger, PEV Recording, PEV_Recorded 0x2->0x0 - PASS");
  }
  else
  {
    write(">>> [FAIL] RecSta_PEV=0x%X, PEV_Recorded=0x%X <<<", recsta_pev, pev_recorded);
    step5_passed = 0;
    Log_Error_Details();
    testStepFail("Step5", "RecSta_PEV=0x%X, PEV_Recorded=0x%X - FAIL", recsta_pev, pev_recorded);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Recorded;BAlarm_BglrAlrm_CurrentSta;BLTN_CAM_State");

  write("=== FINISH STEP 5 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 6: KEY OFF, KEY ON, Switch_CGWNM = 1,
//         Check Prk_Oprable_Time = Set_PrkTime - Prk_Oped_Time
// ============================================================================
testcase OWP_011_6()
{
  int prk_oprable;
  int set_prktime;
  int prk_oped;
  int expected_oprable;
  Send_Value_To_COM(21106);
  SetTestStep("Bước 6 - OWP_011");
  StartTestTimer();

  write("");
  write("=== STEP 6: KEY OFF, KEY ON, CGWNM=1, Check Prk_Oprable_Time ===");
  testStep("Step6", "KEY OFF + KEY ON + CGWNM=1 -> check BLTN_CAM_Prk_Oprable_Time = BLTN_CAM_Set_PrkTime - BLTN_CAM_Prk_Oped_Time, capture screenshot");

  // 6.1: KEY OFF
  write("Step 6.1: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 6.2: KEY ON
  write("Step 6.2: KEY ON...");
  KEY_ON();
  testWaitForTimeout(3000);

  // 6.3: Switch_CGWNM = 1
  write("Step 6.3: Setting Switch_CGWNM = 1...");
  @panel::Switch_CGWNM = 1;
  testWaitForTimeout(2000);

  // 6.4: Read and check BLTN_CAM_Prk_Oprable_Time = BLTN_CAM_Set_PrkTime - BLTN_CAM_Prk_Oped_Time
  write("Step 6.4: Checking Prk_Oprable_Time = Set_PrkTime - Prk_Oped_Time...");
  testWaitForTimeout(3000);

  set_prktime = $BLTN_CAM_Set_PrkTime;
  prk_oped = $BLTN_CAM_Prk_Oped_Time;
  prk_oprable = $BLTN_CAM_Prk_Oprable_Time;
  expected_oprable = set_prktime - prk_oped;

  write("  BLTN_CAM_Set_PrkTime       = 0x%X (%d Hr)", set_prktime, set_prktime);
  write("  BLTN_CAM_Prk_Oped_Time     = 0x%X (%d Hr)", prk_oped, prk_oped);
  write("  BLTN_CAM_Prk_Oprable_Time  = 0x%X (%d Hr)", prk_oprable, prk_oprable);
  write("  Expected (Set - Oped)       = %d Hr", expected_oprable);

  if (prk_oprable == expected_oprable)
  {
    write(">>> [PASS] Prk_Oprable_Time = %d = Set_PrkTime(%d) - Prk_Oped_Time(%d) <<<",
          prk_oprable, set_prktime, prk_oped);
    step6_passed = 1;
    testStepPass("Step6", "Prk_Oprable_Time = Set_PrkTime - Prk_Oped_Time - PASS");
  }
  else
  {
    write(">>> [FAIL] Prk_Oprable_Time = %d, expected %d (Set=%d - Oped=%d) <<<",
          prk_oprable, expected_oprable, set_prktime, prk_oped);
    step6_passed = 0;
    Log_Error_Details();
    testStepFail("Step6", "Prk_Oprable=%d, expected=%d - FAIL", prk_oprable, expected_oprable);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PrkTime;BLTN_CAM_Prk_Oped_Time;BLTN_CAM_Prk_Oprable_Time;BLTN_CAM_State");

  write("=== FINISH STEP 6 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

