// ============================================================================
// STEP 25: If BglrAlrm=9 then set 0, else set 9 wait 15s then set 0.
//          Check RecSta_PEV = 0x0 (OFF)
// ============================================================================
testcase OWP_011_25()
{
  int bglr_val;
  int recsta_pev_result;
  Send_Value_To_COM(21125);
  SetTestStep("Bước 25 - OWP_011");
  StartTestTimer();

  write("");
  write("=== STEP 25: BglrAlrm logic, Check RecSta_PEV = OFF ===");
  testStep("Step25", "BglrAlrm reset logic: if BglrAlrm=0x9 then set 0x0, else set 0x9 wait 15s then set 0x0 -> check BLTN_CAM_RecSta_PEV = 0x0 (OFF)");

  // 25.1: Check current BglrAlrm value
  bglr_val = $BAlarm_BglrAlrm_CurrentSta;
  write("Step 25.1: Current BAlarm_BglrAlrm_CurrentSta = 0x%X", bglr_val);

  if (Check_BglrAlrm(0x9) == 1)
  {
    // BglrAlrm = 9 -> set to 0
    write("Step 25.2: BglrAlrm = 9, setting to 0...");
    Set_BglrAlrm(0x0);
    testWaitForTimeout(3000);
  }
  else
  {
    // BglrAlrm != 9 -> set to 9, wait 15s, then set to 0
    write("Step 25.2: BglrAlrm != 9, setting to 9 first...");
    Set_BglrAlrm(0x9);
    write("  Waiting 15 seconds...");
    testWaitForTimeout(15000);
    write("  Now setting BglrAlrm to 0...");
    Set_BglrAlrm(0x0);
    testWaitForTimeout(3000);
  }

  // 25.3: Check RecSta_PEV = 0x0 (OFF)
  write("Step 25.3: Checking RecSta_PEV = OFF...");
  recsta_pev_result = Check_RecSta_PEV_OFF();

  if (recsta_pev_result == 1)
  {
    write(">>> [PASS] RecSta_PEV = OFF <<<");
    step25_passed = 1;
    testStepPass("Step25", "BglrAlrm reset, RecSta_PEV=OFF - PASS");
  }
  else
  {
    write(">>> [FAIL] RecSta_PEV is NOT OFF <<<");
    step25_passed = 0;
    Log_Error_Details();
    testStepFail("Step25", "RecSta_PEV not OFF - FAIL");
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PEV;BAlarm_BglrAlrm_CurrentSta;BLTN_CAM_State");

  write("=== FINISH STEP 25 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

