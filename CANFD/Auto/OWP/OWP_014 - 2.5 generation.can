// ============================================================================
// Summary
// ============================================================================

void MainTest()
{
  testReportFileName("TestReports\\OWP_014 - 2.5 generation_report");

  OWP_014_Init();

  OWP_014_1();
  OWP_014_2_3();
  OWP_014_4();
  OWP_014_5_6_7_8_9();
  OWP_014_10();
  OWP_014_11();
  OWP_014_12_13_14();
  OWP_014_15();
  OWP_014_16();
  OWP_014_17_18();

}
