/*@!Encoding:65001*/

includes
{
  #include "../DeclarationFunction_Gen2.5.h"
}

//Preconditions: - ACC and IGN and ccNC/ccIC switch OFF, AVN mode
//               - Add signal: BLTN_CAM_RecSta_MAR, BLTN_CAM_RecSet_OWP,
//                             BLTN_CAM_RecSet_PEV, BLTN_CAM_State

/*
  Test Case: OWP_014 - 2.5 (OWP_014)
  Title: [MAR Manual Event Recording - RecSta_MAR Check, Multi-Event, OWP/PEV OFF Check]

  Step 1:  Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, KEY OFF,
           Check BLTN_CAM_RecSta_MAR = 0x0 (OFF), capture screenshot
  Step 2_3: Log "check anh den LED"
  Step 4:  Click_Evt_Switch, Check BLTN_CAM_RecSta_MAR = 0x1 (ON), capture screenshot
  Step 5_6_7_8_9: Log "check anh den LED" (5 steps combined)
  Step 10: Wait 10s, Click_Evt_Switch, wait 11s, Click_Evt_Switch, wait 11s, Click_Evt_Switch,
           Log "check video man hinh truc tiep"
  Step 11: Log "lay anh man hinh video truc tiep o buoc 10"
  Step 12_13_14: Log "check video tren may tinh"
  Step 15: KEY ON, Turn_OFF_OWP, Turn_OFF_PEV,
           Check BLTN_CAM_RecSet_OWP = 0x1 (OFF), Check BLTN_CAM_RecSet_PEV = 0x1 (OFF),
           capture screenshot
  Step 16: KEY OFF, Check BLTN_CAM_RecSta_MAR = 0x0 (OFF), capture screenshot
  Step 17_18: Log "check anh den LED"

  NOTE: Uses 2-5s delay for signal propagation after each state transition.
*/

variables
{
  // Result tracking
  int step1_passed = 0;
  int step2_3_passed = 0;
  int step4_passed = 0;
  int step5_6_7_8_9_passed = 0;
  int step10_passed = 0;
  int step11_passed = 0;
  int step12_13_14_passed = 0;
  int step15_passed = 0;
  int step16_passed = 0;
  int step17_18_passed = 0;

  // Message Declaration for CAN FD
  message HU_BLTN_CAM_02_200ms _HU_BLTN_CAM_02_200ms;
  message HU_BLTN_CAM_01_00ms  _HU_BLTN_CAM_01_00ms;
  message HU_CLOCK_01_1000ms   _HU_CLOCK_01_1000ms;
}


// ============================================================================
// Test Cases
// ============================================================================

testcase OWP_014_Init()
{
  Send_Value_To_COM(21400);
  write("========================================");
  write("=== START TEST OWP_014 - 2.5 ===");
  write("========================================");
  testStep("Notification", "Start test OWP_014 - 2.5");
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 1: Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset, KEY OFF,
//         Check BLTN_CAM_RecSta_MAR = 0x0 (OFF)
// ============================================================================
testcase OWP_014_1()
{
  Send_Value_To_COM(21401);
  SetTestStep("Bước 1 - OWP_014");
  StartTestTimer();
  write("");
  write("=== STEP 1: Init + KEY OFF, Check RecSta_MAR = 0x0 (OFF) ===");
  testStep("Step1", "Set_SMK_IGN, USM/Rec Reset, KEY OFF, Check RecSta_MAR = OFF");

  // 1.1: Set_SMK_IGN
  write("");
  write("Step 1.1: Setting SMK_Signal to IGN...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);

  // 1.2: Click USM Reset
  write("");
  write("Step 1.2: Clicking USM Reset...");
  Click_USM_Reset();

  // 1.3: Click Rec Reset
  write("");
  write("Step 1.3: Clicking Rec Reset...");
  Click_Rec_Reset();

  // 1.4: KEY OFF
  write("");
  write("Step 1.4: KEY OFF, waiting 5s...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 1.5: Check BLTN_CAM_RecSta_MAR = 0x0 (OFF)
  write("");
  write("Step 1.5: Checking BLTN_CAM_RecSta_MAR...");
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);

  if ($BLTN_CAM_RecSta_MAR == 0x0)
  {
    write(">>> [PASS] BLTN_CAM_RecSta_MAR = 0x0 (OFF) <<<");
    step1_passed = 1;
    testStepPass("Step1", "BLTN_CAM_RecSta_MAR = 0x0 (OFF) - PASS");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_RecSta_MAR = 0x%X, expected 0x0 (OFF) <<<", $BLTN_CAM_RecSta_MAR);
    step1_passed = 0;
    Log_Error_Details();
    testStepFail("Step1", "BLTN_CAM_RecSta_MAR = 0x%X, expected 0x0 - FAIL", $BLTN_CAM_RecSta_MAR);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_MAR;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSet_PEV;BLTN_CAM_State");

  write("=== FINISH STEP 1 ===");
  testwaitForTimeout(2000);
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 2 & 3: Log "check anh den LED"
// ============================================================================
testcase OWP_014_2_3()
{
  Send_Value_To_COM(21402);
  SetTestStep("Bước 2 và 3 - OWP_014");
  StartTestTimer();
  write("");
  write("=== STEP 2 & 3: Check anh den LED ===");
  testStep("Step2_3", "Check anh den LED");

  write("");
  write("*************************************************************");
  write("*** [MANUAL VERIFICATION REQUIRED]                        ***");
  write("*** Hay CHECK ANH DEN LED tren thiet bi!                  ***");
  write("*** Kiem tra den LED co nhap nhay dung khong.             ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_MAR;BLTN_CAM_State");

  step2_3_passed = 1;
  testStepPass("Step2_3", "Log: check anh den LED - manual check required");
  write("=== FINISH STEP 2 & 3 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 4: Click_Evt_Switch, Check BLTN_CAM_RecSta_MAR = 0x1 (ON)
// ============================================================================
testcase OWP_014_4()
{
  Send_Value_To_COM(21404);
  SetTestStep("Bước 4 - OWP_014");
  StartTestTimer();
  write("");
  write("=== STEP 4: Click_Evt_Switch, Check RecSta_MAR = 0x1 (ON) ===");
  testStep("Step4", "Click_Evt_Switch, Check RecSta_MAR = ON");

  // 4.1: Click Event Switch
  write("");
  write("Step 4.1: Clicking Event Switch (MAR trigger)...");
  Click_Evt_Switch();
  testWaitForTimeout(5000);

  // 4.2: Check BLTN_CAM_RecSta_MAR = 0x1 (ON)
  write("");
  write("Step 4.2: Checking BLTN_CAM_RecSta_MAR...");
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);

  if ($BLTN_CAM_RecSta_MAR == 0x1)
  {
    write(">>> [PASS] BLTN_CAM_RecSta_MAR = 0x1 (ON) <<<");
    step4_passed = 1;
    testStepPass("Step4", "BLTN_CAM_RecSta_MAR = 0x1 (ON) - PASS");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_RecSta_MAR = 0x%X, expected 0x1 (ON) <<<", $BLTN_CAM_RecSta_MAR);
    step4_passed = 0;
    Log_Error_Details();
    testStepFail("Step4", "BLTN_CAM_RecSta_MAR = 0x%X, expected 0x1 - FAIL", $BLTN_CAM_RecSta_MAR);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_MAR;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSet_PEV;BLTN_CAM_State");

  write("=== FINISH STEP 4 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

