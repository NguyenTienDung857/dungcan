// ============================================================================
// STEP 10: Wait 10s, Click_Evt_Switch, wait 11s, Click_Evt_Switch,
//          wait 11s, Click_Evt_Switch, log check video man hinh truc tiep
// ============================================================================
testcase OWP_014_10()
{
  Send_Value_To_COM(21410);
  SetTestStep("Bước 10 - OWP_014");
  StartTestTimer();
  write("");
  write("=== STEP 10: 3x MAR events (10s+11s+11s), Check video ===");
  testStep("Step10", "3x Click_Evt_Switch with delays, check live video");

  // 10.1: Wait 10 seconds
  write("");
  write("Step 10.1: Waiting 10 seconds before first event...");
  testWaitForTimeout(10000);

  // 10.2: First Click_Evt_Switch
  write("");
  write("Step 10.2: MAR event 1/3 - Click_Evt_Switch...");
  Click_Evt_Switch();
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);

  // 10.3: Wait 11 seconds
  write("");
  write("Step 10.3: Waiting 11 seconds before second event...");
  testWaitForTimeout(11000);

  // 10.4: Second Click_Evt_Switch
  write("");
  write("Step 10.4: MAR event 2/3 - Click_Evt_Switch...");
  Click_Evt_Switch();
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);

  // 10.5: Wait 11 seconds
  write("");
  write("Step 10.5: Waiting 11 seconds before third event...");
  testWaitForTimeout(11000);

  // 10.6: Third Click_Evt_Switch
  write("");
  write("Step 10.6: MAR event 3/3 - Click_Evt_Switch...");
  Click_Evt_Switch();
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);

  // 10.7: Log check video man hinh truc tiep
  write("");
  write("*************************************************************");
  write("*** [ACTION REQUIRED]                                     ***");
  write("*** Hay CHECK VIDEO MAN HINH TRUC TIEP tren thiet bi!     ***");
  write("*** Kiem tra video co ghi nhan 3 su kien MAR.              ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_MAR;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSet_PEV;BLTN_CAM_State");

  step10_passed = 1;
  testStepPass("Step10", "3x MAR events triggered, live video check notified - PASS");
  write("=== FINISH STEP 10 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

