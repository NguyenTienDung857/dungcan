  // 16.1: KEY OFF
  write("");
  write("Step 16.1: KEY OFF, waiting 5s...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 16.2: Check BLTN_CAM_RecSta_MAR = 0x0 (OFF)
  write("");
  write("Step 16.2: Checking BLTN_CAM_RecSta_MAR...");
  write("  BLTN_CAM_RecSta_MAR = 0x%X", $BLTN_CAM_RecSta_MAR);

  if ($BLTN_CAM_RecSta_MAR == 0x0)
  {
    write(">>> [PASS] BLTN_CAM_RecSta_MAR = 0x0 (OFF) <<<");
    step16_passed = 1;
    testStepPass("Step16", "BLTN_CAM_RecSta_MAR = 0x0 (OFF) - PASS");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_RecSta_MAR = 0x%X, expected 0x0 (OFF) <<<", $BLTN_CAM_RecSta_MAR);
    step16_passed = 0;
    Log_Error_Details();
    testStepFail("Step16", "BLTN_CAM_RecSta_MAR = 0x%X, expected 0x0 - FAIL", $BLTN_CAM_RecSta_MAR);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_MAR;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSet_PEV;BLTN_CAM_State");

  write("=== FINISH STEP 16 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

