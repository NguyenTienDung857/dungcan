  write("***                                                       ***");
  write("*** Step 12: Kiem tra video MAR da ghi tren may tinh      ***");
  write("*** Step 13: Kiem tra chat luong video MAR                ***");
  write("*** Step 14: Kiem tra thoi gian ghi video MAR             ***");
  write("*************************************************************");
  write("");

  step12_13_14_passed = 1;
