// ============================================================================
// STEP 15: KEY ON, Turn_OFF_OWP, Turn_OFF_PEV,
//          Check BLTN_CAM_RecSet_OWP = 0x1 (OFF),
//          Check BLTN_CAM_RecSet_PEV = 0x1 (OFF)
// ============================================================================
testcase OWP_014_15()
{
  int owp_ok;
  int pev_ok;
  Send_Value_To_COM(21415);
  SetTestStep("Bước 15 - OWP_014");
  StartTestTimer();

  write("");
  write("=== STEP 15: KEY ON, Turn OFF OWP & PEV, Check RecSet = OFF ===");
  testStep("Step15", "KEY ON, Turn OFF OWP, Turn OFF PEV, Check RecSet OFF");

  // 15.1: KEY ON
  write("");
  write("Step 15.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // 15.2: Turn OFF OWP
  write("");
  write("Step 15.2: Turn OFF OWP...");
  Turn_OFF_OWP();
  testWaitForTimeout(3000);

  // 15.3: Turn OFF PEV
  write("");
  write("Step 15.3: Turn OFF PEV...");
  Turn_OFF_PEV();
  testWaitForTimeout(3000);

  // 15.4: Check BLTN_CAM_RecSet_OWP = 0x1 (OFF)
  write("");
  write("Step 15.4: Checking BLTN_CAM_RecSet_OWP...");
  write("  BLTN_CAM_RecSet_OWP = 0x%X", $BLTN_CAM_RecSet_OWP);
  owp_ok = 0;
  if ($BLTN_CAM_RecSet_OWP == 0x1)
  {
    write(">>> [OK] BLTN_CAM_RecSet_OWP = 0x1 (OFF) <<<");
    owp_ok = 1;
  }
  else
  {
    write(">>> [NG] BLTN_CAM_RecSet_OWP = 0x%X, expected 0x1 (OFF) <<<", $BLTN_CAM_RecSet_OWP);
  }

  // 15.5: Check BLTN_CAM_RecSet_PEV = 0x1 (OFF)
  write("");
  write("Step 15.5: Checking BLTN_CAM_RecSet_PEV...");
  write("  BLTN_CAM_RecSet_PEV = 0x%X", $BLTN_CAM_RecSet_PEV);
  pev_ok = 0;
  if ($BLTN_CAM_RecSet_PEV == 0x1)
  {
    write(">>> [OK] BLTN_CAM_RecSet_PEV = 0x1 (OFF) <<<");
    pev_ok = 1;
  }
  else
  {
    write(">>> [NG] BLTN_CAM_RecSet_PEV = 0x%X, expected 0x1 (OFF) <<<", $BLTN_CAM_RecSet_PEV);
  }

  if (owp_ok == 1 && pev_ok == 1)
  {
    write(">>> [PASS] Both OWP and PEV = OFF <<<");
    step15_passed = 1;
    testStepPass("Step15", "RecSet_OWP=0x1, RecSet_PEV=0x1 (both OFF) - PASS");
  }
  else
  {
    write(">>> [FAIL] OWP or PEV not OFF <<<");
    step15_passed = 0;
    Log_Error_Details();
    testStepFail("Step15", "RecSet_OWP=0x%X, RecSet_PEV=0x%X - FAIL", $BLTN_CAM_RecSet_OWP, $BLTN_CAM_RecSet_PEV);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSet_OWP;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_MAR;BLTN_CAM_State");

  write("=== FINISH STEP 15 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 16: KEY OFF, Check BLTN_CAM_RecSta_MAR = 0x0 (OFF)
// ============================================================================
