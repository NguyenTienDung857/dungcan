// ============================================================================
// STEP 11: KEY ON, KEY OFF, WaitFor_RecSta_PMD_Recording, Check RecSta_PMD
// ============================================================================
testcase OWP_017_11()
{
  int pmd_result;
  int pmd_sta_val;
  Send_Value_To_COM(21711);
  SetTestStep("Bước 11 - OWP_017");
  StartTestTimer();

  write("");
  write("=== STEP 11: KEY ON, KEY OFF, Wait PMD Recording, Check RecSta_PMD ===");
  testStep("Step11", "KEY ON, KEY OFF, WaitFor PMD Recording");

  // 11.1: KEY ON
  write("Step 11.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // 11.2: KEY OFF
  write("Step 11.2: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 11.3: Wait for PMD Recording (max 120s)
  write("Step 11.3: Waiting for PMD Recording (max 120s)...");
  pmd_result = WaitFor_RecSta_PMD_Recording(120000);

  // 11.4: Check BLTN_CAM_RecSta_PMD
  pmd_sta_val = $BLTN_CAM_RecSta_PMD;
  write("  BLTN_CAM_RecSta_PMD = 0x%X", pmd_sta_val);

  if (pmd_result == 1 && pmd_sta_val == 0x1)
  {
    write(">>> [PASS] PMD Recording detected, RecSta_PMD = 0x1 <<<");
    step11_passed = 1;
    testStepPass("Step11", "PMD Recording, RecSta_PMD = 0x1 - PASS");
  }
  else
  {
    write(">>> [FAIL] PMD=%d, RecSta_PMD=0x%X <<<", pmd_result, pmd_sta_val);
    step11_passed = 0;
    Log_Error_Details();
    testStepFail("Step11", "PMD=%d, RecSta_PMD=0x%X - FAIL", pmd_result, pmd_sta_val);
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_PMD_Count;BLTN_CAM_State");

  write("=== FINISH STEP 11 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 12: Log tac dong su kien 3 lan (5s interval), wait 60s,
//          KEY ON, wait 5s, log check video
// ============================================================================
testcase OWP_017_12()
{
  Send_Value_To_COM(21712);
  SetTestStep("Bước 12 - OWP_017");
  StartTestTimer();
  KEY_ON();
  KEY_OFF ();
  testWaitForTimeout(5000);
  write("");
  write("=== STEP 12: Tac dong su kien 3 lan, wait 60s, KEY ON, check video ===");
  testStep("Step12", "Tac dong su kien 3 lan, wait 60s, KEY ON, check video");
  WaitFor_RecSta_PMD_Recording(120000);
  WaitFor_RecSta_PMD_OFF(120000);
  WaitFor_RecSta_PMD_Recording(120000);
  WaitFor_RecSta_PMD_OFF(120000);
  WaitFor_RecSta_PMD_Recording(120000);
  WaitFor_RecSta_PMD_OFF(120000);
  // 12.2: Wait for manual action + interval (3 events * 5s + buffer = ~20s)


  testWaitForTimeout(5000);



  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_PMD_Count;BLTN_CAM_State");

  step12_passed = 1;
  testStepPass("Step12", "Tac dong 3 lan, wait 60s, KEY ON, check video - PASS");
  write("=== FINISH STEP 12 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

