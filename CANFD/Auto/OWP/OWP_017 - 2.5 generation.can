// ============================================================================
// STEP 15: KEY ON, Turn_ON_PMD, Turn_ON_PEV, KEY OFF,
//          WaitFor_RecSta_PMD_Recording, Check RecSta_PMD = 0x1, log future
// ============================================================================
testcase OWP_017_15()
{
  int pmd_sta_val;
  Send_Value_To_COM(21715);
  SetTestStep("Bước 15 - OWP_017");
  StartTestTimer();

  write("");
  write("=== STEP 15: KEY ON, Turn ON PMD+PEV, KEY OFF, Wait PMD Recording ===");
  testStep("Step15", "KEY ON, Turn ON PMD+PEV, KEY OFF, PMD Recording");

  // 15.1: KEY ON
  write("Step 15.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // 15.2: Turn ON PMD
  write("Step 15.2: Turn ON PMD...");
  Turn_ON_PMD();
  testWaitForTimeout(2000);

  // 15.3: Turn ON PEV
  write("Step 15.3: Turn ON PEV...");
  Turn_ON_PEV();
  testWaitForTimeout(2000);

  // 15.4: KEY OFF
  write("Step 15.4: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 15.5: Wait for PMD Recording (max 120s)
  write("Step 15.5: Waiting for PMD Recording (max 120s)...");
  if (WaitFor_RecSta_PMD_Recording(120000) != 1)
  {
    write(">>> [FAIL] PMD Recording NOT detected! <<<");
    CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSet_PEV;BLTN_CAM_State");
    step15_passed = 0;
    Log_Error_Details();
    testStepFail("Step15", "PMD Recording not detected");
    return;
  }

  // 15.6: Check BLTN_CAM_RecSta_PMD = 0x1 (Recording)
  pmd_sta_val = $BLTN_CAM_RecSta_PMD;
  write("  BLTN_CAM_RecSta_PMD = 0x%X", pmd_sta_val);

  if (pmd_sta_val == 0x1)
  {
    write(">>> [PASS] BLTN_CAM_RecSta_PMD = 0x1 (Recording) <<<");
    step15_passed = 1;
    testStepPass("Step15", "PMD+PEV ON, RecSta_PMD = 0x1 - PASS");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_RecSta_PMD = 0x%X, expected 0x1 <<<", pmd_sta_val);
    step15_passed = 0;
    Log_Error_Details();
    testStepFail("Step15", "RecSta_PMD = 0x%X, expected 0x1 - FAIL", pmd_sta_val);
  }

  // 15.7: Log future check
  write("");
  write("*************************************************************");
  write("*** [INFO] SAU NAY CHECK CHI TIET HON!                    ***");
  write("*** Can kiem tra chi tiet hon o cac buoc tiep theo.         ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSet_PEV;BLTN_CAM_RecSta_PEV;BLTN_CAM_State");

  write("=== FINISH STEP 15 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 16: WaitFor_RecSta_PMD_Recording, WaitFor_RecSta_PEV_Recording,
//          wait 20s, Check_RecSta_PMD_Recording
// ============================================================================
testcase OWP_017_16()
{
  int pev_result;
  int pmd_result;
  Send_Value_To_COM(21716);
  SetTestStep("Bước 16 - OWP_017");
  StartTestTimer();

  write("");
  write("=== STEP 16: Wait PMD, Trigger PEV, wait 20s, Check PMD still Recording ===");
  testStep("Step16", "PMD Recording, PEV trigger, check PMD still active");

  // 16.1: Wait for PMD Recording (max 120s)
  write("Step 16.1: Waiting for PMD Recording (max 120s)...");
  if (WaitFor_RecSta_PMD_Recording(120000) != 1)
  {
    write(">>> [FAIL] PMD Recording NOT detected! <<<");
    CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_State");
    step16_passed = 0;
    Log_Error_Details();
    testStepFail("Step16", "PMD Recording not detected");
    return;
  }
  write(">>> [OK] PMD Recording active <<<");

  // 16.2: WaitFor_RecSta_PEV_Recording
  write("Step 16.2: Triggering PEV event...");
  pev_result = WaitFor_RecSta_PEV_Recording(60);

  if (pev_result == 1)
    write(">>> [OK] PEV recording detected <<<");
  else
    write(">>> [WARNING] PEV recording not detected within timeout <<<");

  // 16.3: Wait 20 seconds
  write("Step 16.3: Waiting 20 seconds...");
  testWaitForTimeout(20000);

  // 16.4: Check PMD still Recording
  write("Step 16.4: Check PMD still Recording after PEV trigger...");
  pmd_result = Check_RecSta_PMD_Recording();

  if (pmd_result == 1)
  {
    write(">>> [PASS] PMD still Recording after PEV trigger + 20s <<<");
    step16_passed = 1;
    testStepPass("Step16", "PMD active after PEV + 20s - PASS");
  }
  else
  {
    write(">>> [FAIL] PMD NOT Recording after PEV trigger + 20s <<<");
    step16_passed = 0;
    Log_Error_Details();
    testStepFail("Step16", "PMD not recording after PEV + 20s - FAIL");
  }

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_PEV_Count;BLTN_CAM_PMD_Count;BLTN_CAM_State");

  write("=== FINISH STEP 16 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 17: KEY ON, KEY OFF, WaitFor_RecSta_PMD_Recording, wait 5s,
//          WaitFor_RecSta_PEV_Recording x3 (5s each), WaitForNetworkSleep,
//          wait 10s, screenshot
// ============================================================================
testcase OWP_017_17()
{
  Send_Value_To_COM(21717);
  SetTestStep("Bước 17 - OWP_017");
  StartTestTimer();
  write("");
  write("=== STEP 17: KEY ON/OFF, wait RecSta PMD/PEV recording, network sleep, screenshot ===");
  testStep("Step17", "KEY ON/OFF, wait recording states, network sleep, screenshot");

  // 17.1: KEY ON
  write("Step 17.1: KEY ON...");
  KEY_ON();
  testWaitForTimeout(5000);

  // 17.2: KEY OFF
  write("Step 17.2: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 17.3: Wait for PMD Recording state
  write("Step 17.3: WaitFor_RecSta_PMD_Recording...");
  WaitFor_RecSta_PMD_Recording(30000);
  testWaitForTimeout(5000);

  // 17.4: Wait for PEV Recording state - lan 1
  write("Step 17.4: WaitFor_RecSta_PEV_Recording - lan 1...");
  WaitFor_RecSta_PEV_Recording(30000);
  testWaitForTimeout(5000);

  // 17.5: Wait for PEV Recording state - lan 2
  write("Step 17.5: WaitFor_RecSta_PEV_Recording - lan 2...");
  WaitFor_RecSta_PEV_Recording(30000);
  testWaitForTimeout(5000);

  // 17.6: Wait for PEV Recording state - lan 3
  write("Step 17.6: WaitFor_RecSta_PEV_Recording - lan 3...");
  WaitFor_RecSta_PEV_Recording(30000);

  // 17.7: Wait for network sleep
  write("Step 17.7: WaitForNetworkSleep...");
  WaitForNetworkSleep(120);

  // 17.8: Wait 10 seconds after network sleep
  write("Step 17.8: Waiting 10s after network sleep...");
  testWaitForTimeout(10000);

  // 17.9: Screenshot
  write("Step 17.9: Capturing screenshot...");
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_PMD_Count;BLTN_CAM_State");

  step17_passed = 1;
  testStepPass("Step17", "KEY ON/OFF, recording states, network sleep, screenshot - PASS");
  write("=== FINISH STEP 17 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

