/*@!Encoding:65001*/
includes
{
  #include "../DeclarationFunction_Gen2.5.h"
}

//Preconditions: - ACC and IGN and ccNC/ccIC switch OFF, AVN mode
//               - Add signal: BLTN_CAM_Set_PMD, BLTN_CAM_RecSta_PMD,
//                             BLTN_CAM_RecSet_PEV, BLTN_CAM_RecSta_PEV,
//                             BLTN_CAM_PMD_Count, BLTN_CAM_State,
//                             SMK_TrmnlCtrlGrpStaBDC

/*
  Test Case: OWP_017 - 2.5 (OWP_017)
  Title: [PMD Recording Check + PMD Count + PEV Interaction]

  Step 1:  Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset,
           Check Set_PMD=0x1(OFF), RecSta_PMD=0x0(OFF)
  Step 2_3: Log check den LED
  Step 4:  Turn_ON_PMD, Check Set_PMD=ON, RecSta_PMD=0x0(OFF)
  Step 5:  KEY OFF, log motion, WaitFor_RecSta_PMD_Recording(60s),
           Check RecSta_PMD=0x1(Recording), screenshot, log panel check
  Step 6:  WaitFor_RecSta_PMD_OFF, Check RecSta_PMD=0x2
  Step 7_8_9: Log check den LED
  Step 10: Log check video o buoc 5
  Step 11: KEY ON, KEY OFF, WaitFor_RecSta_PMD_Recording, Check RecSta_PMD
  Step 12: Log tac dong su kien 3 lan (5s interval), wait 60s, KEY ON,
           wait 5s, log check video
  Step 13: Check PMD_Count = 0x03
  Step 14: KEY OFF, Check PMD_Count = 0x00
  Step 15: KEY ON, Turn_ON_PMD, Turn_ON_PEV, KEY OFF,
           WaitFor_RecSta_PMD_Recording, Check RecSta_PMD=0x1, log future check
  Step 16: WaitFor_RecSta_PMD_Recording, WaitFor_RecSta_PEV_Recording,
           wait 20s, Check_RecSta_PMD_Recording
  Step 17: KEY ON, KEY OFF, wait 20s, log tac dong 3 lan, wait 60s,
           KEY ON, wait 5s, screenshot, log check network sleep
  Step 18_19_20: Log check video tren PC

  NOTE: Uses 2-5s delay for signal propagation after each state transition.
*/

variables
{
  // Result tracking
  int step1_passed = 0;
  int step2_3_passed = 0;
  int step4_passed = 0;
  int step5_passed = 0;
  int step6_passed = 0;
  int step7_8_9_passed = 0;
  int step10_passed = 0;
  int step11_passed = 0;
  int step12_passed = 0;
  int step13_passed = 0;
  int step14_passed = 0;
  int step15_passed = 0;
  int step16_passed = 0;
  int step17_passed = 0;
  int step18_19_20_passed = 0;

  // Message Declaration for CAN FD
  message HU_BLTN_CAM_02_200ms _HU_BLTN_CAM_02_200ms;
  message HU_BLTN_CAM_01_00ms _HU_BLTN_CAM_01_00ms;
  message HU_CLOCK_01_1000ms _HU_CLOCK_01_1000ms;
}


// ============================================================================
// Test Cases
// ============================================================================

testcase OWP_017_Init()
{
  Send_Value_To_COM(21700);
  write("========================================");
  write("=== START TEST OWP_017 - 2.5 ===");
  write("========================================");
  write("===START TEST===");
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 1: Set_SMK_IGN, Click_USM_Reset, Click_Rec_Reset,
//         Check Set_PMD = 0x1 (OFF), RecSta_PMD = 0x0 (OFF)
// ============================================================================
testcase OWP_017_1()
{
  int pmd_set_val;
  int pmd_sta_val;
  Send_Value_To_COM(21701);
  SetTestStep("Bước 1 - OWP_017");
  StartTestTimer();

  write("");
  write("=== STEP 1: Init, Check Set_PMD=OFF, RecSta_PMD=OFF ===");
  testStep("Step1", "Set_SMK_IGN, USM/Rec Reset, Check PMD OFF states");

  // 1.1: Set_SMK_IGN
  write("Step 1.1: Set_SMK_IGN (KEY ON with CGWNM)...");
  Set_SMK_IGN();
  testWaitForTimeout(3000);
  write("  SMK_TrmnlCtrlGrpStaBDC = 0x%X", $SMK_TrmnlCtrlGrpStaBDC);

  // 1.2: Click USM Reset
  write("Step 1.2: USM Reset...");
  Click_USM_Reset();

  // 1.3: Click Rec Reset
  write("Step 1.3: Rec Reset...");
  Click_Rec_Reset();
  testWaitForTimeout(3000);

  // 1.4: Check BLTN_CAM_Set_PMD = 0x1 (OFF)
  write("Step 1.4: Check BLTN_CAM_Set_PMD...");
  pmd_set_val = $BLTN_CAM_Set_PMD;
  write("  BLTN_CAM_Set_PMD = 0x%X", pmd_set_val);

  if (pmd_set_val == 0x1)
    write(">>> [PASS] BLTN_CAM_Set_PMD = 0x1 (OFF) <<<");
  else
    write(">>> [FAIL] BLTN_CAM_Set_PMD = 0x%X, expected 0x1 (OFF) <<<", pmd_set_val);

  // 1.5: Check BLTN_CAM_RecSta_PMD = 0x0 (OFF)
  write("Step 1.5: Check BLTN_CAM_RecSta_PMD...");
  pmd_sta_val = $BLTN_CAM_RecSta_PMD;
  write("  BLTN_CAM_RecSta_PMD = 0x%X", pmd_sta_val);

  if (pmd_sta_val == 0x0)
    write(">>> [PASS] BLTN_CAM_RecSta_PMD = 0x0 (OFF) <<<");
  else
    write(">>> [FAIL] BLTN_CAM_RecSta_PMD = 0x%X, expected 0x0 (OFF) <<<", pmd_sta_val);

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_State");

  if (pmd_set_val == 0x1 && pmd_sta_val == 0x0)
  {
    step1_passed = 1;
    testStepPass("Step1", "Set_PMD=0x1(OFF), RecSta_PMD=0x0(OFF) - PASS");
  }
  else
  {
    step1_passed = 0;
    Log_Error_Details();
    testStepFail("Step1", "Set_PMD=0x%X, RecSta_PMD=0x%X - FAIL", pmd_set_val, pmd_sta_val);
  }

  write("=== FINISH STEP 1 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 2 & 3: Log check den LED
// ============================================================================
testcase OWP_017_2_3()
{
  Send_Value_To_COM(21702);
  SetTestStep("Bước 2 và 3 - OWP_017");
  StartTestTimer();
  write("");
  write("=== STEP 2 & 3: Check den LED ===");
  testStep("Step2_3", "Check den LED");

  write("");
  write("*************************************************************");
  write("*** [MANUAL VERIFICATION REQUIRED]                        ***");
  write("*** Hay CHECK DEN LED tren thiet bi!                      ***");
  write("*** Kiem tra den LED co nhap nhay dung khong.             ***");
  write("*************************************************************");
  write("");

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_State");

  step2_3_passed = 1;
  testStepPass("Step2_3", "Log: check den LED - manual check required");
  write("=== FINISH STEP 2 & 3 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 4: Turn_ON_PMD, Check Set_PMD = ON, RecSta_PMD = 0x0 (OFF)
// ============================================================================
testcase OWP_017_4()
{
  int pmd_set_result;
  int pmd_sta_val;
  Send_Value_To_COM(21704);
  SetTestStep("Bước 4 - OWP_017");
  StartTestTimer();

  write("");
  write("=== STEP 4: Turn ON PMD, Check Set_PMD=ON, RecSta_PMD=OFF ===");
  testStep("Step4", "Turn ON PMD, Check Set_PMD ON, RecSta_PMD OFF");

  // 4.1: Turn ON PMD
  write("Step 4.1: Turn ON PMD...");
  Turn_ON_PMD();
  testWaitForTimeout(3000);

  // 4.2: Check BLTN_CAM_Set_PMD = ON
  write("Step 4.2: Check BLTN_CAM_Set_PMD...");
  pmd_set_result = Check_Set_PMD_ON();
  write("  BLTN_CAM_Set_PMD = 0x%X", $BLTN_CAM_Set_PMD);

  // 4.3: Check BLTN_CAM_RecSta_PMD = 0x0 (OFF)
  write("Step 4.3: Check BLTN_CAM_RecSta_PMD...");
  pmd_sta_val = $BLTN_CAM_RecSta_PMD;
  write("  BLTN_CAM_RecSta_PMD = 0x%X", pmd_sta_val);

  if (pmd_sta_val == 0x0)
    write(">>> [PASS] BLTN_CAM_RecSta_PMD = 0x0 (OFF) <<<");
  else
    write(">>> [FAIL] BLTN_CAM_RecSta_PMD = 0x%X, expected 0x0 (OFF) <<<", pmd_sta_val);

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_State");

  if (pmd_set_result == 1 && pmd_sta_val == 0x0)
  {
    step4_passed = 1;
    testStepPass("Step4", "Set_PMD=ON, RecSta_PMD=0x0(OFF) - PASS");
  }
  else
  {
    step4_passed = 0;
    Log_Error_Details();
    testStepFail("Step4", "Set_PMD=%d, RecSta_PMD=0x%X - FAIL", pmd_set_result, pmd_sta_val);
  }

  write("=== FINISH STEP 4 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 5: KEY OFF, log motion, WaitFor_RecSta_PMD_Recording (60s),
//         Check RecSta_PMD = 0x1 (Recording), screenshot, log panel check
// ============================================================================
testcase OWP_017_5()
{
  int pmd_sta_val;
  Send_Value_To_COM(21705);
  SetTestStep("Bước 5 - OWP_017");
  StartTestTimer();

  write("");
  write("=== STEP 5: KEY OFF, Motion trigger, PMD Recording check ===");
  testStep("Step5", "KEY OFF, Motion, WaitFor PMD Recording 60s");

  // 5.1: KEY OFF
  write("Step 5.1: KEY OFF...");
  KEY_OFF();
  testWaitForTimeout(5000);

  // 5.2: Log motion instruction
  write("");
  write("*************************************************************");
  write("*** [ACTION REQUIRED] DI CHUYEN / MOTION TRUOC CAMERA!    ***");
  write("*** Hay tao chuyen dong truoc camera PMD ngay bay gio.     ***");
  write("*************************************************************");
  write("");

  // 5.3: Wait for PMD Recording (max 60s)
  write("Step 5.3: Waiting for PMD Recording (max 60s)...");
  if (WaitFor_RecSta_PMD_Recording(60000) != 1)
  {
    write(">>> [FAIL] PMD Recording NOT detected within 60s! <<<");
    CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_State");
    step5_passed = 0;
    Log_Error_Details();
    testStepFail("Step5", "PMD Recording not detected within 60s");
    return;
  }

  // 5.4: Check BLTN_CAM_RecSta_PMD = 0x1 (Recording)
  write("Step 5.4: Check BLTN_CAM_RecSta_PMD...");
  pmd_sta_val = $BLTN_CAM_RecSta_PMD;
  write("  BLTN_CAM_RecSta_PMD = 0x%X", pmd_sta_val);

  if (pmd_sta_val == 0x1)
  {
    write(">>> [PASS] BLTN_CAM_RecSta_PMD = 0x1 (Recording) <<<");
    step5_passed = 1;
    testStepPass("Step5", "RecSta_PMD = 0x1 (Recording) - PASS");
  }
  else
  {
    write(">>> [FAIL] BLTN_CAM_RecSta_PMD = 0x%X, expected 0x1 <<<", pmd_sta_val);
    step5_passed = 0;
    Log_Error_Details();
    testStepFail("Step5", "RecSta_PMD = 0x%X, expected 0x1 - FAIL", pmd_sta_val);
  }

  // 5.5: Screenshot
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_PMD_Count;BLTN_CAM_State");

  // 5.6: Log panel check
  write("");
  write("*************************************************************");
  write("*** [INFO] CASE NAY DUNG PANEL CHECK KY HON!              ***");
  write("*** Su dung panel de kiem tra chi tiet hon.                 ***");
  write("*************************************************************");
  write("");

  write("=== FINISH STEP 5 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

