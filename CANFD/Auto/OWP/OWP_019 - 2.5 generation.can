// ============================================================================
// STEP 8: Check Set_PMD_ON, Check RecSet_OWP_OFF, screenshot,
//         log "nen thao tac truc tiep"
// ============================================================================
testcase OWP_019_8()
{
  int pmd_on_result;
  int owp_off_result;
  Send_Value_To_COM(21908);
  SetTestStep("Bước 8 - OWP_019");
  StartTestTimer();

  write("");
  write("=== STEP 8: Check Set_PMD=ON, RecSet_OWP=OFF, log thao tac ===");
  testStep("Step8", "Check Set_PMD ON, RecSet_OWP OFF, thao tac truc tiep");

  // 8.1: Check Set_PMD_ON
  write("Step 8.1: Check Set_PMD_ON...");
  pmd_on_result = Check_Set_PMD_ON();

  // 8.2: Check RecSet_OWP_OFF
  write("Step 8.2: Check RecSet_OWP_OFF...");
  owp_off_result = Check_RecSet_OWP_OFF();

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSet_OWP;BLTN_CAM_State");

  if (pmd_on_result == 1 && owp_off_result == 1)
  {
    write(">>> [PASS] Set_PMD=ON, RecSet_OWP=OFF <<<");
    step8_passed = 1;
    testStepPass("Step8", "Set_PMD ON, RecSet_OWP OFF - PASS");
  }
  else
  {
    write(">>> [FAIL] Set_PMD_ON=%d, RecSet_OWP_OFF=%d <<<", pmd_on_result, owp_off_result);
    step8_passed = 0;
    Log_Error_Details();
    testStepFail("Step8", "Set_PMD_ON=%d, RecSet_OWP_OFF=%d - FAIL", pmd_on_result, owp_off_result);
  }

  // 8.3: Log thao tac truc tiep
  write("");
  write("*************************************************************");
  write("*** [INFO] NEN THAO TAC TRUC TIEP!                        ***");
  write("*** Cac buoc nay nen thao tac truc tiep tren thiet bi.     ***");
  write("*************************************************************");
  write("");

  write("=== FINISH STEP 8 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// STEP 9: Turn_ON_PMD, Turn_OFF_OWP, Turn_ON_OWP, Turn_OFF_OWP,
//         Check Set_PMD_OFF, Check RecSet_OWP_OFF
// ============================================================================
testcase OWP_019_9()
{
  int pmd_off_result;
  int owp_off_result;
  Send_Value_To_COM(21909);
  SetTestStep("Bước 9 - OWP_019");
  StartTestTimer();

  write("");
  write("=== STEP 9: PMD ON, OWP OFF/ON/OFF, Check PMD=OFF, OWP=OFF ===");
  testStep("Step9", "PMD ON, OWP toggle, Check Set_PMD OFF, RecSet_OWP OFF");

  // 9.1: Turn ON PMD
  write("Step 9.1: Turn ON PMD...");
  Turn_ON_PMD();
  testWaitForTimeout(2000);

  // 9.2: Turn OFF OWP
  write("Step 9.2: Turn OFF OWP...");
  Turn_OFF_OWP();
  testWaitForTimeout(2000);

  // 9.3: Turn ON OWP
  write("Step 9.3: Turn ON OWP...");
  Turn_ON_OWP();
  testWaitForTimeout(2000);

  // 9.4: Turn OFF OWP
  write("Step 9.4: Turn OFF OWP...");
  Turn_OFF_OWP();
  testWaitForTimeout(3000);

  // 9.5: Check Set_PMD_OFF
  write("Step 9.5: Check Set_PMD_OFF...");
  pmd_off_result = Check_Set_PMD_OFF();

  // 9.6: Check RecSet_OWP_OFF
  write("Step 9.6: Check RecSet_OWP_OFF...");
  owp_off_result = Check_RecSet_OWP_OFF();

  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSet_OWP;BLTN_CAM_State");

  if (pmd_off_result == 1 && owp_off_result == 1)
  {
    write(">>> [PASS] Set_PMD=OFF, RecSet_OWP=OFF <<<");
    step9_passed = 1;
    testStepPass("Step9", "Set_PMD OFF, RecSet_OWP OFF - PASS");
  }
  else
  {
    write(">>> [FAIL] Set_PMD_OFF=%d, RecSet_OWP_OFF=%d <<<", pmd_off_result, owp_off_result);
    step9_passed = 0;
    Log_Error_Details();
    testStepFail("Step9", "Set_PMD_OFF=%d, RecSet_OWP_OFF=%d - FAIL", pmd_off_result, owp_off_result);
  }

  write("=== FINISH STEP 9 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

// ============================================================================
// Summary
// ============================================================================

void MainTest()
{
  testReportFileName("TestReports\\OWP_019 - 2.5 generation_report");

  OWP_019_Init();

  OWP_019_1();
  OWP_019_2();
  OWP_019_3();
  OWP_019_4();
  OWP_019_5();
  OWP_019_6();
  OWP_019_7();
  OWP_019_8();
  OWP_019_9();

}
