testcase OWP_023_20()
{
  int pmd_rec_first_ok;
  int pev_first_ok;
  int pmd_rec_second_ok;
  int pev_second_ok;
  int pmd_off_ok;
  int pev_off_ok;

  Send_Value_To_COM(22320);
  SetTestStep("Buoc 20 - OWP_023");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 20: SOC stop, restore SOC, PMD/PEV off, BLTN_CAM UI   ===");
  write("=================================================================");
  testStep("Step20", "KEY ON/OFF, PMD/PEV, SOC 0, KEY ON, SOC 100, KEY OFF, PMD/PEV, PMD/PEV OFF, KEY ON, BLTN_CAM");

  write("[20.1] KEY ON");
  KEY_ON();
  testWaitForTimeout(5000);

  write("[20.2] KEY OFF");
  KEY_OFF();
  testWaitForTimeout(5000);

  write("[20.3] WaitFor_RecSta_PMD_Recording max 4 minutes");
  pmd_rec_first_ok = WaitFor_RecSta_PMD_Recording(max_signal_wait_ms);
  write("  BLTN_CAM_RecSta_PMD = 0x%X", $BLTN_CAM_RecSta_PMD);

  write("[20.4] Wait 5 seconds");
  testWaitForTimeout(5000);

  write("[20.5] WaitFor_RecSta_PEV_Recording max 4 minutes");
  pev_first_ok = WaitFor_RecSta_PEV_Recording(max_signal_wait_s);

  write("[20.6] Wait 10 seconds");
  testWaitForTimeout(10000);

  write("[20.7] Stop Motion/Impact Recording by Activating SOC = 0 percent");
  setSignal(ICU_BS2SoC, 0x00);
  setSignal(BAT_SOC_for_BLTN_CAM, 0x00);
  testWaitForTimeout(5000);
  write("  ICU_BS2SoC = 0x%X", $ICU_BS2SoC);
  write("  BAT_SOC_for_BLTN_CAM = 0x%X", $BAT_SOC_for_BLTN_CAM);

  write("[20.8] KEY ON");
  KEY_ON();
  testWaitForTimeout(5000);

  write("[20.9] SOC = 100 percent");
  setSignal(ICU_BS2SoC, 0x64);
  setSignal(BAT_SOC_for_BLTN_CAM, 0x64);
  testWaitForTimeout(5000);
  write("  ICU_BS2SoC = 0x%X", $ICU_BS2SoC);
  write("  BAT_SOC_for_BLTN_CAM = 0x%X", $BAT_SOC_for_BLTN_CAM);

  write("[20.10] KEY OFF");
  KEY_OFF();
  testWaitForTimeout(5000);

  write("[20.11] WaitFor_RecSta_PMD_Recording max 4 minutes");
  pmd_rec_second_ok = WaitFor_RecSta_PMD_Recording(max_signal_wait_ms);
  write("  BLTN_CAM_RecSta_PMD = 0x%X", $BLTN_CAM_RecSta_PMD);

  write("[20.12] Wait 5 seconds");
  testWaitForTimeout(5000);

  write("[20.13] WaitFor_RecSta_PEV_Recording max 4 minutes");
  pev_second_ok = WaitFor_RecSta_PEV_Recording(max_signal_wait_s);

  write("[20.14] WaitFor_RecSta_PMD_OFF max 4 minutes");
  pmd_off_ok = WaitFor_RecSta_PMD_OFF(max_signal_wait_ms);

  write("[20.15] WaitFor_RecSta_PEV_OFF max 4 minutes");
  pev_off_ok = WaitFor_RecSta_PEV_OFF(max_signal_wait_s);

  write("[20.16] KEY ON");
  KEY_ON();
  testWaitForTimeout(5000);

  write("[20.17] Enter_BLTN_CAM");
  Enter_BLTN_CAM();
  testWaitForTimeout(5000);

  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;ICU_BS2SoC;BAT_SOC_for_BLTN_CAM;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_RecSta_DEV;BLTN_CAM_State");

  if (pmd_rec_first_ok == 1 && pev_first_ok == 1 && pmd_rec_second_ok == 1 && pev_second_ok == 1 && pmd_off_ok == 1 && pev_off_ok == 1)
  {
    step20_passed = 1;
    testStepPass("Step20", "Step 20 PASS");
  }
  else
  {
    step20_passed = 0;
    snprintf(failReason, elcount(failReason),
             "Step 20 FAIL: pmd1=%d, pev1=%d, pmd2=%d, pev2=%d, pmd_off=%d, pev_off=%d, PMD=0x%X, PEV=0x%X.",
             pmd_rec_first_ok, pev_first_ok, pmd_rec_second_ok, pev_second_ok, pmd_off_ok, pev_off_ok,
             $BLTN_CAM_RecSta_PMD, $BLTN_CAM_RecSta_PEV);
    Log_Error_Details();
    testStepFail("Step20", failReason);
  }

  write("=== FINISH STEP 20 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

