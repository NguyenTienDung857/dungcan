    step16_passed = 0;
    snprintf(failReason, elcount(failReason),
             "Step 16 FAIL: pmd1=%d, pev1=%d, sleep=%d, pmd2=%d, pev2=%d, PMD=0x%X, PEV=0x%X.",
             pmd_rec_first_ok, pev_first_ok, sleep_ok, pmd_rec_second_ok, pev_second_ok,
             $BLTN_CAM_RecSta_PMD, $BLTN_CAM_RecSta_PEV);
    Log_Error_Details();
    testStepFail("Step16", failReason);
  }

  write("=== FINISH STEP 16 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

