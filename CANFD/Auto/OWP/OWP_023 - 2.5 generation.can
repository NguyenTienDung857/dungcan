/*@!Encoding:65001*/

includes
{
  #include "../DeclarationFunction_Gen2.5.h"
}

/*
  Test Case: OWP_023 - 2.5 generation
  Title: PMD/PEV recovery across network sleep, NM wake, camera angle, camera detach,
         SD card, SOC stop, and BLTN_CAM UI re-entry

  Step details:
    - Step 1: KEY ON, SMK IGN, USM/Rec reset, Turn_ON_PMD, KEY OFF, wait PMD
      OFF, wait network sleep, NM ON for 30s, NM OFF, wait PEV Recording, then capture.
    - Step 2: KEY ON/OFF, wait PMD OFF and network sleep, wait PMD Recording,
      wait 10s, wait PMD OFF, wait PEV Recording immediately, then capture.
    - Step 4: Repeat Step 2 flow for PMD OFF/sleep/PMD Recording/PEV evidence.
    - Step 6: KEY ON/OFF, wait PMD OFF, wait 5s, wait PMD Recording, wait 2min,
      wait network sleep up to 8min, wait 5s, wait PEV Recording, then capture.
    - Step 9: KEY ON, wait OWD Recording, set FR/RR display angle to -5/-5,
      KEY OFF, wait PMD Recording, wait PEV Recording, KEY ON, check OWD ON.
    - Step 11: KEY ON/OFF, wait PMD OFF, network sleep, wait PMD Recording,
      wait 5s, KEY ON, then capture.
    - Step 15: KEY ON/OFF, wait PMD Recording, wait 5s, wait PEV Recording,
      wait 10s, KEY ON, then capture.
    - Step 16: KEY ON/OFF, wait PMD Recording, wait PEV Recording, detach front,
      wait network sleep up to 8min, attach front, wait PMD Recording and PEV.
    - Step 17: KEY ON/OFF, wait PMD Recording and PEV, detach front, wait sleep,
      SET_NM_ON, check/capture BLTN_CAM_RecSta_PMD.
    - Step 19: KEY ON/OFF, wait PMD Recording and PEV, Set_SDcard, wait PMD
      Recording again, wait DEV Recording, then capture.
    - Step 20: KEY ON/OFF, wait PMD/PEV, set SOC 0%, KEY ON, set SOC 100%,
      KEY OFF, wait PMD/PEV, wait PMD/PEV OFF, KEY ON, enter BLTN_CAM, capture.

  NOTE:
    - Requested actions are written sequentially inside each testcase.
    - Network sleep waits use 8 minutes maximum.
    - Signal waits use several minutes maximum.
    - PMD Recording waits use WaitFor_RecSta_PMD_Recording() from the shared
      header. That helper intentionally triggers PEV first, then waits PMD.
    - This file intentionally avoids raw CAPL signal-range wait calls.
    - Each step waits 5 seconds before final screenshot capture.
*/

variables
{
  char failReason[512];

  long max_signal_wait_ms = 240000;
  int max_signal_wait_s = 240;
  int max_network_sleep_s = 480;

  int step1_passed = 0;
  int step2_passed = 0;
  int step4_passed = 0;
  int step6_passed = 0;
  int step9_passed = 0;
  int step11_passed = 0;
  int step15_passed = 0;
  int step16_passed = 0;
  int step17_passed = 0;
  int step19_passed = 0;
  int step20_passed = 0;
}

testcase OWP_023_Init()
{
  Send_Value_To_COM(22300);
  write("========================================");
  write("=== START TEST OWP_023 - 2.5 ===");
  write("========================================");
  testStep("Notification", "Start test OWP_023 - 2.5");
  Send_Value_To_COM(44);
}

testcase OWP_023_1()
{
  int pmd_set_ok;
  int pmd_off_ok;
  int sleep_ok;
  int nm_on_ok;
  int nm_off_ok;
  int pev_ok;

  Send_Value_To_COM(22301);
  SetTestStep("Buoc 1 - OWP_023");
  StartTestTimer();

  write("");
  write("=================================================================");
  write("=== STEP 1: Setup PMD, sleep, NM cycle, PEV trigger           ===");
  write("=================================================================");
  testStep("Step1", "KEY ON, SMK IGN, reset, Turn_ON_PMD, KEY OFF, PMD OFF, network sleep, NM ON/OFF, PEV");

  write("[1.1] KEY ON");
  KEY_ON();
  testWaitForTimeout(5000);

  write("[1.2] Set_SMK_IGN");
  Set_SMK_IGN();
  testWaitForTimeout(3000);

  write("[1.3] Click_USM_Reset");
  Click_USM_Reset();
  testWaitForTimeout(3000);

  write("[1.4] Click_Rec_Reset");
  Click_Rec_Reset();
  testWaitForTimeout(5000);

  write("[1.5] Turn_ON_PMD");
  Turn_ON_PMD();
  testWaitForTimeout(3000);
  pmd_set_ok = Check_Set_PMD_ON();

  write("[1.6] KEY OFF before PMD wait");
  KEY_OFF();
  testWaitForTimeout(5000);

  write("[1.7] WaitFor_RecSta_PMD_OFF max 4 minutes");
  pmd_off_ok = WaitFor_RecSta_PMD_OFF(max_signal_wait_ms);

  write("[1.8] WaitForNetworkSleep max 8 minutes");
  sleep_ok = WaitForNetworkSleep(max_network_sleep_s);

  write("[1.9] SET_NM_ON");
  SET_NM_ON();
  nm_on_ok = Check_NM();

  write("[1.10] Wait 30 seconds");
  testWaitForTimeout(30000);

  write("[1.11] SET_NM_OFF");
  SET_NM_OFF();
  nm_off_ok = (Check_NM() == 0);

  write("[1.12] WaitFor_RecSta_PEV_Recording max 4 minutes");
  pev_ok = WaitFor_RecSta_PEV_Recording(max_signal_wait_s);

  write("[1.13] Wait 20 seconds");
  testWaitForTimeout(20000);

  write("[Capture] Wait 5 seconds before screenshot");
  testWaitForTimeout(5000);
  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_State");

  if (pmd_set_ok == 1 && pmd_off_ok == 1 && sleep_ok == 1 && nm_on_ok == 1 && nm_off_ok == 1 && pev_ok == 1)
  {
    step1_passed = 1;
    testStepPass("Step1", "Step 1 PASS");
  }
  else
  {
    step1_passed = 0;
    snprintf(failReason, elcount(failReason),
             "Step 1 FAIL: pmd_set=%d, pmd_off=%d, sleep=%d, nm_on=%d, nm_off=%d, pev=%d, PMD=0x%X, PEV=0x%X.",
             pmd_set_ok, pmd_off_ok, sleep_ok, nm_on_ok, nm_off_ok, pev_ok,
             $BLTN_CAM_RecSta_PMD, $BLTN_CAM_RecSta_PEV);
    Log_Error_Details();
    testStepFail("Step1", failReason);
  }

  write("=== FINISH STEP 1 ===");
  StopTestTimer();
  Send_Value_To_COM(44);
}

