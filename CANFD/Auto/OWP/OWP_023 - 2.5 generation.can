  CaptureGraphics("OWP", "SMK_TrmnlCtrlGrpStaBDC;BLTN_CAM_Set_PMD;BLTN_CAM_RecSta_PMD;BLTN_CAM_RecSta_PEV;BLTN_CAM_State");

  if (pmd_rec_first_ok == 1 && pev_first_ok == 1 && sleep_ok == 1 && pmd_rec_second_ok == 1 && pev_second_ok == 1)
