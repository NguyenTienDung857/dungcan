on sysvar_update panel::TrackBar_DEV_Sen
{
  DEVSenSetValue = getSignal(BLTN_CAM_SenSet_DEV);
  
  if(@panel::TrackBar_DEV_Sen != DEVSenSetValue)
  {
    valueSet_HU_BLTN_CAM_E_00();
    
    switch (@panel::TrackBar_DEV_Sen) {
      case 1 : _HU_BLTN_CAM_E_00.BLTN_CAM_Sen_DEV_NvalueSet = 0x1; output(_HU_BLTN_CAM_E_00); break;
      case 2 : _HU_BLTN_CAM_E_00.BLTN_CAM_Sen_DEV_NvalueSet = 0x2; output(_HU_BLTN_CAM_E_00); break;
      case 3 : _HU_BLTN_CAM_E_00.BLTN_CAM_Sen_DEV_NvalueSet = 0x3; output(_HU_BLTN_CAM_E_00); break;
      case 4 : _HU_BLTN_CAM_E_00.BLTN_CAM_Sen_DEV_NvalueSet = 0x4; output(_HU_BLTN_CAM_E_00); break;
      case 5 : _HU_BLTN_CAM_E_00.BLTN_CAM_Sen_DEV_NvalueSet = 0x5; output(_HU_BLTN_CAM_E_00); break;
      default : write("TrackBar_DEV_Sen default"); break;
    }
     write("DEVSenSetValue");
  }
}

