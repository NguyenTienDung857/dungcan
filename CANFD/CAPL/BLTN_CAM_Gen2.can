    case 3 : if(CAM_Pos_RR == MINUS_3) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_RR_VerPos_NvalueSet = MINUS_3; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_RR -3"); break;
    case 4 : if(CAM_Pos_RR == MINUS_2) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_RR_VerPos_NvalueSet = MINUS_2; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_RR -2"); break;
    case 5 : if(CAM_Pos_RR == MINUS_1) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_RR_VerPos_NvalueSet = MINUS_1; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_RR -1"); break;
    case 6 : if(CAM_Pos_RR == ZERO_0) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_RR_VerPos_NvalueSet = ZERO_0; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_RR 0"); break;
    case 7 : if(CAM_Pos_RR == PLUS_1) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_RR_VerPos_NvalueSet = PLUS_1; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_RR +1"); break;
    case 8 : if(CAM_Pos_RR == PLUS_2) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_RR_VerPos_NvalueSet = PLUS_2; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_RR +2"); break;
    case 9 : if(CAM_Pos_RR == PLUS_3) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_RR_VerPos_NvalueSet = PLUS_3; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_RR +3"); break;
    case 10 : if(CAM_Pos_RR == PLUS_4) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_RR_VerPos_NvalueSet = PLUS_4; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_RR +4"); break;
    case 11 : if(CAM_Pos_RR == PLUS_5) break;
      _HU_BLTN_CAM_E_01.BLTN_CAM_RR_VerPos_NvalueSet = PLUS_5; output(_HU_BLTN_CAM_E_01); write("CAM_Pos_RR +5"); break;
    default : write("TrackBar_RR_Ver_Pos default"); break;
