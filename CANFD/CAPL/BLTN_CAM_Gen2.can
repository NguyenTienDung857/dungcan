}

on message BLTN_CAM_FD_HU_01_200ms{
  byte check_Hour_value, check_Minute_value, check_Second_value;
  
  check_Hour_value = getSignal(HU_DisplayHour);
  check_Minute_value = getSignal(HU_DisplayMinute);
  check_Second_value = getSignal(HU_DisplaySecond);
  
  setClockControlTime("BLTN_CAM_Gen2_DrvInfo","Clock Control 1", check_Hour_value,check_Minute_value,check_Second_value);
  setClockControlTime("Recording_Setting","Clock Control 1", check_Hour_value,check_Minute_value,check_Second_value);
  setClockControlTime("Panel_TestBench","Clock Control 1", check_Hour_value,check_Minute_value,check_Second_value);
  
}