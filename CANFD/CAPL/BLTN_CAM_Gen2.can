on sysvar_update panel::Button_clu_USMReset
{
  if(@panel::Button_clu_USMReset == 0x1)//Pressed
  {
    message HU_USM_02_00ms _HU_USM_E_04;//CANFD  
    //message HU_USM_E_04 _HU_USM_E_04;//CAN
    
    _HU_USM_E_04.CF_AVN_CluUSMReset = 0x1;
    output(_HU_USM_E_04); 
    
    timer_CF_AVN_CluUSMReset.Set(40);
  }
}

on sysvar_update panel::Button_USMReset
{
  if(@panel::Button_USMReset == 0x1)//Pressed
  {
    message HU_BLTN_CAM_01_00ms _HU_BLTN_CAM_E_01; //CANFD
    //message HU_BLTN_CAM_E_01 _HU_BLTN_CAM_E_01; //CAN
    
    int i;
    for( i=0; i<8; i++)
    {
      _HU_BLTN_CAM_E_01.byte(i) = 0xFF;
    }

    _HU_BLTN_CAM_E_01.CF_AVN_BLTN_CAM_USMReset = 0x1;
    output(_HU_BLTN_CAM_E_01);

    timer_HU_BLTN_CAM_E_01.Set(40);
  }
}

