/// <Diagnostic>
void makeText_putValueToControl(char output[], char discription[], char data[])
{
  int i;
  int length;
  length=strlen(output);
  
  //버퍼 초기화
  for (i = 0; i < length ; i++) output[i] = 0;
  
  strncpy(output, discription, strlen(discription) + 1);
  strncat(output, data, strlen(output) + strlen(data) + 1);
  strncat(output, "\n", strlen(output) + 2);
}

/// <빌트인캠 상태>
on signal_update BLTN_CAM_State
{
  switch ($BLTN_CAM_State)
  {
    case 0: 
      setControlProperty("Panel_TestBench", "text_BLTN_CAM_State", "Text", "정상"); break;
    case 1:
      setControlProperty("Panel_TestBench", "text_BLTN_CAM_State", "Text", "전방카메라 미인식"); break;
    case 2:
      setControlProperty("Panel_TestBench", "text_BLTN_CAM_State", "Text", "후방카메라 미인식"); break;
    case 3:
     setControlProperty("Panel_TestBench", "text_BLTN_CAM_State", "Text", "전/후방카메라 미인식"); break;
    case 4:
     setControlProperty("Panel_TestBench", "text_BLTN_CAM_State", "Text", "녹화 불가"); break;
    case 5:
     setControlProperty("Panel_TestBench", "text_BLTN_CAM_State", "Text", "내부오류/이더넷 통신불량"); break;
  }
}


/// <Diagnostic>
on sysvar_update panel::Switch_ReadDTC
{
  if(@panel::Switch_ReadDTC)
    setTimer(timer_ReadDTC, TIME_ReadDTC);
  
  else
    cancelTimer(timer_ReadDTC);
}

/// <Diagnostic>
on diagResponse DVRS.DVRS_Input_Output_Record_Local_Identifier_1_Byte_Read
{
  long ret;
  byte buffer_CurrentHIGH[2];
  byte buffer_CurrentLOW[2];
  byte buffer_ConfirmedHIGH[2];
  byte buffer_ConfirmedLOW[2];
  
  char DTC_Current_RCAM[10];
  char DTC_Current_FCAM[10];
  char DTC_Current_CAMPower[10];
  char DTC_Current_LowVolt[10];
  char DTC_Current_HighVolt[10];
  char DTC_Current_Gsensor[10];
  char DTC_Current_CPU[10];
  char DTC_Current_MCU[10];
  
  char DTC_Current_ExtMemoryCAM[10];
  char DTC_Current_WiFiModule[10];
  char DTC_Current_BCANBusOff[10];
  char DTC_Current_EventSwitch[10];

  char DTC_Confirmed_RCAM[10];
  char DTC_Confirmed_FCAM[10];
  char DTC_Confirmed_CAMPower[10];
  char DTC_Confirmed_LowVolt[10];
  char DTC_Confirmed_HighVolt[10];
  char DTC_Confirmed_Gsensor[10];
  char DTC_Confirmed_CPU[10];
  char DTC_Confirmed_MCU[10];

  char DTC_Confirmed_ExtMemoryCAM[10];
  char DTC_Confirmed_WiFiModule[10];
  char DTC_Confirmed_BCANBusOff[10];
  char DTC_Confirmed_EventSwitch[10];
  
  char text[50];
  char textReturn[50];

  if(diagIsPositiveResponse(this))
  {
    ret = diagGetParameterRaw(this, "DTC_Current_High", buffer_CurrentHIGH, elCount(buffer_CurrentHIGH));
    diagGetParameterRaw(this, "DTC_Current_Low", buffer_CurrentLOW, elCount(buffer_CurrentLOW));
    diagGetParameterRaw(this, "DTC_Confirmed_High", buffer_ConfirmedHIGH, elCount(buffer_ConfirmedHIGH));
    diagGetParameterRaw(this, "DTC_Confirmed_Low", buffer_ConfirmedLOW, elCount(buffer_ConfirmedLOW));
    
    write("buffer_CurrentHIGH %X %X", buffer_CurrentHIGH[0],  buffer_CurrentHIGH[1]);
    write("buffer_CurrentLOW %X %X", buffer_CurrentLOW[0],  buffer_CurrentLOW[1]);
    write("buffer_ConfirmedHIGH %X %X", buffer_ConfirmedHIGH[0],  buffer_ConfirmedHIGH[1]);
    write("buffer_ConfirmedLOW %X %X", buffer_ConfirmedLOW[0],  buffer_ConfirmedLOW[1]);
    
    write("buffer_CurrentHIGH[0] & 0x1 : %x", buffer_CurrentHIGH[0] & 0x1);
    write("buffer_CurrentHIGH[0] & 0x2 : %x", buffer_CurrentHIGH[0] & 0x2);
    write("buffer_CurrentHIGH[0] & 0x3 : %x", buffer_CurrentHIGH[0] & 0x3);
    write("buffer_CurrentHIGH[0] & 0x4 : %x", buffer_CurrentHIGH[0] & 0x4);
    write("buffer_CurrentHIGH[1] & 0x1 : %x", buffer_CurrentHIGH[1] & 0x1);
    write("buffer_CurrentHIGH[1] & 0x2 : %x", buffer_CurrentHIGH[1] & 0x2);
    write("buffer_CurrentHIGH[1] & 0x3 : %x", buffer_CurrentHIGH[1] & 0x3);
    write("buffer_CurrentHIGH[1] & 0x4 : %x", buffer_CurrentHIGH[1] & 0x4);
    
    if(buffer_CurrentHIGH[0] & 0x1) strncpy(DTC_Current_RCAM, "현재", 2); else strncpy(DTC_Current_RCAM, "과거", 2);
    if(buffer_CurrentHIGH[0] & 0x2) strncpy(DTC_Current_FCAM, "현재", 2); else strncpy(DTC_Current_FCAM, "과거", 2);
    if(buffer_CurrentHIGH[0] & 0x3) strncpy(DTC_Current_CAMPower, "현재", 2); else strncpy(DTC_Current_CAMPower, "과거", 2);
    if(buffer_CurrentHIGH[0] & 0x4) strncpy(DTC_Current_LowVolt, "현재", 2); else strncpy(DTC_Current_LowVolt, "과거", 2);
    if(buffer_CurrentHIGH[1] & 0x1) strncpy(DTC_Current_HighVolt, "현재", 2); else strncpy(DTC_Current_HighVolt, "과거", 2);
    if(buffer_CurrentHIGH[1] & 0x2) strncpy(DTC_Current_Gsensor, "현재", 2); else strncpy(DTC_Current_Gsensor, "과거", 2);
    if(buffer_CurrentHIGH[1] & 0x3) strncpy(DTC_Current_CPU, "현재", 2); else strncpy(DTC_Current_CPU, "과거", 2);
    if(buffer_CurrentHIGH[1] & 0x4) strncpy(DTC_Current_MCU, "현재", 2); else strncpy(DTC_Current_MCU, "과거", 2);
    
    if(buffer_CurrentLOW[0] & 0x1) strncpy(DTC_Current_ExtMemoryCAM, "현재", 2); else strncpy(DTC_Current_RCAM, "과거", 2);
    if(buffer_CurrentLOW[0] & 0x2) strncpy(DTC_Current_WiFiModule, "현재", 2); else strncpy(DTC_Current_RCAM, "과거", 2);
    //if(buffer_CurrentLOW[0] & 0x3) strncpy(, "현재", 2); else strncpy(, "과거", 2);
    if(buffer_CurrentLOW[0] & 0x4) strncpy(DTC_Current_BCANBusOff, "현재", 2); else strncpy(DTC_Current_RCAM, "과거", 2);
    if(buffer_CurrentLOW[1] & 0x1) strncpy(DTC_Current_EventSwitch, "현재", 2); else strncpy(DTC_Current_RCAM, "과거", 2);
    //if(buffer_CurrentLOW[1] & 0x2) strncpy(, "현재", 2); else strncpy(, "과거", 2);
    //if(buffer_CurrentLOW[1] & 0x3) strncpy(, "현재", 2); else strncpy(, "과거", 2);
    //if(buffer_CurrentLOW[1] & 0x4) strncpy(, "현재", 2); else strncpy(, "과거", 2);
    
    if(buffer_ConfirmedHIGH[0] & 0x1) strncpy(DTC_Confirmed_RCAM, "현재", 2); else strncpy(DTC_Confirmed_RCAM, "과거", 2);
    if(buffer_ConfirmedHIGH[0] & 0x2) strncpy(DTC_Confirmed_FCAM, "현재", 2); else strncpy(DTC_Confirmed_FCAM, "과거", 2);
    if(buffer_ConfirmedHIGH[0] & 0x3) strncpy(DTC_Confirmed_CAMPower, "현재", 2); else strncpy(DTC_Confirmed_CAMPower, "과거", 2);
    if(buffer_ConfirmedHIGH[0] & 0x4) strncpy(DTC_Confirmed_LowVolt, "현재", 2); else strncpy(DTC_Confirmed_LowVolt, "과거", 2);
    if(buffer_ConfirmedHIGH[1] & 0x1) strncpy(DTC_Confirmed_HighVolt, "현재", 2); else strncpy(DTC_Confirmed_HighVolt, "과거", 2);
    if(buffer_ConfirmedHIGH[1] & 0x2) strncpy(DTC_Confirmed_Gsensor, "현재", 2); else strncpy(DTC_Confirmed_Gsensor, "과거", 2);
    if(buffer_ConfirmedHIGH[1] & 0x3) strncpy(DTC_Confirmed_CPU, "현재", 2); else strncpy(DTC_Confirmed_CPU, "과거", 2);
    if(buffer_ConfirmedHIGH[1] & 0x4) strncpy(DTC_Confirmed_MCU, "현재", 2); else strncpy(DTC_Confirmed_MCU, "과거", 2);
    
    if(buffer_ConfirmedLOW[0] & 0x1) strncpy(DTC_Confirmed_ExtMemoryCAM, "현재", 2); else strncpy(DTC_Confirmed_RCAM, "과거", 2);
    if(buffer_ConfirmedLOW[0] & 0x2) strncpy(DTC_Confirmed_WiFiModule, "현재", 2); else strncpy(DTC_Confirmed_RCAM, "과거", 2);
    //if(buffer_ConfirmedLOW[0] & 0x3) strncpy(, "현재", 2); else strncpy(, "과거", 2);
    if(buffer_ConfirmedLOW[0] & 0x4) strncpy(DTC_Confirmed_BCANBusOff, "현재", 2); else strncpy(DTC_Confirmed_RCAM, "과거", 2);
    if(buffer_ConfirmedLOW[1] & 0x1) strncpy(DTC_Confirmed_EventSwitch, "현재", 2); else strncpy(DTC_Confirmed_RCAM, "과거", 2);
    //if(buffer_ConfirmedLOW[1] & 0x2) strncpy(, "현재", 2); else strncpy(, "과거", 2);
    //if(buffer_ConfirmedLOW[1] & 0x3) strncpy(, "현재", 2); else strncpy(, "과거", 2);
    //if(buffer_ConfirmedLOW[1] & 0x4) strncpy(, "현재", 2); else strncpy(, "과거", 2);
    
    if(ret>=0)
    {
//      write("현재 고장");
//      write("F-CAM: %d,R-CAM: %d", buffer_CurrentHIGH[0], buffer_CurrentHIGH[1]);
//      write("Ext Memory: %d,WiFi Module: %d", buffer_CurrentLOW[0] , buffer_CurrentLOW[1]);
//      write("과거 고장");
//      write("F-CAM: %d,R-CAM: %d", buffer_ConfirmedHIGH[0] , buffer_ConfirmedHIGH[1]);
//      write("Ext Memory: %d,WiFi Module: %d", buffer_ConfirmedLOW[0] , buffer_ConfirmedLOW[1]);
      
      DeleteControlContent("Panel_TestBench","CAPL Output View 2");

      makeText_putValueToControl(textReturn, "RCAM : ", DTC_Current_RCAM);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);

      makeText_putValueToControl(textReturn, "FCAM : ", DTC_Current_FCAM);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);

      makeText_putValueToControl(textReturn, "CAMPower : ", DTC_Current_CAMPower);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);

      makeText_putValueToControl(textReturn, "LowVolt: ", DTC_Current_LowVolt);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);

      makeText_putValueToControl(textReturn, "HighVolt: ", DTC_Current_HighVolt);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);
      
      makeText_putValueToControl(textReturn, "Gsensor: ", DTC_Current_Gsensor);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);

      makeText_putValueToControl(textReturn, "CPU: ", DTC_Current_CPU);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);

      makeText_putValueToControl(textReturn, "MCU: ", DTC_Current_MCU);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);

      makeText_putValueToControl(textReturn, "ExtMemoryCAM: ", DTC_Current_ExtMemoryCAM);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);

      makeText_putValueToControl(textReturn, "WiFiModule: ", DTC_Current_WiFiModule);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);
      
      makeText_putValueToControl(textReturn, "BCANBusOff: ", DTC_Current_BCANBusOff);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);
      
      makeText_putValueToControl(textReturn, "EventSwitch: ", DTC_Current_EventSwitch);
      putValueToControl("Panel_TestBench","CAPL Output View 2", textReturn);
    }
    
    else
      write("Could not retrieve parameter");
  }
  
  else
  {
     write("Negative response code: 0x%02X", 
     diagGetResponseCode(this));
  }
}


on timer timer_ReadDTC
{
  write("timer_ReadDTC");
  diagSendRequest(diag_Extended_Session_Start);
  diagSendRequest(diag_Identifier_1_Byte_Rea);
  
  setTimer(timer_ReadDTC, TIME_ReadDTC);
}

on signal_update CLU_DisSpdVal
{
  setControlProperty("Panel_TestBench", "text_Speed", "Text", $CLU_DisSpdVal);
}
