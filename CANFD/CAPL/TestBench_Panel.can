on signal_update Trunk_TrnkTlgtSwSta
{
  if( $Trunk_TrnkTlgtSwSta == Open) setControlVisibility("Panel_TestBench","Picture_Box_Trunk", 1);    
  Else if( $Trunk_TrnkTlgtSwSta == Closed) setControlVisibility("Panel_TestBench","Picture_Box_Trunk", 0);
}

/// <Gear Siganl>
on sysvar_update panel::Button_Gear
{
  int vehicleType;
  int currentGear;
  
  if(@panel::Button_Gear != 15)
  {
    GearSelect = @panel::Button_Gear;

    vehicleType = @panel::RadioBtn_Vehicle_Type;

    if (vehicleType == 0) currentGear = $TCU_GearSlctDis;
    else if (vehicleType == 1) currentGear = $HTCU_GearSlctrDis;
    else if (vehicleType == 2) currentGear = $VCU_GearPosStaDisp;

    if(currentGear != GearSelect)
    {
      if (vehicleType == 0) setSignal(TCU_GearSlctDis, 6);
      else if (vehicleType == 1) setSignal(HTCU_GearSlctrDis, 6);
      else if (vehicleType == 2) setSignal(VCU_GearPosStaDisp, 6);

      @panel::SwitchIndi_Gear = 6;
      setTimer(timer_GearShifting, TIME_GearShifting);
    }
  }
}

/// <Gear Siganl>
on timer timer_GearShifting
{
  if(@panel::RadioBtn_Vehicle_Type == 0) setSignal(TCU_GearSlctDis, GearSelect);
  if(@panel::RadioBtn_Vehicle_Type == 1) setSignal(HTCU_GearSlctrDis, GearSelect);
  if(@panel::RadioBtn_Vehicle_Type == 2) setSignal(VCU_GearPosStaDisp, GearSelect);

  //기어 이미지 변경
  @panel::SwitchIndi_Gear = GearSelect;
}

//자동차 타입 변경 시 다른 타입 신호는 P 단으로 변경
/// <Vehicle Type>
on sysvar_update panel::RadioBtn_Vehicle_Type
{
  if(@panel::RadioBtn_Vehicle_Type == 0)
  {
    setSignal(HTCU_GearSlctrDis, 0);
    setSignal(VCU_GearPosStaDisp, 0);
  }
  else if(@panel::RadioBtn_Vehicle_Type == 1)
  {
    setSignal(TCU_GearSlctDis, 0);
    setSignal(VCU_GearPosStaDisp, 0);
  }
  else if(@panel::RadioBtn_Vehicle_Type == 2)
  {
    setSignal(TCU_GearSlctDis, 0);
    setSignal(HTCU_GearSlctrDis, 0);
  }
}

/// <Diagnostic>
on sysvar_update panel::Button_diag_getECUInfo
{
  if(@panel::Button_diag_getECUInfo)
  {
    diagSendRequest(diag_ReadCPUVersion_req);
    diagSendRequest(diag_ReadMCUVersion);
    diagSendRequest(diag_ReadPartNumber);
  }
}

/// <Diagnostic>
on diagResponse DVRS.Read_DVRS_CPU_Version_Read
{
  long ret;
  byte buffer[50];
  char text[50];
  char textReturn[50];

  if(diagIsPositiveResponse(this))
  {
    ret = diagGetParameterRaw(this, "DataRecord", buffer, elCount(buffer));

    DecodeString(text, elCount(buffer), buffer, elCount(buffer), 0);

    if(ret>=0)
    {
      makeText_putValueToControl(textReturn, "CPU: ", text);
      DeleteControlContent("Panel_TestBench","CAPL Output View 1");
      putValueToControl("Panel_TestBench","CAPL Output View 1", textReturn);
    }
    else
      write("Could not retrieve parameter");
  }
  else
  {
   write("Negative response code: 0x%02X", 
   diagGetResponseCode(this));
  }
}

