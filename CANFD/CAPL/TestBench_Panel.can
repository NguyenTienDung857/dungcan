  if( $Warn_HoodSwSta == Open) setControlVisibility("Panel_TestBench","Picture_Box_Hood", 1);    
  Else if( $Warn_HoodSwSta == Closed) setControlVisibility("Panel_TestBench","Picture_Box_Hood", 0);
