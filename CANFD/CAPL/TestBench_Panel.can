/*@!Encoding:949*/
includes
{
}
////////////////
variables
{
  enum DoorState
  {
    Open = 1, Closed = 0
  };
  
  //Turn Siganl Timer
  msTimer timer_HazrdLmp;
  msTimer timer_RightTurnSignal;
  msTimer timer_LeftTurnSignal;
  int TIME_BlinkLmp = 400;
  
  int state_Lamp_TrnSigLmpRtOnReq = 0;
  int state_Lamp_TrnSigLmpLftOnReq = 0;
  
  //Gear Timer
  msTimer timer_GearShifting;
  int TIME_GearShifting = 500;
  int GearSelect;
  
  //read DTC interval
  msTimer timer_ReadDTC;
  int TIME_ReadDTC = 2000;
  
  diagRequest DVRS.Read_DVRS_CPU_Version_Read diag_ReadCPUVersion_req;
  diagRequest DVRS.Read_DVRS_MCU_Version_Read diag_ReadMCUVersion;
  diagRequest DVRS.HMC_KMC_Part_Number_Read diag_ReadPartNumber;
  diagRequest DVRS.DVRS_Input_Output_Record_Local_Identifier_1_Byte_Read diag_Identifier_1_Byte_Rea;
  diagRequest DVRS.Default_Session_Start diag_Default_Session_Start;
  diagRequest DVRS.Extended_Session_Start diag_Extended_Session_Start;
}

on start
{
  @panel::SwitchIndi_HazardLamp = 0;
  @panel::SwitchIndi_TurnSignal_Right = 0;
  @panel::SwitchIndi_TurnSignal_Left = 0;
}

/// <Turn Siganl>
on sysvar_update panel::SwitchIndi_HazardLamp
{
  if(@panel::SwitchIndi_HazardLamp)
  {
    //턴시그널 끄고 시작
    cancelTimer(timer_LeftTurnSignal);
    cancelTimer(timer_RightTurnSignal);
    @panel::SwitchIndi_TurnSignal_Right = 0;
    @panel::SwitchIndi_TurnSignal_Left = 0;
    
    //값 동기화
    state_Lamp_TrnSigLmpRtOnReq = 1;
    state_Lamp_TrnSigLmpLftOnReq = 1;
    setTimer(timer_HazrdLmp, TIME_BlinkLmp);
  }
  else
  {
    setSignal(Lamp_TrnSigLmpRtOnReq, 1);//Right(2: ON, 1: OFF)
    setSignal(Lamp_TrnSigLmpLftOnReq, 1);//Left(2: ON, 1: OFF)
    cancelTimer(timer_HazrdLmp);
    
    setControlProperty("Panel_TestBench", "Switch/Indicator 7", "Display Only", "False");
    setControlProperty("Panel_TestBench", "Switch/Indicator 6", "Display Only", "False");
  }
}

/// <Turn Siganl>
on timer timer_HazrdLmp
{
  //하자드 동작중에 턴시그널 켜면 바로 꺼버려
  if(@panel::SwitchIndi_TurnSignal_Right) @panel::SwitchIndi_TurnSignal_Right = 0;
  if(@panel::SwitchIndi_TurnSignal_Left) @panel::SwitchIndi_TurnSignal_Left = 0;
  
  state_Lamp_TrnSigLmpRtOnReq = !state_Lamp_TrnSigLmpRtOnReq;
  state_Lamp_TrnSigLmpLftOnReq = !state_Lamp_TrnSigLmpLftOnReq;

  setSignal(Lamp_TrnSigLmpRtOnReq, state_Lamp_TrnSigLmpRtOnReq +1);//Right(2: ON, 1: OFF)
  setSignal(Lamp_TrnSigLmpLftOnReq, state_Lamp_TrnSigLmpLftOnReq +1);//Left(2: ON, 1: OFF)

  setTimer(timer_HazrdLmp, TIME_BlinkLmp);
}

/// <Turn Siganl>
on sysvar_update panel::SwitchIndi_TurnSignal_Right
{
  if(@panel::SwitchIndi_TurnSignal_Right)
  {
    //hazard off, turnsignal on
    if(@panel::SwitchIndi_HazardLamp) @panel::SwitchIndi_HazardLamp = 0;
    @panel::SwitchIndi_TurnSignal_Left = 0;
    @panel::SwitchIndi_TurnSignalSwitch = 1;//Right image
    setTimer(timer_RightTurnSignal, TIME_BlinkLmp);
  }
  
  else
  {
    @panel::SwitchIndi_TurnSignalSwitch = 0;//Off image
    setSignal(Lamp_TrnSigLmpRtOnReq, 1);//Right(2: ON, 1: OFF)
    cancelTimer(timer_RightTurnSignal);
  }
}

/// <Turn Siganl>
on timer timer_RightTurnSignal
{
  @panel::SwitchIndi_TurnSignalSwitch = 1;//Right image
  
  state_Lamp_TrnSigLmpRtOnReq = !state_Lamp_TrnSigLmpRtOnReq;

  setSignal(Lamp_TrnSigLmpRtOnReq, state_Lamp_TrnSigLmpRtOnReq +1);//Right(2: ON, 1: OFF)

  setTimer(timer_RightTurnSignal, TIME_BlinkLmp);
}

/// <Turn Siganl>
on sysvar_update panel::SwitchIndi_TurnSignal_Left
{  
  if(@panel::SwitchIndi_TurnSignal_Left)
  {
    //hazard off, turnsignal on
    if(@panel::SwitchIndi_HazardLamp) @panel::SwitchIndi_HazardLamp = 0;
    @panel::SwitchIndi_TurnSignal_Right = 0;
    @panel::SwitchIndi_TurnSignalSwitch = 2;//Left image
    setTimer(timer_LeftTurnSignal, TIME_BlinkLmp);
  }
  
  else
  {
    @panel::SwitchIndi_TurnSignalSwitch = 0;//Left image
    setSignal(Lamp_TrnSigLmpLftOnReq, 1);//Right(2: ON, 1: OFF)
    cancelTimer(timer_LeftTurnSignal);
  }
}

/// <Turn Siganl>
on timer timer_LeftTurnSignal
{
  @panel::SwitchIndi_TurnSignalSwitch = 2;//Left image
  
  state_Lamp_TrnSigLmpLftOnReq = !state_Lamp_TrnSigLmpLftOnReq;

  setSignal(Lamp_TrnSigLmpLftOnReq, state_Lamp_TrnSigLmpLftOnReq +1);//Right(2: ON, 1: OFF)

  setTimer(timer_LeftTurnSignal, TIME_BlinkLmp);
}

/// <Turn Siganl>
on sysvar_update panel::SwitchIndi_TurnSignal_Zero
{
  @panel::SwitchIndi_TurnSignal_Right = 0;
  @panel::SwitchIndi_TurnSignal_Left = 0;
}


/// <Door Siganl>
on signal_update Warn_AsstDrSwSta
{
  if( $Warn_AsstDrSwSta == Open) setControlVisibility("Panel_TestBench","Picture_Box_FR", 1);    
  Else if( $Warn_AsstDrSwSta == Closed) setControlVisibility("Panel_TestBench","Picture_Box_FR", 0);
}

