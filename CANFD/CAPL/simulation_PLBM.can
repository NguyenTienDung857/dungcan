on preStop
{
  if(RS232Close(@ControlPowerSupply::Numeric_PortNum))
  {
    @ControlPowerSupply::isConectedPwrSply = 0;
    SetControlBackColor("ControlPowerSupply", "Button 5", MakeRGB(50,205,50));
    setControlProperty("ControlPowerSupply", "Button 5", "Text", "Connect");
    write("Port is closed.");
  }
}

on sysvar_update SimulationPLBM::RadioBtn_SetMasterSlave
{
  linSetChannelMasterMode(@SimulationPLBM::RadioBtn_SetMasterSlave);
}

on sysvar_update SimulationPLBM::Button_WakeUp
{
  if(@SimulationPLBM::Button_WakeUp == 1)//Pressed
  {
    //1000ms 간격으로 3번 날리기
    linSendWakeup(1000, 3);

    /*
    if(linBusIsAwake())
    {
      //linGotoSleep();
      //setControlProperty("Battery Control","Button_LINWakeUp","Text","Wake up");
    }
    else
    {
      //linWakeup(300, 1000, 1000);
      //setControlProperty("Battery Control","Button_LINWakeUp","Text","Go to Sleep");
    }
    linWakeup(300, 10, 1000);
    */
  }
}

on sysvar_update SimulationPLBM::Button_Sleep
{
  if(@SimulationPLBM::Button_Sleep == 1)//Pressed
  {
    linGotoSleep();
  }
}

on sysvar_update SimulationPLBM::Button_PLBM_SetValue
{
  if($BLTN_CAM_AuxBat_Conn_State == 0x1)
  {
    InitPLBM();
  }
  else
  {
    putValueToControl("Battery Control","CAPL Output View 2", "Auxiliary battery not recognized");
  }
}

//on message BLTN_CAM_STAT_PE_00_200ms //CAN
on message BLTN_CAM_FD_STAT_01_200ms //CANFD
{
  if($BLTN_CAM_AuxBat_Conn_State == 0x1)
  {
    putValueToControl("Battery Control","CAPL Output View 2", "Auxiliary battery recognized");
  }
  else if($BLTN_CAM_AuxBat_Conn_State == 0x2)
  {
    putValueToControl("Battery Control","CAPL Output View 2", "Auxiliary battery not recognized");
  }
  else if($BLTN_CAM_AuxBat_Conn_State == 0x3)
  {
    putValueToControl("Battery Control","CAPL Output View 2", "This specification does not allow the use of auxiliary batteries.");
  }
}

/// <BMS_CERTI>
on linFrame BMS_CERTI
{
  putValueToControl("Battery Control", "CAPL Output View 1", "receive BMS_CERTI");
  
  receiveRdmVal1 = getSignal(Rdm_Val1);
  receiveRdmVal2 = getSignal(Rdm_Val2);
  receiveRdmVal3 = getSignal(Rdm_Val3);
  receiveRdmVal4 = getSignal(Rdm_Val4);
  
  transmitRdmRval1 = receiveRdmVal1 + 0xA0;
  transmitRdmRval2 = receiveRdmVal2 + 0xB2;
  transmitRdmRval3 = receiveRdmVal3 + 0xC1;
  transmitRdmRval4 = receiveRdmVal4 + 0xD3;
  
  setSignal(Rdm_Rval1, transmitRdmRval1);
  setSignal(Rdm_Rval2, transmitRdmRval2);
  setSignal(Rdm_Rval3, transmitRdmRval3);
  setSignal(Rdm_Rval4, transmitRdmRval4);
  
  InitPLBM();
}

