void InitPLBM()
{
    setsignal(BMS_INFO_01::BAT_Type, 1);
    setsignal(BMS_INFO_01::BAT_Option_Type, 1);
    setsignal(BMS_INFO_01::BAT_Capa_for_BLTN_CAM, 12);
    setsignal(BMS_INFO_01::BAT_SOH, 100);
    setsignal(BMS_INFO_01::B_VOLTAGE, 12);
    setsignal(BMS_INFO_01::IGN_VOLTAGE, 12);
    setsignal(BMS_INFO_01::BMS_INFO_01_Reserved7, 0);

    setsignal(BMS_INFO_02::BAT_SOC_for_BLTN_CAM, 100);
    setsignal(BMS_INFO_02::BAT_Volt, 10);
    setsignal(BMS_INFO_02::BAT_Current, 0);
    setsignal(BMS_INFO_02::BAT_Temp, 24.7);
    setsignal(BMS_INFO_02::BMS_INFO_02_Reserved6, 0x0);
    setsignal(BMS_INFO_02::BMS_INFO_02_Reserved7, 0x0);

    setsignal(BMS_INFO_03::BAT_Status, 0x0);
    setsignal(BMS_INFO_03::BAT_Volt_Fault_Info, 0x0);
    setsignal(BMS_INFO_03::BAT_Current_Fault_Info, 0x0);
    setsignal(BMS_INFO_03::BAT_Discharging_Time_Info, 0x0);
    setsignal(BMS_INFO_03::BLTM_CAM_Current, 0x0);
    setsignal(BMS_INFO_03::LBM_Maxdischr_Info, 0x0);
    setsignal(BMS_INFO_03::BLTN_CAM_End_Request, 0x0);
    setsignal(BMS_INFO_03::BMS_INFO_03_Reserved1, 0x0);
    setsignal(BMS_INFO_03::BMS_INFO_03_Reserved2, 0x0);
  
  if(@SimulationPLBM::RadioBtn_SelcectPLBM == 0) //19Ah
  {
    setsignal(BMS_INFO_01::BAT_Capa_Total, 19.2);
    putValueToControl("Battery Control","CAPL Output View 1", "NCM battery 19.2Ah specification applied. SOC = 100%");
  }
  
  else //28.8Ah
  {
    setsignal(BMS_INFO_01::BAT_Capa_Total, 28.8);
    putValueToControl("Battery Control","CAPL Output View 1", "NCM battery 28.8Ah specification applied. SOC = 100%");
  }
}


