</UNSDEF>
<UNSDEF id='_000001E06F543430' oid='CFAE2D2C5AD64d2aB5A2D845B7DC728C' temploid='{47702186-8AF5-428e-84A2-910211B0FA17}' attrcatref='_000001E06DBED060' usage='admin' v='500000' df='dec'>
<NAME>
<TUV xml:lang='en-US'>Baudrate</TUV>
</NAME>
<DESC>
<TUV xml:lang='en-US'>Bus Speed of the used transport media. Caution, the Bus Speed has to be set identical in all ECUs connected to one subnet.</TUV>
</DESC>
<QUAL>Diag_CAN.Baudrate</QUAL>
</UNSDEF>
